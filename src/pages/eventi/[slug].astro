---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalePath, publicUrl, getLangFromUrl, type Lang } from '../../i18n/utils';

export async function getStaticPaths() {
  const eventi = await getCollection('eventi');
  return eventi.map((entry) => ({
    params: { slug: entry.slug },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const ev = entry.data;

const lang: Lang = getLangFromUrl(Astro.url);
const p = (path: string) => getLocalePath(lang, path);

const MESI_FULL = [
  'gennaio','febbraio','marzo','aprile','maggio','giugno',
  'luglio','agosto','settembre','ottobre','novembre','dicembre',
];
const dataFormattata =
  `${ev.data.getDate()} ${MESI_FULL[ev.data.getMonth()]} ${ev.data.getFullYear()}`;

const catColor: Record<string, string> = {
  Torneo: '#8B1A1A',
  Clinic: '#1a5a8b',
  Evento: '#1a1a1a',
  Camp:   '#1a7a44',
};
const accent = catColor[ev.categoria] ?? '#8B1A1A';
---

<BaseLayout
  lang={lang}
  title={`${ev.titolo} — Tennis Club Ambrosiano`}
  description={ev.descrizione}
>
  <!-- Hero evento -->
  <section class="ev-hero" style={`--ev-accent: ${accent};`}>
    <div class="ev-hero__inner">
      <nav class="ev-hero__breadcrumb" aria-label="Breadcrumb">
        <a href={p('/eventi')}>← Tutti gli eventi</a>
      </nav>

      <div class="ev-hero__meta">
        <span class="ev-hero__cat">{ev.categoria}</span>
        {ev.luogo && <span class="ev-hero__luogo">{ev.luogo}</span>}
      </div>

      <time
        class="ev-hero__date"
        datetime={ev.data.toISOString().split('T')[0]}
      >
        {dataFormattata}
      </time>

      <h1 class="ev-hero__title">{ev.titolo}</h1>

      <p class="ev-hero__desc">{ev.descrizione}</p>

      {ev.iscrizioniHref && (
        <div class="ev-hero__actions">
          <a class="btn btn-red" href={ev.iscrizioniHref}>Iscriviti ora</a>
        </div>
      )}
    </div>
  </section>

  <!-- Contenuto evento -->
  <section class="ev-body">
    <div class="ev-body__inner">
      <div class="ev-body__content prose">
        <Content />
      </div>

      <aside class="ev-body__sidebar">
        <div class="ev-sidebar__block">
          <h2 class="ev-sidebar__label">Data</h2>
          <p class="ev-sidebar__value">{dataFormattata}</p>
        </div>

        {ev.luogo && (
          <div class="ev-sidebar__block">
            <h2 class="ev-sidebar__label">Luogo</h2>
            <p class="ev-sidebar__value">{ev.luogo}</p>
          </div>
        )}

        <div class="ev-sidebar__block">
          <h2 class="ev-sidebar__label">Categoria</h2>
          <p class="ev-sidebar__value">{ev.categoria}</p>
        </div>

        {ev.iscrizioniHref && (
          <div class="ev-sidebar__cta">
            <a class="btn btn-red" href={ev.iscrizioniHref} style="width:100%;text-align:center;">
              Iscriviti ora
            </a>
          </div>
        )}

        <div class="ev-sidebar__back">
          <a href={p('/eventi')}>← Tutti gli eventi</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style define:vars={{ evAccent: accent }}>
  /* ── Hero ── */
  .ev-hero {
    background: #0f1013;
    padding: calc(var(--header-h) + 5vh) var(--pad-x) 6vh;
    border-bottom: 3px solid var(--ev-accent);
  }

  .ev-hero__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    color: #ffffff;
  }

  .ev-hero__breadcrumb {
    margin-bottom: 2.5vh;
  }

  .ev-hero__breadcrumb a {
    font-family: var(--font-display);
    font-size: clamp(10px, 0.8vw, 12px);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.4);
    text-decoration: none;
    transition: color 0.18s;
  }

  .ev-hero__breadcrumb a:hover { color: rgba(255,255,255,.8); }

  .ev-hero__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.2rem;
  }

  .ev-hero__cat {
    font-family: var(--font-display);
    font-size: clamp(10px, 0.75vw, 12px);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.3em 0.8em;
    background: rgba(255,255,255,.07);
    color: rgba(255,255,255,.7);
    border-left: 3px solid var(--ev-accent);
  }

  .ev-hero__luogo {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.85vw, 14px);
    font-weight: 300;
    color: rgba(255,255,255,.4);
  }

  .ev-hero__date {
    display: block;
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: rgba(255,255,255,.4);
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
    text-transform: lowercase;
  }

  .ev-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.5vw, 6rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.9;
    color: #ffffff;
    margin-bottom: 2rem;
    max-width: 22ch;
  }

  .ev-hero__desc {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.2vw, 19px);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(255,255,255,.62);
    max-width: 56ch;
    margin-bottom: 3vh;
  }

  .ev-hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* ── Body ── */
  .ev-body {
    padding: 6vh var(--pad-x);
    background: var(--color-bg);
  }

  .ev-body__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  /* Prose */
  .prose {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.85;
    color: var(--color-text-light);
  }

  .prose p { margin-bottom: 1.2em; }

  .prose h2, .prose h3 {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-text);
    margin-top: 1.8em;
    margin-bottom: 0.6em;
    letter-spacing: -0.01em;
  }

  .prose h2 { font-size: clamp(1.3rem, 2vw, 1.8rem); }
  .prose h3 { font-size: clamp(1.1rem, 1.5vw, 1.4rem); }

  .prose ul, .prose ol { padding-left: 1.5em; margin-bottom: 1em; }
  .prose li { margin-bottom: 0.4em; }

  /* Sidebar */
  .ev-body__sidebar {
    position: sticky;
    top: calc(var(--header-h) + 2rem);
    border: 1px solid var(--color-border);
    padding: 1.8rem;
    background: var(--color-off-white);
  }

  .ev-sidebar__block {
    padding-bottom: 1.2rem;
    margin-bottom: 1.2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .ev-sidebar__label {
    font-family: var(--font-display);
    font-size: clamp(9px, 0.72vw, 11px);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(26,26,26,.38);
    margin-bottom: 0.35rem;
  }

  .ev-sidebar__value {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 400;
    color: var(--color-text);
  }

  .ev-sidebar__cta {
    margin-top: 1.2rem;
    margin-bottom: 1.2rem;
  }

  .ev-sidebar__back {
    margin-top: 1.2rem;
  }

  .ev-sidebar__back a {
    font-family: var(--font-display);
    font-size: clamp(10px, 0.78vw, 12px);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(26,26,26,.4);
    text-decoration: none;
    transition: color 0.18s;
  }

  .ev-sidebar__back a:hover { color: var(--color-accent); }

  @media (max-width: 900px) {
    .ev-body__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .ev-body__sidebar { position: static; }
  }

  @media (max-width: 560px) {
    .ev-hero { padding-top: calc(var(--header-h) + 3vh); }
    .ev-hero__title { font-size: clamp(1.8rem, 8vw, 3rem); }
  }
</style>
