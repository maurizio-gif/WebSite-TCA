---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import EventiHome from "../components/EventiHome.astro";
import { getEntry } from "astro:content";

const lang = 'it' as const;

// SEO + hero gestibili da TinaCMS → src/content/pagine/eventi.md
const d = (await getEntry("pagine", "eventi"))!.data;
---

<BaseLayout
  title={d.title}
  description={d.description}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
  />

  <EventiHome lang={lang} limit={100} showAllLink={false} />

</BaseLayout>
