---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/prenota-una-visita.md
// Il form contatti in fondo è il LeadFormInline standard (incluso da BaseLayout)
const d = (await getEntry("pagine", "prenota-una-visita"))!.data;

const punti = [
  { numero: "16",      testo: "campi da tennis su ogni superficie, coperti e scoperti" },
  { numero: "30.000",  testo: "mq dedicati a tennis, padel, palestra e famiglia" },
  { numero: "1963",    testo: "l'anno in cui inizia la nostra storia, con la scuola tennis dal 1965" },
  { numero: "M2",      testo: "metro Udine a pochi passi: il club più comodo di Milano" },
];
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctas={[{ label: "Prenota una visita", href: "#lfi-root" }]}
  />

  <section class="visita">
    <div class="visita__inner">
      {punti.map((p) => (
        <div class="visita__stat">
          <span class="visita__num">{p.numero}</span>
          <p class="visita__testo">{p.testo}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .visita {
    padding: 7vh var(--pad-x);
    background: var(--color-off-white);
  }

  .visita__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
  }

  .visita__num {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.4rem, 4vw, 4rem);
    line-height: 1;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .visita__testo {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(13px, 0.95vw, 16px);
    line-height: 1.7;
    color: var(--color-text-light);
    max-width: 26ch;
  }

  @media (max-width: 900px) {
    .visita__inner { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .visita__inner { grid-template-columns: 1fr; }
  }
</style>
