---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { publicUrl, getLocalePath } from "../i18n/utils";
import { getEntry } from "astro:content";

const lang = 'it' as const;
const p = (path: string) => getLocalePath(lang, path);

// SEO + hero + corpo pagina gestibili da TinaCMS → src/content/pagine/scuola-tennis.md
const d = (await getEntry("pagine", "scuola-tennis"))!.data;
const mdBold = (s: string) => s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
const nl2br = (s: string) => s.replace(/\n/g, '<br>');
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    imagePosition="center top"
    ctas={[{ label: "Richiedi la Tua Prova", openModal: true }]}
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">{d.scuola_sezione1_eyebrow}</span>
      <h2 class="section-title">{d.scuola_sezione1_titolo}<br><em>{d.scuola_sezione1_titolo_accent}</em></h2>
      <p class="section-lead body-text">{d.scuola_sezione1_lead}</p>
      <div class="age-grid">
        {d.scuola_livelli.map((l) => (
          <div class="age-card">
            <span class={`level-dot level-dot--${l.dot}`} aria-hidden="true"></span>
            <span class="age-card__range">{l.range}</span>
            <h3>{l.nome}</h3>
            <span class="level-tag">{l.tag}</span>
            <p>{l.testo}</p>
          </div>
        ))}
      </div>
      <p class="level-after body-text">
        {d.scuola_livelli_footer_testo}
        <a href={p('/agonistica')}>{d.scuola_livelli_footer_link_label}</a>
      </p>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.scuola_sezione2_eyebrow}</span>
      <h2 class="section-title">{d.scuola_sezione2_titolo}<br><em>{d.scuola_sezione2_titolo_accent}</em></h2>
      <div class="iscrizione-grid">
        {d.scuola_iscrizione_cards.map((card) => (
          <div class="iscrizione-card">
            <h3>{card.titolo}</h3>
            <span class="iscrizione-card__tag">{card.tag}</span>
            <p set:html={nl2br(card.testo)} />
          </div>
        ))}
      </div>
      <div class="section-cta">
        <button class="btn btn-red" data-open-modal="modal-contatti">{d.scuola_iscrizione_cta_label}</button>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="content-section__inner two-col">
      <div class="two-col__text">
        <span class="eyebrow">{d.scuola_sezione3_eyebrow}</span>
        <h2 class="section-title">{d.scuola_sezione3_titolo}<br><em>{d.scuola_sezione3_titolo_accent}</em></h2>
        <span class="method-badge">{d.scuola_sezione3_badge}</span>
        <p class="body-text" set:html={mdBold(d.scuola_sezione3_paragrafo1)} />
        <p class="body-text">{d.scuola_sezione3_paragrafo2}</p>
        <p class="body-text" set:html={mdBold(d.scuola_sezione3_paragrafo3)} />
      </div>
      <div class="two-col__image">
        <img src={publicUrl(d.scuola_sezione3_immagine)} alt={d.scuola_sezione3_immagine_alt} class="full-img" />
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.scuola_sezione4_eyebrow}</span>
      <h2 class="section-title">{d.scuola_sezione4_titolo}<br><em>{d.scuola_sezione4_titolo_accent}</em></h2>
      <div class="tornei-grid">
        {d.scuola_tornei.map((t) => (
          <div class="torneo-card">
            <span class="torneo-card__when">{t.quando}</span>
            <h3>{t.nome}</h3>
            <p>{t.testo}</p>
          </div>
        ))}
      </div>
      <p class="level-after body-text" set:html={mdBold(d.scuola_sezione4_footer_testo)} />
    </div>
  </section>

  <!-- Scuola Tennis Estiva -->
  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.scuola_sezione5_eyebrow}</span>
      <h2 class="section-title">{d.scuola_sezione5_titolo}<br><em>{d.scuola_sezione5_titolo_accent}</em></h2>
      <p class="section-lead body-text">{d.scuola_sezione5_testo}</p>

      <div class="info-grid">
        {d.scuola_sezione5_info_rapide!.map((info) => (
          <div class="info-item">
            <span class="info-item__label">{info.label}</span>
            <span class="info-item__value">{info.valore}</span>
          </div>
        ))}
      </div>

      <div class="price-table-wrap">
        <table class="price-table">
          <tbody>
            {d.scuola_sezione5_quote_righe!.map((r) => (
              <tr>
                <td class="price-table__cat">{r.categoria}</td>
                <td>{r.prezzo}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <ul class="bullet-list">
        {d.scuola_sezione5_note!.map((nota) => <li>{nota}</li>)}
      </ul>

      <div class="section-cta">
        <button class="btn btn-red" data-open-modal="modal-contatti">{d.scuola_sezione5_cta_label}</button>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Tennis Academy · Iscrizioni aperte</span>
      <h2 class="section-title">Iscriviti<br><em>Ora.</em></h2>
      <p class="section-lead body-text">
        Le iscrizioni alla Scuola Tennis per la stagione 2026/2027 sono aperte: assicurati il posto con la preiscrizione online, versando un acconto di €300.
      </p>
      <div class="iscrizione-cta">
        <div class="iscrizione-cta__facts">
          <div class="iscrizione-cta__fact">
            <span class="iscrizione-cta__fact-label">Preiscrizione entro</span>
            <span class="iscrizione-cta__fact-val">15 Agosto 2026</span>
          </div>
          <div class="iscrizione-cta__fact">
            <span class="iscrizione-cta__fact-label">Acconto richiesto</span>
            <span class="iscrizione-cta__fact-val">€ 300</span>
          </div>
          <div class="iscrizione-cta__fact">
            <span class="iscrizione-cta__fact-label">Inizio corsi</span>
            <span class="iscrizione-cta__fact-val">21 Settembre 2026</span>
          </div>
        </div>
        <a class="btn btn-red iscrizione-cta__btn" href={p('/iscrizione-scuola-tennis')}>Iscriviti Ora</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 20px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .section-lead {
    margin-bottom: 3vh;
  }

  .section-cta {
    margin-top: 4vh;
  }

  .age-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .age-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .level-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    margin-bottom: 0.4rem;
    box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.04);
  }
  .level-dot--rosso   { background: #E53935; }
  .level-dot--arancio { background: #FB8C00; }
  .level-dot--verde   { background: #43A047; }
  .level-dot--giallo  { background: #FDD835; }

  .age-card__range {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .age-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .level-tag {
    font-family: var(--font-body);
    font-size: clamp(11px, 0.8vw, 12px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  .age-card p {
    font-family: var(--font-body);
    font-size: clamp(15px, 0.9vw, 17px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-top: 0.25rem;
  }

  .level-after {
    margin-top: 2.5vh;
  }
  .level-after a {
    color: var(--color-accent);
    font-weight: 400;
    white-space: nowrap;
  }
  .level-after a:hover { color: var(--color-accent-dark); }

  .iscrizione-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .iscrizione-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .iscrizione-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .iscrizione-card__tag {
    font-family: var(--font-body);
    font-size: clamp(11px, 0.8vw, 12px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .iscrizione-card p {
    font-family: var(--font-body);
    font-size: clamp(15px, 0.9vw, 17px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-top: 0.25rem;
  }

  .tornei-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .torneo-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .torneo-card__when {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .torneo-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .torneo-card p {
    font-family: var(--font-body);
    font-size: clamp(15px, 0.9vw, 17px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .two-col {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .method-badge {
    font-family: var(--font-body);
    font-size: clamp(11px, 0.8vw, 12px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .full-img {
    width: 100%;
    height: clamp(280px, 42vh, 520px);
    object-fit: cover;
    display: block;
    margin-top: 2.5rem;
  }

  /* Scuola Tennis Estiva: info rapide, tabella quote, elenco condizioni */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 3vh;
  }

  .info-item {
    background: var(--color-bg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .info-item__label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .info-item__value {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.95vw, 16px);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.5;
  }

  .price-table-wrap {
    overflow-x: auto;
    max-width: 480px;
    margin-bottom: 2.5vh;
  }

  .price-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 320px;
  }

  .price-table td {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.95vw, 16px);
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .price-table__cat {
    font-weight: 600;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .price-table tbody tr:nth-child(odd) {
    background: var(--color-bg);
  }

  .content-section--alt .price-table tbody tr:nth-child(odd) {
    background: var(--color-off-white);
  }

  .bullet-list {
    list-style: none;
    margin: 0 0 3vh;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    max-width: 70ch;
  }

  .bullet-list li {
    position: relative;
    padding-left: 1.4rem;
    font-family: var(--font-body);
    font-size: clamp(14px, 0.95vw, 16px);
    font-weight: 300;
    line-height: 1.5;
    color: var(--color-text);
  }

  .bullet-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  @media (max-width: 1024px) {
    .age-grid { grid-template-columns: repeat(2, 1fr); }
    .info-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 860px) {
    .tornei-grid { grid-template-columns: 1fr; }
    .iscrizione-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .age-grid { grid-template-columns: 1fr; }
    .info-grid { grid-template-columns: 1fr; }
  }

  .iscrizione-cta {
    margin-top: 3vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    background: var(--color-off-white);
    padding: 1.6rem 2rem;
  }

  .iscrizione-cta__facts {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .iscrizione-cta__fact {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .iscrizione-cta__fact-label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .iscrizione-cta__fact-val {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.6vw, 1.3rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .iscrizione-cta__btn {
    flex-shrink: 0;
  }

  @media (max-width: 700px) {
    .iscrizione-cta { flex-direction: column; align-items: stretch; }
    .iscrizione-cta__btn { text-align: center; }
  }
</style>
