---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { publicUrl, getLocalePath } from "../i18n/utils";

const lang = 'it' as const;
const p = (path: string) => getLocalePath(lang, path);

const livelli = [
  {
    dot: 'rosso',
    name: 'Rosso',
    tag: 'Mini Tennis',
    range: 'Circa 4 – 6 anni',
    text: 'Il primo approccio al tennis, con palla rossa a rimbalzo ridotto e campo ridotto. Un’ora di gioco, una o due volte a settimana, in gruppi omogenei per età.',
  },
  {
    dot: 'arancio',
    name: 'Arancio',
    tag: 'Scuola Tennis',
    range: 'Per livello · indicativamente 7 – 9 anni',
    text: 'Si entra nella scuola tennis vera e propria: palla arancio e campo ridotto. Ogni seduta unisce 30 minuti di preparazione atletica e un’ora di tennis, da una a tre volte a settimana.',
  },
  {
    dot: 'verde',
    name: 'Verde',
    tag: 'Scuola Tennis',
    range: 'Per livello',
    text: 'Palla verde, racchetta e campo più vicini al tennis tradizionale. Seduta da un’ora e mezza, da una a tre volte a settimana, con un lavoro tecnico e tattico più strutturato.',
  },
  {
    dot: 'giallo',
    name: 'Giallo',
    tag: 'Scuola Tennis',
    range: 'Per livello',
    text: 'Palla tradizionale e campo intero: l’ultimo livello prima dell’agonistica. Seduta da un’ora e mezza, da una a tre volte a settimana.',
  },
];

const tornei = [
  {
    when: 'Dicembre',
    name: 'Torneo di Natale',
    text: 'Il primo appuntamento dell’anno, aperto a tutte le categorie, dal Mini Tennis ai livelli più avanzati.',
  },
  {
    when: 'Febbraio',
    name: 'Torneo di Carnevale',
    text: 'Una giornata di gioco e di festa per mettere alla prova quanto imparato nella prima parte della stagione.',
  },
  {
    when: 'Fine corso',
    name: 'Torneo di fine corso',
    text: 'La chiusura della stagione: si gioca tutti insieme per celebrare il percorso fatto durante l’anno.',
  },
];
---

<BaseLayout
  title="Scuola Tennis | Tennis Club Ambrosiano"
  description="Scuola tennis per bambini e ragazzi al TCA. Mini tennis e livelli rosso, arancio, verde e giallo con metodo FIT. La scuola tennis più storica di Milano."
>
  <PageHero
    eyebrow="Junior · Scuola Tennis"
    title="Scuola"
    titleAccent="Tennis"
    sub="Mini tennis e percorsi a livelli — rosso, arancio, verde e giallo — fino alla preparazione agonistica. La scuola tennis più storica di Milano dal 1965."
    image="/SCUOLA%20TENNIS%205.avif"
    imageAlt="Bambini a scuola tennis TCA"
    imagePosition="center top"
    ctas={[{ label: "Richiedi la Tua Prova", openModal: true }]}
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Percorsi</span>
      <h2 class="section-title">Un percorso<br><em>per ogni livello.</em></h2>
      <p class="section-lead body-text">
        Il Mini Tennis è organizzato per età; dal livello successivo i gruppi
        seguono il livello di gioco, secondo la progressione a colori della
        Federazione Italiana Tennis. Le età indicate sono puramente orientative.
      </p>
      <div class="age-grid">
        {livelli.map((l) => (
          <div class="age-card">
            <span class={`level-dot level-dot--${l.dot}`} aria-hidden="true"></span>
            <span class="age-card__range">{l.range}</span>
            <h3>{l.name}</h3>
            <span class="level-tag">{l.tag}</span>
            <p>{l.text}</p>
          </div>
        ))}
      </div>
      <p class="level-after body-text">
        Dopo il livello giallo si entra nella squadra agonistica.
        <a href={p('/agonistica')}>Scopri l’agonistica →</a>
      </p>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">Dettagli iscrizione</span>
      <h2 class="section-title">Corsi e<br><em>frequenza.</em></h2>
      <div class="iscrizione-grid">
        <div class="iscrizione-card">
          <h3>Scuola Mini-Tennis</h3>
          <span class="iscrizione-card__tag">Nati nel 2020 e 2021</span>
          <p>Lezioni di 60 minuti, solo tennis.<br>Frequenza: 1 o 2 volte a settimana.</p>
        </div>
        <div class="iscrizione-card">
          <h3>Scuola Tennis</h3>
          <span class="iscrizione-card__tag">Nati nel 2019 e anni precedenti</span>
          <p>Lezioni di 60 minuti di tennis + 30 minuti di atletica.<br>Frequenza: 1, 2 o 3 volte a settimana.</p>
        </div>
      </div>
      <div class="section-cta">
        <button class="btn btn-red" data-open-modal="modal-contatti">Richiedi la Tua Prova</button>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="content-section__inner two-col">
      <div class="two-col__text">
        <span class="eyebrow">Il nostro metodo</span>
        <h2 class="section-title">Maestri FIT.<br><em>Metodo TCA.</em></h2>
        <p class="body-text">
          I gruppi sono costruiti per età e per livello, il più omogenei
          possibile. Ogni allenamento abbina preparazione atletica e tennis,
          con una frequenza di una, due o tre volte a settimana.
        </p>
        <p class="body-text">
          La progressione segue la metodologia FIT: salendo di livello la palla
          diventa più veloce e il campo si allunga, fino al campo intero del
          livello giallo. Tutti i nostri maestri sono certificati dalla
          Federazione Italiana Tennis: il metodo TCA unisce tecnica, gioco e
          valori dello sport per formare non solo tennisti, ma persone.
        </p>
      </div>
      <div class="two-col__image">
        <img
          src={publicUrl("/cbc758d7-c31f-4a46-8337-7c7e8fcb34a9_TCA+Tennis+8.avif")}
          alt="Maestro con allieva alla scuola tennis TCA"
          class="full-img"
        />
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">Durante l’anno</span>
      <h2 class="section-title">Si gioca,<br><em>tutto l’anno.</em></h2>
      <div class="tornei-grid">
        {tornei.map((t) => (
          <div class="torneo-card">
            <span class="torneo-card__when">{t.when}</span>
            <h3>{t.name}</h3>
            <p>{t.text}</p>
          </div>
        ))}
      </div>
      <p class="level-after body-text">
        Agli allievi selezionati viene inoltre proposto il <strong>FIT Junior
        Program</strong>, l’attività non agonistica del circuito federale: un
        percorso di tornei a tappe, da novembre alla primavera, per chi vuole
        iniziare a confrontarsi in gara.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .section-lead {
    max-width: 70ch;
    margin-bottom: 3vh;
  }

  .section-cta {
    margin-top: 4vh;
  }

  .age-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .age-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .level-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    margin-bottom: 0.4rem;
    box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.04);
  }
  .level-dot--rosso   { background: #E53935; }
  .level-dot--arancio { background: #FB8C00; }
  .level-dot--verde   { background: #43A047; }
  .level-dot--giallo  { background: #FDD835; }

  .age-card__range {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .age-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .level-tag {
    font-family: var(--font-body);
    font-size: clamp(11px, 0.8vw, 12px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  .age-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-top: 0.25rem;
  }

  .level-after {
    margin-top: 2.5vh;
  }
  .level-after a {
    color: var(--color-accent);
    font-weight: 400;
    white-space: nowrap;
  }
  .level-after a:hover { color: var(--color-accent-dark); }

  .iscrizione-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .iscrizione-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .iscrizione-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .iscrizione-card__tag {
    font-family: var(--font-body);
    font-size: clamp(11px, 0.8vw, 12px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .iscrizione-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-top: 0.25rem;
  }

  .tornei-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .torneo-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .torneo-card__when {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .torneo-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .torneo-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .full-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1024px) {
    .age-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .two-col__image { order: -1; }
    .tornei-grid { grid-template-columns: 1fr; }
    .iscrizione-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .age-grid { grid-template-columns: 1fr; }
  }
</style>
