---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import LeadFormPlaceholder from "../components/LeadFormPlaceholder.astro";
import InfoPratiche from "../components/InfoPratiche.astro";
---

<BaseLayout
  title="Scuola Tennis | Tennis Club Ambrosiano"
  description="Scuola tennis per bambini e ragazzi al TCA. Mini tennis, corsi per principianti, agonismo e percorsi FIT. La scuola tennis più storica di Milano."
>
  <PageHero
    eyebrow="Junior · Scuola Tennis"
    title="Scuola"
    titleAccent="Tennis"
    sub="Mini tennis, corsi per bambini e ragazzi, percorsi FIT e preparazione agonistica. La scuola tennis più storica di Milano dal 1965."
    image="/ajAJSI1P9HI4UhOS_tenniskidsTCA.avif"
    imageAlt="Bambini a scuola tennis TCA"
    ctaLabel="Iscriviti alla scuola"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Percorsi</span>
      <h2 class="section-title">Un programma<br><em>per ogni età.</em></h2>
      <div class="age-grid">
        <div class="age-card">
          <span class="age-card__range">3 – 5 anni</span>
          <h3>Mini Tennis</h3>
          <p>Prime esperienze con la racchetta: coordinazione, divertimento e movimento in un ambiente sicuro e stimolante.</p>
        </div>
        <div class="age-card">
          <span class="age-card__range">6 – 9 anni</span>
          <h3>Propedeutica</h3>
          <p>Apprendimento tecnico con metodologia FIT: fondamentali, regole e gioco ridotto su campo corto.</p>
        </div>
        <div class="age-card">
          <span class="age-card__range">10 – 13 anni</span>
          <h3>Sviluppo</h3>
          <p>Consolidamento tecnico-tattico, prime competizioni e costruzione del gioco personale.</p>
        </div>
        <div class="age-card">
          <span class="age-card__range">14 + anni</span>
          <h3>Avanzato</h3>
          <p>Programmi per giocatori evoluti, preparazione ai tornei e supporto al percorso agonistico.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner two-col">
      <div class="two-col__text">
        <span class="eyebrow">Il nostro approccio</span>
        <h2 class="section-title">Maestri FIT.<br><em>Metodo TCA.</em></h2>
        <p class="body-text">
          Tutti i nostri maestri sono certificati dalla Federazione Italiana Tennis.
          Il metodo TCA combina tecnica, gioco e valori dello sport per formare
          non solo tennisti, ma persone.
        </p>
      </div>
      <div class="two-col__image">
        <img
          src="/ajADiI1P9HI4UhIx_girl-with-tennis-racket-ball.avif"
          alt="Ragazza a scuola tennis TCA"
          class="full-img"
        />
      </div>
    </div>
  </section>

  <LeadFormPlaceholder />
  <InfoPratiche />
</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .age-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .age-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .age-card__range {
    font-family: var(--font-display);
    font-size: clamp(9px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .age-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .age-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .full-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1024px) {
    .age-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .two-col__image { order: -1; }
  }

  @media (max-width: 600px) {
    .age-grid { grid-template-columns: 1fr; }
  }
</style>
