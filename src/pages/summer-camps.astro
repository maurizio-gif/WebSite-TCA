---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero + corpo pagina gestibili da TinaCMS → src/content/pagine/summer-camps.md
const d = (await getEntry("pagine", "summer-camps"))!.data;
---

<BaseLayout
  title={d.title}
  description={d.description}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctaLabel="Prenota il tuo posto"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">{d.camps_sezione1_eyebrow}</span>
      <h2 class="section-title">{d.camps_sezione1_titolo}<br><em>{d.camps_sezione1_titolo_accent}</em></h2>
      <div class="features-grid">
        {d.camps_features!.map((f, i) => (
          <div class="feature">
            <span class="feature__num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{f.titolo}</h3>
            <p>{f.testo}</p>
          </div>
        ))}
      </div>

      <div class="camp-img-row">
        <img src={publicUrl(d.camps_immagine1!)} alt={d.camps_immagine1_alt!} class="camp-img" />
        <img src={publicUrl(d.camps_immagine2!)} alt={d.camps_immagine2_alt!} class="camp-img" />
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.camps_sezione2_eyebrow}</span>
      <h2 class="section-title">{d.camps_sezione2_titolo}<br><em>{d.camps_sezione2_titolo_accent}</em></h2>
      <div class="dates-grid">
        {d.camps_settimane!.map((s) => (
          <div class="date-item">
            <span class="date-item__week">{s.settimana}</span>
            <span class="date-item__dates">{s.date}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 4vh;
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature__num {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .feature h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .feature p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .camp-img-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
  }

  .camp-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .camp-img-row .camp-img:last-child { aspect-ratio: 4/3; }

  .dates-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .date-item {
    background: var(--color-bg);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .date-item__week {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .date-item__dates {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 400;
    color: var(--color-text);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .dates-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .features-grid { grid-template-columns: 1fr; }
    .camp-img-row { grid-template-columns: 1fr; }
    .dates-grid { grid-template-columns: 1fr; }
  }
</style>
