---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import LeadFormPlaceholder from "../components/LeadFormPlaceholder.astro";
import InfoPratiche from "../components/InfoPratiche.astro";
import { publicUrl } from "../i18n/utils";
---

<BaseLayout
  title="Summer Camps | Tennis Club Ambrosiano"
  description="Summer Camps TCA: tennis, sport e divertimento per bambini e ragazzi durante l'estate. Settimane intensive, animazione e tanto sole a Milano."
>
  <PageHero
    eyebrow="Junior · Summer Camps"
    title="Summer"
    titleAccent="Camps 2026"
    sub="L'estate più attiva di Milano. Tennis, sport, amicizie e divertimento per bambini e ragazzi da giugno a settembre. Settimane intensive con maestri e animatori dedicati."
    image="/aYszOt0YXLCxVpqZ_TCA_summercamp2026_orizzontale_tennisfemmina_nologhi.avif"
    imageAlt="Summer Camps TCA 2026"
    ctaLabel="Prenota il tuo posto"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Il programma</span>
      <h2 class="section-title">Un'estate<br><em>indimenticabile.</em></h2>
      <div class="features-grid">
        <div class="feature">
          <span class="feature__num">01</span>
          <h3>Tennis ogni mattina</h3>
          <p>Sessioni tecniche e match play guidati dai nostri maestri FIT.</p>
        </div>
        <div class="feature">
          <span class="feature__num">02</span>
          <h3>Multisport pomeridiano</h3>
          <p>Padel, calcio, nuoto e altri sport per un'estate completa.</p>
        </div>
        <div class="feature">
          <span class="feature__num">03</span>
          <h3>Animazione e giochi</h3>
          <p>Un team dedicato crea ogni giorno momenti divertenti e memorabili.</p>
        </div>
        <div class="feature">
          <span class="feature__num">04</span>
          <h3>Gruppi per età</h3>
          <p>Gruppi omogenei per garantire la massima sicurezza e il giusto ritmo.</p>
        </div>
      </div>

      <div class="camp-img-row">
        <img
          src={publicUrl("/aYszOt0YXLCxVpqZ_TCA_summercamp2026_orizzontale_tennisfemmina_nologhi.avif")}
          alt="Summer Camps tennis TCA"
          class="camp-img"
        />
        <img
          src={publicUrl("/ZhlJNzjCgu4jzybm_shutterstock_409391734_kidsrunfunoutdoor.avif")}
          alt="Bambini che corrono all'aperto"
          class="camp-img"
        />
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">Date 2026</span>
      <h2 class="section-title">Settimane<br><em>disponibili.</em></h2>
      <div class="dates-grid">
        {[
          { week: "1ª Settimana", dates: "15 – 19 Giugno 2026" },
          { week: "2ª Settimana", dates: "22 – 26 Giugno 2026" },
          { week: "3ª Settimana", dates: "29 Giugno – 3 Luglio 2026" },
          { week: "4ª Settimana", dates: "6 – 10 Luglio 2026" },
          { week: "5ª Settimana", dates: "13 – 17 Luglio 2026" },
          { week: "6ª Settimana", dates: "20 – 24 Luglio 2026" },
          { week: "7ª Settimana", dates: "27 – 31 Luglio 2026" },
          { week: "8ª Settimana", dates: "31 Agosto – 4 Settembre 2026" },
        ].map((d) => (
          <div class="date-item">
            <span class="date-item__week">{d.week}</span>
            <span class="date-item__dates">{d.dates}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadFormPlaceholder />
  <InfoPratiche />
</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 4vh;
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature__num {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .feature h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .feature p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .camp-img-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
  }

  .camp-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .camp-img-row .camp-img:last-child { aspect-ratio: 4/3; }

  .dates-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .date-item {
    background: var(--color-bg);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .date-item__week {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .date-item__dates {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 400;
    color: var(--color-text);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .dates-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .features-grid { grid-template-columns: 1fr; }
    .camp-img-row { grid-template-columns: 1fr; }
    .dates-grid { grid-template-columns: 1fr; }
  }
</style>
