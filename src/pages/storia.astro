---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { publicUrl } from "../i18n/utils";
---

<BaseLayout
  title="La Nostra Storia | Tennis Club Ambrosiano"
  description="La storia del Tennis Club Ambrosiano: dalla fondazione nel 1963 ai giorni nostri, sessant'anni di tennis, sport e community a Milano."
>
  <PageHero
    eyebrow="Dal 1963"
    title="La nostra"
    titleAccent="Storia"
    sub="Sessant'anni di passione per il tennis e per lo sport. Una storia fatta di campioni, community, tradizione e innovazione nel cuore di Milano."
    image="/HERO.avif"
    imageAlt="Il Tennis Club Ambrosiano visto dall'alto"
    imagePosition="center 40%"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">La timeline</span>
      <h2 class="section-title">Sessant'anni<br><em>di storia.</em></h2>

      <div class="timeline">
        {[
          { year: "1963", text: "Fondazione del Tennis Club Ambrosiano e apertura della sede di Via Feltre, nel cuore del quartiere Feltre-Udine di Milano." },
          { year: "1965", text: "Prima edizione del Torneo Avvenire, destinato a diventare uno dei più prestigiosi tornei giovanili internazionali." },
          { year: "1969", text: "Il Torneo Avvenire si apre ai migliori talenti internazionali." },
          { year: "1980s", text: "Ampliamento della struttura: nuovi campi, spogliatoi e servizi per rispondere alla crescente domanda dei soci." },
          { year: "2000s", text: "Apertura dei campi da padel. Il club abbraccia il nuovo sport e lo integra nell'offerta per i soci." },
          { year: "2020s", text: "Avvio del progetto di modernizzazione digitale e ampliamento dell'offerta con il pickleball e i programmi di preparazione atletica." },
          { year: "2023", text: "Introduzione della categoria Under 14 al Torneo Avvenire nel circuito Tennis Europe." },
          { year: "2025", text: "Il Torneo Avvenire diventa ufficialmente un torneo Under 14 Super Category, il più alto livello del tennis giovanile europeo." },
          { year: "2026", text: "Il Club continua il proprio percorso di innovazione con il rinnovamento digitale e l'ampliamento dei servizi dedicati a sport e famiglie." },
        ].map((item) => (
          <div class="timeline__item">
            <span class="timeline__year">{item.year}</span>
            <p class="timeline__text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <div class="two-col">
        <div>
          <span class="eyebrow">Il club oggi</span>
          <h2 class="section-title">Una community<br><em>viva.</em></h2>
          <p class="body-text">
            Oggi il Tennis Club Ambrosiano è uno dei più importanti punti di riferimento per
            gli sport di racchetta a Milano. Con <strong>quasi 2.000 soci</strong>, 16 campi da
            tennis, 2 campi da padel, 2 campi da pickleball, oltre 80 corsi settimanali, aree
            dedicate alla preparazione atletica, una Scuola Tennis riconosciuta
            <strong>TOP School FITP</strong> e un settore agonistico di alto livello, il Club
            accoglie ogni giorno sportivi di tutte le età e livello.
          </p>
          <p class="body-text" style="margin-top:1.25rem;">
            Ma il TCA è molto più di un centro sportivo: <strong>è una comunità</strong>. Durante
            tutto l'anno organizza tornei, eventi sociali, clinic, feste e momenti di incontro
            dedicati a soci, famiglie e amici, trasformando la terrazza affacciata sui campi e le
            aree verdi in luoghi di condivisione, convivialità e amicizia.
          </p>
        </div>
        <div class="gallery">
          <img src={publicUrl("/aW-n8QIvOtkhBvwi_HCM_Tennis_Outdoor_July-2025.avif")} alt="Club TCA" class="gallery__img" />
          <img src={publicUrl("/aW-n8gIvOtkhBvwl_HCM_Tennis_Outdoor_July-2025-2.avif")} alt="Club TCA" class="gallery__img" />
          <img src={publicUrl("/EricDavanzo1169.jpg")} alt="Club TCA" class="gallery__img" />
          <img src={publicUrl("/aW-n8wIvOtkhBvwn_HCM_Tennis_Outdoor_July-2025-3.avif")} alt="Club TCA" class="gallery__img" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
    max-width: 60ch;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 2rem;
    padding: 1.75rem 2rem;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .timeline__item:last-child { border-bottom: none; }

  .timeline__year {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 2rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .timeline__text {
    font-family: var(--font-body);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  /* Two col */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .gallery__img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .timeline__item { grid-template-columns: 80px 1fr; gap: 1rem; }
  }

  @media (max-width: 500px) {
    .timeline__item { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>
