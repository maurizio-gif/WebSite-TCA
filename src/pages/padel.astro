---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/padel.md
const d = (await getEntry("pagine", "padel"))!.data;
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctaLabel="Richiedi informazioni"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <div class="two-col">
        <div class="two-col__text">
          <span class="eyebrow">Padel</span>
          <h2 class="section-title">Lo sport<br><em>del momento.</em></h2>
          <p class="body-text">
            Il padel è il gioco di squadra per eccellenza: doppi, tornei interni,
            e un'atmosfera che unisce agonismo e divertimento. Al TCA trovi
            <strong>campi illuminati, maestri certificati FITP</strong> e una comunità
            di giocatori di ogni livello pronta ad accoglierti.
          </p>
          <a class="btn btn-red" href="#lead" style="margin-top: 1.5rem;">Inizia a giocare</a>
        </div>
        <div class="two-col__image">
          <img
            src={publicUrl("/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif")}
            alt="Campo da padel TCA"
            class="rounded-img"
          />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 2.5vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .two-col {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .two-col__image {
    margin-top: 2.5rem;
  }

  .rounded-img {
    width: 100%;
    height: clamp(280px, 42vh, 520px);
    object-fit: cover;
    display: block;
  }
</style>
