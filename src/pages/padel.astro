---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import LeadFormPlaceholder from "../components/LeadFormPlaceholder.astro";
import InfoPratiche from "../components/InfoPratiche.astro";
import { publicUrl } from "../i18n/utils";
---

<BaseLayout
  title="Padel e Pickleball | Tennis Club Ambrosiano"
  description="Padel e Pickleball al Tennis Club Ambrosiano. Campi coperti e scoperti, corsi per tutti i livelli, ambiente dinamico e community attiva a Milano."
>
  <PageHero
    eyebrow="Adulti · Padel e Pickleball"
    title="Padel"
    titleAccent="e Pickleball"
    sub="Due sport, un'unica community. Campi coperti e scoperti per il padel e nuovi spazi per il pickleball, lo sport in più rapida crescita d'Italia."
    image="/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif"
    imageAlt="Campo da padel del Tennis Club Ambrosiano"
    ctaLabel="Richiedi informazioni"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <div class="two-col">
        <div class="two-col__text">
          <span class="eyebrow">Padel</span>
          <h2 class="section-title">Lo sport<br><em>del momento.</em></h2>
          <p class="body-text">
            Il padel è il gioco di squadra per eccellenza: doppi, tornei interni,
            e un'atmosfera che unisce agonismo e divertimento. Al TCA trovi campi
            illuminati, maestri certificati FIP e una comunità di giocatori di
            ogni livello pronta ad accoglierti.
          </p>
          <a class="btn btn-red" href="#lead" style="margin-top: 1.5rem;">Inizia a giocare</a>
        </div>
        <div class="two-col__image">
          <img
            src={publicUrl("/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif")}
            alt="Campo da padel TCA"
            class="rounded-img"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">Pickleball</span>
      <h2 class="section-title">Il nuovo<br><em>sport del club.</em></h2>
      <p class="body-text body-text--max">
        Agile, inclusivo, divertente. Il pickleball conquista giocatori di ogni età
        con le sue regole semplici e il ritmo dinamico. Sperimenta il nuovo
        sul nostro campo dedicato.
      </p>
    </div>
  </section>

  <LeadFormPlaceholder />
  <InfoPratiche />
</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 2.5vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .body-text--max { max-width: 68ch; }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rounded-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .two-col__image { order: -1; }
  }
</style>
