---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import MembershipSection from "../components/MembershipSection.astro";
import ConversionBlock from "../components/ConversionBlock.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/padel.md
const d = (await getEntry("pagine", "padel"))!.data;
const mdBold = (s: string) => s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
  hideLeadFormInline
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctas={[
      { label: "Diventa Socio", href: "#membership" },
      { label: "Prenota un Campo", href: "https://playtomic.io/club-ambrosiano-padel/3c5b3aaa-85e7-41dc-838e-e72899aae1cd?q=PADEL~2024-10-23~~~", external: true, outline: true },
    ]}
  />

  <section class="content-section">
    <div class="content-section__inner">
      <div class="two-col">
        <div class="two-col__text">
          <span class="eyebrow">Padel</span>
          <h2 class="section-title">Lo sport<br><em>del momento.</em></h2>
          <p class="body-text">
            Il padel è il gioco di squadra per eccellenza: doppi, tornei interni,
            e un'atmosfera che unisce agonismo e divertimento. Al TCA trovi
            <strong>campi illuminati, maestri certificati FITP</strong> e una comunità
            di giocatori di ogni livello pronta ad accoglierti.
          </p>
          <button class="btn btn-red" data-open-modal="modal-contatti" style="margin-top: 1.5rem;">Inizia a giocare</button>
        </div>
        <div class="two-col__image">
          <img
            src={publicUrl("/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif")}
            alt="Campo da padel TCA"
            class="rounded-img"
          />
        </div>
      </div>
    </div>
  </section>

  <div id="membership" class="anchor-target">
    <MembershipSection />
  </div>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.padel_corsi_eyebrow}</span>
      <h2 class="section-title">{d.padel_corsi_titolo}<br><em>{d.padel_corsi_titolo_accent}</em></h2>
      <p class="section-lead" set:html={mdBold(d.padel_corsi_intro)} />
      <div class="content-grid content-grid--4">
        {d.padel_corsi_livelli!.map((l) => (
          <div class="content-card content-card--simple">
            <strong>{l.titolo}</strong>
            <p>{l.testo}</p>
          </div>
        ))}
      </div>
      <div class="section-cta">
        <button class="btn btn-red" data-open-modal="modal-contatti">{d.padel_corsi_cta_label}</button>
      </div>
    </div>
  </section>

  <ConversionBlock />

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 2.5vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 20px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .two-col {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .two-col__image {
    margin-top: 2.5rem;
  }

  .rounded-img {
    width: 100%;
    height: clamp(280px, 42vh, 520px);
    object-fit: cover;
    display: block;
  }

  .section-lead {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    max-width: none;
    margin-bottom: 4vh;
  }

  .section-cta {
    margin-top: 4vh;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .content-grid--4 { grid-template-columns: repeat(4, 1fr); }

  .content-card--simple {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .content-card--simple strong {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  .content-card--simple p {
    font-family: var(--font-body);
    font-size: clamp(15px, 1vw, 18px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  @media (max-width: 1024px) {
    .content-grid--4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .content-grid--4 { grid-template-columns: 1fr; }
  }

  /* ── Anchor offset per navbar fissa ── */
  .anchor-target {
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }
</style>
