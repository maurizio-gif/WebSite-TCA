---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import LeadFormPlaceholder from "../components/LeadFormPlaceholder.astro";
import InfoPratiche from "../components/InfoPratiche.astro";

interface Course {
  name: string;
  duration: string;
  intensity: 1 | 2 | 3;
  level: string;
  desc: string;
}

interface Category {
  id: string;
  label: string;
  color: string;
  courses: Course[];
}

const categories: Category[] = [
  {
    id: 'endurance',
    label: 'Endurance',
    color: '#B83A00',
    courses: [
      { name: 'Dance', duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Coreografie su musica pop e latina. Cardio coinvolgente e coordinazione ritmica.' },
      { name: 'Zumba', duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Mix di danza latino-americana e fitness. Brucia calorie con il sorriso.' },
      { name: 'Cycling', duration: '45 min', intensity: 3, level: 'Tutti i livelli', desc: 'Allenamento su bike al ritmo della musica. Massima resa cardiovascolare.' },
      { name: 'Aeroboxe', duration: '60 min', intensity: 3, level: 'Intermedio', desc: 'Combinazione di arti marziali e aerobica. Potenza, riflessi e resistenza.' },
      { name: 'Functional Step', duration: '45 min', intensity: 2, level: 'Tutti i livelli', desc: 'Step rivisitato con movimenti funzionali. Tonifica e migliora la resistenza.' },
      { name: 'Step & Tone', duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Step cardio abbinato a tonificazione. Allenamento a corpo completo.' },
    ]
  },
  {
    id: 'strength',
    label: 'Strength',
    color: '#1A1A1A',
    courses: [
      { name: 'Funracket', duration: '60 min', intensity: 3, level: 'Intermedio', desc: 'Sport-specific per tennisti e padellisti. Forza esplosiva, reattività e agilità.' },
      { name: 'Tribal-x', duration: '45 min', intensity: 3, level: 'Intermedio', desc: 'Circuito ad alta intensità con carichi liberi. Forza e potenza muscolare.' },
      { name: 'Functional', duration: '45 min', intensity: 2, level: 'Tutti i livelli', desc: 'Allenamento col peso corporeo. Forza funzionale e stabilità articolare.' },
      { name: 'Active Pump', duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Barbell workout con bilanciere. Tonificazione totale su musica.' },
      { name: 'Total Body', duration: '60 min', intensity: 3, level: 'Tutti i livelli', desc: 'Lavoro su tutti i distretti muscolari. Forza, resistenza e postura.' },
      { name: 'Circuit', duration: '45 min', intensity: 3, level: 'Intermedio', desc: 'Stazioni cardio e forza in sequenza. Metabolismo alle stelle.' },
      { name: 'Suspension Training', duration: '60 min', intensity: 3, level: 'Intermedio', desc: 'TRX e sling training. Core, stabilità e forza funzionale in sospensione.' },
    ]
  },
  {
    id: 'balance',
    label: 'Balance',
    color: '#1E4D3A',
    courses: [
      { name: 'Pilates Funzionale', duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Pilates applicato al movimento quotidiano. Core, postura e consapevolezza corporea.' },
      { name: 'Flexability', duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Flessibilità e mobilità articolare. Previene infortuni e libera le tensioni.' },
      { name: 'Hatha Yoga', duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Pratica yogica classica. Equilibrio corpo-mente attraverso asana e respiro.' },
      { name: 'Pilates', duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Metodo originale di controllo e precisione. Rinforza il centro, migliora la postura.' },
      { name: 'Postural', duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Rieducazione posturale attiva. Corregge le tensioni e riequilibra il corpo.' },
      { name: 'Power Yoga', duration: '60 min', intensity: 2, level: 'Intermedio', desc: 'Yoga dinamico e intenso. Forza, flessibilità e concentrazione unite.' },
      { name: 'Ginnastica Dolce', duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Mobilità dolce per tutti. Ideale per over 50 e recupero attivo.' },
    ]
  }
];
---

<BaseLayout
  title="Preparazione Atletica | Tennis Club Ambrosiano"
  description="Preparazione atletica al Tennis Club Ambrosiano: personal training, sala pesi, corsi funzionali e programmi sport-specific per tennisti e atleti di ogni livello."
>
  <PageHero
    eyebrow="Adulti · Preparazione Atletica"
    title="Preparazione"
    titleAccent="Atletica"
    sub="Programmi di allenamento sport-specific, personal training e sala attrezzi professionale. Migliora le tue performance in campo e fuori."
    image="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
    imageAlt="Sala di preparazione atletica TCA"
    ctaLabel="Richiedi informazioni"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Programmi</span>
      <h2 class="section-title">Il tuo<br><em>allenamento.</em></h2>
      <div class="prog-grid">
        <div class="prog-card">
          <img
            src="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
            alt="Personal training TCA"
            class="prog-card__img"
          />
          <div class="prog-card__body">
            <h3>Personal Training</h3>
            <p>Sedute individuali con preparatori atletici certificati. Obiettivi personalizzati, progressi misurabili.</p>
          </div>
        </div>
        <div class="prog-card">
          <img
            src="/c99ebd5f-16b9-442f-9bb7-2437d5203cd2_TCA+Fitness+5.avif"
            alt="Allenamento funzionale TCA"
            class="prog-card__img"
          />
          <div class="prog-card__body">
            <h3>Allenamento Funzionale</h3>
            <p>Corsi in piccoli gruppi focalizzati su forza, mobilità e condizione fisica generale.</p>
          </div>
        </div>
        <div class="prog-card">
          <div class="img-placeholder" data-name="sport-specific.avif" style="min-height:200px"></div>
          <div class="prog-card__body">
            <h3>Sport Specific per Tennisti</h3>
            <p>Programmi dedicati al tennis: esplosività, agilità laterale, core stability e prevenzione infortuni.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Corsi di Gruppo ── -->
  <section class="corsi-section">
    <div class="corsi-section__inner">
      <span class="eyebrow">Corsi di Gruppo</span>
      <h2 class="section-title">Allenati in<br><em>gruppo.</em></h2>
      <p class="corsi-sub">Ogni settimana sessioni guidate da istruttori certificati. Scegli il corso adatto al tuo obiettivo e prenota il tuo posto direttamente su PerfectGym.</p>

      {categories.map((cat) => (
        <div class="cat-block">
          <div class="cat-block__head" style={`--cat-color: ${cat.color}`}>
            <span class="cat-block__label">{cat.label}</span>
            <div class="cat-block__line"></div>
            <span class="cat-block__count">{cat.courses.length} corsi</span>
          </div>
          <div class="courses-grid">
            {cat.courses.map((course) => (
              <div class="course-card" style={`--cat-color: ${cat.color}`}>
                <div class="course-card__media">
                  <div class="img-placeholder" data-name={`${course.name.toLowerCase().replace(/[^a-z0-9]/g, '-')}.avif`} style="min-height:180px"></div>
                </div>
                <div class="course-card__body">
                  <span class="course-card__cat">{cat.label}</span>
                  <h3 class="course-card__name">{course.name}</h3>
                  <p class="course-card__desc">{course.desc}</p>
                  <div class="course-card__params">
                    <div class="param-item">
                      <span class="param-item__label">Intensità</span>
                      <span class="param-item__dots" aria-label={course.intensity === 3 ? 'Alta' : course.intensity === 2 ? 'Media' : 'Bassa'}>
                        {[1,2,3].map(n => (
                          <span class={`dot${n <= course.intensity ? ' dot--on' : ''}`}></span>
                        ))}
                      </span>
                    </div>
                    <div class="param-item">
                      <span class="param-item__label">Durata</span>
                      <span class="param-item__value">{course.duration}</span>
                    </div>
                    <div class="param-item">
                      <span class="param-item__label">Livello</span>
                      <span class="param-item__value">{course.level}</span>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Calendario corsi ── -->
  <section class="calendar-section">
    <div class="calendar-section__inner">
      <span class="eyebrow">Calendario</span>
      <h2 class="section-title">Prenota il tuo<br><em>corso.</em></h2>
      <p class="corsi-sub">Controlla il calendario settimanale e riserva il tuo posto direttamente su PerfectGym.</p>

      <div class="calendar-wrap" id="calendar-wrap">
        <div id="pg-calendar" class="pg-embed"></div>
        <div class="calendar-fallback" id="pg-fallback" style="display:none">
          <p class="calendar-fallback__msg">Accedi al calendario dal portale PerfectGym.</p>
          <a
            href="https://tcambrosiano.perfectgym.com/clientportal2/?lang=it#/Classes/1/Calendar"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-red"
          >
            Vedi il Calendario
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PerfectGym Calendar Embed -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@perfectgym/client-portal@latest/dist/ClientPortal.css" />
  <script is:inline src="https://cdn.jsdelivr.net/npm/@iframe-resizer/parent@5.5.7/index.umd.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@perfectgym/client-portal@latest/dist/ClientPortal.min.js"></script>
  <script is:inline>
    window.addEventListener('load', function () {
      var el = document.getElementById('pg-calendar');
      var fallback = document.getElementById('pg-fallback');
      if (!el || typeof window.PerfectGym === 'undefined') {
        if (fallback) fallback.style.display = 'flex';
        return;
      }

      var connected = false;

      new window.PerfectGym.ClientPortal(el, {
        url: 'https://tcambrosiano.perfectgym.com/clientportal2/',
        language: 'it',
        forceUrl: 'https://tcambrosiano.perfectgym.com/clientportal2/?lang=it#/Classes/1/Calendar',
        navigation: { hide: true },
        calendarPage: {
          hideBookingIfNotLogged: true,
          disableCourseEnrollment: true
        },
        onConnect: function () {
          connected = true;
        }
      });

      setTimeout(function () {
        if (!connected) {
          el.style.display = 'none';
          if (fallback) fallback.style.display = 'flex';
        }
      }, 5000);
    });
  </script>

  <LeadFormPlaceholder />
  <InfoPratiche />
</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .prog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .prog-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .prog-card__img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    display: block;
  }

  .prog-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prog-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prog-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  /* ── Corsi di Gruppo ── */
  .corsi-section {
    padding: 7vh var(--pad-x);
    background: var(--color-off-white);
  }

  .corsi-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .corsi-sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    max-width: 64ch;
    margin-bottom: 6vh;
  }

  /* ── Category block ── */
  .cat-block {
    margin-bottom: 6vh;
  }

  .cat-block:last-child {
    margin-bottom: 0;
  }

  .cat-block__head {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 2rem;
  }

  .cat-block__label {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.6vw, 1.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cat-color);
    white-space: nowrap;
  }

  .cat-block__line {
    flex: 1;
    height: 1px;
    background: var(--cat-color);
    opacity: 0.25;
  }

  .cat-block__count {
    font-family: var(--font-display);
    font-size: clamp(10px, 0.75vw, 12px);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
  }

  /* ── Course grid ── */
  .courses-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  /* ── Course card ── */
  .course-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .course-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .course-card__media {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #E5E7EB;
  }

  .course-card__media .img-placeholder {
    width: 100%;
    height: 100%;
    min-height: unset !important;
  }

  .course-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .course-card__cat {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cat-color);
  }

  .course-card__name {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--color-text);
    margin-top: 0.1rem;
  }

  .course-card__desc {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.85vw, 13.5px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
    margin: 0.3rem 0 0.6rem;
    flex: 1;
  }

  /* ── Parameters ── */
  .course-card__params {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .param-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .param-item__label {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-light);
    flex-shrink: 0;
  }

  .param-item__dots {
    display: flex;
    gap: 4px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    display: inline-block;
  }

  .dot--on {
    background: var(--cat-color);
  }

  .param-item__value {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    text-align: right;
  }

  /* ── Calendar section ── */
  .calendar-section {
    padding: 7vh var(--pad-x);
  }

  .calendar-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .calendar-wrap {
    border: 1px solid var(--color-border);
    background: #fff;
    overflow: hidden;
    min-height: 200px;
  }

  .pg-embed {
    min-height: 640px;
    width: 100%;
  }

  .calendar-fallback {
    min-height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 4rem 2rem;
    background: var(--color-off-white);
  }

  .calendar-fallback__msg {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 16px);
    font-weight: 300;
    color: var(--color-text-light);
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .courses-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 860px) {
    .prog-grid { grid-template-columns: 1fr 1fr; }
    .courses-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .prog-grid { grid-template-columns: 1fr; }
    .courses-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 400px) {
    .courses-grid { grid-template-columns: 1fr; }
  }
</style>
