---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import LeadFormPlaceholder from "../components/LeadFormPlaceholder.astro";
import InfoPratiche from "../components/InfoPratiche.astro";
---

<BaseLayout
  title="Preparazione Atletica | Tennis Club Ambrosiano"
  description="Preparazione atletica al Tennis Club Ambrosiano: personal training, sala pesi, corsi funzionali e programmi sport-specific per tennisti e atleti di ogni livello."
>
  <PageHero
    eyebrow="Adulti · Preparazione Atletica"
    title="Preparazione"
    titleAccent="Atletica"
    sub="Programmi di allenamento sport-specific, personal training e sala attrezzi professionale. Migliora le tue performance in campo e fuori."
    image="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
    imageAlt="Sala di preparazione atletica TCA"
    ctaLabel="Richiedi informazioni"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Programmi</span>
      <h2 class="section-title">Il tuo<br><em>allenamento.</em></h2>
      <div class="prog-grid">
        <div class="prog-card">
          <img
            src="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
            alt="Personal training TCA"
            class="prog-card__img"
          />
          <div class="prog-card__body">
            <h3>Personal Training</h3>
            <p>Sedute individuali con preparatori atletici certificati. Obiettivi personalizzati, progressi misurabili.</p>
          </div>
        </div>
        <div class="prog-card">
          <img
            src="/c99ebd5f-16b9-442f-9bb7-2437d5203cd2_TCA+Fitness+5.avif"
            alt="Allenamento funzionale TCA"
            class="prog-card__img"
          />
          <div class="prog-card__body">
            <h3>Allenamento Funzionale</h3>
            <p>Corsi in piccoli gruppi focalizzati su forza, mobilità e condizione fisica generale.</p>
          </div>
        </div>
        <div class="prog-card">
          <div class="img-placeholder" data-name="sport-specific.avif" style="min-height:200px"></div>
          <div class="prog-card__body">
            <h3>Sport Specific per Tennisti</h3>
            <p>Programmi dedicati al tennis: esplosività, agilità laterale, core stability e prevenzione infortuni.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Corsi di Gruppo ── -->
  <section class="corsi-section">
    <div class="corsi-section__inner">
      <span class="eyebrow">Corsi di Gruppo</span>
      <h2 class="section-title">Allenati in<br><em>gruppo.</em></h2>
      <p class="corsi-sub">Ogni settimana sessioni guidate da istruttori certificati. Scegli il corso adatto al tuo obiettivo — forza, flessibilità, resistenza — e prenota il tuo posto direttamente dal calendario.</p>

      <div class="corsi-categories">
        <div class="corsi-cat">
          <span class="corsi-cat__label">Endurance</span>
          <ul class="corsi-list">
            <li>Dance</li>
            <li>Zumba</li>
            <li>Cycling</li>
            <li>Aeroboxe</li>
            <li>Functional Step</li>
            <li>Step &amp; Tone</li>
          </ul>
        </div>
        <div class="corsi-cat">
          <span class="corsi-cat__label">Strength</span>
          <ul class="corsi-list">
            <li>Funracket</li>
            <li>Tribal-x</li>
            <li>Functional</li>
            <li>Active Pump</li>
            <li>Total Body</li>
            <li>Circuit</li>
            <li>Suspension Training</li>
          </ul>
        </div>
        <div class="corsi-cat">
          <span class="corsi-cat__label">Balance</span>
          <ul class="corsi-list">
            <li>Pilates Funzionale</li>
            <li>Flexability</li>
            <li>Hatha Yoga</li>
            <li>Pilates</li>
            <li>Postural</li>
            <li>Power Yoga</li>
            <li>Ginnastica Dolce</li>
          </ul>
        </div>
      </div>

      <div class="corsi-calendar-wrap">
        <div id="pg-calendar" class="pg-embed"></div>
      </div>
    </div>
  </section>

  <LeadFormPlaceholder />
  <InfoPratiche />

  <!-- PerfectGym Calendar Embed -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@perfectgym/client-portal@latest/dist/ClientPortal.css" />
  <script is:inline src="https://cdn.jsdelivr.net/npm/@iframe-resizer/parent@5.5.7/index.umd.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@perfectgym/client-portal@latest/dist/ClientPortal.min.js"></script>
  <script is:inline>
    window.addEventListener('load', function () {
      var el = document.getElementById('pg-calendar');
      if (!el || typeof window.PerfectGym === 'undefined') return;
      new window.PerfectGym.ClientPortal(el, {
        url: 'https://tcambrosiano.perfectgym.com/clientportal2/',
        language: 'it',
        forceUrl: 'https://tcambrosiano.perfectgym.com/clientportal2/?lang=it#/Classes/1/Calendar',
        navigation: { hide: true },
        calendarPage: {
          hideBookingIfNotLogged: true,
          disableCourseEnrollment: true
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .prog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .prog-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .prog-card__img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    display: block;
  }

  .prog-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prog-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prog-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  /* ── Corsi di Gruppo ── */
  .corsi-section {
    padding: 7vh var(--pad-x);
    background: var(--color-off-white);
  }

  .corsi-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .corsi-sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    max-width: 64ch;
    margin-bottom: 4vh;
  }

  .corsi-categories {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 6vh;
  }

  .corsi-cat__label {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(10px, 0.75vw, 12px);
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.8rem;
  }

  .corsi-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .corsi-list li {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.85vw, 13px);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 8px 18px;
    border: 1.5px solid var(--color-border);
    background: #fff;
    color: var(--color-text);
  }

  .corsi-calendar-wrap {
    border: 1px solid var(--color-border);
    background: #fff;
    overflow: hidden;
  }

  .pg-embed {
    min-height: 640px;
    width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .prog-grid { grid-template-columns: 1fr 1fr; }
    .corsi-categories { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 560px) {
    .prog-grid { grid-template-columns: 1fr; }
    .corsi-categories { grid-template-columns: 1fr; }
  }
</style>
