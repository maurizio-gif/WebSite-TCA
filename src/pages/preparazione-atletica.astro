---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import MembershipSection from "../components/MembershipSection.astro";
import WeeklySchedule from "../components/WeeklySchedule.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/preparazione-atletica.md
const d = (await getEntry("pagine", "preparazione-atletica"))!.data;

interface Course {
  name: string;
  duration: string;
  intensity: 1 | 2 | 3;
  level: string;
  desc: string;
  img: string;
}

interface Category {
  id: string;
  label: string;
  desc: string;
  color: string;
  courses: Course[];
}

const YOGA      = '/b9c52423-5bff-496a-8686-bffe1b123195_Aspria_Milano_Outdoor_Yoga+1.avif';
const GYM       = '/Sala%20Attrezzi%202.avif';
const RACKET    = '/aXCJ_AIvOtkhBw2j_Lifestyle_232026SpeedMP_DXT56509.avif';
const CARDIO    = '/4af14e95-b254-472b-8b91-a0bfb9815ceb_shutterstock_564025705.avif';
const YOGA2     = '/Yoga.avif';
const CYCLING   = '/Cycling.avif';
const DAVANZO   = '/EricDavanzo0475.avif';
const KETTLE    = '/a46fcf94-e41a-460d-b6c9-0af53fdc34a9_EricDavanzo_ph_TENNIS_CLUB_AMBROSIANO0685.avif';
const AIRBIKE   = '/Sala%20Attrezzi%206.jpg';
const ISOTONICA = '/Sala%20Attrezzi%207.jpg';
const TAPIS     = '/Sala%20Attrezzi%201.avif';
const TREADMILL = '/Sala%20Attrezzi.avif';
const FUNCTIONAL = '/Functional.jpg';

// Slideshow sala attrezzi — solo foto
const salaImgs = [
  { src: '/Sala%20Attrezzi%202.avif', alt: 'Sala attrezzi del Tennis Club Ambrosiano' },
  { src: '/Sala%20Attrezzi%203.avif', alt: 'Area pesi liberi e macchinari professionali' },
  { src: '/Sala%20Attrezzi%204.avif', alt: 'Zona cardio della sala attrezzi' },
  { src: '/Sala%20Attrezzi%205.avif', alt: 'Allenamento funzionale nella sala attrezzi' },
  { src: '/Sala%20Attrezzi%206.jpg', alt: 'Area funzionale e TRX' },
  { src: '/Sala%20Attrezzi%207.jpg', alt: 'Macchinari isotonici della sala attrezzi' },
  { src: '/Sala%20Attrezzi%201.avif', alt: 'Zona cardio con tapis roulant' },
  { src: '/TCA_Gym%2012.jpg',        alt: 'Sala attrezzi TCA - vista generale' },
];

const categories: Category[] = [
  {
    id: 'endurance',
    label: 'Endurance',
    desc: 'Allena il sistema cardiovascolare, brucia calorie e migliora la resistenza e la coordinazione ritmica con corsi dinamici e coinvolgenti.',
    color: '#B83A00',
    courses: [
      { name: 'Dance',           duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Coreografie su musica pop e latina. Cardio coinvolgente e coordinazione ritmica.',    img: CARDIO },
      { name: 'Zumba',           duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Mix di danza latino-americana e fitness. Brucia calorie con il sorriso.',             img: DAVANZO },
      { name: 'Cycling',         duration: '45 min', intensity: 3, level: 'Tutti i livelli', desc: 'Allenamento su bike al ritmo della musica. Massima resa cardiovascolare.',            img: CYCLING },
      { name: 'Aeroboxe',        duration: '60 min', intensity: 3, level: 'Intermedio',      desc: 'Combinazione di arti marziali e aerobica. Potenza, riflessi e resistenza.',          img: AIRBIKE },
      { name: 'Functional Step', duration: '45 min', intensity: 2, level: 'Tutti i livelli', desc: 'Step rivisitato con movimenti funzionali. Tonifica e migliora la resistenza.',       img: GYM },
      { name: 'Step & Tone',     duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Step cardio abbinato a tonificazione. Allenamento a corpo completo.',                img: TREADMILL },
    ]
  },
  {
    id: 'strength',
    label: 'Strength',
    desc: 'Costruisci forza muscolare, potenza e stabilità. Allenamenti con pesi liberi, carichi e a corpo libero per una fisicità solida e funzionale.',
    color: '#1E3A8A',
    courses: [
      { name: 'Funracket',            duration: '60 min', intensity: 3, level: 'Intermedio',      desc: 'Sport-specific per tennisti e padellisti. Forza esplosiva, reattività e agilità.',    img: RACKET },
      { name: 'Tribal-x',             duration: '45 min', intensity: 3, level: 'Intermedio',      desc: 'Circuito ad alta intensità con carichi liberi. Forza e potenza muscolare.',           img: KETTLE },
      { name: 'Functional',           duration: '45 min', intensity: 2, level: 'Tutti i livelli', desc: 'Allenamento col peso corporeo. Forza funzionale e stabilità articolare.',            img: '/Functional.jpg' },
      { name: 'Active Pump',          duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Barbell workout con bilanciere. Tonificazione totale su musica.',                    img: ISOTONICA },
      { name: 'Total Body',           duration: '60 min', intensity: 3, level: 'Tutti i livelli', desc: 'Lavoro su tutti i distretti muscolari. Forza, resistenza e postura.',               img: TAPIS },
      { name: 'Circuit',              duration: '45 min', intensity: 3, level: 'Intermedio',      desc: 'Stazioni cardio e forza in sequenza. Metabolismo alle stelle.',                     img: '/Strenght%20Circuit.jpg' },
      { name: 'Suspension Training',  duration: '60 min', intensity: 3, level: 'Intermedio',      desc: 'TRX e sling training. Core, stabilità e forza funzionale in sospensione.',          img: FUNCTIONAL },
    ]
  },
  {
    id: 'balance',
    label: 'Balance',
    desc: 'Equilibrio, flessibilità e benessere corpo-mente. Migliora postura, mobilità e consapevolezza corporea con pratiche dolci e dinamiche.',
    color: '#0F7B5A',
    courses: [
      { name: 'Pilates Funzionale', duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Pilates applicato al movimento quotidiano. Core, postura e consapevolezza corporea.', img: YOGA },
      { name: 'Flexability',        duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Flessibilità e mobilità articolare. Previene infortuni e libera le tensioni.',        img: YOGA },
      { name: 'Hatha Yoga',         duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Pratica yogica classica. Equilibrio corpo-mente attraverso asana e respiro.',        img: YOGA2 },
      { name: 'Pilates',            duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Metodo originale di controllo e precisione. Rinforza il centro, migliora la postura.', img: YOGA2 },
      { name: 'Postural',           duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Rieducazione posturale attiva. Corregge le tensioni e riequilibra il corpo.',        img: YOGA },
      { name: 'Power Yoga',         duration: '60 min', intensity: 2, level: 'Intermedio',      desc: 'Yoga dinamico e intenso. Forza, flessibilità e concentrazione unite.',               img: YOGA },
      { name: 'Ginnastica Dolce',   duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Mobilità dolce per tutti. Ideale per over 50 e recupero attivo.',                   img: DAVANZO },
    ]
  }
];
---

<BaseLayout
  title={d.title}
  description={d.description}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctas={[
      { label: "I nostri abbonamenti", href: "#membership" },
      { label: "Il nostro planning",   href: "#planning", outline: true },
    ]}
  />

  <!-- ── Sala Attrezzi ── -->
  <section class="sala-section">
    <div class="sala-section__inner">
      <div class="sala-split">

        <div class="sala-split__media" data-anim="scale">
          <div class="sala-slider" data-sala-slider>
            <div class="sala-slider__track">
              {salaImgs.map((img, i) => (
                <div class="sala-slider__slide">
                  <img
                    src={publicUrl(img.src)}
                    alt={img.alt}
                    class="sala-slider__img"
                    loading={i === 0 ? "eager" : "lazy"}
                  />
                </div>
              ))}
            </div>
            <div class="sala-slider__dots">
              {salaImgs.map((_, i) => (
                <button
                  class={`sala-slider__dot${i === 0 ? " is-active" : ""}`}
                  data-sala-dot={i}
                  type="button"
                  aria-label={`Vai alla foto ${i + 1}`}
                ></button>
              ))}
            </div>
          </div>
        </div>

        <div class="sala-split__content">
          <span class="eyebrow">Sala Attrezzi</span>
          <h2 class="section-title">Potenziamento<br><em>su misura.</em></h2>
          <p class="sala-body">
            Uno spazio ampio e luminoso, riservato ai soci, con macchinari isotonici di ultima generazione, un'area cardio completa e una zona funzionale per il lavoro a corpo libero. Ogni postazione è pensata per accompagnarti in tutte le fasi dell'allenamento, dal riscaldamento al defaticamento.
          </p>
          <p class="sala-body">
            Che il tuo obiettivo sia aumentare la forza, migliorare la resistenza, preparare la stagione agonistica o semplicemente mantenerti in forma, qui trovi tutto il necessario — affiancato da personal trainer qualificati pronti a costruire con te un programma su misura.
          </p>

          <ul class="sala-features">
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 12h2m14 0h2M5 12a7 7 0 1 0 14 0 7 7 0 0 0-14 0zm4 0h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <div>
                <strong>Macchine Cardio</strong>
                <span>Tapis roulant, ellittiche, rowing machine, bike</span>
              </div>
            </li>
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="11" width="4" height="2" rx="1" stroke="currentColor" stroke-width="1.8"/><rect x="18" y="11" width="4" height="2" rx="1" stroke="currentColor" stroke-width="1.8"/><path d="M6 12h12M6 9v6M18 9v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <div>
                <strong>Pesi Liberi</strong>
                <span>Manubri 1–40 kg, bilancieri, cavi multifunzione</span>
              </div>
            </li>
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16M4 12h10M4 18h7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <div>
                <strong>Area Funzionale</strong>
                <span>TRX, kettlebell, slam ball, battle rope</span>
              </div>
            </li>
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="3" stroke="currentColor" stroke-width="1.8"/><path d="M5 20c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <div>
                <strong>Accesso Riservato</strong>
                <span>Sala esclusiva, disponibile tutti i giorni per i soci</span>
              </div>
            </li>
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4M4 10h16M4 10v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M9 14h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <div>
                <strong>Spogliatoi e Servizi</strong>
                <span>Docce, armadietti e area relax a disposizione</span>
              </div>
            </li>
          </ul>

          <a href="/personal-trainer" class="btn btn-red sala-cta">
            Scopri i nostri Personal Trainer
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 13L13 1M13 1H5M13 1V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Corsi di Gruppo ── -->
  <section class="corsi-section" id="corsi">
    <div class="corsi-section__inner">
      <span class="eyebrow">Corsi di Gruppo</span>
      <h2 class="section-title">Allenati in<br><em>gruppo.</em></h2>
      <p class="corsi-sub">Ogni settimana sessioni guidate da istruttori certificati. Scegli il corso adatto al tuo obiettivo e prenota il tuo posto direttamente su PerfectGym.</p>

      {categories.map((cat) => (
        <div class="cat-block">
          <div class="cat-block__head" style={`--cat-color: ${cat.color}`}>
            <div class="cat-block__title-row">
              <span class="cat-block__label">{cat.label}</span>
              <div class="courses-nav">
                <button class="courses-btn" data-dir="-1" data-track={`courses-${cat.id}`} aria-label="Precedente">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="courses-btn" data-dir="1" data-track={`courses-${cat.id}`} aria-label="Successivo">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </div>
            <div class="cat-block__meta">
              <p class="cat-block__desc">{cat.desc}</p>
              <div class="cat-block__line"></div>
              <span class="cat-block__count">{cat.courses.length} corsi</span>
            </div>
          </div>
          <div class="courses-track-wrap">
            <div class="courses-track" data-carousel-id={`courses-${cat.id}`}>
              {cat.courses.map((course) => (
                <div class="course-card" style={`--cat-color: ${cat.color}`}>
                  <div class="course-card__media">
                    <img
                      src={publicUrl(course.img)}
                      alt={course.name}
                      class="course-card__media-img"
                      loading="lazy"
                    />
                  </div>
                  <div class="course-card__body">
                    <span class="course-card__cat">{cat.label}</span>
                    <h3 class="course-card__name">{course.name}</h3>
                    <p class="course-card__desc">{course.desc}</p>
                    <div class="course-card__params">
                      <div class="param-item">
                        <span class="param-item__label">Intensità</span>
                        <span class="param-item__dots" aria-label={course.intensity === 3 ? 'Alta' : course.intensity === 2 ? 'Media' : 'Bassa'}>
                          {[1,2,3].map(n => (
                            <span class={`dot${n <= course.intensity ? ' dot--on' : ''}`}></span>
                          ))}
                        </span>
                      </div>
                      <div class="param-item">
                        <span class="param-item__label">Durata</span>
                        <span class="param-item__value">{course.duration}</span>
                      </div>
                      <div class="param-item">
                        <span class="param-item__label">Livello</span>
                        <span class="param-item__value">{course.level}</span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Calendario corsi ── -->
  <section class="calendar-section" id="planning">
    <div class="calendar-section__inner">
      <span class="eyebrow">Calendario</span>
      <h2 class="section-title">Prenota il tuo<br><em>corso.</em></h2>
      <p class="corsi-sub">Controlla il calendario settimanale e riserva il tuo posto direttamente su PerfectGym.</p>

      <WeeklySchedule />
    </div>
  </section>

  <div id="membership" class="anchor-target">
    <MembershipSection />
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const GAP = 20; // 1.25rem

      // ── Manual navigation ──
      document.querySelectorAll<HTMLButtonElement>('.courses-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = Number(btn.dataset.dir);
          const track = document.querySelector<HTMLElement>(
            `[data-carousel-id="${btn.dataset.track}"]`
          );
          if (!track) return;
          const card = track.querySelector<HTMLElement>('.course-card');
          if (!card) return;
          track.scrollBy({ left: dir * (card.offsetWidth + GAP), behavior: 'smooth' });
        });
      });

      // ── Auto-scroll ──
      document.querySelectorAll<HTMLElement>('.courses-track').forEach((track) => {
        let paused = false;

        const advance = () => {
          if (paused) return;
          const card = track.querySelector<HTMLElement>('.course-card');
          if (!card) return;
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (track.scrollLeft >= maxScroll - 4) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: card.offsetWidth + GAP, behavior: 'smooth' });
          }
        };

        const interval = setInterval(advance, 3500);

        // Pause on hover / touch
        track.addEventListener('mouseenter', () => { paused = true; });
        track.addEventListener('mouseleave', () => { paused = false; });
        track.addEventListener('touchstart', () => { paused = true; }, { passive: true });
        track.addEventListener('touchend',   () => {
          setTimeout(() => { paused = false; }, 4000);
        }, { passive: true });

        // Clean up on page unload
        window.addEventListener('pagehide', () => clearInterval(interval), { once: true });
      });
    });
  </script>

  <!-- ── Slideshow Sala Attrezzi ── -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const slider = document.querySelector<HTMLElement>('[data-sala-slider]');
      if (!slider) return;
      const track = slider.querySelector<HTMLElement>('.sala-slider__track');
      const slides = slider.querySelectorAll('.sala-slider__slide');
      const dots = Array.from(slider.querySelectorAll<HTMLButtonElement>('[data-sala-dot]'));
      if (!track || slides.length < 2) return;

      const total = slides.length;
      const DELAY = 4000;
      let idx = 0;
      let timer: ReturnType<typeof setInterval> | undefined;

      function go(n: number) {
        idx = ((n % total) + total) % total;
        track!.style.transform = `translateX(-${idx * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      }
      function start() { stop(); timer = setInterval(() => go(idx + 1), DELAY); }
      function stop() { if (timer) clearInterval(timer); }

      dots.forEach((d, i) => d.addEventListener('click', () => { go(i); start(); }));

      // Pausa su hover (desktop)
      slider.addEventListener('mouseenter', stop);
      slider.addEventListener('mouseleave', start);

      // Swipe su touch
      let x0: number | null = null;
      slider.addEventListener('touchstart', (e) => { x0 = e.touches[0].clientX; stop(); }, { passive: true });
      slider.addEventListener('touchend', (e) => {
        if (x0 === null) return;
        const dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) go(idx + (dx < 0 ? 1 : -1));
        x0 = null;
        start();
      }, { passive: true });

      start();
      window.addEventListener('pagehide', stop, { once: true });
    });
  </script>
</BaseLayout>

<style>
  /* ── Anchor offset per navbar fissa ── */
  .anchor-target,
  #corsi,
  #planning {
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }

  /* ── Sala Attrezzi ── */
  .sala-section {
    padding: 7vh var(--pad-x);
  }

  .sala-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .sala-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: center;
  }

  .sala-split__media {
    position: relative;
    overflow: hidden;
  }

  /* ── Slideshow sala (solo foto) ── */
  .sala-slider {
    position: relative;
    overflow: hidden;
  }

  .sala-slider__track {
    display: flex;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .sala-slider__slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  .sala-slider__img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    display: block;
  }

  .sala-slider__dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 16px;
    display: flex;
    justify-content: center;
    gap: 9px;
    z-index: 2;
  }

  .sala-slider__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: background 0.25s, transform 0.25s;
  }

  .sala-slider__dot:hover { background: rgba(255, 255, 255, 0.8); }

  .sala-slider__dot.is-active {
    background: #fff;
    transform: scale(1.35);
  }

  .sala-split__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin: 0;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .sala-body {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    max-width: 52ch;
  }

  .sala-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .sala-feat {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .sala-feat__icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .sala-feat strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 2px;
  }

  .sala-feat span {
    font-family: var(--font-body);
