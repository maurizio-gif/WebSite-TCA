---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import MembershipSection from "../components/MembershipSection.astro";
import WeeklySchedule from "../components/WeeklySchedule.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/preparazione-atletica.md
const d = (await getEntry("pagine", "preparazione-atletica"))!.data;

const mdBold = (s: string) => s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

// Le 5 icone SVG delle caratteristiche sala attrezzi restano fisse per ordine (testo da Tina)
const salaIcons = [
  '<path d="M3 12h2m14 0h2M5 12a7 7 0 1 0 14 0 7 7 0 0 0-14 0zm4 0h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  '<rect x="2" y="11" width="4" height="2" rx="1" stroke="currentColor" stroke-width="1.8"/><rect x="18" y="11" width="4" height="2" rx="1" stroke="currentColor" stroke-width="1.8"/><path d="M6 12h12M6 9v6M18 9v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  '<path d="M4 6h16M4 12h10M4 18h7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  '<circle cx="12" cy="8" r="3" stroke="currentColor" stroke-width="1.8"/><path d="M5 20c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  '<path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4M4 10h16M4 10v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M9 14h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
];
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctas={[
      { label: "I nostri abbonamenti", href: "#membership" },
      { label: "Il nostro planning",   href: "#planning", outline: true },
    ]}
  />

  <!-- ── Sala Attrezzi ── -->
  <section class="sala-section">
    <div class="sala-section__inner">
      <div class="sala-split">
        <div class="sala-split__content">
          <span class="eyebrow">{d.prep_sala_eyebrow}</span>
          <h2 class="section-title">{d.prep_sala_titolo}<br><em>{d.prep_sala_titolo_accent}</em></h2>
          <p class="sala-body" set:html={mdBold(d.prep_sala_paragrafo1)} />
          <p class="sala-body" set:html={mdBold(d.prep_sala_paragrafo2)} />
        </div>
      </div>

      <div class="sala-gallery">
        {d.prep_sala_slideshow.map((img, i) => (
          <div class="sala-gallery__item" data-anim="true" data-anim-delay={String(i * 60)}>
            <img
              src={publicUrl(img.immagine)}
              alt={img.alt}
              loading={i === 0 ? "eager" : "lazy"}
            />
          </div>
        ))}
      </div>

      <div class="sala-features-grid">
        {d.prep_sala_features.map((f, i) => (
          <div class="sala-feat-card" data-anim="true" data-anim-delay={String(i * 80)}>
            <span class="sala-feat-card__icon-wrap">
              <svg class="sala-feat-card__icon" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={salaIcons[i]} />
            </span>
            <h3 class="sala-feat-card__title">{f.titolo}</h3>
            <p class="sala-feat-card__text">{f.testo}</p>
          </div>
        ))}
      </div>

      <div class="sala-cta-wrap">
        <a href="/personal-trainer" class="btn btn-red sala-cta">
          {d.prep_sala_cta_label}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 13L13 1M13 1H5M13 1V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Corsi di Gruppo ── -->
  <section class="corsi-section" id="corsi">
    <div class="corsi-section__inner">
      <span class="eyebrow">{d.prep_corsi_eyebrow}</span>
      <h2 class="section-title">{d.prep_corsi_titolo}<br><em>{d.prep_corsi_titolo_accent}</em></h2>
      <p class="corsi-sub">{d.prep_corsi_sub}</p>

      {d.prep_categorie.map((cat) => (
        <div class="cat-block">
          <div class="cat-block__head" style={`--cat-color: ${cat.color}`}>
            <div class="cat-block__title-row">
              <span class="cat-block__label">{cat.label}</span>
              <div class="courses-nav">
                <button class="courses-btn" data-dir="-1" data-track={`courses-${cat.id}`} aria-label="Precedente">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="courses-btn" data-dir="1" data-track={`courses-${cat.id}`} aria-label="Successivo">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </div>
            <div class="cat-block__meta">
              <p class="cat-block__desc">{cat.desc}</p>
              <div class="cat-block__line"></div>
              <span class="cat-block__count">{cat.corsi.length} corsi</span>
            </div>
          </div>
          <div class="courses-track-wrap">
            <div class="courses-track" data-carousel-id={`courses-${cat.id}`}>
              {cat.corsi.map((course) => (
                <div class="course-card" style={`--cat-color: ${cat.color}`}>
                  <div class="course-card__media">
                    <img
                      src={publicUrl(course.immagine)}
                      alt={course.nome}
                      class="course-card__media-img"
                      loading="lazy"
                    />
                  </div>
                  <div class="course-card__body">
                    <span class="course-card__cat">{cat.label}</span>
                    <h3 class="course-card__name">{course.nome}</h3>
                    <p class="course-card__desc">{course.desc}</p>
                    <div class="course-card__params">
                      <div class="param-item">
                        <span class="param-item__label">Intensità</span>
                        <span class="param-item__dots" aria-label={course.intensita === 3 ? 'Alta' : course.intensita === 2 ? 'Media' : 'Bassa'}>
                          {[1,2,3].map(n => (
                            <span class={`dot${n <= course.intensita ? ' dot--on' : ''}`}></span>
                          ))}
                        </span>
                      </div>
                      <div class="param-item">
                        <span class="param-item__label">Durata</span>
                        <span class="param-item__value">{course.durata}</span>
                      </div>
                      <div class="param-item">
                        <span class="param-item__label">Livello</span>
                        <span class="param-item__value">{course.livello}</span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Calendario corsi ── -->
  <section class="calendar-section" id="planning">
    <div class="calendar-section__inner">
      <span class="eyebrow">{d.prep_calendario_eyebrow}</span>
      <h2 class="section-title">{d.prep_calendario_titolo}<br><em>{d.prep_calendario_titolo_accent}</em></h2>
      <p class="corsi-sub">{d.prep_calendario_sub}</p>

      <WeeklySchedule />
    </div>
  </section>

  <div id="membership" class="anchor-target">
    <MembershipSection />
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const GAP = 20; // 1.25rem

      // ── Manual navigation ──
      document.querySelectorAll<HTMLButtonElement>('.courses-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = Number(btn.dataset.dir);
          const track = document.querySelector<HTMLElement>(
            `[data-carousel-id="${btn.dataset.track}"]`
          );
          if (!track) return;
          const card = track.querySelector<HTMLElement>('.course-card');
          if (!card) return;
          track.scrollBy({ left: dir * (card.offsetWidth + GAP), behavior: 'smooth' });
        });
      });

      // ── Auto-scroll ──
      document.querySelectorAll<HTMLElement>('.courses-track').forEach((track) => {
        let paused = false;

        const advance = () => {
          if (paused) return;
          const card = track.querySelector<HTMLElement>('.course-card');
          if (!card) return;
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (track.scrollLeft >= maxScroll - 4) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: card.offsetWidth + GAP, behavior: 'smooth' });
          }
        };

        const interval = setInterval(advance, 3500);

        // Pause on hover / touch
        track.addEventListener('mouseenter', () => { paused = true; });
        track.addEventListener('mouseleave', () => { paused = false; });
        track.addEventListener('touchstart', () => { paused = true; }, { passive: true });
        track.addEventListener('touchend',   () => {
          setTimeout(() => { paused = false; }, 4000);
        }, { passive: true });

        // Clean up on page unload
        window.addEventListener('pagehide', () => clearInterval(interval), { once: true });
      });
    });
  </script>

</BaseLayout>

<style>
  /* ── Anchor offset per navbar fissa ── */
  .anchor-target,
  #corsi,
  #planning {
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }

  /* ── Sala Attrezzi ── */
  .sala-section {
    padding: 7vh var(--pad-x);
  }

  .sala-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .sala-split {
    display: flex;
    flex-direction: column;
  }

  /* ── Galleria bento sala attrezzi ── */
  .sala-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: clamp(130px, 15vw, 200px);
    gap: 0.85rem;
    margin-top: 3.5rem;
  }

  /* Posizionamento esplicito per le prime 4 foto (grande + 2 + larga):
     con il solo "span" l'auto-placement riempie la cella libera più vicina
     nell'ordine del DOM e la 4ª foto "ruba" il posto destinato alla larga. */
  .sala-gallery__item:nth-child(1) { grid-column: 1 / 3; grid-row: 1 / 3; }
  .sala-gallery__item:nth-child(2) { grid-column: 3 / 4; grid-row: 1 / 2; }
  .sala-gallery__item:nth-child(3) { grid-column: 4 / 5; grid-row: 1 / 2; }
  .sala-gallery__item:nth-child(4) { grid-column: 3 / 5; grid-row: 2 / 3; }

  .sala-gallery__item {
    position: relative;
    overflow: hidden;
  }

  .sala-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .sala-gallery__item:hover img {
    transform: scale(1.06);
  }

  @media (max-width: 700px) {
    .sala-gallery {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: clamp(140px, 38vw, 220px);
    }

    .sala-gallery__item:nth-child(1),
    .sala-gallery__item:nth-child(2),
    .sala-gallery__item:nth-child(3),
    .sala-gallery__item:nth-child(4) {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  .sala-split__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin: 0;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .sala-body {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  /* ── Griglia caratteristiche sala attrezzi (a piena larghezza, sotto lo split) ── */
  .sala-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1.25rem;
    margin-top: 5vh;
  }

  .sala-feat-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1.75rem 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .sala-feat-card:hover {
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
    transform: translateY(-3px);
    border-color: var(--color-accent);
  }

  .sala-feat-card__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(139, 26, 26, 0.08);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .sala-feat-card__title {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.1vw, 1.1rem);
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .sala-feat-card__text {
    font-family: var(--font-body);
    font-size: clamp(14.5px, 0.95vw, 16px);
    font-weight: 300;
    color: var(--color-text-light);
    line-height: 1.55;
  }

  .sala-cta-wrap {
    margin-top: 5vh;
    text-align: center;
  }

  .sala-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ── Corsi di Gruppo ── */
  .corsi-section {
    padding: 7vh var(--pad-x);
    background: var(--color-off-white);
  }

  .corsi-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .corsi-sub {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    margin-bottom: 6vh;
  }

  /* ── Category block ── */
  .cat-block {
    margin-bottom: 7vh;
  }

  .cat-block:last-child {
    margin-bottom: 0;
  }

  .cat-block__head {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .cat-block__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cat-block__label {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 6rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.9;
    color: var(--cat-color);
  }

  .cat-block__meta {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .cat-block__desc {
    font-family: var(--font-body);
    font-size: clamp(15px, 0.95vw, 17px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
    margin: 0;
    max-width: 52ch;
    flex-shrink: 0;
  }

  .cat-block__line {
    flex: 1;
    height: 1px;
    background: var(--cat-color);
    opacity: 0.2;
  }

  .cat-block__count {
    font-family: var(--font-display);
    font-size: clamp(10px, 0.75vw, 12px);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
  }

  /* ── Nav arrows ── */
  .courses-nav {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .courses-btn {
    width: 34px;
    height: 34px;
    border: 1.5px solid var(--color-border);
    border-radius: 50%;
    background: #fff;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    flex-shrink: 0;
  }

  .courses-btn:hover {
    background: var(--color-text);
    border-color: var(--color-text);
    color: #fff;
  }

  /* ── Course carousel ── */
  .courses-track-wrap {
    overflow: hidden;
    margin: 0 calc(-1 * var(--pad-x));
  }

  .courses-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.5rem var(--pad-x) 1.5rem;
    scroll-padding-left: var(--pad-x);
  }

  .courses-track::-webkit-scrollbar { display: none; }

  /* ── Course card ── */
  .course-card {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .course-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .course-card__media {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #E5E7EB;
  }

  .course-card__media .img-placeholder,
  .course-card__media-img {
    width: 100%;
    height: 100%;
    min-height: unset !important;
    object-fit: cover;
    display: block;
  }

  .course-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .course-card__cat {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cat-color);
  }

  .course-card__name {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--color-text);
    margin-top: 0.1rem;
  }

  .course-card__desc {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.85vw, 15.5px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
    margin: 0.3rem 0 0.6rem;
    flex: 1;
  }

  /* ── Parameters ── */
  .course-card__params {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .param-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .param-item__label {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-light);
    flex-shrink: 0;
  }

  .param-item__dots {
    display: flex;
    gap: 4px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    display: inline-block;
  }

  .dot--on {
    background: var(--cat-color);
  }

  .param-item__value {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    text-align: right;
  }

  /* ── Calendar section ── */
  .calendar-section {
    padding: 7vh var(--pad-x);
  }

  .calendar-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Calendar weekly schedule → WeeklySchedule.astro */

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .course-card { flex: 0 0 calc((100% - 1.25rem) / 2); }
    .cat-block__meta { flex-wrap: wrap; }
    .cat-block__desc { max-width: 100%; flex-shrink: 1; }
  }

  @media (max-width: 640px) {
    .course-card { flex: 0 0 calc(78vw); }
    .cat-block__label { font-size: clamp(2.2rem, 10vw, 3.5rem); }
    .cat-block__line { display: none; }
    .cat-block__count { display: none; }
  }
</style>
