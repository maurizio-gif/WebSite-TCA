---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import LeadFormPlaceholder from "../components/LeadFormPlaceholder.astro";
import InfoPratiche from "../components/InfoPratiche.astro";
---

<BaseLayout
  title="Preparazione Atletica | Tennis Club Ambrosiano"
  description="Preparazione atletica al Tennis Club Ambrosiano: personal training, sala pesi, corsi funzionali e programmi sport-specific per tennisti e atleti di ogni livello."
>
  <PageHero
    eyebrow="Adulti · Preparazione Atletica"
    title="Preparazione"
    titleAccent="Atletica"
    sub="Programmi di allenamento sport-specific, personal training e sala attrezzi professionale. Migliora le tue performance in campo e fuori."
    image="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
    imageAlt="Sala di preparazione atletica TCA"
    ctaLabel="Richiedi informazioni"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Programmi</span>
      <h2 class="section-title">Il tuo<br><em>allenamento.</em></h2>
      <div class="prog-grid">
        <div class="prog-card">
          <img
            src="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
            alt="Personal training TCA"
            class="prog-card__img"
          />
          <div class="prog-card__body">
            <h3>Personal Training</h3>
            <p>Sedute individuali con preparatori atletici certificati. Obiettivi personalizzati, progressi misurabili.</p>
          </div>
        </div>
        <div class="prog-card">
          <img
            src="/c99ebd5f-16b9-442f-9bb7-2437d5203cd2_TCA+Fitness+5.avif"
            alt="Allenamento funzionale TCA"
            class="prog-card__img"
          />
          <div class="prog-card__body">
            <h3>Allenamento Funzionale</h3>
            <p>Corsi in piccoli gruppi focalizzati su forza, mobilità e condizione fisica generale.</p>
          </div>
        </div>
        <div class="prog-card">
          <div class="img-placeholder" data-name="sport-specific.avif" style="min-height:200px"></div>
          <div class="prog-card__body">
            <h3>Sport Specific per Tennisti</h3>
            <p>Programmi dedicati al tennis: esplosività, agilità laterale, core stability e prevenzione infortuni.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <LeadFormPlaceholder />
  <InfoPratiche />
</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .prog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .prog-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .prog-card__img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    display: block;
  }

  .prog-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prog-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prog-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  @media (max-width: 860px) {
    .prog-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 560px) {
    .prog-grid { grid-template-columns: 1fr; }
  }
</style>
