---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import MembershipSection from "../components/MembershipSection.astro";
import WeeklySchedule from "../components/WeeklySchedule.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/preparazione-atletica.md
const d = (await getEntry("pagine", "preparazione-atletica"))!.data;

const mdBold = (s: string) => s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

// Le 5 icone SVG delle caratteristiche sala attrezzi restano fisse per ordine (testo da Tina)
const salaIcons = [
  '<path d="M3 12h2m14 0h2M5 12a7 7 0 1 0 14 0 7 7 0 0 0-14 0zm4 0h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  '<rect x="2" y="11" width="4" height="2" rx="1" stroke="currentColor" stroke-width="1.8"/><rect x="18" y="11" width="4" height="2" rx="1" stroke="currentColor" stroke-width="1.8"/><path d="M6 12h12M6 9v6M18 9v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  '<path d="M4 6h16M4 12h10M4 18h7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  '<circle cx="12" cy="8" r="3" stroke="currentColor" stroke-width="1.8"/><path d="M5 20c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  '<path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4M4 10h16M4 10v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M9 14h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
];
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctas={[
      { label: "I nostri abbonamenti", href: "#membership" },
      { label: "Il nostro planning",   href: "#planning", outline: true },
    ]}
  />

  <!-- ── Sala Attrezzi ── -->
  <section class="sala-section">
    <div class="sala-section__inner">
      <div class="sala-split">

        <div class="sala-split__content">
          <span class="eyebrow">{d.prep_sala_eyebrow}</span>
          <h2 class="section-title">{d.prep_sala_titolo}<br><em>{d.prep_sala_titolo_accent}</em></h2>
          <p class="sala-body" set:html={mdBold(d.prep_sala_paragrafo1)} />
          <p class="sala-body" set:html={mdBold(d.prep_sala_paragrafo2)} />

          <ul class="sala-features">
            {d.prep_sala_features.map((f, i) => (
              <li class="sala-feat">
                <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={salaIcons[i]} />
                <div>
                  <strong>{f.titolo}</strong>
                  <span>{f.testo}</span>
                </div>
              </li>
            ))}
          </ul>

          <a href="/personal-trainer" class="btn btn-red sala-cta">
            {d.prep_sala_cta_label}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 13L13 1M13 1H5M13 1V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="sala-split__media" data-anim="scale">
          <div class="sala-slider" data-sala-slider>
            <div class="sala-slider__track">
              {d.prep_sala_slideshow.map((img, i) => (
                <div class="sala-slider__slide">
                  <img
                    src={publicUrl(img.immagine)}
                    alt={img.alt}
                    class="sala-slider__img"
                    loading={i === 0 ? "eager" : "lazy"}
                  />
                </div>
              ))}
            </div>
            <div class="sala-slider__dots">
              {d.prep_sala_slideshow.map((_, i) => (
                <button
                  class={`sala-slider__dot${i === 0 ? " is-active" : ""}`}
                  data-sala-dot={i}
                  type="button"
                  aria-label={`Vai alla foto ${i + 1}`}
                ></button>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Corsi di Gruppo ── -->
  <section class="corsi-section" id="corsi">
    <div class="corsi-section__inner">
      <span class="eyebrow">{d.prep_corsi_eyebrow}</span>
      <h2 class="section-title">{d.prep_corsi_titolo}<br><em>{d.prep_corsi_titolo_accent}</em></h2>
      <p class="corsi-sub">{d.prep_corsi_sub}</p>

      {d.prep_categorie.map((cat) => (
        <div class="cat-block">
          <div class="cat-block__head" style={`--cat-color: ${cat.color}`}>
            <div class="cat-block__title-row">
              <span class="cat-block__label">{cat.label}</span>
              <div class="courses-nav">
                <button class="courses-btn" data-dir="-1" data-track={`courses-${cat.id}`} aria-label="Precedente">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="courses-btn" data-dir="1" data-track={`courses-${cat.id}`} aria-label="Successivo">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </div>
            <div class="cat-block__meta">
              <p class="cat-block__desc">{cat.desc}</p>
              <div class="cat-block__line"></div>
              <span class="cat-block__count">{cat.corsi.length} corsi</span>
            </div>
          </div>
          <div class="courses-track-wrap">
            <div class="courses-track" data-carousel-id={`courses-${cat.id}`}>
              {cat.corsi.map((course) => (
                <div class="course-card" style={`--cat-color: ${cat.color}`}>
                  <div class="course-card__media">
                    <img
                      src={publicUrl(course.immagine)}
                      alt={course.nome}
                      class="course-card__media-img"
                      loading="lazy"
                    />
                  </div>
                  <div class="course-card__body">
                    <span class="course-card__cat">{cat.label}</span>
                    <h3 class="course-card__name">{course.nome}</h3>
                    <p class="course-card__desc">{course.desc}</p>
                    <div class="course-card__params">
                      <div class="param-item">
                        <span class="param-item__label">Intensità</span>
                        <span class="param-item__dots" aria-label={course.intensita === 3 ? 'Alta' : course.intensita === 2 ? 'Media' : 'Bassa'}>
                          {[1,2,3].map(n => (
                            <span class={`dot${n <= course.intensita ? ' dot--on' : ''}`}></span>
                          ))}
                        </span>
                      </div>
                      <div class="param-item">
                        <span class="param-item__label">Durata</span>
                        <span class="param-item__value">{course.durata}</span>
                      </div>
                      <div class="param-item">
                        <span class="param-item__label">Livello</span>
                        <span class="param-item__value">{course.livello}</span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Calendario corsi ── -->
  <section class="calendar-section" id="planning">
    <div class="calendar-section__inner">
      <span class="eyebrow">{d.prep_calendario_eyebrow}</span>
      <h2 class="section-title">{d.prep_calendario_titolo}<br><em>{d.prep_calendario_titolo_accent}</em></h2>
      <p class="corsi-sub">{d.prep_calendario_sub}</p>

      <WeeklySchedule />
    </div>
  </section>

  <div id="membership" class="anchor-target">
    <MembershipSection />
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const GAP = 20; // 1.25rem

      // ── Manual navigation ──
      document.querySelectorAll<HTMLButtonElement>('.courses-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = Number(btn.dataset.dir);
          const track = document.querySelector<HTMLElement>(
            `[data-carousel-id="${btn.dataset.track}"]`
          );
          if (!track) return;
          const card = track.querySelector<HTMLElement>('.course-card');
          if (!card) return;
          track.scrollBy({ left: dir * (card.offsetWidth + GAP), behavior: 'smooth' });
        });
      });

      // ── Auto-scroll ──
      document.querySelectorAll<HTMLElement>('.courses-track').forEach((track) => {
        let paused = false;

        const advance = () => {
          if (paused) return;
          const card = track.querySelector<HTMLElement>('.course-card');
          if (!card) return;
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (track.scrollLeft >= maxScroll - 4) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: card.offsetWidth + GAP, behavior: 'smooth' });
          }
        };

        const interval = setInterval(advance, 3500);

        // Pause on hover / touch
        track.addEventListener('mouseenter', () => { paused = true; });
        track.addEventListener('mouseleave', () => { paused = false; });
        track.addEventListener('touchstart', () => { paused = true; }, { passive: true });
        track.addEventListener('touchend',   () => {
          setTimeout(() => { paused = false; }, 4000);
        }, { passive: true });

        // Clean up on page unload
        window.addEventListener('pagehide', () => clearInterval(interval), { once: true });
      });
    });
  </script>

  <!-- ── Slideshow Sala Attrezzi ── -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const slider = document.querySelector<HTMLElement>('[data-sala-slider]');
      if (!slider) return;
      const track = slider.querySelector<HTMLElement>('.sala-slider__track');
      const slides = slider.querySelectorAll('.sala-slider__slide');
      const dots = Array.from(slider.querySelectorAll<HTMLButtonElement>('[data-sala-dot]'));
      if (!track || slides.length < 2) return;

      const total = slides.length;
      const DELAY = 4000;
      let idx = 0;
      let timer: ReturnType<typeof setInterval> | undefined;

      function go(n: number) {
        idx = ((n % total) + total) % total;
        track!.style.transform = `translateX(-${idx * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      }
      function start() { stop(); timer = setInterval(() => go(idx + 1), DELAY); }
      function stop() { if (timer) clearInterval(timer); }

      dots.forEach((d, i) => d.addEventListener('click', () => { go(i); start(); }));

      // Pausa su hover (desktop)
      slider.addEventListener('mouseenter', stop);
      slider.addEventListener('mouseleave', start);

      // Swipe su touch
      let x0: number | null = null;
      slider.addEventListener('touchstart', (e) => { x0 = e.touches[0].clientX; stop(); }, { passive: true });
      slider.addEventListener('touchend', (e) => {
        if (x0 === null) return;
        const dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) go(idx + (dx < 0 ? 1 : -1));
        x0 = null;
        start();
      }, { passive: true });

      start();
      window.addEventListener('pagehide', stop, { once: true });
    });
  </script>
</BaseLayout>

<style>
  /* ── Anchor offset per navbar fissa ── */
  .anchor-target,
  #corsi,
  #planning {
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }

  /* ── Sala Attrezzi ── */
  .sala-section {
    padding: 7vh var(--pad-x);
  }

  .sala-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .sala-split {
    display: flex;
    flex-direction: column;
  }

  .sala-split__media {
    position: relative;
    overflow: hidden;
    margin-top: 2.5rem;
  }

  /* ── Slideshow sala (solo foto) ── */
  .sala-slider {
    position: relative;
    overflow: hidden;
  }

  .sala-slider__track {
    display: flex;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .sala-slider__slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  .sala-slider__img {
    width: 100%;
    height: clamp(280px, 42vh, 520px);
    object-fit: cover;
    display: block;
  }

  .sala-slider__dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 16px;
    display: flex;
    justify-content: center;
    gap: 9px;
    z-index: 2;
  }

  .sala-slider__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: background 0.25s, transform 0.25s;
  }

  .sala-slider__dot:hover { background: rgba(255, 255, 255, 0.8); }

  .sala-slider__dot.is-active {
    background: #fff;
    transform: scale(1.35);
  }

  .sala-split__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin: 0;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .sala-body {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  .sala-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .sala-feat {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .sala-feat__icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .sala-feat strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 2px;
  }

  .sala-feat span {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.85vw, 15.5px);
    font-weight: 300;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  .sala-cta {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  /* ── Corsi di Gruppo ── */
  .corsi-section {
    padding: 7vh var(--pad-x);
    background: var(--color-off-white);
  }

  .corsi-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .corsi-sub {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    margin-bottom: 6vh;
  }

  /* ── Category block ── */
  .cat-block {
    margin-bottom: 7vh;
  }

  .cat-block:last-child {
    margin-bottom: 0;
  }

  .cat-block__head {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .cat-block__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cat-block__label {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 6rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.9;
    color: var(--cat-color);
  }

  .cat-block__meta {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .cat-block__desc {
    font-family: var(--font-body);
    font-size: clamp(15px, 0.95vw, 17px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
    margin: 0;
    max-width: 52ch;
    flex-shrink: 0;
  }

  .cat-block__line {
    flex: 1;
    height: 1px;
    background: var(--cat-color);
    opacity: 0.2;
  }

  .cat-block__count {
    font-family: var(--font-display);
    font-size: clamp(10px, 0.75vw, 12px);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
  }

  /* ── Nav arrows ── */
  .courses-nav {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .courses-btn {
    width: 34px;
    height: 34px;
    border: 1.5px solid var(--color-border);
    border-radius: 50%;
    background: #fff;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    flex-shrink: 0;
  }

  .courses-btn:hover {
    background: var(--color-text);
    border-color: var(--color-text);
    color: #fff;
  }

  /* ── Course carousel ── */
  .courses-track-wrap {
    overflow: hidden;
    margin: 0 calc(-1 * var(--pad-x));
  }

  .courses-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.5rem var(--pad-x) 1.5rem;
    scroll-padding-left: var(--pad-x);
  }

  .courses-track::-webkit-scrollbar { display: none; }

  /* ── Course card ── */
  .course-card {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .course-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .course-card__media {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #E5E7EB;
  }

  .course-card__media .img-placeholder,
  .course-card__media-img {
    width: 100%;
    height: 100%;
    min-height: unset !important;
    object-fit: cover;
    display: block;
  }

  .course-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .course-card__cat {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cat-color);
  }

  .course-card__name {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--color-text);
    margin-top: 0.1rem;
  }

  .course-card__desc {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.85vw, 15.5px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
    margin: 0.3rem 0 0.6rem;
    flex: 1;
  }

  /* ── Parameters ── */
  .course-card__params {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .param-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .param-item__label {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-light);
    flex-shrink: 0;
  }

  .param-item__dots {
    display: flex;
    gap: 4px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    display: inline-block;
  }

  .dot--on {
    background: var(--cat-color);
  }

  .param-item__value {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    text-align: right;
  }

  /* ── Calendar section ── */
  .calendar-section {
    padding: 7vh var(--pad-x);
  }

  .calendar-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Calendar weekly schedule → WeeklySchedule.astro */

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .course-card { flex: 0 0 calc((100% - 1.25rem) / 2); }
    .cat-block__meta { flex-wrap: wrap; }
    .cat-block__desc { max-width: 100%; flex-shrink: 1; }
  }

  @media (max-width: 640px) {
    .course-card { flex: 0 0 calc(78vw); }
    .cat-block__label { font-size: clamp(2.2rem, 10vw, 3.5rem); }
    .cat-block__line { display: none; }
    .cat-block__count { display: none; }
  }
</style>
