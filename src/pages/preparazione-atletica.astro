---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import MembershipSection from "../components/MembershipSection.astro";
import WeeklySchedule from "../components/WeeklySchedule.astro";
import LeadFormInline from "../components/LeadFormInline.astro";
import InfoPratiche from "../components/InfoPratiche.astro";

interface Course {
  name: string;
  duration: string;
  intensity: 1 | 2 | 3;
  level: string;
  desc: string;
  img: string;
}

interface Category {
  id: string;
  label: string;
  desc: string;
  color: string;
  courses: Course[];
}

const pex = (id: string) =>
  `https://images.pexels.com/photos/${id}/pexels-photo-${id}.jpeg?auto=compress&cs=tinysrgb&w=800&h=600&fit=crop`;

const YOGA   = '/b9c52423-5bff-496a-8686-bffe1b123195_Aspria_Milano_Outdoor_Yoga+1.avif';
const GYM    = '/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif';
const RACKET = '/aXCJ_AIvOtkhBw2j_Lifestyle_232026SpeedMP_DXT56509.avif';

const categories: Category[] = [
  {
    id: 'endurance',
    label: 'Endurance',
    desc: 'Allena il sistema cardiovascolare, brucia calorie e migliora la resistenza e la coordinazione ritmica con corsi dinamici e coinvolgenti.',
    color: '#B83A00',
    courses: [
      { name: 'Dance',           duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Coreografie su musica pop e latina. Cardio coinvolgente e coordinazione ritmica.',    img: pex('4090012') },
      { name: 'Zumba',           duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Mix di danza latino-americana e fitness. Brucia calorie con il sorriso.',             img: pex('4090009') },
      { name: 'Cycling',         duration: '45 min', intensity: 3, level: 'Tutti i livelli', desc: 'Allenamento su bike al ritmo della musica. Massima resa cardiovascolare.',            img: pex('8766368') },
      { name: 'Aeroboxe',        duration: '60 min', intensity: 3, level: 'Intermedio',      desc: 'Combinazione di arti marziali e aerobica. Potenza, riflessi e resistenza.',          img: pex('32321639') },
      { name: 'Functional Step', duration: '45 min', intensity: 2, level: 'Tutti i livelli', desc: 'Step rivisitato con movimenti funzionali. Tonifica e migliora la resistenza.',       img: pex('6285220') },
      { name: 'Step & Tone',     duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Step cardio abbinato a tonificazione. Allenamento a corpo completo.',                img: pex('6285206') },
    ]
  },
  {
    id: 'strength',
    label: 'Strength',
    desc: 'Costruisci forza muscolare, potenza e stabilità. Allenamenti con pesi liberi, carichi e a corpo libero per una fisicità solida e funzionale.',
    color: '#1A1A1A',
    courses: [
      { name: 'Funracket',            duration: '60 min', intensity: 3, level: 'Intermedio',      desc: 'Sport-specific per tennisti e padellisti. Forza esplosiva, reattività e agilità.',    img: RACKET },
      { name: 'Tribal-x',             duration: '45 min', intensity: 3, level: 'Intermedio',      desc: 'Circuito ad alta intensità con carichi liberi. Forza e potenza muscolare.',           img: pex('4720807') },
      { name: 'Functional',           duration: '45 min', intensity: 2, level: 'Tutti i livelli', desc: 'Allenamento col peso corporeo. Forza funzionale e stabilità articolare.',            img: GYM },
      { name: 'Active Pump',          duration: '60 min', intensity: 2, level: 'Tutti i livelli', desc: 'Barbell workout con bilanciere. Tonificazione totale su musica.',                    img: pex('703012') },
      { name: 'Total Body',           duration: '60 min', intensity: 3, level: 'Tutti i livelli', desc: 'Lavoro su tutti i distretti muscolari. Forza, resistenza e postura.',               img: GYM },
      { name: 'Circuit',              duration: '45 min', intensity: 3, level: 'Intermedio',      desc: 'Stazioni cardio e forza in sequenza. Metabolismo alle stelle.',                     img: pex('4720291') },
      { name: 'Suspension Training',  duration: '60 min', intensity: 3, level: 'Intermedio',      desc: 'TRX e sling training. Core, stabilità e forza funzionale in sospensione.',          img: pex('5480481') },
    ]
  },
  {
    id: 'balance',
    label: 'Balance',
    desc: 'Equilibrio, flessibilità e benessere corpo-mente. Migliora postura, mobilità e consapevolezza corporea con pratiche dolci e dinamiche.',
    color: '#1E4D3A',
    courses: [
      { name: 'Pilates Funzionale', duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Pilates applicato al movimento quotidiano. Core, postura e consapevolezza corporea.', img: pex('25596884') },
      { name: 'Flexability',        duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Flessibilità e mobilità articolare. Previene infortuni e libera le tensioni.',        img: pex('2424257') },
      { name: 'Hatha Yoga',         duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Pratica yogica classica. Equilibrio corpo-mente attraverso asana e respiro.',        img: YOGA },
      { name: 'Pilates',            duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Metodo originale di controllo e precisione. Rinforza il centro, migliora la postura.', img: pex('25596885') },
      { name: 'Postural',           duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Rieducazione posturale attiva. Corregge le tensioni e riequilibra il corpo.',        img: pex('7992044') },
      { name: 'Power Yoga',         duration: '60 min', intensity: 2, level: 'Intermedio',      desc: 'Yoga dinamico e intenso. Forza, flessibilità e concentrazione unite.',               img: YOGA },
      { name: 'Ginnastica Dolce',   duration: '60 min', intensity: 1, level: 'Tutti i livelli', desc: 'Mobilità dolce per tutti. Ideale per over 50 e recupero attivo.',                   img: pex('11674389') },
    ]
  }
];
---

<BaseLayout
  title="Sala Attrezzi e Corsi di Gruppo | Tennis Club Ambrosiano Milano"
  description="Sala pesi professionale, personal trainer certificati e oltre 20 corsi di gruppo settimanali al Tennis Club Ambrosiano di Milano. Allenati con metodo e raggiungi i tuoi obiettivi."
>
  <PageHero
    eyebrow="Adulti · Preparazione Atletica"
    title="Allenamento"
    titleAccent="& Benessere"
    sub="Sala attrezzi professionale, personal trainer certificati e oltre 20 corsi di gruppo a settimana. Due anime, un unico obiettivo: il tuo."
    image="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
    imageAlt="Sala attrezzi professionale TCA"
    ctas={[
      { label: "I nostri abbonamenti", href: "#membership" },
      { label: "Il nostro planning",   href: "#planning", outline: true },
    ]}
  />

  <!-- ── Sala Attrezzi ── -->
  <section class="sala-section">
    <div class="sala-section__inner">
      <div class="sala-split">

        <div class="sala-split__media">
          <img
            src="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
            alt="Sala attrezzi professionale Tennis Club Ambrosiano"
            class="sala-split__img"
          />
        </div>

        <div class="sala-split__content">
          <span class="eyebrow">Sala Attrezzi</span>
          <h2 class="section-title">Potenziamento<br><em>su misura.</em></h2>
          <p class="sala-body">
            Una sala attrezzi completa riservata ai soci, con macchinari professionali, area cardio e spazio per l'allenamento funzionale. Che tu voglia aumentare la forza, migliorare la resistenza o semplicemente mantenerti in forma, qui hai tutto il necessario — e i professionisti giusti per guidarti.
          </p>

          <ul class="sala-features">
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 12h2m14 0h2M5 12a7 7 0 1 0 14 0 7 7 0 0 0-14 0zm4 0h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <div>
                <strong>Macchine Cardio</strong>
                <span>Tapis roulant, ellittiche, rowing machine, bike</span>
              </div>
            </li>
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="11" width="4" height="2" rx="1" stroke="currentColor" stroke-width="1.8"/><rect x="18" y="11" width="4" height="2" rx="1" stroke="currentColor" stroke-width="1.8"/><path d="M6 12h12M6 9v6M18 9v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <div>
                <strong>Pesi Liberi</strong>
                <span>Manubri 1–40 kg, bilancieri, cavi multifunzione</span>
              </div>
            </li>
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16M4 12h10M4 18h7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <div>
                <strong>Area Funzionale</strong>
                <span>TRX, kettlebell, slam ball, battle rope</span>
              </div>
            </li>
            <li class="sala-feat">
              <svg class="sala-feat__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="3" stroke="currentColor" stroke-width="1.8"/><path d="M5 20c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              <div>
                <strong>Accesso Riservato</strong>
                <span>Sala esclusiva, disponibile tutti i giorni per i soci</span>
              </div>
            </li>
          </ul>

          <a href="/personal-trainer" class="btn btn-red sala-cta">
            Scopri i nostri Personal Trainer
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 13L13 1M13 1H5M13 1V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Corsi di Gruppo ── -->
  <section class="corsi-section" id="corsi">
    <div class="corsi-section__inner">
      <span class="eyebrow">Corsi di Gruppo</span>
      <h2 class="section-title">Allenati in<br><em>gruppo.</em></h2>
      <p class="corsi-sub">Ogni settimana sessioni guidate da istruttori certificati. Scegli il corso adatto al tuo obiettivo e prenota il tuo posto direttamente su PerfectGym.</p>

      {categories.map((cat) => (
        <div class="cat-block">
          <div class="cat-block__head" style={`--cat-color: ${cat.color}`}>
            <div class="cat-block__title-row">
              <span class="cat-block__label">{cat.label}</span>
              <div class="courses-nav">
                <button class="courses-btn" data-dir="-1" data-track={`courses-${cat.id}`} aria-label="Precedente">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="courses-btn" data-dir="1" data-track={`courses-${cat.id}`} aria-label="Successivo">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </div>
            <div class="cat-block__meta">
              <p class="cat-block__desc">{cat.desc}</p>
              <div class="cat-block__line"></div>
              <span class="cat-block__count">{cat.courses.length} corsi</span>
            </div>
          </div>
          <div class="courses-track-wrap">
            <div class="courses-track" data-carousel-id={`courses-${cat.id}`}>
              {cat.courses.map((course) => (
                <div class="course-card" style={`--cat-color: ${cat.color}`}>
                  <div class="course-card__media">
                    <img
                      src={course.img}
                      alt={course.name}
                      class="course-card__media-img"
                      loading="lazy"
                    />
                  </div>
                  <div class="course-card__body">
                    <span class="course-card__cat">{cat.label}</span>
                    <h3 class="course-card__name">{course.name}</h3>
                    <p class="course-card__desc">{course.desc}</p>
                    <div class="course-card__params">
                      <div class="param-item">
                        <span class="param-item__label">Intensità</span>
                        <span class="param-item__dots" aria-label={course.intensity === 3 ? 'Alta' : course.intensity === 2 ? 'Media' : 'Bassa'}>
                          {[1,2,3].map(n => (
                            <span class={`dot${n <= course.intensity ? ' dot--on' : ''}`}></span>
                          ))}
                        </span>
                      </div>
                      <div class="param-item">
                        <span class="param-item__label">Durata</span>
                        <span class="param-item__value">{course.duration}</span>
                      </div>
                      <div class="param-item">
                        <span class="param-item__label">Livello</span>
                        <span class="param-item__value">{course.level}</span>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Calendario corsi ── -->
  <section class="calendar-section" id="planning">
    <div class="calendar-section__inner">
      <span class="eyebrow">Calendario</span>
      <h2 class="section-title">Prenota il tuo<br><em>corso.</em></h2>
      <p class="corsi-sub">Controlla il calendario settimanale e riserva il tuo posto direttamente su PerfectGym.</p>

      <WeeklySchedule />
    </div>
  </section>

  <div id="membership" class="anchor-target">
    <MembershipSection />
  </div>
  <LeadFormInline />
  <InfoPratiche />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const GAP = 20; // 1.25rem

      // ── Manual navigation ──
      document.querySelectorAll<HTMLButtonElement>('.courses-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = Number(btn.dataset.dir);
          const track = document.querySelector<HTMLElement>(
            `[data-carousel-id="${btn.dataset.track}"]`
          );
          if (!track) return;
          const card = track.querySelector<HTMLElement>('.course-card');
          if (!card) return;
          track.scrollBy({ left: dir * (card.offsetWidth + GAP), behavior: 'smooth' });
        });
      });

      // ── Auto-scroll ──
      document.querySelectorAll<HTMLElement>('.courses-track').forEach((track) => {
        let paused = false;

        const advance = () => {
          if (paused) return;
          const card = track.querySelector<HTMLElement>('.course-card');
          if (!card) return;
          const maxScroll = track.scrollWidth - track.clientWidth;
          if (track.scrollLeft >= maxScroll - 4) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: card.offsetWidth + GAP, behavior: 'smooth' });
          }
        };

        const interval = setInterval(advance, 3500);

        // Pause on hover / touch
        track.addEventListener('mouseenter', () => { paused = true; });
        track.addEventListener('mouseleave', () => { paused = false; });
        track.addEventListener('touchstart', () => { paused = true; }, { passive: true });
        track.addEventListener('touchend',   () => {
          setTimeout(() => { paused = false; }, 4000);
        }, { passive: true });

        // Clean up on page unload
        window.addEventListener('pagehide', () => clearInterval(interval), { once: true });
      });
    });
  </script>
</BaseLayout>

<style>
  /* ── Anchor offset per navbar fissa ── */
  .anchor-target,
  #corsi,
  #planning {
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }

  /* ── Sala Attrezzi ── */
  .sala-section {
    padding: 7vh var(--pad-x);
  }

  .sala-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .sala-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: center;
  }

  .sala-split__media {
    position: relative;
    overflow: hidden;
  }

  .sala-split__img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    display: block;
  }

  .sala-split__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin: 0;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .sala-body {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    max-width: 52ch;
  }

  .sala-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .sala-feat {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .sala-feat__icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .sala-feat strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 2px;
  }

  .sala-feat span {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.85vw, 13.5px);
    font-weight: 300;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  .sala-cta {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 860px) {
    .sala-split {
      grid-template-columns: 1fr;
    }
    .sala-split__img {
      aspect-ratio: 16/9;
    }
  }

  /* ── Corsi di Gruppo ── */
  .corsi-section {
    padding: 7vh var(--pad-x);
    background: var(--color-off-white);
  }

  .corsi-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .corsi-sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    max-width: 64ch;
    margin-bottom: 6vh;
  }

  /* ── Category block ── */
  .cat-block {
    margin-bottom: 7vh;
  }

  .cat-block:last-child {
    margin-bottom: 0;
  }

  .cat-block__head {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .cat-block__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cat-block__label {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 6rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.9;
    color: var(--cat-color);
  }

  .cat-block__meta {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .cat-block__desc {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
    margin: 0;
    max-width: 52ch;
    flex-shrink: 0;
  }

  .cat-block__line {
    flex: 1;
    height: 1px;
    background: var(--cat-color);
    opacity: 0.2;
  }

  .cat-block__count {
    font-family: var(--font-display);
    font-size: clamp(10px, 0.75vw, 12px);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
  }

  /* ── Nav arrows ── */
  .courses-nav {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .courses-btn {
    width: 34px;
    height: 34px;
    border: 1.5px solid var(--color-border);
    border-radius: 50%;
    background: #fff;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    flex-shrink: 0;
  }

  .courses-btn:hover {
    background: var(--color-text);
    border-color: var(--color-text);
    color: #fff;
  }

  /* ── Course carousel ── */
  .courses-track-wrap {
    overflow: hidden;
    margin: 0 calc(-1 * var(--pad-x));
  }

  .courses-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.5rem var(--pad-x) 1.5rem;
    scroll-padding-left: var(--pad-x);
  }

  .courses-track::-webkit-scrollbar { display: none; }

  /* ── Course card ── */
  .course-card {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .course-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .course-card__media {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #E5E7EB;
  }

  .course-card__media .img-placeholder,
  .course-card__media-img {
    width: 100%;
    height: 100%;
    min-height: unset !important;
    object-fit: cover;
    display: block;
  }

  .course-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .course-card__cat {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
