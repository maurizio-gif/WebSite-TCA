---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ClubLifeHeroMenu from "../components/ClubLifeHeroMenu.astro";
import ClubLifeAssistBtn from "../components/ClubLifeAssistBtn.astro";
import ClubLifeLangSwitch from "../components/ClubLifeLangSwitch.astro";
import EventiHome from "../components/EventiHome.astro";
import ClubLifeNews from "../components/ClubLifeNews.astro";
import ClubLifeHelpDesk from "../components/ClubLifeHelpDesk.astro";
import ClubLifeServizi from "../components/ClubLifeServizi.astro";
import ClubLifeHelpForm from "../components/ClubLifeHelpForm.astro";
import { useTranslations } from "../i18n/utils";

const lang = 'it' as const;
const t = useTranslations(lang);
---

<BaseLayout
  title="Club Life | Tennis Club Ambrosiano"
  description="Eventi, news, servizi e Help Desk del Tennis Club Ambrosiano: la bacheca del Club per soci e famiglie."
  hideLeadFormInline
  hideChrome
>
  <ClubLifeLangSwitch lang={lang} />
  <ClubLifeAssistBtn lang={lang} />

  <PageHero
    eyebrow={t.clubLife.heroEyebrow}
    title={t.clubLife.heroTitle}
    sub={t.clubLife.heroSub}
    image="/HERO.avif"
    imageAlt="Vista aerea dei campi del Tennis Club Ambrosiano"
  />

  <ClubLifeHeroMenu lang={lang} />

  <div id="eventi" class="cl-eventi-anchor">
    <EventiHome lang={lang} limit={3} showAllLink={true} />
  </div>

  <ClubLifeNews lang={lang} />

  <ClubLifeHelpDesk lang={lang} />

  <ClubLifeServizi lang={lang} />

  <ClubLifeHelpForm lang={lang} />

</BaseLayout>

<style>
  .cl-eventi-anchor {
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }
</style>
