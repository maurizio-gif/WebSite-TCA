---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import MembershipSection from "../components/MembershipSection.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/personal-trainer.md
const d = (await getEntry("pagine", "personal-trainer"))!.data;

const nl2br = (s: string) => s.replace(/\n/g, '<br>');
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctas={[{ label: "Prenota una sessione", openModal: true }]}
  />

  <!-- ── Intro ── -->
  <section class="intro-section">
    <div class="intro-section__inner">
      <div class="intro-split">
        <div class="intro-split__text">
          <span class="eyebrow">{d.pt_sezione1_eyebrow}</span>
          <h2 class="pt-title">{d.pt_sezione1_titolo}<br><em>{d.pt_sezione1_titolo_accent}</em></h2>
          <p>{d.pt_sezione1_paragrafo1}</p>
          <p>{d.pt_sezione1_paragrafo2}</p>
        </div>
        <div class="intro-split__stats">
          {d.pt_stats.map((s) => (
            <div class="stat-item">
              <span class="stat-num">{s.numero}</span>
              <span class="stat-label" set:html={nl2br(s.etichetta)} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Team ── -->
  <section class="team-section">
    <div class="team-section__inner">
      <div class="team-head">
        <div>
          <span class="eyebrow">{d.pt_sezione2_eyebrow}</span>
          <h2 class="pt-title">{d.pt_sezione2_titolo}<br><em>{d.pt_sezione2_titolo_accent}</em></h2>
        </div>
        <div class="trainer-nav">
          <button class="courses-btn" data-dir="-1" data-track="trainers" aria-label="Precedente">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="courses-btn" data-dir="1" data-track="trainers" aria-label="Successivo">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>

      <div class="trainer-track-wrap">
        <div class="trainer-track" data-carousel-id="trainers">
          {d.pt_trainers.map((trainer) => (
            <article class="trainer-card">
              <div class="trainer-card__media">
                {trainer.foto
                  ? <img src={publicUrl(trainer.foto)} alt={trainer.nome} class="trainer-card__img" />
                  : <div class="img-placeholder" data-name={`${trainer.nome}.jpg`}></div>}
              </div>
              <div class="trainer-card__body">
                <h3 class="trainer-card__name">{trainer.nome}</h3>
                <ul class="trainer-card__specs">
                  {trainer.specializzazioni.map(s => (
                    <li><span class="spec-tag">{s}</span></li>
                  ))}
                </ul>
                <div class="trainer-card__quals">
                  <strong>Qualifiche e certificazioni</strong>
                  <ul>
                    {trainer.qualifiche.map(q => <li>{q}</li>)}
                  </ul>
                </div>
                {trainer.lingue && trainer.lingue.length > 0 && (
                  <p class="trainer-card__langs"><strong>Lingue parlate:</strong> {trainer.lingue.join(', ')}</p>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Come funziona ── -->
  <section class="flow-section">
    <div class="flow-section__inner">
      <span class="eyebrow">{d.pt_sezione3_eyebrow}</span>
      <h2 class="pt-title">{d.pt_sezione3_titolo}<br><em>{d.pt_sezione3_titolo_accent}</em></h2>

      <div class="flow-steps">
        {d.pt_steps.map((s, i) => (
          <div class="flow-step">
            <span class="flow-step__num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{s.titolo}</h3>
            <p>{s.testo}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA contatto ── -->
  <section class="pt-cta-section">
    <div class="pt-cta-section__inner">
      <h2 class="pt-cta-title">{d.pt_sezione4_titolo}</h2>
      <p class="pt-cta-sub">{d.pt_sezione4_sottotitolo}</p>
      <button type="button" class="btn btn-red" data-open-modal="modal-contatti">{d.pt_sezione4_cta_label}</button>
    </div>
  </section>

  <MembershipSection />
</BaseLayout>

<style>
  /* ── Intro ── */
  .intro-section {
    padding: 7vh var(--pad-x);
  }

  .intro-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .intro-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 8rem);
    align-items: start;
  }

  .intro-split__text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .intro-split__text p {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  .pt-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin: 0;
  }

  .pt-title em { color: var(--color-accent); font-style: normal; }

  .intro-split__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    align-self: start;
  }

  .stat-item {
    background: var(--color-off-white);
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4.5vw, 4.5rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.8vw, 13px);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  /* ── Team ── */
  .team-section {
    padding: 7vh 0 7vh var(--pad-x);
    background: var(--color-off-white);
    overflow: hidden;
  }

  .team-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .team-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding-right: var(--pad-x);
    margin-bottom: 4vh;
  }

  .trainer-nav {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .courses-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--color-border);
    background: #fff;
    cursor: pointer;
    color: var(--color-text);
    transition: border-color 0.18s, background 0.18s;
  }

  .courses-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Carousel */
  .trainer-track-wrap {
    overflow: hidden;
  }

  .trainer-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-right: var(--pad-x);
  }

  .trainer-track::-webkit-scrollbar { display: none; }

  .trainer-card {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    min-width: 280px;
    scroll-snap-align: start;
    background: #fff;
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .trainer-card__media {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #E5E7EB;
  }

  .trainer-card__media .img-placeholder {
    width: 100%;
    height: 100%;
    min-height: unset;
  }

  .trainer-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .trainer-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .trainer-card__name {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1.9vw, 1.85rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text);
  }

  .trainer-card__specs {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0.65rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin: 0.25rem 0;
  }

  .spec-tag {
    font-family: var(--font-display);
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--color-off-white);
    color: var(--color-text);
    padding: 5px 11px;
  }

  .trainer-card__quals {
    font-family: var(--font-body);
    font-size: clamp(14.5px, 1.05vw, 16px);
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-light);
    flex: 1;
  }

  .trainer-card__quals strong {
    display: block;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .trainer-card__quals ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .trainer-card__quals li {
    padding-left: 0.9rem;
    position: relative;
  }

  .trainer-card__quals li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .trainer-card__langs {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 14.5px);
    font-weight: 300;
    color: var(--color-text-light);
    padding-top: 0.6rem;
    border-top: 1px solid var(--color-border);
  }

  .trainer-card__langs strong {
    font-family: var(--font-display);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-right: 0.3rem;
  }

  /* ── Come funziona ── */
  .flow-section {
    padding: 7vh var(--pad-x);
  }

  .flow-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .flow-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 4vh;
    border: 1px solid var(--color-border);
  }

  .flow-step {
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .flow-step:last-child { border-right: none; }

  .flow-step__num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 800;
    color: var(--color-accent);
    opacity: 0.25;
    line-height: 1;
  }

  .flow-step h3 {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.2vw, 1.15rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .flow-step p {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.85vw, 15.5px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
  }

  /* ── CTA ── */
  .pt-cta-section {
    padding: 7vh var(--pad-x);
    background: var(--color-text);
    text-align: center;
  }

  .pt-cta-section__inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .pt-cta-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: #fff;
    line-height: 1;
    margin: 0;
  }

  .pt-cta-sub {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .trainer-card { flex: 0 0 calc((100% - 1.25rem) / 2); }
    .flow-steps {
      grid-template-columns: repeat(2, 1fr);
    }
    .flow-step:nth-child(2) { border-right: none; }
    .flow-step:nth-child(1),
    .flow-step:nth-child(2) {
      border-bottom: 1px solid var(--color-border);
    }
  }

  @media (max-width: 860px) {
    .intro-split { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .trainer-card { flex: 0 0 calc(100% - 3rem); }
    .intro-split__stats { grid-template-columns: 1fr 1fr; }
    .flow-steps { grid-template-columns: 1fr; }
    .flow-step { border-right: none; border-bottom: 1px solid var(--color-border); }
    .flow-step:last-child { border-bottom: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLButtonElement>('[data-dir][data-track]').forEach(btn => {
      btn.addEventListener('click', () => {
        const trackId = btn.dataset.track!;
        const dir = parseInt(btn.dataset.dir!, 10);
        const track = document.querySelector<HTMLElement>(`[data-carousel-id="${trackId}"]`);
        if (!track) return;
        const card = track.querySelector<HTMLElement>('.trainer-card');
        if (!card) return;
        const gap = 1.25 * parseFloat(getComputedStyle(document.documentElement).fontSize);
        const cardW = card.offsetWidth + gap;
        track.scrollBy({ left: dir * cardW, behavior: 'smooth' });
      });
    });

    /* auto-scroll */
    document.querySelectorAll<HTMLElement>('[data-carousel-id="trainers"]').forEach(track => {
      let timer: ReturnType<typeof setInterval>;
      const step = () => {
        const card = track.querySelector<HTMLElement>('.trainer-card');
        if (!card) return;
        const gap = 1.25 * parseFloat(getComputedStyle(document.documentElement).fontSize);
        const cardW = card.offsetWidth + gap;
        const maxScroll = track.scrollWidth - track.clientWidth;
        if (track.scrollLeft + cardW >= maxScroll - 1) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: cardW, behavior: 'smooth' });
        }
      };
      const start = () => { timer = setInterval(step, 4000); };
      const stop  = () => clearInterval(timer);
      track.addEventListener('mouseenter', stop);
      track.addEventListener('mouseleave', start);
      track.addEventListener('touchstart', stop, { passive: true });
      start();
    });
  });
</script>
