---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import MembershipSection from "../components/MembershipSection.astro";
import ConversionBlock from "../components/ConversionBlock.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero + corpo pagina gestibili da TinaCMS → src/content/pagine/tennis.md
const d = (await getEntry("pagine", "tennis"))!.data;
const mdBold = (s: string) => s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
  hideLeadFormInline
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctas={[
      { label: "Diventa Socio", href: "#membership" },
      { label: "Prenota un Campo", href: "https://playtomic.io/tennis-club-ambrosiano/5440b3ab-1500-4d62-8c9b-6a8b96949501?q=TENNIS~2022-12-08~~~", external: true, outline: true },
    ]}
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">{d.tennis_campi_eyebrow}</span>
      <h2 class="section-title">{d.tennis_campi_titolo}<br><em>{d.tennis_campi_titolo_accent}</em></h2>
      <div class="content-grid">
        <div class="content-card">
          <img src={publicUrl('/0b28cd5a-d9a8-4ffb-b8de-e5c6e675fbd2_TCA+Tennis+4.avif')} alt="Campo in terra rossa visto dall'alto durante una lezione" style="width:100%;height:220px;object-fit:cover;display:block" loading="lazy" />
          <h3>{d.tennis_campi[0].titolo}</h3>
          <p>{d.tennis_campi[0].testo}</p>
        </div>
        <div class="content-card">
          <img src={publicUrl('/Tennis%20court%20indoor.jpeg')} alt="Campo da tennis indoor del Tennis Club Ambrosiano" style="width:100%;height:220px;object-fit:cover;display:block" loading="lazy" />
          <h3>{d.tennis_campi[1].titolo}</h3>
          <p>{d.tennis_campi[1].testo}</p>
        </div>
        <div class="content-card">
          <img src={publicUrl('/3fc4b526-1192-4919-9507-0700f9dbd3bd_TCA+Tennis+2.avif')} alt="Giocatrice in azione su superficie rapida" style="width:100%;height:220px;object-fit:cover;display:block" loading="lazy" />
          <h3>{d.tennis_campi[2].titolo}</h3>
          <p>{d.tennis_campi[2].testo}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.tennis_soci_eyebrow}</span>
      <h2 class="section-title">{d.tennis_soci_titolo}<br><em>{d.tennis_soci_titolo_accent}</em></h2>
      <p class="section-lead" set:html={mdBold(d.tennis_soci_testo)} />
    </div>
  </section>

  <div id="membership" class="anchor-target">
    <MembershipSection />
  </div>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.tennis_corsi_eyebrow}</span>
      <h2 class="section-title">{d.tennis_corsi_titolo}<br><em>{d.tennis_corsi_titolo_accent}</em></h2>
      <p class="section-lead" set:html={mdBold(d.tennis_corsi_intro)} />
      <div class="content-grid content-grid--4">
        {d.tennis_corsi_livelli.map((l) => (
          <div class="content-card content-card--simple">
            <strong>{l.titolo}</strong>
            <p>{l.testo}</p>
          </div>
        ))}
      </div>
      <div class="section-cta">
        <button class="btn btn-red" data-open-modal="modal-contatti">{d.tennis_corsi_cta_label}</button>
      </div>
    </div>
  </section>

  <ConversionBlock />

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .section-lead {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    max-width: none;
    margin-bottom: 4vh;
  }

  .section-cta {
    margin-top: 4vh;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .content-grid--4 { grid-template-columns: repeat(4, 1fr); }

  .content-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .content-card h3,
  .content-card strong {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  .content-card--simple {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
  }

  .content-card p {
    font-family: var(--font-body);
    font-size: clamp(15px, 1vw, 18px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  @media (max-width: 1024px) {
    .content-grid { grid-template-columns: repeat(2, 1fr); }
    .content-grid--4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .content-grid,
    .content-grid--4 { grid-template-columns: 1fr; }
  }

  /* ── Anchor offset per navbar fissa ── */
  .anchor-target {
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }
</style>
