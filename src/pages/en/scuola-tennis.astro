---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { publicUrl, getLocalePath } from "../../i18n/utils";
import { getEntry } from "astro:content";

const lang = 'en' as const;
const p = (path: string) => getLocalePath(lang, path);

// SEO + hero + corpo pagina gestibili da TinaCMS → src/content/pagine/scuola-tennis.md (campi _en)
const d = (await getEntry("pagine", "scuola-tennis"))!.data;
const mdBold = (s: string) => s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
const nl2br = (s: string) => s.replace(/\n/g, '<br>');
---

<BaseLayout
  lang={lang}
  title={d.title_en ?? d.title}
  description={d.description_en ?? d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt_en ?? d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow_en ?? d.hero_eyebrow}
    title={d.hero_titolo_en ?? d.hero_titolo}
    titleAccent={d.hero_titolo_accent_en ?? d.hero_titolo_accent}
    sub={d.hero_sottotitolo_en ?? d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt_en ?? d.hero_immagine_alt}
    imagePosition="center top"
    ctas={[{ label: "Request Your Trial", openModal: true }]}
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">{d.scuola_sezione1_eyebrow_en ?? d.scuola_sezione1_eyebrow}</span>
      <h2 class="section-title">{d.scuola_sezione1_titolo_en ?? d.scuola_sezione1_titolo}<br><em>{d.scuola_sezione1_titolo_accent_en ?? d.scuola_sezione1_titolo_accent}</em></h2>
      <p class="section-lead body-text">{d.scuola_sezione1_lead_en ?? d.scuola_sezione1_lead}</p>
      <div class="age-grid">
        {d.scuola_livelli.map((l) => (
          <div class="age-card">
            <span class={`level-dot level-dot--${l.dot}`} aria-hidden="true"></span>
            <span class="age-card__range">{l.range_en ?? l.range}</span>
            <h3>{l.nome_en ?? l.nome}</h3>
            <span class="level-tag">{l.tag_en ?? l.tag}</span>
            <p>{l.testo_en ?? l.testo}</p>
          </div>
        ))}
      </div>
      <p class="level-after body-text">
        {d.scuola_livelli_footer_testo_en ?? d.scuola_livelli_footer_testo}
        <a href={p('/agonistica')}>{d.scuola_livelli_footer_link_label_en ?? d.scuola_livelli_footer_link_label}</a>
      </p>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.scuola_sezione2_eyebrow_en ?? d.scuola_sezione2_eyebrow}</span>
      <h2 class="section-title">{d.scuola_sezione2_titolo_en ?? d.scuola_sezione2_titolo}<br><em>{d.scuola_sezione2_titolo_accent_en ?? d.scuola_sezione2_titolo_accent}</em></h2>
      <div class="iscrizione-grid">
        {d.scuola_iscrizione_cards.map((card) => (
          <div class="iscrizione-card">
            <h3>{card.titolo_en ?? card.titolo}</h3>
            <span class="iscrizione-card__tag">{card.tag_en ?? card.tag}</span>
            <p set:html={nl2br(card.testo_en ?? card.testo)} />
          </div>
        ))}
      </div>
      <div class="section-cta">
        <button class="btn btn-red" data-open-modal="modal-contatti">{d.scuola_iscrizione_cta_label_en ?? d.scuola_iscrizione_cta_label}</button>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="content-section__inner two-col">
      <div class="two-col__text">
        <span class="eyebrow">{d.scuola_sezione3_eyebrow_en ?? d.scuola_sezione3_eyebrow}</span>
        <h2 class="section-title">{d.scuola_sezione3_titolo_en ?? d.scuola_sezione3_titolo}<br><em>{d.scuola_sezione3_titolo_accent_en ?? d.scuola_sezione3_titolo_accent}</em></h2>
        <span class="method-badge">{d.scuola_sezione3_badge_en ?? d.scuola_sezione3_badge}</span>
        <p class="body-text" set:html={mdBold(d.scuola_sezione3_paragrafo1_en ?? d.scuola_sezione3_paragrafo1)} />
        <p class="body-text">{d.scuola_sezione3_paragrafo2_en ?? d.scuola_sezione3_paragrafo2}</p>
        <p class="body-text" set:html={mdBold(d.scuola_sezione3_paragrafo3_en ?? d.scuola_sezione3_paragrafo3)} />
      </div>
      <div class="two-col__image">
        <img src={publicUrl(d.scuola_sezione3_immagine)} alt={d.scuola_sezione3_immagine_alt_en ?? d.scuola_sezione3_immagine_alt} class="full-img" />
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.scuola_sezione4_eyebrow_en ?? d.scuola_sezione4_eyebrow}</span>
      <h2 class="section-title">{d.scuola_sezione4_titolo_en ?? d.scuola_sezione4_titolo}<br><em>{d.scuola_sezione4_titolo_accent_en ?? d.scuola_sezione4_titolo_accent}</em></h2>
      <div class="tornei-grid">
        {d.scuola_tornei.map((t) => (
          <div class="torneo-card">
            <span class="torneo-card__when">{t.quando_en ?? t.quando}</span>
            <h3>{t.nome_en ?? t.nome}</h3>
            <p>{t.testo_en ?? t.testo}</p>
          </div>
        ))}
      </div>
      <p class="level-after body-text" set:html={mdBold(d.scuola_sezione4_footer_testo_en ?? d.scuola_sezione4_footer_testo)} />
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .section-lead {
    max-width: 70ch;
    margin-bottom: 3vh;
  }

  .section-cta {
    margin-top: 4vh;
  }

  .age-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .age-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .level-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    margin-bottom: 0.4rem;
    box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.04);
  }
  .level-dot--rosso   { background: #E53935; }
  .level-dot--arancio { background: #FB8C00; }
  .level-dot--verde   { background: #43A047; }
  .level-dot--giallo  { background: #FDD835; }

  .age-card__range {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .age-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .level-tag {
    font-family: var(--font-body);
    font-size: clamp(11px, 0.8vw, 12px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  .age-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-top: 0.25rem;
  }

  .level-after {
    margin-top: 2.5vh;
  }
  .level-after a {
    color: var(--color-accent);
    font-weight: 400;
    white-space: nowrap;
  }
  .level-after a:hover { color: var(--color-accent-dark); }

  .iscrizione-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .iscrizione-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .iscrizione-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .iscrizione-card__tag {
    font-family: var(--font-body);
    font-size: clamp(11px, 0.8vw, 12px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .iscrizione-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-top: 0.25rem;
  }

  .tornei-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .torneo-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .torneo-card__when {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .torneo-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .torneo-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .method-badge {
    font-family: var(--font-body);
    font-size: clamp(11px, 0.8vw, 12px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .full-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1024px) {
    .age-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .two-col__image { order: -1; }
    .tornei-grid { grid-template-columns: 1fr; }
    .iscrizione-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .age-grid { grid-template-columns: 1fr; }
  }
</style>
