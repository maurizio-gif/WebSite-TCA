---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Tennis School | Tennis Club Ambrosiano Milan"
  description="Tennis school for children and teenagers at TCA. Mini tennis, beginner courses, competition and FIT pathways. Milan's most historic tennis school."
>
  <PageHero
    eyebrow="Junior · Tennis School"
    title="Tennis"
    titleAccent="School"
    sub="Mini tennis, courses for children and teenagers, FIT pathways and competitive preparation. Milan's most historic tennis school since 1965."
    image="/ajAJSI1P9HI4UhOS_tenniskidsTCA.avif"
    imageAlt="Children at TCA tennis school"
    ctaLabel="Enrol at the school"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Pathways</span>
      <h2 class="section-title">A programme<br><em>for every age.</em></h2>
      <div class="age-grid">
        <div class="age-card">
          <span class="age-card__range">Ages 3 – 5</span>
          <h3>Mini Tennis</h3>
          <p>First experiences with the racket: coordination, fun and movement in a safe and stimulating environment.</p>
        </div>
        <div class="age-card">
          <span class="age-card__range">Ages 6 – 9</span>
          <h3>Foundation</h3>
          <p>Technical learning with the FIT method: fundamentals, rules and reduced play on a short court.</p>
        </div>
        <div class="age-card">
          <span class="age-card__range">Ages 10 – 13</span>
          <h3>Development</h3>
          <p>Technical and tactical consolidation, first competitions and building a personal game.</p>
        </div>
        <div class="age-card">
          <span class="age-card__range">Ages 14 +</span>
          <h3>Advanced</h3>
          <p>Programmes for advanced players, tournament preparation and support along the competitive pathway.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner two-col">
      <div class="two-col__text">
        <span class="eyebrow">Our approach</span>
        <h2 class="section-title">FIT coaches.<br><em>The TCA method.</em></h2>
        <p class="body-text">
          All our coaches are certified by the Italian Tennis Federation.
          The TCA method combines technique, play and the values of sport to shape
          not only tennis players, but people.
        </p>
      </div>
      <div class="two-col__image">
        <img
          src="/ajADiI1P9HI4UhIx_girl-with-tennis-racket-ball.avif"
          alt="Girl at TCA tennis school"
          class="full-img"
        />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .age-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .age-card {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .age-card__range {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .age-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .age-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .full-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1024px) {
    .age-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .two-col__image { order: -1; }
  }

  @media (max-width: 600px) {
    .age-grid { grid-template-columns: 1fr; }
  }
</style>
