---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Competitive | Tennis Club Ambrosiano Milan"
  description="The competitive programme at Tennis Club Ambrosiano: junior squads, FITP tournament preparation and pathways for under-18 athletes in Milan."
>
  <PageHero
    eyebrow="Junior · Competitive"
    title="Junior"
    titleAccent="Competitive"
    sub="TCA has been shaping champions since 1965. Junior squads, FITP tournaments, technical and athletic preparation for young players with competitive ambitions."
    image="/Tennis%20Agonistica.jpg"
    imageAlt="TCA junior competitive tennis"
    ctaLabel="Join the squad"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">The pathway</span>
      <h2 class="section-title">From the school<br><em>to competition.</em></h2>
      <div class="steps">
        <div class="step">
          <span class="step__n">01</span>
          <div class="step__body">
            <h3>Selection and assessment</h3>
            <p>Coaches assess each player's potential and define the most suitable pathway.</p>
          </div>
        </div>
        <div class="step">
          <span class="step__n">02</span>
          <div class="step__body">
            <h3>Technical and tactical training</h3>
            <p>Daily high-level sessions focused on strokes, tactics and match play.</p>
          </div>
        </div>
        <div class="step">
          <span class="step__n">03</span>
          <div class="step__body">
            <h3>Dedicated athletic preparation</h3>
            <p>Sport-specific programmes for tennis performance: explosiveness, endurance and agility.</p>
          </div>
        </div>
        <div class="step">
          <span class="step__n">04</span>
          <div class="step__body">
            <h3>Tournaments and away games</h3>
            <p>Participation in regional and national FITP circuits with full technical support.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    padding: 2rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .step:last-child { border-bottom: none; }

  .step__n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    flex-shrink: 0;
    min-width: 3rem;
  }

  .step__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.25rem;
  }

  .step h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .step p {
    font-family: var(--font-body);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    max-width: 65ch;
  }
</style>
