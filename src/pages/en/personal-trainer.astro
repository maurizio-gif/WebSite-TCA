---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import MembershipSection from "../../components/MembershipSection.astro";
import { getLocalePath } from "../../i18n/utils";

const lang = 'en' as const;
const p = (path: string) => getLocalePath(lang, path);

const pex = (id: string) =>
  `https://images.pexels.com/photos/${id}/pexels-photo-${id}.jpeg?auto=compress&cs=tinysrgb&w=600&h=700&fit=crop`;

interface Trainer {
  name: string;
  role: string;
  specializations: string[];
  bio: string;
  img: string;
}

const trainers: Trainer[] = [
  {
    name: 'Marco R.',
    role: 'Personal Trainer & Athletic Coach',
    specializations: ['Strength & Power', 'Tennis Sport Specific', 'Functional Rehabilitation'],
    bio: 'Degree in Sport Science and NSCA-CSCS certification. Specialised in athletic preparation for competitive and recreational tennis players, with a focus on explosive strength and injury prevention.',
    img: pex('6456138'),
  },
  {
    name: 'Giulia T.',
    role: 'Personal Trainer & Class Instructor',
    specializations: ['Weight Loss & Body Composition', 'Functional Pilates', "Women's Training"],
    bio: 'Master’s in Sport Science and ACSM certification. She guides her clients towards concrete goals with personalised programmes that combine training and lifestyle.',
    img: pex('4498362'),
  },
  {
    name: 'Luca M.',
    role: 'Strength & Conditioning Coach',
    specializations: ['Powerlifting & Kettlebell', 'Over-50 Training', 'Mobility & Posture'],
    bio: 'FIF and StrongFirst certified. An expert in resistance training and conditioning programmes for every age group. A technical, progressive and results-oriented approach.',
    img: pex('1681010'),
  },
];
---

<BaseLayout
  lang={lang}
  title="Personal Trainer | Tennis Club Ambrosiano Milan"
  description="The personal trainers at Tennis Club Ambrosiano: certified professionals for tailored training programmes, strength building and athletic preparation in Milan."
>
  <PageHero
    eyebrow="Adults · Athletic Training"
    title="Personal"
    titleAccent="Trainer"
    sub="Certified professionals who build your training programme around your goal. No standard protocol: only tailored work."
    image="/ef9e517a-0ca4-473f-a6fc-a46a18263aa3_TCA+Fitness+3.avif"
    imageAlt="TCA personal trainer"
    ctaLabel="Book a session"
  />

  <!-- ── Intro ── -->
  <section class="intro-section">
    <div class="intro-section__inner">
      <div class="intro-split">
        <div class="intro-split__text">
          <span class="eyebrow">Your training</span>
          <h2 class="pt-title">Training well<br><em>is a science.</em></h2>
          <p>
            Everyone is different: medical history, goals, recovery times, motivation. Our personal trainers start with an in-depth initial assessment to build a programme that delivers real results, without wasting energy or time.
          </p>
          <p>
            Whether you want to lose weight, build strength, prepare for a tennis match or simply move better, you'll always work with someone who knows where they want to take you.
          </p>
        </div>
        <div class="intro-split__stats">
          <div class="stat-item">
            <span class="stat-num">3</span>
            <span class="stat-label">Certified<br>personal trainers</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">1:1</span>
            <span class="stat-label">Individual sessions<br>or in pairs</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">60'</span>
            <span class="stat-label">Standard duration<br>per session</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">∞</span>
            <span class="stat-label">Achievable<br>goals</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Team ── -->
  <section class="team-section">
    <div class="team-section__inner">
      <div class="team-head">
        <div>
          <span class="eyebrow">The Team</span>
          <h2 class="pt-title">Meet your<br><em>trainers.</em></h2>
        </div>
        <div class="trainer-nav">
          <button class="courses-btn" data-dir="-1" data-track="trainers" aria-label="Previous">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="courses-btn" data-dir="1" data-track="trainers" aria-label="Next">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>

      <div class="trainer-track-wrap">
        <div class="trainer-track" data-carousel-id="trainers">
          {trainers.map((trainer) => (
            <article class="trainer-card">
              <div class="trainer-card__media">
                <img
                  src={trainer.img}
                  alt={trainer.name}
                  class="trainer-card__img"
                  loading="lazy"
                />
              </div>
              <div class="trainer-card__body">
                <h3 class="trainer-card__name">{trainer.name}</h3>
                <p class="trainer-card__role">{trainer.role}</p>
                <ul class="trainer-card__specs">
                  {trainer.specializations.map(s => (
                    <li><span class="spec-tag">{s}</span></li>
                  ))}
                </ul>
                <p class="trainer-card__bio">{trainer.bio}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── How it works ── -->
  <section class="flow-section">
    <div class="flow-section__inner">
      <span class="eyebrow">How it works</span>
      <h2 class="pt-title">From day one<br><em>to your goal.</em></h2>

      <div class="flow-steps">
        <div class="flow-step">
          <span class="flow-step__num">01</span>
          <h3>Initial assessment</h3>
          <p>A free meeting with the trainer to assess posture, mobility and strength and to define your goals.</p>
        </div>
        <div class="flow-step">
          <span class="flow-step__num">02</span>
          <h3>Tailored programme</h3>
          <p>The trainer builds a periodised plan week by week, adapted to your schedule and your condition.</p>
        </div>
        <div class="flow-step">
          <span class="flow-step__num">03</span>
          <h3>Training & monitoring</h3>
          <p>Guided sessions in the gym with continuous feedback and progressive updates to the programme.</p>
        </div>
        <div class="flow-step">
          <span class="flow-step__num">04</span>
          <h3>Measurable results</h3>
          <p>Periodic re-assessment to track progress and adjust course. Every data point counts.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Contact CTA ── -->
  <section class="pt-cta-section">
    <div class="pt-cta-section__inner">
      <h2 class="pt-cta-title">Ready to start?</h2>
      <p class="pt-cta-sub">Book a free assessment session with one of our trainers. No commitment: just one hour to understand how to train better.</p>
      <a href={p('/contatti')} class="btn btn-red">Book your free assessment</a>
    </div>
  </section>

  <MembershipSection lang={lang} />
</BaseLayout>

<style>
  /* ── Intro ── */
  .intro-section {
    padding: 7vh var(--pad-x);
  }

  .intro-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .intro-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 8rem);
    align-items: start;
  }

  .intro-split__text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .intro-split__text p {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
  }

  .pt-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin: 0;
  }

  .pt-title em { color: var(--color-accent); font-style: normal; }

  .intro-split__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    align-self: start;
  }

  .stat-item {
    background: var(--color-off-white);
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4.5vw, 4.5rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.8vw, 13px);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  /* ── Team ── */
  .team-section {
    padding: 7vh 0 7vh var(--pad-x);
    background: var(--color-off-white);
    overflow: hidden;
  }

  .team-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .team-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding-right: var(--pad-x);
    margin-bottom: 4vh;
  }

  .trainer-nav {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .courses-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--color-border);
    background: #fff;
    cursor: pointer;
    color: var(--color-text);
    transition: border-color 0.18s, background 0.18s;
  }

  .courses-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Carousel */
  .trainer-track-wrap {
    overflow: hidden;
  }

  .trainer-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-right: var(--pad-x);
  }

  .trainer-track::-webkit-scrollbar { display: none; }

  .trainer-card {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    min-width: 280px;
    scroll-snap-align: start;
    background: #fff;
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .trainer-card__media {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #E5E7EB;
  }

  .trainer-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.4s ease;
  }

  .trainer-card:hover .trainer-card__img {
    transform: scale(1.03);
  }

  .trainer-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .trainer-card__name {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.4vw, 1.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .trainer-card__role {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.85vw, 13px);
    font-weight: 400;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .trainer-card__specs {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin: 0.25rem 0;
  }

  .spec-tag {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-off-white);
    color: var(--color-text);
    padding: 3px 8px;
  }

  .trainer-card__bio {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.85vw, 13.5px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
    flex: 1;
  }

  /* ── How it works ── */
  .flow-section {
    padding: 7vh var(--pad-x);
  }

  .flow-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .flow-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 4vh;
    border: 1px solid var(--color-border);
  }

  .flow-step {
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .flow-step:last-child { border-right: none; }

  .flow-step__num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 800;
    color: var(--color-accent);
    opacity: 0.25;
    line-height: 1;
  }

  .flow-step h3 {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.2vw, 1.15rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .flow-step p {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.85vw, 13.5px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
  }

  /* ── CTA ── */
  .pt-cta-section {
    padding: 7vh var(--pad-x);
    background: var(--color-text);
    text-align: center;
  }

  .pt-cta-section__inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .pt-cta-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: #fff;
    line-height: 1;
    margin: 0;
  }

  .pt-cta-sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
    max-width: 52ch;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .trainer-card { flex: 0 0 calc((100% - 1.25rem) / 2); }
    .flow-steps {
      grid-template-columns: repeat(2, 1fr);
    }
    .flow-step:nth-child(2) { border-right: none; }
    .flow-step:nth-child(1),
    .flow-step:nth-child(2) {
      border-bottom: 1px solid var(--color-border);
    }
  }

  @media (max-width: 860px) {
    .intro-split { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .trainer-card { flex: 0 0 calc(100% - 3rem); }
    .intro-split__stats { grid-template-columns: 1fr 1fr; }
    .flow-steps { grid-template-columns: 1fr; }
    .flow-step { border-right: none; border-bottom: 1px solid var(--color-border); }
    .flow-step:last-child { border-bottom: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLButtonElement>('[data-dir][data-track]').forEach(btn => {
      btn.addEventListener('click', () => {
        const trackId = btn.dataset.track!;
        const dir = parseInt(btn.dataset.dir!, 10);
        const track = document.querySelector<HTMLElement>(`[data-carousel-id="${trackId}"]`);
        if (!track) return;
        const card = track.querySelector<HTMLElement>('.trainer-card');
        if (!card) return;
        const gap = 1.25 * parseFloat(getComputedStyle(document.documentElement).fontSize);
        const cardW = card.offsetWidth + gap;
        track.scrollBy({ left: dir * cardW, behavior: 'smooth' });
      });
    });

    /* auto-scroll */
    document.querySelectorAll<HTMLElement>('[data-carousel-id="trainers"]').forEach(track => {
      let timer: ReturnType<typeof setInterval>;
      const step = () => {
        const card = track.querySelector<HTMLElement>('.trainer-card');
        if (!card) return;
        const gap = 1.25 * parseFloat(getComputedStyle(document.documentElement).fontSize);
        const cardW = card.offsetWidth + gap;
        const maxScroll = track.scrollWidth - track.clientWidth;
        if (track.scrollLeft + cardW >= maxScroll - 1) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: cardW, behavior: 'smooth' });
        }
      };
      const start = () => { timer = setInterval(step, 4000); };
      const stop  = () => clearInterval(timer);
      track.addEventListener('mouseenter', stop);
      track.addEventListener('mouseleave', start);
      track.addEventListener('touchstart', stop, { passive: true });
      start();
    });
  });
</script>
