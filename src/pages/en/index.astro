---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Manifesto from "../../components/Manifesto.astro";
import DiventaSocio from "../../components/DiventaSocio.astro";
import AttivitaSplit from "../../components/AttivitaSplit.astro";
import Reassurance from "../../components/Reassurance.astro";
import TorneoAvvenire from "../../components/TorneoAvvenire.astro";
import EventiHome from "../../components/EventiHome.astro";
import ConversionBlock from "../../components/ConversionBlock.astro";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Tennis Club Ambrosiano Milan | Premier Tennis School Since 1963"
  description="Milan's premier tennis school since 1963: 16 courts, padel, gym and athletic training. Home of the Avvenire Tournament, steps from Udine metro station."
  image="/HERO.avif"
  imageAlt="Aerial view of Tennis Club Ambrosiano courts"
>
  <Hero lang={lang} />
  <Manifesto lang={lang} />
  <DiventaSocio lang={lang} />
  <AttivitaSplit lang={lang} />
  <Reassurance lang={lang} />
  <TorneoAvvenire lang={lang} />
  <EventiHome lang={lang} />
  <ConversionBlock lang={lang} />
</BaseLayout>
