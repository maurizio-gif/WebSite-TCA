---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { publicUrl } from "../../i18n/utils";
import { getEntry } from "astro:content";

const lang = 'en' as const;

// SEO + hero + corpo pagina gestibili da TinaCMS → src/content/pagine/storia.md (campi _en)
const d = (await getEntry("pagine", "storia"))!.data;
const mdBold = (s: string) => s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
---

<BaseLayout
  lang={lang}
  title={d.title_en ?? d.title}
  description={d.description_en ?? d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt_en ?? d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow_en ?? d.hero_eyebrow}
    title={d.hero_titolo_en ?? d.hero_titolo}
    titleAccent={d.hero_titolo_accent_en ?? d.hero_titolo_accent}
    sub={d.hero_sottotitolo_en ?? d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt_en ?? d.hero_immagine_alt}
    imagePosition="center 40%"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">{d.storia_sezione1_eyebrow_en ?? d.storia_sezione1_eyebrow}</span>
      <h2 class="section-title">{d.storia_sezione1_titolo_en ?? d.storia_sezione1_titolo}<br><em>{d.storia_sezione1_titolo_accent_en ?? d.storia_sezione1_titolo_accent}</em></h2>

      <div class="timeline">
        {d.storia_timeline!.map((item) => (
          <div class="timeline__item">
            <span class="timeline__year">{item.anno}</span>
            <p class="timeline__text">{item.testo_en ?? item.testo}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <div class="two-col">
        <div>
          <span class="eyebrow">{d.storia_sezione2_eyebrow_en ?? d.storia_sezione2_eyebrow}</span>
          <h2 class="section-title">{d.storia_sezione2_titolo_en ?? d.storia_sezione2_titolo}<br><em>{d.storia_sezione2_titolo_accent_en ?? d.storia_sezione2_titolo_accent}</em></h2>
          <p class="body-text" set:html={mdBold(d.storia_paragrafo1_en ?? d.storia_paragrafo1!)} />
          <p class="body-text" style="margin-top:1.25rem;" set:html={mdBold(d.storia_paragrafo2_en ?? d.storia_paragrafo2!)} />
        </div>
        <div class="gallery">
          {d.storia_galleria!.map((img) => (
            <img src={publicUrl(img.immagine)} alt={img.alt} class="gallery__img" />
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
    max-width: 60ch;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 2rem;
    padding: 1.75rem 2rem;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .timeline__item:last-child { border-bottom: none; }

  .timeline__year {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 2rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .timeline__text {
    font-family: var(--font-body);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  /* Two col */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .gallery__img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .timeline__item { grid-template-columns: 80px 1fr; gap: 1rem; }
  }

  @media (max-width: 500px) {
    .timeline__item { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>
