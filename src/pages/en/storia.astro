---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { publicUrl } from "../../i18n/utils";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Our History | Tennis Club Ambrosiano Milan"
  description="The history of Tennis Club Ambrosiano: from its foundation in 1963 to the present day, sixty years of tennis, sport and community in Milan."
>
  <PageHero
    eyebrow="Since 1963"
    title="Our"
    titleAccent="History"
    sub="Sixty years of passion for tennis and sport. A story of champions, community, tradition and innovation in the heart of Milan."
    image="/HERO.avif"
    imageAlt="Aerial view of Tennis Club Ambrosiano"
    imagePosition="center 40%"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">The timeline</span>
      <h2 class="section-title">Sixty years<br><em>of history.</em></h2>

      <div class="timeline">
        {[
          { year: "1963", text: "Tennis Club Ambrosiano is founded, opening its home on Via Feltre, in the heart of Milan's Feltre-Udine district." },
          { year: "1965", text: "First edition of the Avvenire Tournament, destined to become one of the most prestigious international junior tournaments." },
          { year: "1969", text: "The Avvenire Tournament opens up to the best international talents." },
          { year: "1980s", text: "Expansion of the facility: new courts, changing rooms and services to meet growing demand from members." },
          { year: "2000s", text: "Padel courts open. The club embraces the new sport and integrates it into its offering for members." },
          { year: "2020s", text: "Launch of the digital modernisation project and expansion of the offering with pickleball and athletic training programmes." },
          { year: "2023", text: "The Under-14 category joins the Avvenire Tournament within the Tennis Europe circuit." },
          { year: "2025", text: "The Avvenire Tournament officially becomes an Under-14 Super Category tournament, the highest level of European junior tennis." },
          { year: "2026", text: "The Club continues its path of innovation with digital renewal and an expanded range of services for sport and families." },
        ].map((item) => (
          <div class="timeline__item">
            <span class="timeline__year">{item.year}</span>
            <p class="timeline__text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <div class="two-col">
        <div>
          <span class="eyebrow">The club today</span>
          <h2 class="section-title">A living<br><em>community.</em></h2>
          <p class="body-text">
            Today Tennis Club Ambrosiano is one of the most important reference points for
            racket sports in Milan. With <strong>nearly 2,000 members</strong>, 16 tennis courts,
            2 padel courts, 2 pickleball courts, over 80 weekly classes, areas dedicated to
            athletic training, a Tennis School recognised as a <strong>FITP Top School</strong>
            and a high-level competitive programme, the Club welcomes athletes of every age and
            level every day.
          </p>
          <p class="body-text" style="margin-top:1.25rem;">
            But TCA is much more than a sports centre: <strong>it's a community</strong>.
            Throughout the year it organises tournaments, social events, clinics, parties and
            get-togethers for members, families and friends, turning the terrace overlooking the
            courts and the green spaces into places to share, connect and make friends.
          </p>
        </div>
        <div class="gallery">
          <img src={publicUrl("/aW-n8QIvOtkhBvwi_HCM_Tennis_Outdoor_July-2025.avif")} alt="TCA club" class="gallery__img" />
          <img src={publicUrl("/aW-n8gIvOtkhBvwl_HCM_Tennis_Outdoor_July-2025-2.avif")} alt="TCA club" class="gallery__img" />
          <img src={publicUrl("/EricDavanzo1169.jpg")} alt="TCA club" class="gallery__img" />
          <img src={publicUrl("/aW-n8wIvOtkhBvwn_HCM_Tennis_Outdoor_July-2025-3.avif")} alt="TCA club" class="gallery__img" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
    max-width: 60ch;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 2rem;
    padding: 1.75rem 2rem;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .timeline__item:last-child { border-bottom: none; }

  .timeline__year {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 2rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .timeline__text {
    font-family: var(--font-body);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  /* Two col */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .gallery__img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .timeline__item { grid-template-columns: 80px 1fr; gap: 1rem; }
  }

  @media (max-width: 500px) {
    .timeline__item { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>
