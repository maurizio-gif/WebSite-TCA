---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { publicUrl } from "../../i18n/utils";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Padel & Pickleball | Tennis Club Ambrosiano Milan"
  description="Padel and Pickleball at Tennis Club Ambrosiano. Indoor and outdoor courts, courses for all levels, a dynamic environment and an active community in Milan."
>
  <PageHero
    eyebrow="Adults · Padel & Pickleball"
    title="Padel"
    titleAccent="& Pickleball"
    sub="Two sports, one community. Indoor and outdoor courts for padel and new spaces for pickleball, the fastest-growing sport in Italy."
    image="/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif"
    imageAlt="Padel court at Tennis Club Ambrosiano"
    ctaLabel="Request Information"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <div class="two-col">
        <div class="two-col__text">
          <span class="eyebrow">Padel</span>
          <h2 class="section-title">The sport<br><em>of the moment.</em></h2>
          <p class="body-text">
            Padel is the team game par excellence: doubles, in-house tournaments,
            and an atmosphere that combines competition and fun. At TCA you'll find
            floodlit courts, FIP-certified coaches and a community of players of
            every level ready to welcome you.
          </p>
          <a class="btn btn-red" href="#lead" style="margin-top: 1.5rem;">Start playing</a>
        </div>
        <div class="two-col__image">
          <img
            src={publicUrl("/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif")}
            alt="TCA padel court"
            class="rounded-img"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">Pickleball</span>
      <h2 class="section-title">The club's<br><em>new sport.</em></h2>
      <p class="body-text body-text--max">
        Agile, inclusive, fun. Pickleball is winning over players of every age
        with its simple rules and dynamic pace. Try something new
        on our dedicated court.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 2.5vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .body-text--max { max-width: 68ch; }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .two-col__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rounded-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 860px) {
    .two-col { grid-template-columns: 1fr; }
    .two-col__image { order: -1; }
  }
</style>
