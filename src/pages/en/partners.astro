---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { publicUrl } from "../../i18n/utils";
import { getEntry } from "astro:content";

const lang = 'en' as const;

// SEO + hero + elenco partner gestibili da TinaCMS → src/content/pagine/partners.md (campi _en)
const d = (await getEntry("pagine", "partners"))!.data;
const partners = d.partners_lista ?? [];
---

<BaseLayout
  lang={lang}
  title={d.title_en ?? d.title}
  description={d.description_en ?? d.description}
>
  <div class="page-header">
    <div class="page-header__inner">
      <span class="eyebrow">{d.hero_eyebrow_en ?? d.hero_eyebrow}</span>
      <h1 class="page-header__title">
        {d.hero_titolo_en ?? d.hero_titolo} <em>{d.hero_titolo_accent_en ?? d.hero_titolo_accent}</em>
      </h1>
      <p class="page-header__sub">{d.hero_sottotitolo_en ?? d.hero_sottotitolo}</p>
    </div>
  </div>

  <section class="partners">
    <div class="partners__inner">
      {partners.map((p) => (
        <article class="partner-card">
          <div class="partner-card__logo">
            <img src={publicUrl(p.logo)} alt={`${p.nome} logo`} loading="lazy" />
          </div>
          <div class="partner-card__body">
            <h2 class="partner-card__name">{p.nome}</h2>
            <p class="partner-card__desc">{p.descrizione_en ?? p.descrizione}</p>
            <a class="partner-card__link" href={p.sito} target="_blank" rel="noopener">
              Visit the website →
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: calc(var(--header-h) + 6vh) var(--pad-x) 5vh;
    background: var(--color-off-white);
    border-bottom: 1px solid var(--color-border);
  }

  .page-header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .page-header__title {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    color: var(--color-text);
    margin: 0.4em 0 0.6em;
  }

  .page-header__title em {
    font-style: normal;
    color: var(--color-accent);
  }

  .page-header__sub {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(17px, 1.2vw, 21px);
    color: var(--color-text-light);
  }

  .partners {
    padding: 6vh var(--pad-x) 8vh;
  }

  .partners__inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .partner-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    align-items: center;
    border: 1px solid var(--color-border);
    padding: 2rem;
    background: var(--color-bg);
  }

  .partner-card__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
  }

  .partner-card__logo img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .partner-card__name {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    font-size: clamp(1.2rem, 1.8vw, 1.6rem);
    color: var(--color-text);
    margin-bottom: 0.6rem;
  }

  .partner-card__desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(16px, 1vw, 18px);
    line-height: 1.8;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .partner-card__link {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.85vw, 13px);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.18s;
  }

  .partner-card__link:hover { color: var(--color-accent-dark); }

  @media (max-width: 720px) {
    .partner-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .partner-card__logo img { max-width: 220px; }
  }
</style>
