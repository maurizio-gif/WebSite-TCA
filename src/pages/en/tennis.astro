---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import MembershipSection from "../../components/MembershipSection.astro";
import ConversionBlock from "../../components/ConversionBlock.astro";
import { publicUrl } from "../../i18n/utils";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Tennis | Tennis Club Ambrosiano Milan"
  description="Sixteen tennis courts, qualified FIT coaches, adult courses for all levels. Discover tennis at Tennis Club Ambrosiano in Milan."
  hideLeadFormInline
>
  <PageHero
    eyebrow="Adults · Tennis"
    title="Tennis"
    titleAccent="at TCA"
    sub="Sixteen courts, qualified FIT coaches and a tradition that started in 1965. Whether you want to improve your game or start from scratch, we have the right course for you."
    image="/c06f453c-9d44-46ee-9c7e-4101654893cc_TCA+Tennis+Header.avif"
    imageAlt="Tennis courts at Tennis Club Ambrosiano"
    ctas={[
      { label: "Become a Member", href: "#membership" },
      { label: "Book a Court", href: "https://playtomic.io/tennis-club-ambrosiano/5440b3ab-1500-4d62-8c9b-6a8b96949501?q=TENNIS~2022-12-08~~~", external: true, outline: true },
    ]}
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Our courts</span>
      <h2 class="section-title">16 Courts.<br><em>Every surface.</em></h2>
      <div class="content-grid">
        <div class="content-card">
          <img src={publicUrl('/0b28cd5a-d9a8-4ffb-b8de-e5c6e675fbd2_TCA+Tennis+4.avif')} alt="Clay court seen from above during a lesson" style="width:100%;height:220px;object-fit:cover;display:block" loading="lazy" />
          <h3>Clay</h3>
          <p>FIT-certified courts, perfect for classic play and competitive training.</p>
        </div>
        <div class="content-card">
          <img src={publicUrl('/Tennis%20court%20indoor.jpeg')} alt="Indoor tennis court at Tennis Club Ambrosiano" style="width:100%;height:220px;object-fit:cover;display:block" loading="lazy" />
          <h3>Indoor Courts</h3>
          <p>Covered facility to play all year round, with professional lighting.</p>
        </div>
        <div class="content-card">
          <img src={publicUrl('/3fc4b526-1192-4919-9507-0700f9dbd3bd_TCA+Tennis+2.avif')} alt="Player in action on a hard court" style="width:100%;height:220px;object-fit:cover;display:block" loading="lazy" />
          <h3>Hard Court</h3>
          <p>Synthetic surface suited to fast play and the needs of every level.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">For our members</span>
      <h2 class="section-title">Sixteen courts.<br><em>Always at your service.</em></h2>
      <p class="section-lead">Become a member of Tennis Club Ambrosiano and play all year round on our sixteen courts, outdoor and indoor — and padel too, on our dedicated courts. Every membership includes a different level of booking priority: choose the one that best suits the way you play.</p>
    </div>
  </section>

  <div id="membership" class="anchor-target">
    <MembershipSection lang={lang} />
  </div>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">Adult courses</span>
      <h2 class="section-title">Want to learn or refine<br><em>your technique?</em></h2>
      <p class="section-lead">It's never too early, or too late, to learn tennis or take your game to the next level. At Tennis Club Ambrosiano we run adult courses for every age and experience level, with weekly, twice-weekly or three-times-weekly frequency depending on the time you want to dedicate to the court and the goals you want to reach. Lessons in small groups or one-to-one, led by our FIT-certified coaches. We also offer padel lessons, individual or in groups. Request information: we'll help you find the solution that suits you best.</p>
      <div class="content-grid content-grid--4">
        <div class="content-card content-card--simple">
          <strong>Beginners</strong>
          <p>For those starting from scratch. Small groups, patient coaches, a gradual approach.</p>
        </div>
        <div class="content-card content-card--simple">
          <strong>Intermediate</strong>
          <p>Consolidate your technique and improve consistency and tactics in your game.</p>
        </div>
        <div class="content-card content-card--simple">
          <strong>Advanced</strong>
          <p>Match play, video analysis and stroke-specific work for competitive players.</p>
        </div>
        <div class="content-card content-card--simple">
          <strong>Private Lessons</strong>
          <p>One-to-one work with the coach. Maximum intensity, rapid progress.</p>
        </div>
      </div>
      <div class="section-cta">
        <button class="btn btn-red" data-open-modal="modal-contatti">Request Information</button>
      </div>
    </div>
  </section>

  <ConversionBlock lang={lang} />

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .section-lead {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-light);
    max-width: 64ch;
    margin-bottom: 4vh;
  }

  .section-cta {
    margin-top: 4vh;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .content-grid--4 { grid-template-columns: repeat(4, 1fr); }

  .content-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .content-card h3,
  .content-card strong {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  .content-card--simple {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
  }

  .content-card p {
    font-family: var(--font-body);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  @media (max-width: 1024px) {
    .content-grid { grid-template-columns: repeat(2, 1fr); }
    .content-grid--4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .content-grid,
    .content-grid--4 { grid-template-columns: 1fr; }
  }

  /* ── Anchor offset per navbar fissa ── */
  .anchor-target {
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }
</style>
