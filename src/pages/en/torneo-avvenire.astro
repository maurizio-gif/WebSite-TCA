---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { publicUrl } from "../../i18n/utils";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Avvenire Tournament | Tennis Club Ambrosiano Milan"
  description="The Avvenire Tournament is the most important junior tennis tournament in Italy, hosted by Tennis Club Ambrosiano in Milan since 1960."
>
  <PageHero
    eyebrow="The Tournament"
    title="Avvenire"
    titleAccent="Tournament"
    sub="The most important junior tennis tournament in Italy. Since 1960, TCA has hosted one of the most prestigious under-14 competitions in the world. Champions were born here."
    image="/TCA_foto%20torneo%20Avvenire%202025.jpg"
    imageAlt="Avvenire Tournament at Tennis Club Ambrosiano"
    ctaLabel="Discover the tournament"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">The history</span>
      <h2 class="section-title">A legendary<br><em>tournament.</em></h2>
      <div class="torneo-intro">
        <p class="body-text">
          The Avvenire Tournament is one of the most important junior tennis events in the world.
          Since 1960, every year TCA hosts the best under-14 talents from across the globe.
          Champions such as Boris Becker, Stefan Edberg and many other stars of world tennis
          have emerged from the courts of the Avvenire Tournament.
        </p>
        <p class="body-text">
          A tradition that Tennis Club Ambrosiano carries forward with pride,
          year after year, in the name of excellence and respect for the sport.
        </p>
      </div>

      <div class="stats-row">
        <div class="stat">
          <span class="stat__n">60+</span>
          <span class="stat__label">Years of history</span>
        </div>
        <div class="stat">
          <span class="stat__n">40+</span>
          <span class="stat__label">Countries represented</span>
        </div>
        <div class="stat">
          <span class="stat__n">Under 14</span>
          <span class="stat__label">Category</span>
        </div>
        <div class="stat">
          <span class="stat__n">Top 10</span>
          <span class="stat__label">Former players in the ATP rankings</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Champions who played the Avvenire ── -->
  <section class="content-section content-section--grey">
    <div class="content-section__inner">
      <span class="eyebrow">Distinguished alumni</span>
      <h2 class="section-title">Champions born<br><em>here.</em></h2>
      <p class="body-text" style="max-width:64ch; margin-bottom:4vh;">
        Some of the greatest names in world tennis took their first steps on TCA's courts, competing in the Avvenire Tournament as juniors.
      </p>
      <div class="champions-grid">
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Lendl.avif")} alt="Ivan Lendl at the Avvenire Tournament" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Ivan Lendl</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Ivanisevic.avif")} alt="Goran Ivanisevic at the Avvenire Tournament" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Goran Ivanisevic</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Hingis.avif")} alt="Martina Hingis at the Avvenire Tournament" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Martina Hingis</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Sharapova.avif")} alt="Maria Sharapova at the Avvenire Tournament" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Maria Sharapova</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Pennetta.avif")} alt="Flavia Pennetta at the Avvenire Tournament" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Flavia Pennetta</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Giorgi.avif")} alt="Camila Giorgi at the Avvenire Tournament" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Camila Giorgi</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Zabaleta.avif")} alt="Pablo Zabaleta at the Avvenire Tournament" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Pablo Zabaleta</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── Recent editions gallery ── -->
  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Gallery</span>
      <h2 class="section-title">The tournament<br><em>in pictures.</em></h2>
      <div class="gallery-grid">
        <img src={publicUrl("/TCA_foto%20torneo%20Avvenire%202025.jpg")} alt="Avvenire Tournament 2025" loading="lazy" class="gallery-img gallery-img--wide" />
        <img src={publicUrl("/TCA_foto%20torneo%20Avvenire%202024.jpg")} alt="Avvenire Tournament 2024" loading="lazy" class="gallery-img" />
        <img src={publicUrl("/TCA_Avvenire_2025%201.jpg")} alt="Avvenire Tournament 2025 - match moment" loading="lazy" class="gallery-img" />
        <img src={publicUrl("/TCA_Avvenire_2025%206.jpg")} alt="Avvenire Tournament 2025 - atmosphere" loading="lazy" class="gallery-img gallery-img--wide" />
      </div>
    </div>
  </section>

  <section class="content-section content-section--dark">
    <div class="content-section__inner">
      <span class="eyebrow eyebrow--grey">Next edition</span>
      <h2 class="section-title section-title--light">2026<br><em>edition.</em></h2>
      <p class="body-text body-text--light">
        Registration for the 2026 edition will be available soon.
        Stay updated by following our official channels.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--dark {
    background: #0f1013;
    color: #fff;
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }
  .section-title--light { color: #fff; }

  .torneo-intro {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 72ch;
    margin-bottom: 5vh;
  }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .body-text--light { color: rgba(255, 255, 255, 0.65); max-width: 60ch; }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .stat {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .stat__n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat__label {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: var(--color-text-light);
  }

  @media (max-width: 860px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .stats-row { grid-template-columns: 1fr; }
  }

  .content-section--grey {
    background: var(--color-off-white);
    padding: 7vh var(--pad-x);
  }

  .champions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .champion-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .champion-img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .champion-cap {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.85vw, 13px);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  @media (max-width: 860px) {
    .champions-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 540px) {
    .champions-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 0.75rem;
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .gallery-img--wide {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }

  @media (max-width: 640px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-img--wide { grid-column: span 1; aspect-ratio: 4/3; }
  }
</style>
