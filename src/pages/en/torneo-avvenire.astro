---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import PhotoLightbox from "../../components/PhotoLightbox.astro";
import { publicUrl } from "../../i18n/utils";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Avvenire Tournament | Tennis Club Ambrosiano Milan"
  description="The Avvenire Tournament is the most important junior tennis tournament in Italy, hosted by Tennis Club Ambrosiano in Milan since 1965."
>
  <PageHero
    eyebrow="The Tournament"
    title="Avvenire"
    titleAccent="Tournament"
    sub="The most important junior tennis tournament in Italy. Since 1965, TCA has hosted one of the most prestigious under-14 competitions in the world. Champions were born here."
    image="/TCA_foto%20torneo%20Avvenire%202025.jpg"
    imageAlt="Avvenire Tournament at Tennis Club Ambrosiano"
    ctaLabel="Discover the tournament"
  />

  <p class="torneo-quote">
    "The tournament that never gets a prediction wrong"<span>— Rino Tommasi</span>
  </p>

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">The history</span>
      <h2 class="section-title">A legendary<br><em>tournament.</em></h2>
      <div class="torneo-intro">
        <p class="body-text">
          The Avvenire Tournament is one of the most important junior tennis events in the
          world, igniting the dreams of young talents on the courts of Tennis Club Ambrosiano
          since 1965. TCA has hosted the best under-16 and under-14 talents from across the
          globe. On these clay courts, champions destined to write the history of world tennis
          took their first steps — from <strong>Björn Borg</strong> to <strong>Roger Federer</strong>,
          from <strong>Martina Hingis</strong> to <strong>Novak Djokovic</strong>.
        </p>
        <p class="body-text">
          Since 2025 the Avvenire Tournament has become a prestigious <strong>Under-14 Super
          Category</strong> tournament, the highest level of international junior tennis,
          continuing its mission of discovering and nurturing tomorrow's champions.
        </p>
      </div>

      <div class="stats-row">
        <div class="stat">
          <span class="stat__n">60+</span>
          <span class="stat__label">Years of history</span>
        </div>
        <div class="stat">
          <span class="stat__n">40+</span>
          <span class="stat__label">Countries represented</span>
        </div>
        <div class="stat">
          <span class="stat__n">U14</span>
          <span class="stat__label">Super Category</span>
        </div>
        <div class="stat">
          <span class="stat__n">57</span>
          <span class="stat__label">Grand Slam titles won by our former players</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Champions who played the Avvenire ── -->
  <section class="content-section content-section--grey">
    <div class="content-section__inner">
      <span class="eyebrow">Distinguished alumni</span>
      <h2 class="section-title">Champions born<br><em>here.</em></h2>
      <p class="body-text" style="max-width:64ch; margin-bottom:4vh;">
        Some of the greatest names in world tennis took their first steps on TCA's courts, competing in the Avvenire Tournament as juniors.
      </p>
      <div class="champions-grid">
        <figure class="champion-fig">
          <div class="champion-img-wrap" data-lightbox data-lightbox-caption="Ivan Lendl">
            <img src={publicUrl("/Avvenire%20Lendl.avif")} alt="Ivan Lendl at the Avvenire Tournament" loading="lazy" class="champion-img"/>
            <span class="champion-expand" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg></span>
          </div>
          <figcaption class="champion-cap">Ivan Lendl</figcaption>
        </figure>
        <figure class="champion-fig">
          <div class="champion-img-wrap" data-lightbox data-lightbox-caption="Goran Ivanisevic">
            <img src={publicUrl("/Avvenire%20Ivanisevic.avif")} alt="Goran Ivanisevic at the Avvenire Tournament" loading="lazy" class="champion-img"/>
            <span class="champion-expand" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg></span>
          </div>
          <figcaption class="champion-cap">Goran Ivanisevic</figcaption>
        </figure>
        <figure class="champion-fig">
          <div class="champion-img-wrap" data-lightbox data-lightbox-caption="Martina Hingis">
            <img src={publicUrl("/Avvenire%20Hingis.avif")} alt="Martina Hingis at the Avvenire Tournament" loading="lazy" class="champion-img"/>
            <span class="champion-expand" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg></span>
          </div>
          <figcaption class="champion-cap">Martina Hingis</figcaption>
        </figure>
        <figure class="champion-fig">
          <div class="champion-img-wrap" data-lightbox data-lightbox-caption="Maria Sharapova">
            <img src={publicUrl("/Avvenire%20Sharapova.avif")} alt="Maria Sharapova at the Avvenire Tournament" loading="lazy" class="champion-img"/>
            <span class="champion-expand" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg></span>
          </div>
          <figcaption class="champion-cap">Maria Sharapova</figcaption>
        </figure>
        <figure class="champion-fig">
          <div class="champion-img-wrap" data-lightbox data-lightbox-caption="Flavia Pennetta">
            <img src={publicUrl("/Avvenire%20Pennetta.avif")} alt="Flavia Pennetta at the Avvenire Tournament" loading="lazy" class="champion-img"/>
            <span class="champion-expand" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg></span>
          </div>
          <figcaption class="champion-cap">Flavia Pennetta</figcaption>
        </figure>
        <figure class="champion-fig">
          <div class="champion-img-wrap" data-lightbox data-lightbox-caption="Camila Giorgi">
            <img src={publicUrl("/Avvenire%20Giorgi.avif")} alt="Camila Giorgi at the Avvenire Tournament" loading="lazy" class="champion-img"/>
            <span class="champion-expand" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg></span>
          </div>
          <figcaption class="champion-cap">Camila Giorgi</figcaption>
        </figure>
        <figure class="champion-fig">
          <div class="champion-img-wrap" data-lightbox data-lightbox-caption="Pablo Zabaleta">
            <img src={publicUrl("/Avvenire%20Zabaleta.avif")} alt="Pablo Zabaleta at the Avvenire Tournament" loading="lazy" class="champion-img"/>
            <span class="champion-expand" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg></span>
          </div>
          <figcaption class="champion-cap">Pablo Zabaleta</figcaption>
        </figure>
        <figure class="champion-fig">
          <div class="champion-img-wrap" data-lightbox data-lightbox-caption="Jennifer Capriati">
            <img src={publicUrl("/Avvenire%20Capriati.jpg")} alt="Jennifer Capriati at the Avvenire Tournament" loading="lazy" class="champion-img"/>
            <span class="champion-expand" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg></span>
          </div>
          <figcaption class="champion-cap">Jennifer Capriati</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── Recent editions gallery ── -->
  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Gallery</span>
      <h2 class="section-title">The tournament<br><em>in pictures.</em></h2>
      <div class="gallery-grid">
        <img src={publicUrl("/TCA%20Avvenire%202025%20-%20Stretta%20di%20mano.jpg")} alt="Avvenire Tournament 2025 - handshake at the end of the match" loading="lazy" class="gallery-img gallery-img--wide" />
        <img src={publicUrl("/TCA%20Avvenire%202025%20-%20Premiazione%20singolare.jpg")} alt="Avvenire Tournament 2025 - U14 winner's trophy ceremony" loading="lazy" class="gallery-img" />
        <img src={publicUrl("/TCA%20Avvenire%202025%20-%20Coppe.jpg")} alt="Avvenire Tournament 2025 - trophies of the 58th edition" loading="lazy" class="gallery-img" />
        <img src={publicUrl("/TCA%20Avvenire%202025%20-%20Albo%20d%27oro.jpg")} alt="Avvenire Tournament - Roll of Honor" loading="lazy" class="gallery-img" />
        <img src={publicUrl("/TCA%20Avvenire%202024%20-%20Conferenza%20stampa.jpg")} alt="Avvenire Tournament 2024 - press conference" loading="lazy" class="gallery-img" />
        <img src={publicUrl("/TCA%20Avvenire%202025%20-%20Conferenza%20stampa.jpg")} alt="Avvenire Tournament 2025 - press conference of the 58th edition" loading="lazy" class="gallery-img gallery-img--wide" />
        <img src={publicUrl("/TCA%20Avvenire%202025%20-%20Pubblico.jpg")} alt="Avvenire Tournament 2025 - audience at the press conference" loading="lazy" class="gallery-img" />
      </div>
    </div>
  </section>

  <PhotoLightbox lang={lang} />

  <section class="content-section content-section--dark">
    <div class="content-section__inner">
      <span class="eyebrow eyebrow--grey">Next edition</span>
      <h2 class="section-title section-title--light">2026<br><em>edition.</em></h2>
      <p class="body-text body-text--light">
        Registration for the 2026 edition will be available on the Tennis Europe website.
        Stay updated by following our official channels.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--dark {
    background: #0f1013;
    color: #fff;
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }
  .section-title--light { color: #fff; }

  .torneo-quote {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5vh var(--pad-x) 0;
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.2vw, 2rem);
    font-style: italic;
    color: var(--color-text);
    line-height: 1.3;
  }

  .torneo-quote span {
    display: block;
    margin-top: 0.5rem;
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-style: normal;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-light);
  }

  .torneo-intro {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 72ch;
    margin-bottom: 5vh;
  }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .body-text--light { color: rgba(255, 255, 255, 0.65); max-width: 60ch; }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .stat {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .stat__n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat__label {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: var(--color-text-light);
  }

  @media (max-width: 860px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .stats-row { grid-template-columns: 1fr; }
  }

  .content-section--grey {
    background: var(--color-off-white);
    padding: 7vh var(--pad-x);
  }

  .champions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .champion-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .champion-img-wrap {
    position: relative;
    cursor: pointer;
  }

  .champion-img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .champion-expand {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    transition: background 0.18s, transform 0.18s;
  }

  .champion-img-wrap:hover .champion-expand {
    background: var(--color-accent);
    transform: scale(1.08);
  }

  .champion-cap {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.85vw, 13px);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  @media (max-width: 860px) {
    .champions-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 540px) {
    .champions-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 0.75rem;
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .gallery-img--wide {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }

  @media (max-width: 640px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-img--wide { grid-column: span 1; aspect-ratio: 4/3; }
  }
</style>
