---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { publicUrl } from "../../i18n/utils";
import { getEntry } from "astro:content";

const lang = 'en' as const;

// SEO + hero + corpo pagina gestibili da TinaCMS → src/content/pagine/summer-camps.md (campi _en)
const d = (await getEntry("pagine", "summer-camps"))!.data;
---

<BaseLayout
  lang={lang}
  title={d.title_en ?? d.title}
  description={d.description_en ?? d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt_en ?? d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow_en ?? d.hero_eyebrow}
    title={d.hero_titolo_en ?? d.hero_titolo}
    titleAccent={d.hero_titolo_accent_en ?? d.hero_titolo_accent}
    sub={d.hero_sottotitolo_en ?? d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt_en ?? d.hero_immagine_alt}
    ctaLabel="Book your spot"
  />

  <!-- The programme -->
  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">{d.camps_sezione1_eyebrow_en ?? d.camps_sezione1_eyebrow}</span>
      <h2 class="section-title">{d.camps_sezione1_titolo_en ?? d.camps_sezione1_titolo}<br><em>{d.camps_sezione1_titolo_accent_en ?? d.camps_sezione1_titolo_accent}</em></h2>
      <div class="features-grid">
        {d.camps_features!.map((f, i) => (
          <div class="feature">
            <span class="feature__num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{f.titolo_en ?? f.titolo}</h3>
            <p>{f.testo_en ?? f.testo}</p>
          </div>
        ))}
      </div>

      <div class="camp-img-row">
        <img src={publicUrl(d.camps_immagine1!)} alt={d.camps_immagine1_alt_en ?? d.camps_immagine1_alt!} class="camp-img" />
        <img src={publicUrl(d.camps_immagine2!)} alt={d.camps_immagine2_alt_en ?? d.camps_immagine2_alt!} class="camp-img" />
      </div>
    </div>
  </section>

  <!-- When and how it works -->
  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.camps_sezione2_eyebrow_en ?? d.camps_sezione2_eyebrow}</span>
      <h2 class="section-title">{d.camps_sezione2_titolo_en ?? d.camps_sezione2_titolo}<br><em>{d.camps_sezione2_titolo_accent_en ?? d.camps_sezione2_titolo_accent}</em></h2>
      <div class="info-grid">
        {d.camps_info_rapide!.map((info) => (
          <div class="info-item">
            <span class="info-item__label">{info.label_en ?? info.label}</span>
            <span class="info-item__value">{info.valore_en ?? info.valore}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- A typical day -->
  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">{d.camps_giornata_eyebrow_en ?? d.camps_giornata_eyebrow}</span>
      <h2 class="section-title">{d.camps_giornata_titolo_en ?? d.camps_giornata_titolo}</h2>
      <div class="day-grid">
        {d.camps_giornata!.map((g) => (
          <div class="day-card">
            <span class="day-card__time">{g.orario}</span>
            <h3>{g.titolo_en ?? g.titolo}</h3>
            <p>{g.testo_en ?? g.testo}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Weekly technical programme -->
  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.camps_settimanale_eyebrow_en ?? d.camps_settimanale_eyebrow}</span>
      <h2 class="section-title">{d.camps_settimanale_titolo_en ?? d.camps_settimanale_titolo}</h2>
      <div class="week-grid">
        {d.camps_settimanale!.map((s) => (
          <div class="week-card">
            <span class="week-card__day">{s.giorno_en ?? s.giorno}</span>
            <h3>{s.colpo_en ?? s.colpo}</h3>
            <p>{s.testo_en ?? s.testo}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to bring -->
  <section class="content-section">
    <div class="content-section__inner">
      <h2 class="section-title section-title--small">{d.camps_cosa_portare_titolo_en ?? d.camps_cosa_portare_titolo}</h2>
      <div class="portare-row">
        <ul class="bullet-list">
          {(d.camps_cosa_portare_en ?? d.camps_cosa_portare)!.map((voce) => <li>{voce}</li>)}
        </ul>
        <div class="kit-callout">
          <p>{d.camps_kit_benvenuto_en ?? d.camps_kit_benvenuto}</p>
          <p class="kit-callout__obbligo"><strong>{d.camps_obbligatorio_en ?? d.camps_obbligatorio}</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Summer Camp rates -->
  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">{d.camps_quote_eyebrow_en ?? d.camps_quote_eyebrow}</span>
      <h2 class="section-title">{d.camps_quote_titolo_en ?? d.camps_quote_titolo}</h2>

      <div class="price-table-wrap">
        <table class="price-table">
          <thead>
            <tr>
              <th></th>
              <th>Per week</th>
              <th>From week 2</th>
              <th>Siblings</th>
            </tr>
          </thead>
          <tbody>
            {d.camps_quote_righe!.map((r) => (
              <tr>
                <td class="price-table__cat">{r.categoria_en ?? r.categoria}</td>
                <td>{r.prezzo_settimana}</td>
                <td>{r.prezzo_dal2}</td>
                <td>{r.prezzo_fratelli}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <ul class="bullet-list bullet-list--notes">
        {(d.camps_quote_note_en ?? d.camps_quote_note)!.map((nota) => <li>{nota}</li>)}
      </ul>

      <div class="cta-row">
        <button class="btn btn-red" data-open-modal="modal-contatti">{d.camps_cta_label_en ?? d.camps_cta_label}</button>
      </div>
    </div>
  </section>

  <!-- Summer Tennis School -->
  <section class="content-section scuola-estiva">
    <div class="content-section__inner">
      <span class="eyebrow">{d.scuolaestiva_eyebrow_en ?? d.scuolaestiva_eyebrow}</span>
      <h2 class="section-title">{d.scuolaestiva_titolo_en ?? d.scuolaestiva_titolo}<br><em>{d.scuolaestiva_titolo_accent_en ?? d.scuolaestiva_titolo_accent}</em></h2>
      <p class="lead-text">{d.scuolaestiva_testo_en ?? d.scuolaestiva_testo}</p>

      <div class="info-grid info-grid--3">
        {d.scuolaestiva_info_rapide!.map((info) => (
          <div class="info-item">
            <span class="info-item__label">{info.label_en ?? info.label}</span>
            <span class="info-item__value">{info.valore_en ?? info.valore}</span>
          </div>
        ))}
      </div>

      <div class="price-table-wrap price-table-wrap--simple">
        <table class="price-table">
          <tbody>
            {d.scuolaestiva_quote_righe!.map((r) => (
              <tr>
                <td class="price-table__cat">{r.categoria_en ?? r.categoria}</td>
                <td>{r.prezzo}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <ul class="bullet-list bullet-list--notes">
        {(d.scuolaestiva_note_en ?? d.scuolaestiva_note)!.map((nota) => <li>{nota}</li>)}
      </ul>

      <div class="cta-row">
        <button class="btn btn-red" data-open-modal="modal-contatti">{d.scuolaestiva_cta_label_en ?? d.scuolaestiva_cta_label}</button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .scuola-estiva {
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title--small {
    font-size: clamp(1.6rem, 2.6vw, 2.4rem);
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .lead-text {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    max-width: 60ch;
    margin: -2vh 0 4vh;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 4vh;
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature__num {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .feature h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .feature p {
    font-family: var(--font-body);
    font-size: clamp(15px, 0.95vw, 17px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .camp-img-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
  }

  .camp-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .camp-img-row .camp-img:last-child { aspect-ratio: 4/3; }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .info-grid--3 { grid-template-columns: repeat(3, 1fr); margin-bottom: 4vh; }

  .info-item {
    background: var(--color-bg);
    padding: 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .info-item__label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .info-item__value {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.95vw, 16px);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.5;
  }

  .day-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .day-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .day-card__time {
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--color-accent);
    font-size: clamp(1rem, 1.2vw, 1.2rem);
  }

  .day-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .day-card p {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-light);
  }

  .week-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .week-card {
    border-top: 3px solid var(--color-accent);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .week-card__day {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
  }

  .week-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.4vw, 1.4rem);
    font-weight: 800;
    text-transform: uppercase;
  }

  .week-card p {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-light);
  }

  .portare-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .bullet-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .bullet-list li {
    position: relative;
    padding-left: 1.4rem;
    font-family: var(--font-body);
    font-size: clamp(14px, 0.95vw, 16px);
    font-weight: 300;
    line-height: 1.5;
    color: var(--color-text);
  }

  .bullet-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .bullet-list--notes {
    margin: 3vh 0 4vh;
    max-width: 70ch;
  }

  .kit-callout {
    background: var(--color-off-white);
    border: 1px solid var(--color-border);
    padding: 1.75rem;
  }

  .kit-callout p {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.95vw, 16px);
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }

  .kit-callout__obbligo {
    margin-top: 1rem !important;
    color: var(--color-accent-dark) !important;
  }

  .price-table-wrap {
    overflow-x: auto;
    margin-bottom: 2.5vh;
  }

  .price-table-wrap--simple { max-width: 480px; }

  .price-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 480px;
  }

  .price-table th {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: left;
    color: #fff;
    background: var(--color-accent);
    padding: 0.9rem 1.25rem;
  }

  .price-table td {
    font-family: var(--font-body);
    font-size: clamp(14px, 0.95vw, 16px);
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .price-table__cat {
    font-weight: 600;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .price-table tbody tr:nth-child(odd) {
    background: var(--color-off-white);
  }

  .content-section--alt .price-table tbody tr:nth-child(odd) {
    background: var(--color-bg);
  }

  .cta-row {
    display: flex;
    justify-content: center;
    margin-top: 2vh;
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .info-grid { grid-template-columns: repeat(2, 1fr); }
    .info-grid--3 { grid-template-columns: repeat(2, 1fr); }
    .day-grid { grid-template-columns: repeat(2, 1fr); }
    .week-grid { grid-template-columns: repeat(2, 1fr); }
    .portare-row { grid-template-columns: 1fr; gap: 2rem; }
  }

  @media (max-width: 640px) {
    .features-grid { grid-template-columns: 1fr; }
    .camp-img-row { grid-template-columns: 1fr; }
    .info-grid,
    .info-grid--3 { grid-template-columns: 1fr; }
    .day-grid { grid-template-columns: 1fr; }
    .week-grid { grid-template-columns: 1fr; }
  }
</style>
