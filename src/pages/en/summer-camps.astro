---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { publicUrl } from "../../i18n/utils";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Summer Camps | Tennis Club Ambrosiano Milan"
  description="TCA Summer Camps: tennis, sport and fun for children and teenagers throughout the summer. Intensive weeks, activities and plenty of sunshine in Milan."
>
  <PageHero
    eyebrow="Junior · Summer Camps"
    title="Summer"
    titleAccent="Camps 2026"
    sub="Milan's most active summer. Tennis, sport, friendships and fun for children and teenagers from June to September. Intensive weeks with dedicated coaches and activity leaders."
    image="/aYszOt0YXLCxVpqZ_TCA_summercamp2026_orizzontale_tennisfemmina_nologhi.avif"
    imageAlt="TCA Summer Camps 2026"
    ctaLabel="Book your spot"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">The programme</span>
      <h2 class="section-title">An unforgettable<br><em>summer.</em></h2>
      <div class="features-grid">
        <div class="feature">
          <span class="feature__num">01</span>
          <h3>Tennis every morning</h3>
          <p>Technical sessions and match play led by our FITP coaches.</p>
        </div>
        <div class="feature">
          <span class="feature__num">02</span>
          <h3>Afternoon multisport</h3>
          <p>Padel, football, swimming and other sports for a complete summer.</p>
        </div>
        <div class="feature">
          <span class="feature__num">03</span>
          <h3>Activities and games</h3>
          <p>A dedicated team creates fun and memorable moments every day.</p>
        </div>
        <div class="feature">
          <span class="feature__num">04</span>
          <h3>Age groups</h3>
          <p>Groups by age to ensure maximum safety and the right pace for everyone.</p>
        </div>
      </div>

      <div class="camp-img-row">
        <img
          src={publicUrl("/aYszOt0YXLCxVpqZ_TCA_summercamp2026_orizzontale_tennisfemmina_nologhi.avif")}
          alt="TCA tennis summer camps"
          class="camp-img"
        />
        <img
          src={publicUrl("/ZhlJNzjCgu4jzybm_shutterstock_409391734_kidsrunfunoutdoor.avif")}
          alt="Children running outdoors"
          class="camp-img"
        />
      </div>
    </div>
  </section>

  <section class="content-section content-section--alt">
    <div class="content-section__inner">
      <span class="eyebrow">2026 dates</span>
      <h2 class="section-title">Available<br><em>weeks.</em></h2>
      <div class="dates-grid">
        {[
          { week: "Week 1", dates: "15 – 19 June 2026" },
          { week: "Week 2", dates: "22 – 26 June 2026" },
          { week: "Week 3", dates: "29 June – 3 July 2026" },
          { week: "Week 4", dates: "6 – 10 July 2026" },
          { week: "Week 5", dates: "13 – 17 July 2026" },
          { week: "Week 6", dates: "20 – 24 July 2026" },
          { week: "Week 7", dates: "27 – 31 July 2026" },
          { week: "Week 8", dates: "31 August – 4 September 2026" },
        ].map((d) => (
          <div class="date-item">
            <span class="date-item__week">{d.week}</span>
            <span class="date-item__dates">{d.dates}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--alt {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 4vh;
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature__num {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .feature h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .feature p {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }

  .camp-img-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
  }

  .camp-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .camp-img-row .camp-img:last-child { aspect-ratio: 4/3; }

  .dates-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .date-item {
    background: var(--color-bg);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .date-item__week {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.75vw, 11px);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .date-item__dates {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 400;
    color: var(--color-text);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .dates-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .features-grid { grid-template-columns: 1fr; }
    .camp-img-row { grid-template-columns: 1fr; }
    .dates-grid { grid-template-columns: 1fr; }
  }
</style>
