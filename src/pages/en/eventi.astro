---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import EventiHome from "../../components/EventiHome.astro";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Events & Community | Tennis Club Ambrosiano Milan"
  description="Internal tournaments, social evenings, aperitivo nights and exhibitions: life at Tennis Club Ambrosiano goes beyond the court, all year in Milan."
  image="/TCA_Avvenire_2025%201.jpg"
  imageAlt="Event at Tennis Club Ambrosiano"
>
  <PageHero
    eyebrow="Community"
    title="Events"
    titleAccent="& Community"
    sub="Internal tournaments, social evenings, aperitivo nights and much more. Life at TCA goes well beyond the court — it's a community that comes together all year round."
    image="/TCA_Avvenire_2025%201.jpg"
    imageAlt="Events at Tennis Club Ambrosiano"
  />

  <EventiHome lang={lang} limit={100} showAllLink={false} />

</BaseLayout>
