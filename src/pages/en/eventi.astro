---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import EventiHome from "../../components/EventiHome.astro";

const lang = 'en' as const;
---

<BaseLayout
  lang={lang}
  title="Events | Tennis Club Ambrosiano Milan"
  description="Events at Tennis Club Ambrosiano: internal tournaments, social evenings, aperitivo nights, exhibitions and everything that brings the TCA community together throughout the year."
>
  <PageHero
    eyebrow="Community"
    title="Events"
    titleAccent="& Community"
    sub="Internal tournaments, social evenings, aperitivo nights and much more. Life at TCA goes well beyond the court — it's a community that comes together all year round."
    image="/TCA_Avvenire_2025%201.jpg"
    imageAlt="Events at Tennis Club Ambrosiano"
  />

  <EventiHome lang={lang} limit={100} showAllLink={false} />

</BaseLayout>
