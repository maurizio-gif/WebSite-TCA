---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/torneo-avvenire.md
const d = (await getEntry("pagine", "torneo-avvenire"))!.data;
---

<BaseLayout
  title={d.title}
  description={d.description}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctaLabel="Scopri il torneo"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">La storia</span>
      <h2 class="section-title">Un torneo<br><em>leggendario.</em></h2>
      <div class="torneo-intro">
        <p class="body-text">
          Il Torneo Avvenire è uno degli eventi tennis giovanili più importanti al mondo.
          Sin dal 1960, ogni anno il TCA ospita i migliori talenti under 14 da tutto il globo.
          Dal campo del Torneo Avvenire sono emersi campioni come Boris Becker, Stefan Edberg
          e molti altri protagonisti del tennis mondiale.
        </p>
        <p class="body-text">
          Una tradizione che il Tennis Club Ambrosiano porta avanti con orgoglio,
          anno dopo anno, nel segno dell'eccellenza e del rispetto dello sport.
        </p>
      </div>

      <div class="stats-row">
        <div class="stat">
          <span class="stat__n">60+</span>
          <span class="stat__label">Anni di storia</span>
        </div>
        <div class="stat">
          <span class="stat__n">40+</span>
          <span class="stat__label">Paesi rappresentati</span>
        </div>
        <div class="stat">
          <span class="stat__n">Under 14</span>
          <span class="stat__label">Categoria</span>
        </div>
        <div class="stat">
          <span class="stat__n">Top 10</span>
          <span class="stat__label">Ex-partecipanti in classifica ATP</span>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section content-section--dark">
    <div class="content-section__inner">
      <span class="eyebrow eyebrow--grey">Prossima edizione</span>
      <h2 class="section-title section-title--light">Edizione<br><em>2026.</em></h2>
      <p class="body-text body-text--light">
        Le iscrizioni per l'edizione 2026 saranno presto disponibili.
        Resta aggiornato seguendo i nostri canali ufficiali.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--dark {
    background: #0f1013;
    color: #fff;
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }
  .section-title--light { color: #fff; }

  .torneo-intro {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 72ch;
    margin-bottom: 5vh;
  }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .body-text--light { color: rgba(255, 255, 255, 0.65); max-width: 60ch; }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .stat {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .stat__n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat__label {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: var(--color-text-light);
  }

  @media (max-width: 860px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .stats-row { grid-template-columns: 1fr; }
  }
</style>
