---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { publicUrl } from "../i18n/utils";
import { getEntry } from "astro:content";

// SEO + hero gestibili da TinaCMS → src/content/pagine/torneo-avvenire.md
const d = (await getEntry("pagine", "torneo-avvenire"))!.data;
---

<BaseLayout
  title={d.title}
  description={d.description}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctaLabel="Scopri il torneo"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">La storia</span>
      <h2 class="section-title">Un torneo<br><em>leggendario.</em></h2>
      <div class="torneo-intro">
        <p class="body-text">
          Il Torneo Avvenire è uno degli eventi tennis giovanili più importanti al mondo.
          Sin dal 1960, ogni anno il TCA ospita i migliori talenti under 14 da tutto il globo.
          Dal campo del Torneo Avvenire sono emersi campioni come Boris Becker, Stefan Edberg
          e molti altri protagonisti del tennis mondiale.
        </p>
        <p class="body-text">
          Una tradizione che il Tennis Club Ambrosiano porta avanti con orgoglio,
          anno dopo anno, nel segno dell'eccellenza e del rispetto dello sport.
        </p>
      </div>

      <div class="stats-row">
        <div class="stat">
          <span class="stat__n">60+</span>
          <span class="stat__label">Anni di storia</span>
        </div>
        <div class="stat">
          <span class="stat__n">40+</span>
          <span class="stat__label">Paesi rappresentati</span>
        </div>
        <div class="stat">
          <span class="stat__n">Under 14</span>
          <span class="stat__label">Categoria</span>
        </div>
        <div class="stat">
          <span class="stat__n">Top 10</span>
          <span class="stat__label">Ex-partecipanti in classifica ATP</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Campioni che sono passati per l'Avvenire ── -->
  <section class="content-section content-section--grey">
    <div class="content-section__inner">
      <span class="eyebrow">Alumni illustri</span>
      <h2 class="section-title">Campioni nati<br><em>qui.</em></h2>
      <p class="body-text" style="max-width:64ch; margin-bottom:4vh;">
        Alcuni dei più grandi nomi del tennis mondiale hanno mosso i primi passi proprio sui campi del TCA, partecipando al Torneo Avvenire da giovanissimi.
      </p>
      <div class="champions-grid">
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Lendl.avif")} alt="Ivan Lendl al Torneo Avvenire" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Ivan Lendl</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Ivanisevic.avif")} alt="Goran Ivanisevic al Torneo Avvenire" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Goran Ivanisevic</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Hingis.avif")} alt="Martina Hingis al Torneo Avvenire" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Martina Hingis</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Sharapova.avif")} alt="Maria Sharapova al Torneo Avvenire" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Maria Sharapova</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Pennetta.avif")} alt="Flavia Pennetta al Torneo Avvenire" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Flavia Pennetta</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Giorgi.avif")} alt="Camila Giorgi al Torneo Avvenire" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Camila Giorgi</figcaption>
        </figure>
        <figure class="champion-fig">
          <img src={publicUrl("/Avvenire%20Zabaleta.avif")} alt="Pablo Zabaleta al Torneo Avvenire" loading="lazy" class="champion-img" />
          <figcaption class="champion-cap">Pablo Zabaleta</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── Foto edizioni recenti ── -->
  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">Galleria</span>
      <h2 class="section-title">Il torneo<br><em>in immagini.</em></h2>
      <div class="gallery-grid">
        <img src={publicUrl("/TCA_foto%20torneo%20Avvenire%202025.avif")} alt="Torneo Avvenire 2025" loading="lazy" class="gallery-img gallery-img--wide" />
        <img src={publicUrl("/TCA_foto%20torneo%20Avvenire%202024.avif")} alt="Torneo Avvenire 2024" loading="lazy" class="gallery-img" />
        <img src={publicUrl("/TCA_Avvenire_2025%201.avif")} alt="Torneo Avvenire 2025 - momento di gara" loading="lazy" class="gallery-img" />
        <img src={publicUrl("/TCA_Avvenire_2025%206.avif")} alt="Torneo Avvenire 2025 - atmosfera" loading="lazy" class="gallery-img gallery-img--wide" />
      </div>
    </div>
  </section>

  <section class="content-section content-section--dark">
    <div class="content-section__inner">
      <span class="eyebrow eyebrow--grey">Prossima edizione</span>
      <h2 class="section-title section-title--light">Edizione<br><em>2026.</em></h2>
      <p class="body-text body-text--light">
        Le iscrizioni per l'edizione 2026 saranno presto disponibili.
        Resta aggiornato seguendo i nostri canali ufficiali.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section--dark {
    background: #0f1013;
    color: #fff;
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }
  .section-title--light { color: #fff; }

  .torneo-intro {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 72ch;
    margin-bottom: 5vh;
  }

  .body-text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .body-text--light { color: rgba(255, 255, 255, 0.65); max-width: 60ch; }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .stat {
    background: var(--color-bg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .stat__n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat__label {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: var(--color-text-light);
  }

  @media (max-width: 860px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .stats-row { grid-template-columns: 1fr; }
  }

  .content-section--grey {
    background: var(--color-off-white);
    padding: 7vh var(--pad-x);
  }

  /* ── Champions grid ── */
  .champions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .champion-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .champion-img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .champion-cap {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.85vw, 13px);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  @media (max-width: 860px) {
    .champions-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 540px) {
    .champions-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Gallery grid ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 0.75rem;
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .gallery-img--wide {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }

  @media (max-width: 640px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-img--wide { grid-column: span 1; aspect-ratio: 4/3; }
  }
</style>
