<script>
  // Slideshow Preparazione Atletica: auto-avanzamento + dot cliccabili
  (function () {
    var slider = document.querySelector('[data-lp-slider]');
    if (!slider) return;
    var track = slider.querySelector('.lp-slider__track');
    var slides = slider.querySelectorAll('.lp-slider__slide');
    var dots = Array.prototype.slice.call(slider.querySelectorAll('[data-lp-dot]'));
    if (!track || slides.length < 2) return;

    var total = slides.length;
    var idx = 0;
    var timer;
    var DELAY = 3800;

    function go(n) {
      idx = ((n % total) + total) % total;
      track.style.transform = 'translateX(-' + (idx * 100) + '%)';
      dots.forEach(function (d, i) { d.classList.toggle('is-active', i === idx); });
    }
    function stop() { if (timer) { clearInterval(timer); timer = undefined; } }
    function start() { stop(); timer = setInterval(function () { go(idx + 1); }, DELAY); }

    dots.forEach(function (d, i) {
      d.addEventListener('click', function () { go(i); start(); });
    });
    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);

    start();
  })();

  // Stats: count-up numerico quando la sezione entra in viewport
  (function () {
    var els = Array.prototype.slice.call(document.querySelectorAll('.lp-stat__num[data-count-to]'));
    if (!els.length) return;

    var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var DURATION = 1400;

    function format(value, thousands, suffix) {
      var n = Math.round(value);
      var s = thousands ? n.toLocaleString('it-IT') : String(n);
      return s + suffix;
    }

    function animate(el) {
      var target = parseInt(el.dataset.countTo, 10);
      var suffix = el.dataset.suffix || '';
      var thousands = el.dataset.thousands === '1';
      if (!isFinite(target)) return;

      if (reduceMotion) {
        el.textContent = format(target, thousands, suffix);
        return;
      }

      var start = null;
      function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
      function step(ts) {
        if (start === null) start = ts;
        var p = Math.min((ts - start) / DURATION, 1);
        el.textContent = format(target * easeOutCubic(p), thousands, suffix);
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    if (!('IntersectionObserver' in window)) {
      els.forEach(animate);
      return;
    }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        animate(entry.target);
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.5 });

    els.forEach(function (el) { observer.observe(el); });
  })();
</script>
