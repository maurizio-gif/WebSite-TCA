---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry } from "astro:content";

// SEO + hero + corpo pagina gestibili da TinaCMS → src/content/pagine/agonistica.md
const d = (await getEntry("pagine", "agonistica"))!.data;
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.hero_immagine}
  imageAlt={d.hero_immagine_alt}
>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_titolo!}
    titleAccent={d.hero_titolo_accent}
    sub={d.hero_sottotitolo}
    image={d.hero_immagine!}
    imageAlt={d.hero_immagine_alt!}
    ctaLabel="Entra in squadra"
  />

  <section class="content-section">
    <div class="content-section__inner">
      <span class="eyebrow">{d.agonistica_eyebrow}</span>
      <h2 class="section-title">{d.agonistica_titolo}<br><em>{d.agonistica_titolo_accent}</em></h2>
      <div class="steps">
        {d.agonistica_step.map((s, i) => (
          <div class="step">
            <span class="step__n">{String(i + 1).padStart(2, '0')}</span>
            <div class="step__body">
              <h3>{s.titolo}</h3>
              <p>{s.testo}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-section {
    padding: 7vh var(--pad-x);
  }

  .content-section__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .section-title em { color: var(--color-accent); font-style: normal; }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    padding: 2rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .step:last-child { border-bottom: none; }

  .step__n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    flex-shrink: 0;
    min-width: 3rem;
  }

  .step__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.25rem;
  }

  .step h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .step p {
    font-family: var(--font-body);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
  }
</style>
