---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import LeadModal from "../components/LeadModal.astro";
import LeadFormInline from "../components/LeadFormInline.astro";
import InfoPratiche from "../components/InfoPratiche.astro";
import AffiliazioniSlider from "../components/AffiliazioniSlider.astro";
import { getLangFromUrl, useTranslations, getAlternatePath, getLocalePath, publicUrl, type Lang } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  lang?: Lang;
  hideLeadFormInline?: boolean;
  hideChrome?: boolean;
}

const { title, description, image, imageAlt, lang: langProp, hideLeadFormInline = false, hideChrome = false } = Astro.props;

const lang: Lang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const desc = description ?? t.meta.defaultDescription;

// Strip base URL (es. '/WebSite-TCA') per calcolare i path alternativi
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const rawPath = Astro.url.pathname;
const cleanPath = base && rawPath.startsWith(base)
  ? (rawPath.slice(base.length) || '/')
  : rawPath;

const { it: itClean } = getAlternatePath(cleanPath);
const siteOrigin = Astro.site?.origin ?? '';
const itHreflang = `${siteOrigin}${getLocalePath('it', itClean)}`;
const enHreflang = `${siteOrigin}${getLocalePath('en', itClean)}`;
const canonicalUrl = `${siteOrigin}${getLocalePath(lang, itClean)}`;

// Foto social-preview: usa l'immagine hero della pagina (già curata in Tina),
// con fallback sulla foto aerea del Club per le pagine senza hero_immagine.
const DEFAULT_OG_IMAGE = '/HERO.avif';
const ogImage = `${siteOrigin}${publicUrl(image ?? DEFAULT_OG_IMAGE)}`;
const ogImageAlt = imageAlt ?? title;
const ogLocale = lang === 'it' ? 'it_IT' : 'en_US';
const ogLocaleAlternate = lang === 'it' ? 'en_US' : 'it_IT';
---

<!doctype html>
<html lang={lang} class={hideChrome ? 'is-app-embed' : undefined}>
  <head>
    <!-- Start cookieyes banner: deve stare il più in alto possibile in <head>,
         prima di qualsiasi script di tracciamento, così può bloccarli finché
         l'utente non presta consenso (vedi script sotto con
         type="text/plain" data-cookieyes="..."). -->
    <script id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/a52d1f8cdcea8593d12025ba01e05026/script.js"></script>
    <!-- End cookieyes banner -->

    <!-- Preconnect ai domini di GTM/Analytics: la connessione si apre in
         parallelo mentre il resto della pagina carica, invece di attendere
         che lo script GTM la richieda (risparmio stimato ~1.3s da PSI). -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />
    <link rel="preconnect" href="https://region1.analytics.google.com" />
    <link rel="preconnect" href="https://stats.g.doubleclick.net" />

    <!-- Google Tag Manager — bloccato da CookieYes finché l'utente non
         accetta i cookie di analytics (gestisce anche tutti i tag interni
         al container: GA4, Ads, remarketing, ecc.). -->
    <script is:inline type="text/plain" data-cookieyes="cookieyes-analytics">(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-WRDQ2RTG');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}logos/tca-logo.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}logos/tca-logo.png`} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang — SEO multilingua -->
    <link rel="alternate" hreflang="it"        href={itHreflang} />
    <link rel="alternate" hreflang="en"        href={enHreflang} />
    <link rel="alternate" hreflang="x-default" href={itHreflang} />

    <!-- Open Graph — anteprima social (Facebook, LinkedIn, WhatsApp...) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tennis Club Ambrosiano" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts: Barlow Condensed (display/titoli) + Barlow (body).
         Caricamento non bloccante (preload + swap del media) per non
         ritardare il render del testo: font-display=swap fa il resto. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,600;1,300&family=Barlow+Condensed:wght@600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,600;1,300&family=Barlow+Condensed:wght@600;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,600;1,300&family=Barlow+Condensed:wght@600;700;800&display=swap"
      />
    </noscript>
    <slot name="head" />

    <!-- Rilevamento embed in-app (?app=1): nasconde header/footer prima del
         primo paint, per evitare un flash del sito completo. Il sito resta
         completamente statico: nessuna logica lato server, solo una classe
         sull'<html> letta dal CSS globale. -->
    <script is:inline>
      if (new URLSearchParams(location.search).get('app') === '1') {
        document.documentElement.classList.add('is-app-embed');
      }
    </script>

    <!-- Cattura UTM/click-id da campagne Meta/Google Ads al primo touch della
         sessione (sessionStorage, mai sovrascritto): permette di attribuire il
         contatto anche se il form viene compilato dopo una navigazione interna
         che non porta più la querystring della campagna.
         Bloccato da CookieYes finché l'utente non accetta i cookie di analytics. -->
    <script is:inline type="text/plain" data-cookieyes="cookieyes-analytics">
      (function () {
        if (sessionStorage.getItem('tca_utm')) return;
        var params = new URLSearchParams(location.search);
        var KEYS = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','gclid','fbclid'];
        var found = {};
        var hasAny = false;
        KEYS.forEach(function (k) {
          if (params.has(k)) { found[k] = params.get(k); hasAny = true; }
        });
        if (hasAny) sessionStorage.setItem('tca_utm', JSON.stringify(found));
      })();
    </script>

    <!-- ID visitatore persistente (localStorage, non scade): identifica lo
         stesso browser tra una visita e l'altra, così il form (e in futuro
         il beacon qui sotto) possono riconoscere un lead già noto anche
         senza aver ricompilato nulla. Generato una sola volta, poi riletto.
         Bloccato da CookieYes finché l'utente non accetta i cookie di analytics. -->
    <script is:inline type="text/plain" data-cookieyes="cookieyes-analytics">
      (function () {
        var KEY = 'tca_vid';
        var vid;
        try { vid = localStorage.getItem(KEY); } catch (e) { vid = null; }
        if (!vid) {
          vid = (window.crypto && crypto.randomUUID) ? crypto.randomUUID() :
            'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
              var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
              return v.toString(16);
            });
          try { localStorage.setItem(KEY, vid); } catch (e) {}
        }
        window.tcaGetVid = function () { return vid; };
      })();
    </script>

    <!-- Beacon "ritorno sul sito": ad ogni pagina vista segnala l'ID
         visitatore persistente a n8n, così un lead già noto può essere
         riconosciuto anche senza ricompilare il form.
         Bloccato da CookieYes finché l'utente non accetta i cookie di analytics. -->
    <script is:inline type="text/plain" data-cookieyes="cookieyes-analytics">
      (function () {
        var WEBHOOK_VISIT = 'https://automazione.n8ndevelop.it/webhook/ping-tca';
        if (!WEBHOOK_VISIT) return;
        var utm = {};
        try { utm = JSON.parse(sessionStorage.getItem('tca_utm') || '{}'); } catch (e) {}
        var body = JSON.stringify({
          vid: window.tcaGetVid ? window.tcaGetVid() : null,
          pagina: location.pathname,
          referrer: document.referrer || null,
          utm: utm
        });
        if (navigator.sendBeacon) {
          navigator.sendBeacon(WEBHOOK_VISIT, new Blob([body], { type: 'application/json' }));
        } else {
          fetch(WEBHOOK_VISIT, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body, keepalive: true }).catch(function () {});
        }
      })();
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WRDQ2RTG"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    {!hideChrome && <Navbar lang={lang} />}
    <main class="site-main">
      <slot />
    </main>
    {!hideLeadFormInline && <LeadFormInline lang={lang} />}
    {!hideChrome && <InfoPratiche lang={lang} />}
    {!hideChrome && <AffiliazioniSlider lang={lang} />}
    {!hideChrome && <Footer lang={lang} />}
    <LeadModal lang={lang} />

    <!-- ── Back to top ── -->
    <button id="back-to-top" aria-label="Torna in cima" hidden>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2.2"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <style>
      #back-to-top {
        position: fixed;
        bottom: clamp(1.2rem, 3vh, 2rem);
        right: clamp(1rem, 3vw, 2rem);
        z-index: 900;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--color-accent);
        color: #fff;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px rgba(139,26,26,0.35);
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.25s, transform 0.25s, background 0.18s;
        pointer-events: none;
      }
      #back-to-top:not([hidden]) { pointer-events: auto; }
      #back-to-top.is-visible { opacity: 1; transform: translateY(0); }
      #back-to-top:hover { background: var(--color-accent-dark); }
    </style>

    <script>
      // ── Scroll animations ──────────────────────────────────────────────────

      // rootMargin '0px' — nessuna soglia negativa che esclude elementi
      // a bordo viewport; threshold 0.05 = scatta appena 5% è visibile.
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const delay = el.dataset.animDelay ? parseInt(el.dataset.animDelay, 10) : 0;
          setTimeout(() => el.classList.add('is-visible'), delay);
          obs.unobserve(el);
        });
      }, { threshold: 0.05, rootMargin: '0px' });

      function register(
        selector: string,
        type: string,
        baseDelay = 0,
        stagger = 0
      ) {
        document.querySelectorAll<HTMLElement>(selector).forEach((el, i) => {
          if (el.closest('.hero')) return;
          // Non sovrascrivere animazioni già definite nel markup
          if (!el.hasAttribute('data-anim')) el.setAttribute('data-anim', type);
          if (!el.dataset.animDelay && (baseDelay + stagger * i) > 0) {
            el.dataset.animDelay = String(baseDelay + stagger * i);
          }
          obs.observe(el);
        });
      }

      const NH = 'section:not(.hero)';

      // ── Titoli: wipe sinistra→destra ──
      // Escludi .panel__head h2 (AttivitaSplit: ha animazioni proprie sulle righe)
      register(`${NH} h2:not(.panel__title)`,  'reveal',     0,   0);
      register(`${NH} h3`,                     'reveal',    60,   0);

      // ── Eyebrow: slide da sinistra (escludi panel__head che è su sfondo scuro) ──
      register(`${NH} .eyebrow:not(.eyebrow--light)`, 'from-left', 0, 0);

      // ── Panel testa AttivitaSplit: solo fade (già su sfondo scuro, opacity è critica) ──
      register('.panel__head .eyebrow',        'fade',       0,   0);
      register('.panel__title',                'from-left', 60,   0);
      register('.panel__sub',                  'fade',     120,   0);

      // ── Testi / body copy ──
      register('.manifesto__body p',           'from-left', 120, 100);
      register('.manifesto__quote',            'reveal',    200,   0);
      register('.torneo__body',                'from-left', 100,   0);

      // ── Stats Torneo: scale-in in sequenza ──
      register('.torneo__stat',                'scale',     150,  90);

      // ── Pulsanti / CTA: accento "pop" con rimbalzo ──
      register(`${NH} .btn`,                   'pop',       140,  60);

      // ── Card / blocchi ──
      register('.conversion__card',            'true',        0, 120);
      register('.info__item',                  'true',        0,  80);
      register('.info__actions',               'true',      240,   0);
      // .reassurance__item rimosso — sezione why ha logica cycling propria
      register('.eventi-home__head',           'from-left',   0,   0);
      register('.event-item',                  'true',        0, 100);
      // NB: la mappa (.info__map) NON viene animata: applicare
      // transform/filter/will-change a un contenitore che avvolge un iframe
      // cross-origin (Google Maps) provoca un bug di compositing in Chromium
      // per cui l'iframe resta vuoto o non si carica. La mappa è quindi statica.

      // ── Card disciplina (tennis / padel / scuola / agonistica) ──
      register('.content-card',                'true',        0, 100);
      register('.age-card',                    'true',        0,  90);
      register('.step',                        'true',        0, 100);
      register('.feature',                     'true',        0,  90);
      register('.timeline__item',              'true',        0,  80);
      register('.stat-item',                   'scale',     100,  80);
      register('.stat',                        'scale',     100,  80);

      // ── Immagini e media ──
      register('.two-col__image',              'scale',      60,   0);
      register('.rounded-img',                 'scale',      60,   0);
      register('.gallery__img',                'scale',       0,  80);
      register('.camp-img',                    'scale',       0,  90);
      register('.sala-split__media',           'scale',      60,   0);

      // ── Testo body su pagine di disciplina ──
      register(`${NH} .body-text`,             'from-left',  80,   0);
      register(`${NH} .sala-body`,             'from-left',  80,   0);
      register(`${NH} .sala-feat`,             'from-left',  80,  60);
      register(`${NH} .cat-block__desc`,       'from-left',  80,   0);
      register(`${NH} .lfi__sub`,              'from-left',  80,   0);

      // ── Elementi già marcati nel markup ──
      document.querySelectorAll<HTMLElement>('[data-anim]').forEach((el) => {
        if (!el.classList.contains('is-visible')) obs.observe(el);
      });

      // ── Fallback 1: elementi già nel viewport al caricamento ──
      requestAnimationFrame(() => {
        const vh = window.innerHeight;
        document.querySelectorAll<HTMLElement>('[data-anim]').forEach((el) => {
          if (el.classList.contains('is-visible')) return;
          const rect = el.getBoundingClientRect();
          if (rect.top < vh + 60 && rect.bottom > 0) {
            const delay = el.dataset.animDelay ? parseInt(el.dataset.animDelay, 10) : 0;
            setTimeout(() => el.classList.add('is-visible'), delay);
          }
        });
      });

      // ── Failsafe solo se IntersectionObserver non è supportato ──
      // (browser molto vecchi): in tal caso rivela tutto, altrimenti
      // l'animazione resta legata allo scroll tramite l'observer.
      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll<HTMLElement>('[data-anim]').forEach((el) => {
          el.classList.add('is-visible');
        });
      }

      // ── Back to top ──────────────────────────────────────────────────
      const btt = document.getElementById('back-to-top') as HTMLButtonElement | null;
      if (btt) {
        const THRESHOLD = 400;
        const toggle = () => {
          const show = window.scrollY > THRESHOLD;
          if (show) { btt.hidden = false; requestAnimationFrame(() => btt.classList.add('is-visible')); }
          else       { btt.classList.remove('is-visible'); }
        };
        window.addEventListener('scroll', toggle, { passive: true });
        btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      }
    </script>
  </body>
</html>
