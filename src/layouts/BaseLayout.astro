---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import LeadModal from "../components/LeadModal.astro";
import { getLangFromUrl, useTranslations, getAlternatePath, getLocalePath, type Lang } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description, lang: langProp } = Astro.props;

const lang: Lang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const desc = description ?? t.meta.defaultDescription;

// Strip base URL (es. '/WebSite-TCA') per calcolare i path alternativi
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const rawPath = Astro.url.pathname;
const cleanPath = base && rawPath.startsWith(base)
  ? (rawPath.slice(base.length) || '/')
  : rawPath;

const { it: itClean } = getAlternatePath(cleanPath);
const siteOrigin = Astro.site?.origin ?? '';
const itHreflang = `${siteOrigin}${getLocalePath('it', itClean)}`;
const enHreflang = `${siteOrigin}${getLocalePath('en', itClean)}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={desc} />

    <!-- hreflang — SEO multilingua -->
    <link rel="alternate" hreflang="it"        href={itHreflang} />
    <link rel="alternate" hreflang="en"        href={enHreflang} />
    <link rel="alternate" hreflang="x-default" href={itHreflang} />

    <!-- Google Fonts: Barlow Condensed (display/titoli) + Barlow (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,600;1,300&family=Barlow+Condensed:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Navbar lang={lang} />
    <main class="site-main">
      <slot />
    </main>
    <Footer lang={lang} />
    <LeadModal />

    <script>
      // ── Scroll animations ──────────────────────────────────────────────────
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.dataset.animDelay ? parseInt(el.dataset.animDelay) : 0;
            setTimeout(() => el.classList.add('is-visible'), delay);
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

      // Auto-applica data-anim agli elementi chiave fuori dall'hero
      document.querySelectorAll<HTMLElement>(
        'section:not(.hero) .eyebrow, ' +
        'section:not(.hero) h2, ' +
        'section:not(.hero) h3, ' +
        '.manifesto__text, ' +
        '.manifesto__values, ' +
        '.panel__head, ' +
        '.torneo__content, ' +
        '.torneo__stats, ' +
        '.eventi-home__head, ' +
        '.conversion__card, ' +
        '.info__grid, ' +
        '.info__actions'
      ).forEach((el, i) => {
        if (!el.hasAttribute('data-anim')) {
          el.setAttribute('data-anim', 'true');
        }
        // stagger leggero tra elementi nello stesso parent
        const siblings = el.parentElement
          ? Array.from(el.parentElement.querySelectorAll('[data-anim]'))
          : [];
        const idx = siblings.indexOf(el);
        if (idx > 0 && !el.dataset.animDelay) {
          el.dataset.animDelay = String(idx * 80);
        }
        observer.observe(el);
      });

      // Osserva anche gli elementi con data-anim già presenti nel markup
      document.querySelectorAll<HTMLElement>('[data-anim]').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
