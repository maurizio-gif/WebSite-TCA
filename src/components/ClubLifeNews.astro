---
import { useTranslations, publicUrl, getLocalePath, type Lang } from '../i18n/utils';
import { getCollection } from 'astro:content';

interface Props { lang?: Lang; }
const { lang = 'it' } = Astro.props;
const t = useTranslations(lang);
const tx = (itVal: string, enVal?: string) => (lang === 'en' && enVal ? enVal : itVal);

// News gestibili da TinaCMS → src/content/news/ (una per file .md)
const MESI_IT = [
  'gennaio','febbraio','marzo','aprile','maggio','giugno',
  'luglio','agosto','settembre','ottobre','novembre','dicembre',
];
const MESI_EN = [
  'January','February','March','April','May','June',
  'July','August','September','October','November','December',
];
const formatData = (d: Date) =>
  lang === 'en'
    ? `${MESI_EN[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`
    : `${d.getDate()} ${MESI_IT[d.getMonth()]} ${d.getFullYear()}`;

const entries = (await getCollection('news', ({ data }) => data.pubblicato))
  .sort((a, b) => b.data.data.getTime() - a.data.data.getTime());

const newsArticles = await Promise.all(entries.map(async (entry) => {
  const { Content } = await entry.render();
  const d = entry.data;
  return {
    slug: entry.slug,
    categoria: tx(d.categoria, d.categoria_en),
    dataLabel: formatData(d.data),
    titolo: tx(d.titolo, d.titolo_en),
    sintesi: tx(d.sintesi, d.sintesi_en),
    img: publicUrl(d.immagine),
    imgAlt: tx(d.immagine_alt, d.immagine_alt_en),
    // CTA opzionale: pulsante nel popup, solo se il link è compilato.
    // I percorsi interni (es. /contatti) vengono localizzati per lingua.
    ctaHref: d.cta_href
      ? (d.cta_href.startsWith('/') ? getLocalePath(lang, d.cta_href) : d.cta_href)
      : null,
    ctaLabel: tx(d.cta_label ?? '', d.cta_label_en) || d.cta_label,
    ctaExternal: !!d.cta_href && !d.cta_href.startsWith('/'),
    Content,
    // In inglese il corpo è un campo testo: un paragrafo per riga vuota
    paragrafiEn: lang === 'en' && d.corpo_en
      ? d.corpo_en.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean)
      : null,
  };
}));
---

<section class="cl-news" id="news">
  <div class="cl-news__inner">
    <div class="cl-news__head">
      <div>
        <span class="eyebrow">{t.clubLife.newsEyebrow}</span>
        <h2 class="cl-news__title">{t.clubLife.newsTitle}</h2>
      </div>
      <div class="carousel-nav" aria-label={t.clubLife.newsTitle}>
        <button class="carousel-btn" type="button" data-dir="-1" data-track="cl-news" aria-label={t.attivita.prev}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="carousel-btn" type="button" data-dir="1" data-track="cl-news" aria-label={t.attivita.next}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <div class="cl-news-carousel">
      <div class="cl-news-carousel__track" data-carousel-id="cl-news">
        {newsArticles.map((art) => (
          <button class="cl-news-card" type="button" data-open-news={art.slug} aria-haspopup="dialog">
            <div class="cl-news-card__img" style={`background-image:url('${art.img}')`}></div>
            <div class="cl-news-card__body">
              <div class="cl-news-card__meta">
                <span class="cl-news-card__cat">{art.categoria}</span>
                <span class="cl-news-card__date">{art.dataLabel}</span>
              </div>
              <h3 class="cl-news-card__title">{art.titolo}</h3>
              <p class="cl-news-card__desc">{art.sintesi}</p>
              <span class="cl-news-card__link">{t.clubLife.newsReadMore} <span aria-hidden="true">→</span></span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Modali articolo (uno per news) -->
{newsArticles.map((art) => (
  <dialog id={`news-${art.slug}`} class="cl-news-modal" aria-labelledby={`news-title-${art.slug}`}>
    <div class="cl-news-modal__panel">
      <div class="cl-news-modal__img" style={`background-image:url('${art.img}')`}></div>
      <div class="cl-news-modal__body">
        <button class="cl-news-modal__close" data-news-close aria-label={t.clubLife.newsClose}>✕</button>
        <div class="cl-news-modal__meta">
          <span class="cl-news-card__cat">{art.categoria}</span>
          <span class="cl-news-card__date">{art.dataLabel}</span>
        </div>
        <h2 class="cl-news-modal__title" id={`news-title-${art.slug}`}>{art.titolo}</h2>
        <div class="cl-news-modal__prose">
          {art.paragrafiEn
            ? art.paragrafiEn.map((par) => <p>{par}</p>)
            : <art.Content />}
        </div>
        {art.ctaHref && art.ctaLabel && (
          <div class="cl-news-modal__actions">
            <a
              class="btn btn-red"
              href={art.ctaHref}
              target={art.ctaExternal ? '_blank' : undefined}
              rel={art.ctaExternal ? 'noopener noreferrer' : undefined}
            >{art.ctaLabel}</a>
          </div>
        )}
      </div>
    </div>
  </dialog>
))}

<style>
  .cl-news {
    padding: 7vh var(--pad-x);
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }

  .cl-news__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .cl-news__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 4vh;
  }

  .cl-news__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-top: 0.4rem;
  }

  /* ── Carousel nav arrows (stesso pattern di AttivitaSplit) ── */
  .carousel-nav {
    display: flex;
    gap: 8px;
    align-items: center;
    padding-bottom: 2px;
    flex-shrink: 0;
  }

  .carousel-btn {
    width: 38px;
    height: 38px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background: transparent;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
  }

  .carousel-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* ── Carousel ── */
  .cl-news-carousel {
    margin: 0 calc(var(--pad-x) * -1);
    overflow: hidden;
  }

  .cl-news-carousel__track {
    display: flex;
    gap: 1.25rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.5rem var(--pad-x) 1.5rem;
    scroll-padding-left: var(--pad-x);
  }

  .cl-news-carousel__track::-webkit-scrollbar { display: none; }

  .cl-news-card {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    text-align: left;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    font: inherit;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .cl-news-card:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .cl-news-card__img {
    width: 100%;
    aspect-ratio: 4/3;
    background-size: cover;
    background-position: center;
  }

  .cl-news-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .cl-news-card__meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .cl-news-card__cat {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .cl-news-card__date {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 300;
    color: var(--color-text-light);
  }

  .cl-news-card__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    line-height: 1.15;
    color: var(--color-text);
  }

  .cl-news-card__desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-light);
    flex: 1;
  }

  .cl-news-card__link {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  @media (max-width: 860px) {
    .cl-news-card { flex: 0 0 calc((100% - 1.25rem) / 2); }
  }

  @media (max-width: 640px) {
    .cl-news-card { flex: 0 0 78vw; }
  }

  /* ── Modal ── */
  .cl-news-modal {
    border: none;
    padding: 0;
    background: transparent;
    max-width: min(95vw, 720px);
    width: 100%;
    margin: auto;
    max-height: 92vh;
  }

  .cl-news-modal::backdrop {
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(7px);
  }

  .cl-news-modal__panel {
    background: #ffffff;
    color: var(--color-text);
    max-height: 92vh;
    overflow-y: auto;
  }

  .cl-news-modal__img {
    width: 100%;
    aspect-ratio: 16/7;
    background-size: cover;
    background-position: center;
  }

  .cl-news-modal__body {
    position: relative;
    padding: 2rem;
  }

  .cl-news-modal__close {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    background: #fff;
    border: 1px solid var(--color-border);
    color: rgba(26, 26, 26, 0.45);
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .cl-news-modal__close:hover { border-color: var(--color-text); color: var(--color-text); }

  .cl-news-modal__meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.8rem;
  }

  .cl-news-modal__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 1.4rem;
  }

  .cl-news-modal__prose {
    font-family: var(--font-body);
    font-size: clamp(16px, 1vw, 18px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .cl-news-modal__actions {
    margin-top: 1.5rem;
  }

  .cl-news-modal__prose :global(p) { margin-bottom: 1em; }

  @media (max-width: 640px) {
    .cl-news-modal__body { padding: 1.5rem; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.carousel-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const dir = Number(btn.dataset.dir);
      const trackId = btn.dataset.track;
      const track = document.querySelector<HTMLElement>(`[data-carousel-id="${trackId}"]`);
      if (!track) return;
      const card = track.querySelector<HTMLElement>('.cl-news-card');
      if (!card) return;
      const cardWidth = card.offsetWidth + 20; // 20px = gap (1.25rem)
      track.scrollBy({ left: dir * cardWidth, behavior: 'smooth' });
    });
  });

  document.querySelectorAll<HTMLElement>('[data-open-news]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.openNews;
      const dialog = document.getElementById(`news-${slug}`) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  document.addEventListener('click', (e) => {
    const closeBtn = (e.target as Element).closest('[data-news-close]');
    if (closeBtn) (closeBtn.closest('dialog') as HTMLDialogElement | null)?.close();
  });

  document.querySelectorAll<HTMLDialogElement>('.cl-news-modal').forEach((dialog) => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>
