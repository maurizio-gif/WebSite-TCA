---
import { getEntry } from 'astro:content';
import { publicUrl, type Lang } from '../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'it' } = Astro.props;

type Cat = 'S' | 'B' | 'E';
interface Lesson { t: string; c: Cat; n: string; desc: string; durata: string; livello: string; img: string; }

const CAT: Record<Cat, { label: string }> = {
  S: { label: 'Strength'  },
  B: { label: 'Balance'   },
  E: { label: 'Endurance' },
};

// Lezioni gestibili da TinaCMS → src/content/planning/corsi.md
const { lezioni } = (await getEntry('planning', 'corsi'))!.data;

// Descrizione, durata, livello e foto di ogni corso: unica fonte editabile
// da TinaCMS → src/content/pagine/preparazione-atletica.md (prep_categorie,
// stessa immagine mostrata nella card del corso). Il planning qui sopra fa
// solo riferimento al nome del corso: qualunque modifica al testo o alla
// foto in quella pagina si riflette automaticamente nel modal, senza
// doverla duplicare altrove.
const prep = (await getEntry('pagine', 'preparazione-atletica'))!.data;
const courseInfo = new Map<string, { nome: string; desc: string; durata: string; livello: string; img: string }>();
(prep.prep_categorie ?? []).forEach((cat) => {
  (cat.corsi ?? []).forEach((corso) => {
    courseInfo.set(corso.nome, {
      nome: (lang === 'en' && corso.nome_en) ? corso.nome_en : corso.nome,
      desc: (lang === 'en' && corso.desc_en) ? corso.desc_en : corso.desc,
      durata: corso.durata,
      livello: (lang === 'en' && corso.livello_en) ? corso.livello_en : corso.livello,
      img: corso.immagine ? publicUrl(corso.immagine) : '',
    });
  });
});

const NO_DESC = lang === 'en'
  ? 'Description coming soon — ask our staff for details.'
  : 'Descrizione in arrivo — chiedi pure allo staff per i dettagli.';

const t = lang === 'en' ? {
  restDay: 'Rest day',
  note1: 'Indicative schedule, subject to weekly changes.',
  note2: 'Book your spot on our web portal',
  downloadApple: 'Download on the', appStore: 'App Store',
  downloadAndroid: 'Get it on', playStore: 'Google Play',
  close: 'Close',
} : {
  restDay: 'Giornata di riposo',
  note1: 'Planning indicativo, soggetto a variazioni settimanali.',
  note2: 'Prenota il tuo posto sul nostro portale web',
  downloadApple: 'Scarica su', appStore: 'App Store',
  downloadAndroid: 'Disponibile su', playStore: 'Google Play',
  close: 'Chiudi',
};

const GIORNI = [
  { id: 'lun', full: 'Lunedì',    short: 'LUN' },
  { id: 'mar', full: 'Martedì',   short: 'MAR' },
  { id: 'mer', full: 'Mercoledì', short: 'MER' },
  { id: 'gio', full: 'Giovedì',   short: 'GIO' },
  { id: 'ven', full: 'Venerdì',   short: 'VEN' },
  { id: 'sab', full: 'Sabato',    short: 'SAB' },
  { id: 'dom', full: 'Domenica',  short: 'DOM' },
] as const;

const DAYS: Array<{ full: string; short: string; lessons: Lesson[] }> = GIORNI.map((g) => ({
  full: g.full,
  short: g.short,
  lessons: lezioni
    .filter((l) => l.giorno === g.id)
    .sort((a, b) => a.ora.localeCompare(b.ora))
    .map((l) => {
      const info = courseInfo.get(l.nome);
      return {
        t: l.ora,
        c: l.categoria,
        n: info?.nome ?? l.nome,
        desc: info?.desc ?? '',
        durata: info?.durata ?? '',
        livello: info?.livello ?? '',
        img: info?.img ?? '',
      };
    }),
}));

const PG_URL      = 'https://tcambrosiano.perfectgym.com/clientportal2/?lang=it#/Classes/1/Calendar';
const APPLE_URL   = 'https://apps.apple.com/it/app/club-ambrosiano/id1583896957';
const ANDROID_URL = 'https://play.google.com/store/apps/details?id=com.perfectgym.perfectgymgo2.ambrosiano';
---

<div class="ws">
  <!-- Legenda categorie -->
  <div class="ws__legend">
    <span class="ws__leg ws__leg--s">Strength</span>
    <span class="ws__leg ws__leg--b">Balance</span>
    <span class="ws__leg ws__leg--e">Endurance</span>
  </div>

  <div class="ws__scroll-wrap">
    <div class="ws__grid">
      {DAYS.map(day => (
        <div class="ws__col">
          <!-- Intestazione giorno -->
          <div class="ws__day-head">
            <span class="ws__day-abbr">{day.short}</span>
            <span class="ws__day-name">{day.full}</span>
          </div>

          <!-- Lista corsi -->
          <div class="ws__cards">
            {day.lessons.length === 0
              ? <div class="ws__rest">{t.restDay}</div>
              : day.lessons.map(l => (
                  <button
                    type="button"
                    class={`ws__card ws__card--${l.c.toLowerCase()}`}
                    data-open-lesson
                    data-name={l.n}
                    data-cat={CAT[l.c].label}
                    data-time={l.t}
                    data-day={day.full}
                    data-durata={l.durata}
                    data-livello={l.livello}
                    data-desc={l.desc}
                    data-img={l.img}
                  >
                    <span class="ws__card-time">{l.t}</span>
                    <span class="ws__card-body">
                      <span class="ws__card-cat">{CAT[l.c].label}</span>
                      <span class="ws__card-name">{l.n}</span>
                    </span>
                  </button>
                ))
            }
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- CTA footer -->
  <div class="ws__footer">
    <p class="ws__cta-note">
      {t.note1} &nbsp;
      <a class="ws__cta-link" href={PG_URL} target="_blank" rel="noopener noreferrer">
        {t.note2}
        <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 13L13 1M13 1H5M13 1V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </p>

    <div class="ws__badges">
      <!-- Apple App Store -->
      <a class="ws__badge" href={APPLE_URL} target="_blank" rel="noopener noreferrer" aria-label={`${t.downloadApple} ${t.appStore}`}>
        <svg class="ws__badge-logo" viewBox="0 0 814 1000" fill="currentColor" aria-hidden="true">
          <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-42.3-148.2-105.3c-47.1-67.5-89.1-172.8-89.1-278s56.2-198.3 148.2-261.8c60.9-42.2 128.3-65.5 203.7-65.5 73 0 130.3 30.7 175.7 60.7 45.4 30 62.4 61.1 64.2 63.4zM590.6 98.5c21.5-25.3 36.7-60.6 36.7-95.9 0-4.9-.3-9.9-1-14.8-34.8 1.3-76 23.3-100.8 52.3-19.8 22.8-37.3 57.8-37.3 93.1 0 5.1.8 10.3 1.2 11.9 2.3.4 6.1.8 9.9.8 31.2 0 70-21 92.3-47.4z"/>
        </svg>
        <span class="ws__badge-text">
          <span class="ws__badge-small">{t.downloadApple}</span>
          <span class="ws__badge-big">{t.appStore}</span>
        </span>
      </a>

      <!-- Google Play -->
      <a class="ws__badge" href={ANDROID_URL} target="_blank" rel="noopener noreferrer" aria-label={`${t.downloadAndroid} ${t.playStore}`}>
        <svg class="ws__badge-logo ws__badge-logo--play" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3.18 23.76c.34.19.72.24 1.1.14l12.02-12.02L12.63 8.2 3.18 23.76z" fill="#EA4335"/>
          <path d="M22.49 10.56L19.04 8.6l-3.8 3.8 3.8 3.8 3.47-2c1-.57 1-.2 1-3.32-.01-.53-.02-1.74-1.02-2.32z" fill="#FBBC05"/>
          <path d="M4.28.1a2.03 2.03 0 0 0-.1.68v22.44c0 .24.04.46.1.68L16.32 11.9 4.28.1z" fill="#4285F4"/>
          <path d="M16.32 11.9 4.28 23.9c.3.17.65.1.98-.08l12.02-7.22-1-4.7z" fill="#34A853"/>
        </svg>
        <span class="ws__badge-text">
          <span class="ws__badge-small">{t.downloadAndroid}</span>
          <span class="ws__badge-big">{t.playStore}</span>
        </span>
      </a>
    </div>
  </div>

  <!-- Modal descrizione lezione -->
  <dialog class="ws-modal" id="ws-lesson-modal" aria-labelledby="ws-modal-title" data-no-desc={NO_DESC}>
    <div class="ws-modal__panel">
      <div class="ws-modal__media" id="ws-modal-media" hidden>
        <img class="ws-modal__img" id="ws-modal-img" alt="" loading="lazy" />
      </div>
      <div class="ws-modal__body">
        <div class="ws-modal__head">
          <div>
            <span class="ws-modal__cat" id="ws-modal-cat"></span>
            <p class="ws-modal__title" id="ws-modal-title" role="heading" aria-level="3"></p>
          </div>
          <button type="button" class="ws-modal__close" data-close-lesson aria-label={t.close}>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
        <div class="ws-modal__meta" id="ws-modal-meta"></div>
        <p class="ws-modal__desc" id="ws-modal-desc"></p>
      </div>
    </div>
  </dialog>
</div>

<style>
  /* ── Wrapper ── */
  .ws {
    margin-top: 3rem;
  }

  /* ── Legenda ── */
  .ws__legend {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .ws__leg {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ws__leg::before {
    content: '';
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .ws__leg--s { color: #1A1A1A; }
  .ws__leg--s::before { background: #1A1A1A; }
  .ws__leg--b { color: #1E4D3A; }
  .ws__leg--b::before { background: #1E4D3A; }
  .ws__leg--e { color: #B83A00; }
  .ws__leg--e::before { background: #B83A00; }

  /* ── Scroll wrapper ── */
  .ws__scroll-wrap {
    overflow-x: auto;
    scrollbar-width: none;
    margin: 0 calc(-1 * var(--pad-x));
    padding: 0 var(--pad-x) 2px;
  }

  .ws__scroll-wrap::-webkit-scrollbar { display: none; }

  /* ── Grid 7 colonne ── */
  .ws__grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(148px, 1fr));
    min-width: 900px;
    border: 1px solid var(--color-border);
  }

  /* ── Colonna giorno ── */
  .ws__col {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--color-border);
    background: #fff;
  }

  .ws__col:last-child { border-right: none; }

  /* ── Intestazione giorno ── */
  .ws__day-head {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 10px 10px 8px;
    border-bottom: 2px solid var(--color-border);
    background: var(--color-off-white);
  }

  .ws__day-abbr {
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  .ws__day-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text);
    line-height: 1;
  }

  /* ── Lista cards ── */
  .ws__cards {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* ── Singola card corso ── */
  .ws__card {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    width: 100%;
    padding: 7px 8px 7px 11px;
    border: none;
    border-bottom: 1px solid var(--color-border);
    background: none;
    text-align: left;
    text-decoration: none;
    font: inherit;
    color: inherit;
    position: relative;
    transition: background 0.12s;
    cursor: pointer;
  }

  .ws__card:last-child { border-bottom: none; }
  .ws__card:hover, .ws__card:focus-visible { background: var(--color-off-white); }
  .ws__card:focus-visible { outline: 2px solid var(--color-accent); outline-offset: -2px; }

  /* Linea colorata sinistra */
  .ws__card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
  }

  .ws__card--s::before { background: #1A1A1A; }
  .ws__card--b::before { background: #1E4D3A; }
  .ws__card--e::before { background: #B83A00; }

  /* Orario */
  .ws__card-time {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-light);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 1px;
    min-width: 34px;
  }

  .ws__card-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .ws__card-cat {
    font-family: var(--font-display);
    font-size: 8.5px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ws__card--s .ws__card-cat { color: #1A1A1A; }
  .ws__card--b .ws__card-cat { color: #1E4D3A; }
  .ws__card--e .ws__card-cat { color: #B83A00; }

  .ws__card-name {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Giorno vuoto ── */
  .ws__rest {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 0.75rem;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 300;
    color: var(--color-text-light);
    font-style: italic;
    text-align: center;
  }

  /* ── Nota / CTA footer ── */
  .ws__cta-note {
    margin-top: 1.25rem;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .ws__cta-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 400;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .ws__cta-link:hover { text-decoration: underline; }

  /* ── Store badges ── */
  .ws__footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .ws__badges {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .ws__badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #000;
    color: #fff;
    border-radius: 8px;
    padding: 9px 16px;
    text-decoration: none;
    min-width: 150px;
    transition: opacity 0.18s;
    border: 1.5px solid rgba(255,255,255,0.12);
  }

  .ws__badge:hover { opacity: 0.85; }

  .ws__badge-logo {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    fill: #fff;
  }

  .ws__badge-logo--play {
    fill: none;
  }

  .ws__badge-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .ws__badge-small {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.75);
    line-height: 1;
  }

  .ws__badge-big {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #fff;
    line-height: 1.15;
  }

  /* ── Mobile: nascondi giorno-full, abbr già visibile ── */
  @media (max-width: 600px) {
    .ws__day-name { font-size: 12px; }
    .ws__card-time { font-size: 10px; min-width: 28px; }
    .ws__card-name { font-size: 11px; }
  }

  /* ══════════════════════════════════════════════════════════════
     MODAL DESCRIZIONE LEZIONE
  ══════════════════════════════════════════════════════════════ */
  .ws-modal {
    border: none;
    padding: 0;
    background: transparent;
    max-width: min(94vw, 480px);
    width: 100%;
    margin: auto;
  }

  .ws-modal::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .ws-modal__panel {
    background: var(--color-bg);
    color: var(--color-text);
    overflow: hidden;
  }

  .ws-modal__media {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-off-white);
  }

  .ws-modal__media[hidden] { display: none; }

  .ws-modal__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ws-modal__body {
    padding: 1.75rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .ws-modal__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .ws-modal__cat {
    display: block;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .ws-modal__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
    margin: 0;
  }

  .ws-modal__close {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-light);
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
    transition: border-color 0.18s, color 0.18s;
    padding: 0;
  }

  .ws-modal__close:hover { border-color: var(--color-accent); color: var(--color-accent); }

  .ws-modal__meta {
    display: flex;
    gap: 1.5rem;
    padding: 0.9rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  .ws-modal__meta span strong { color: var(--color-text); font-weight: 800; }

  .ws-modal__desc {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.05vw, 16px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    margin: 0;
  }

  .ws-modal[hidden] { display: none; }
</style>

<script>
  (function () {
    const modal = document.getElementById('ws-lesson-modal') as HTMLDialogElement | null;
    if (!modal) return;

    const catEl  = document.getElementById('ws-modal-cat');
    const titleEl = document.getElementById('ws-modal-title');
    const metaEl = document.getElementById('ws-modal-meta');
    const descEl = document.getElementById('ws-modal-desc');
    const mediaEl = document.getElementById('ws-modal-media') as HTMLElement | null;
    const imgEl = document.getElementById('ws-modal-img') as HTMLImageElement | null;
    const NO_DESC = modal.dataset.noDesc ?? '';

    document.querySelectorAll<HTMLButtonElement>('[data-open-lesson]').forEach((card) => {
      card.addEventListener('click', () => {
        const d = card.dataset;
        if (catEl) catEl.textContent = `${d.cat} · ${d.day} ${d.time}`;
        if (titleEl) titleEl.textContent = d.name ?? '';

        if (metaEl) {
          const parts: string[] = [];
          if (d.durata) parts.push(`<span><strong>${d.durata}</strong></span>`);
          if (d.livello) parts.push(`<span><strong>${d.livello}</strong></span>`);
          metaEl.innerHTML = parts.join('');
          metaEl.style.display = parts.length === 0 ? 'none' : 'flex';
        }

        if (descEl) descEl.textContent = d.desc && d.desc.trim() ? d.desc : NO_DESC;

        if (mediaEl && imgEl) {
          if (d.img && d.img.trim()) {
            imgEl.src = d.img;
            imgEl.alt = d.name ?? '';
            mediaEl.hidden = false;
          } else {
            imgEl.src = '';
            mediaEl.hidden = true;
          }
        }

        modal.showModal();
      });
    });

    modal.querySelector('[data-close-lesson]')?.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
  })();
</script>
