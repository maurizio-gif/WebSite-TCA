<style>
  /* ── Wrapper ── */
  .ws {
    margin-top: 3rem;
  }

  /* ── Legenda ── */
  .ws__legend {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .ws__leg {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ws__leg::before {
    content: '';
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .ws__leg--s { color: #1A1A1A; }
  .ws__leg--s::before { background: #1A1A1A; }
  .ws__leg--b { color: #1E4D3A; }
  .ws__leg--b::before { background: #1E4D3A; }
  .ws__leg--e { color: #B83A00; }
  .ws__leg--e::before { background: #B83A00; }

  /* ── Scroll wrapper ── */
  .ws__scroll-wrap {
    overflow-x: auto;
    scrollbar-width: none;
    margin: 0 calc(-1 * var(--pad-x));
    padding: 0 var(--pad-x) 2px;
  }

  .ws__scroll-wrap::-webkit-scrollbar { display: none; }

  /* ── Grid 7 colonne ── */
  .ws__grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(148px, 1fr));
    min-width: 900px;
    border: 1px solid var(--color-border);
  }

  /* ── Colonna giorno ── */
  .ws__col {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--color-border);
    background: #fff;
  }

  .ws__col:last-child { border-right: none; }

  /* ── Intestazione giorno ── */
  .ws__day-head {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 10px 10px 8px;
    border-bottom: 2px solid var(--color-border);
    background: var(--color-off-white);
  }

  .ws__day-abbr {
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  .ws__day-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text);
    line-height: 1;
  }

  /* ── Lista cards ── */
  .ws__cards {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* ── Singola card corso ── */
  .ws__card {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    padding: 7px 8px 7px 11px;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: background 0.12s;
    cursor: pointer;
  }

  .ws__card:last-child { border-bottom: none; }
  .ws__card:hover { background: var(--color-off-white); }

  /* Linea colorata sinistra */
  .ws__card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
  }

  .ws__card--s::before { background: #1A1A1A; }
  .ws__card--b::before { background: #1E4D3A; }
  .ws__card--e::before { background: #B83A00; }

  /* Orario */
  .ws__card-time {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-light);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 1px;
    min-width: 34px;
  }

  .ws__card-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .ws__card-cat {
    font-family: var(--font-display);
    font-size: 8.5px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ws__card--s .ws__card-cat { color: #1A1A1A; }
  .ws__card--b .ws__card-cat { color: #1E4D3A; }
  .ws__card--e .ws__card-cat { color: #B83A00; }

  .ws__card-name {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Giorno vuoto ── */
  .ws__rest {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 0.75rem;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 300;
    color: var(--color-text-light);
    font-style: italic;
    text-align: center;
  }

  /* ── Nota / CTA footer ── */
  .ws__cta-note {
    margin-top: 1.25rem;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .ws__cta-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 400;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .ws__cta-link:hover { text-decoration: underline; }

  /* ── Store badges ── */
  .ws__footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .ws__badges {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .ws__badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #000;
    color: #fff;
    border-radius: 8px;
    padding: 9px 16px;
    text-decoration: none;
    min-width: 150px;
    transition: opacity 0.18s;
    border: 1.5px solid rgba(255,255,255,0.12);
  }

  .ws__badge:hover { opacity: 0.85; }

  .ws__badge-logo {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    fill: #fff;
  }

  .ws__badge-logo--play {
    fill: none;
  }

  .ws__badge-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .ws__badge-small {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.75);
    line-height: 1;
  }

  .ws__badge-big {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #fff;
    line-height: 1.15;
  }

  /* ── Mobile: nascondi giorno-full, abbr già visibile ── */
  @media (max-width: 600px) {
    .ws__day-name { font-size: 12px; }
    .ws__card-time { font-size: 10px; min-width: 28px; }
    .ws__card-name { font-size: 11px; }
  }
</style>
