---

<div class="isc-form" id="isc-form-root">

  <!-- STEP 1 — Dati minore + genitore -->
  <div class="lm__body" data-isc-step="1">
    <div class="lm__notice">
      <p set:html={t.intro} />
      <p>{t.introTrials}</p>
      <p>{t.introStart}</p>
    </div>

    <p class="lm__section-title lm__section-title--first">{t.minorTitle}</p>
    <p class="lm__sub">{t.minorSub}</p>

    <div class="lm__grid">
      <div class="lm__field">
        <label for="isc-minor-nome">{t.minorFirst} <span aria-hidden="true">*</span></label>
        <input id="isc-minor-nome" type="text" required />
      </div>
      <div class="lm__field">
        <label for="isc-minor-cognome">{t.minorLast} <span aria-hidden="true">*</span></label>
        <input id="isc-minor-cognome" type="text" required />
      </div>
      <div class="lm__field">
        <label for="isc-minor-dob">{t.minorDob} <span aria-hidden="true">*</span></label>
        <input id="isc-minor-dob" type="date" required />
      </div>
      <div class="lm__field">
        <label for="isc-minor-pob">{t.minorPob} <span aria-hidden="true">*</span></label>
        <input id="isc-minor-pob" type="text" required />
      </div>
      <div class="lm__field lm__field--full">
        <label for="isc-minor-cf">{t.minorCf} <span aria-hidden="true">*</span></label>
        <input id="isc-minor-cf" type="text" maxlength="16" class="lm__input--cf" required />
      </div>
    </div>
    <p class="lm__hint">{t.minorCfNote}</p>

    <div class="lm__grid">
      <div class="lm__field lm__field--full">
        <label for="isc-addr">{t.addr} <span aria-hidden="true">*</span></label>
        <input id="isc-addr" type="text" placeholder={t.addrPh} required />
      </div>
      <div class="lm__field">
        <label for="isc-city">{t.city} <span aria-hidden="true">*</span></label>
        <input id="isc-city" type="text" placeholder={t.cityPh} required />
      </div>
      <div class="lm__field">
        <label for="isc-prov">{t.prov} <span aria-hidden="true">*</span></label>
        <input id="isc-prov" type="text" maxlength="2" placeholder={t.provPh} required />
      </div>
      <div class="lm__field lm__field--full">
        <label for="isc-cap">{t.cap} <span aria-hidden="true">*</span></label>
        <input id="isc-cap" type="text" inputmode="numeric" required />
      </div>
    </div>

    <p class="lm__section-title">{t.parentTitle}</p>
    <div class="lm__grid">
      <div class="lm__field">
        <label for="isc-parent-nome">{t.parentFirst} <span aria-hidden="true">*</span></label>
        <input id="isc-parent-nome" type="text" autocomplete="given-name" required />
      </div>
      <div class="lm__field">
        <label for="isc-parent-cognome">{t.parentLast} <span aria-hidden="true">*</span></label>
        <input id="isc-parent-cognome" type="text" autocomplete="family-name" required />
      </div>
      <div class="lm__field lm__field--full">
        <label for="isc-email">{t.email} <span aria-hidden="true">*</span></label>
        <input id="isc-email" type="email" autocomplete="email" placeholder="nome@esempio.com" required />
      </div>
    </div>
    <p class="lm__hint">{t.emailNote}</p>
    <div class="lm__grid">
      <div class="lm__field lm__field--full">
        <label for="isc-cell">{t.mobile} <span aria-hidden="true">*</span></label>
        <input id="isc-cell" type="tel" autocomplete="tel" placeholder="3XX XXX XXXX" required />
      </div>
    </div>

    <p class="lm__error" hidden role="alert"></p>
    <div class="lm__actions">
      <button type="button" class="btn btn-red lm__next" data-isc-next="1">
        {t.next} <span class="lm__arrow" aria-hidden="true">→</span>
      </button>
    </div>
  </div>

  <!-- STEP 2 — Dettagli iscrizione -->
  <div class="lm__body" data-isc-step="2" hidden>
    <p class="lm__section-title lm__section-title--first">{t.detailsTitle}</p>
    <div class="lm__notice">
      <p><strong>{t.miniLabel}</strong> {t.miniAge}<br />{t.miniDesc}</p>
      <p><strong>{t.tennisLabel}</strong> {t.tennisAge}<br />{t.tennisDesc}</p>
    </div>
    <p class="lm__notice-warn">{t.warnSaldo}</p>
    <p class="lm__notice-warn">{t.warnFitp}</p>

    <div class="lm__field">
      <label for="isc-tipo">{t.courseType} <span aria-hidden="true">*</span></label>
      <select id="isc-tipo" required>
        <option value="" selected disabled>{t.courseTypePh}</option>
        <option value="mini">{t.miniLabel}</option>
        <option value="tennis">{t.tennisLabel}</option>
      </select>
    </div>

    <div data-isc-tipo-group="mini" hidden>
      <p class="lm__label-group">{t.frequency} <span aria-hidden="true">*</span></p>
      <div class="lm__checks">
        <label class="lm__check-item"><input type="radio" name="isc-freq-mini" value="mono" /> <span>{t.miniMono}</span></label>
        <label class="lm__check-item"><input type="radio" name="isc-freq-mini" value="bi" /> <span>{t.miniBi}</span></label>
      </div>
      <p class="lm__label-group">{t.days} <span aria-hidden="true">*</span></p>
      <div class="lm__checks">
        {t.dayNames.map((d) => (
          <label class="lm__check-item"><input type="checkbox" name="isc-giorni-mini" value={d} /> <span>{d} 17.30</span></label>
        ))}
      </div>
    </div>

    <div data-isc-tipo-group="tennis" hidden>
      <p class="lm__label-group">{t.frequency} <span aria-hidden="true">*</span></p>
      <div class="lm__checks">
        <label class="lm__check-item"><input type="radio" name="isc-freq-tennis" value="mono" /> <span>{t.tennisMono}</span></label>
        <label class="lm__check-item"><input type="radio" name="isc-freq-tennis" value="bi" /> <span>{t.tennisBi}</span></label>
        <label class="lm__check-item"><input type="radio" name="isc-freq-tennis" value="tri" /> <span>{t.tennisTri}</span></label>
      </div>
      <p class="lm__label-group">{t.days} <span aria-hidden="true">*</span></p>
      <div class="lm__checks">
        {t.dayNames.map((d) => (
          <label class="lm__check-item"><input type="checkbox" name="isc-giorni-tennis" value={d} /> <span>{d}</span></label>
        ))}
      </div>
      <p class="lm__label-group">{t.timePrefs} <span aria-hidden="true">*</span></p>
      <div class="lm__checks">
        {PREP_SLOTS.map((s) => (
          <label class="lm__check-item"><input type="checkbox" name="isc-orari-tennis" value={s} /> <span>{s.replace(':', '.')}</span></label>
        ))}
      </div>
    </div>

    <div class="lm__field">
      <label for="isc-buddy">{t.buddy}</label>
      <input id="isc-buddy" type="text" />
    </div>

    <p class="lm__section-title">{t.athleticTitle}</p>
    <div data-isc-tipo-group="tennis" hidden>
      <div class="lm__field">
        <label for="isc-prep-orario">{t.athleticSlot} <span aria-hidden="true">*</span></label>
        <select id="isc-prep-orario">
          <option value="" selected disabled>{t.athleticSlotPh}</option>
          {PREP_SLOTS.map((s) => <option value={s}>{s}</option>)}
        </select>
      </div>
      <div class="lm__table-wrap">
        <table class="lm__table">
          <thead><tr><th>{t.athleticTablePick}</th><th>{t.athleticTableTime}</th></tr></thead>
          <tbody>
            {t.athleticRows.map((r) => <tr><td>{r[0]}</td><td>{r[1]}</td></tr>)}
          </tbody>
        </table>
      </div>
    </div>
    <p class="lm__hint" data-isc-tipo-group="mini" hidden>{t.athleticNote}</p>

    <p class="lm__error" hidden role="alert"></p>
    <div class="lm__actions">
      <button type="button" class="lm__back" data-isc-back="1">{t.back}</button>
      <button type="button" class="btn btn-red lm__next" data-isc-next="2">
        {t.next} <span class="lm__arrow" aria-hidden="true">→</span>
      </button>
    </div>
  </div>

  <!-- STEP 3 — Taglie kit (solo Scuola Tennis) -->
  <div class="lm__body" data-isc-step="3" hidden>
    <p class="lm__section-title lm__section-title--first">{t.kitTitle}</p>
    <p class="lm__sub">{t.kitIntro}</p>
    <p class="lm__sub" set:html={t.kitGuide.replace('{link}', `<a href="https://www.joma-sport.com/on/demandware.store/Sites-joma_it-Site/it_IT/Page-SizeGuide" target="_blank" rel="noopener">${t.kitGuideLink}</a>`)} />

    <div class="lm__field">
      <label for="isc-size-shirt">{t.sizeShirt} <span aria-hidden="true">*</span></label>
      <select id="isc-size-shirt" required>
        <option value="" selected disabled>{t.sizePh}</option>
        {SIZES.map((s) => <option value={s}>{s}</option>)}
      </select>
    </div>
    <div class="lm__field">
      <label for="isc-size-shorts">{t.sizeShorts} <span aria-hidden="true">*</span></label>
      <select id="isc-size-shorts" required>
        <option value="" selected disabled>{t.sizePh}</option>
        {SIZES.map((s) => <option value={s}>{s}</option>)}
      </select>
    </div>
    <div class="lm__field">
      <label for="isc-size-hoodie">{t.sizeHoodie} <span aria-hidden="true">*</span></label>
      <select id="isc-size-hoodie" required>
        <option value="" selected disabled>{t.sizePh}</option>
        {SIZES.map((s) => <option value={s}>{s}</option>)}
      </select>
    </div>

    <p class="lm__error" hidden role="alert"></p>
    <div class="lm__actions">
      <button type="button" class="lm__back" data-isc-back="2">{t.back}</button>
      <button type="button" class="btn btn-red lm__next" data-isc-next="3">
        {t.next} <span class="lm__arrow" aria-hidden="true">→</span>
      </button>
    </div>
  </div>

  <!-- STEP 4 — Termini e condizioni -->
  <div class="lm__body" data-isc-step="4" hidden>
    <p class="lm__section-title lm__section-title--first">{t.termsTitle}</p>
    <ul class="lm__terms-list">
      {t.termsList.map((item) => <li>{item}</li>)}
    </ul>

    <div class="lm__consent">
      <label class="lm__consent-item">
        <input type="checkbox" id="isc-accept-terms" required />
        <span>{t.acceptTerms}</span>
      </label>
      <label class="lm__consent-item">
        <input type="checkbox" id="isc-accept-rules" required />
        <span set:html={t.acceptRules.replace('{link}', `<a href="/regolamento" target="_blank">${t.acceptRulesLink}</a>`)} />
      </label>
      <label class="lm__consent-item">
        <input type="checkbox" id="isc-accept-privacy" required />
        <span set:html={t.acceptPrivacy.replace('{link}', `<a href="/privacy-policy" target="_blank">${t.acceptPrivacyLink}</a>`)} />
      </label>
    </div>

    <p class="lm__error" hidden role="alert"></p>
    <div class="lm__actions">
      <button type="button" class="lm__back" data-isc-back-dynamic>{t.back}</button>
      <button type="button" class="btn btn-red lm__next" id="isc-submit">
        {t.submit} <span class="lm__arrow" aria-hidden="true">→</span>
      </button>
    </div>
  </div>

  <!-- CONFERMA -->
  <div class="lm__body lm__confirm" data-isc-step="confirm" hidden aria-live="polite">
    <div class="lm__confirm-check" aria-hidden="true">
      <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
        <path d="M4 13L10 19L22 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h3 class="lm__confirm-title" set:html={t.confirmTitle} />
    <p class="lm__confirm-note">{t.confirmNote}</p>
    <p class="lm__confirm-note" set:html={t.confirmPayNote} />
    <div class="lm__confirm-summary">
      <div class="lm__confirm-row"><span>{t.payName}</span><span>Tennis Club Ambrosiano SSD a R.L.</span></div>
      <div class="lm__confirm-row"><span>{t.payIban}</span><span>IE50SUMU99036511541465</span></div>
      <div class="lm__confirm-row"><span>{t.payBic}</span><span>SUMUIE22XXX</span></div>
      <div class="lm__confirm-row"><span>{t.payReason}</span><span>{t.payReasonVal}</span></div>
    </div>
    <a class="btn btn-red lm__confirm-cta" href={backHref}>{t.backToPage}</a>
  </div>

</div>

<style>
  .isc-form {
    background: var(--lm-bg);
    color: var(--lm-text);
    border: 1px solid var(--lm-border);
  }
</style>

<style is:global>
  /* ── Select coerenti con input/textarea del sistema .lm ─────────── */
  .lm__field select {
    font-family: var(--font-body); font-size: clamp(13px,.95vw,15px);
    font-weight: 300; padding: 0.7rem 2rem 0.7rem 0.85rem;
    border: 1px solid var(--lm-input-bd);
    background: var(--lm-input-bg); color: var(--lm-text);
    width: 100%; transition: border-color 0.18s;
    -webkit-appearance: none; appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%236B5C57' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat; background-position: right 14px center;
  }
  .lm__field select:invalid { color: var(--lm-text-dim); }
  .lm__field select:focus { outline: none; border-color: var(--color-accent); background-color: #fff; }

  .lm__check-item input[type="radio"] { accent-color: var(--color-accent); flex-shrink: 0; }

  .lm__input--cf { text-transform: uppercase; }

  /* ── Titoli di sotto-sezione dentro uno step ─────────────────────── */
  .lm__section-title {
    font-family: var(--font-display); font-size: clamp(1rem,1.6vw,1.25rem);
    font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em;
    color: var(--lm-text); margin: 0.6rem 0 0;
    padding-top: 1rem; border-top: 1px solid var(--lm-border);
  }
  .lm__section-title--first { padding-top: 0; border-top: none; margin-top: 0; }

  .lm__hint {
    font-family: var(--font-body); font-size: clamp(11px,.8vw,12px);
    font-weight: 300; color: var(--lm-text-dim); margin: -0.6rem 0 0;
  }

  .lm__sub a { color: var(--color-accent); text-decoration: underline; }
  .lm__sub a:hover { color: var(--color-accent-dark); }

  /* ── Box informativo (date, quote di riferimento) ────────────────── */
  .lm__notice {
    background: var(--lm-input-bg); border: 1px solid var(--lm-border);
    border-left: 3px solid var(--color-accent);
    padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.6rem;
  }
  .lm__notice p {
    font-family: var(--font-body); font-size: clamp(12px,.9vw,13px);
    font-weight: 300; line-height: 1.6; color: var(--lm-text-sub); margin: 0;
  }
  .lm__notice p strong { color: var(--lm-text); font-weight: 700; }

  .lm__notice-warn {
    font-family: var(--font-body); font-size: clamp(12px,.9vw,13px);
    font-weight: 400; line-height: 1.6; color: var(--color-accent); margin: 0;
  }

  /* ── Elenco termini e condizioni ──────────────────────────────────── */
  .lm__terms-list {
    margin: 0; padding-left: 1.1rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    font-family: var(--font-body); font-size: clamp(12px,.9vw,13px);
    font-weight: 300; line-height: 1.6; color: var(--lm-text-sub);
  }

  /* ── Tabella slot preparazione fisica ─────────────────────────────── */
  .lm__table-wrap { overflow-x: auto; border: 1px solid var(--lm-border); }
  .lm__table { width: 100%; border-collapse: collapse; font-family: var(--font-body); font-size: clamp(11px,.85vw,12.5px); }
  .lm__table th, .lm__table td { padding: 0.55rem 0.7rem; border-bottom: 1px solid var(--lm-border); text-align: left; }
  .lm__table th { font-weight: 700; color: var(--lm-text); background: var(--lm-bg-head); white-space: nowrap; }
  .lm__table td { font-weight: 300; color: var(--lm-text-sub); }
  .lm__table tr:last-child td { border-bottom: none; }

</style>

<script define:vars={{ ERR: {
  required: t.errRequired,
  email: t.errEmail,
  choice: t.errChoice,
  check: t.errCheck,
  consent: t.errConsent,
} }}>
  const root = document.getElementById('isc-form-root');

  const WEBHOOK_ISCRIZIONE = 'https://automazione.n8ndevelop.it/webhook/scuola-tennis-tca';

  // UTM/click-id e ID visitatore persistente (vedi BaseLayout.astro)
  function getUtm() {
    try { return JSON.parse(sessionStorage.getItem('tca_utm') || '{}'); } catch (e) { return {}; }
  }
  function getVid() {
    return window.tcaGetVid ? window.tcaGetVid() : null;
  }

  function isValidEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim()); }

  function showStep(key) {
    root.querySelectorAll('[data-isc-step]').forEach((el) => {
      el.hidden = el.dataset.iscStep !== String(key);
    });
    root.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function showError(step, msg) {
    const err = root.querySelector(`[data-isc-step="${step}"] > .lm__error`);
    if (err) { err.textContent = msg; err.hidden = false; }
  }
  function clearError(step) {
    const err = root.querySelector(`[data-isc-step="${step}"] > .lm__error`);
    if (err) err.hidden = true;
  }

  const tipoSelect = document.getElementById('isc-tipo');
  const prepSelect = document.getElementById('isc-prep-orario');

  function syncTipoGroups() {
    const tipo = tipoSelect.value;
    root.querySelectorAll('[data-isc-tipo-group]').forEach((el) => {
      el.hidden = el.dataset.iscTipoGroup !== tipo;
    });
  }
  tipoSelect.addEventListener('change', syncTipoGroups);

  root.querySelectorAll('[data-isc-back]').forEach((btn) => {
    btn.addEventListener('click', () => showStep(btn.dataset.iscBack));
  });

  // STEP 1 → 2
  root.querySelector('[data-isc-next="1"]').addEventListener('click', () => {
    clearError('1');
    const required = ['isc-minor-nome','isc-minor-cognome','isc-minor-dob','isc-minor-pob','isc-minor-cf',
                      'isc-addr','isc-city','isc-prov','isc-cap',
                      'isc-parent-nome','isc-parent-cognome','isc-email','isc-cell'];
    for (const id of required) {
      const el = document.getElementById(id);
      if (!el.value.trim()) { showError('1', ERR.required); el.focus(); return; }
    }
    const emailEl = document.getElementById('isc-email');
    if (!isValidEmail(emailEl.value)) { showError('1', ERR.email); emailEl.focus(); return; }
    showStep('2');
  });

  // STEP 2 → 3 (o 4 se Mini Tennis)
  root.querySelector('[data-isc-next="2"]').addEventListener('click', () => {
    clearError('2');
    const tipo = tipoSelect.value;
    if (!tipo) { showError('2', ERR.choice); tipoSelect.focus(); return; }

    const freqChecked = root.querySelector(`input[name="isc-freq-${tipo}"]:checked`);
    if (!freqChecked) { showError('2', ERR.choice); return; }

    const giorniChecked = root.querySelectorAll(`input[name="isc-giorni-${tipo}"]:checked`);
    if (giorniChecked.length === 0) { showError('2', ERR.check); return; }

    if (tipo === 'tennis') {
      const orariChecked = root.querySelectorAll('input[name="isc-orari-tennis"]:checked');
      if (orariChecked.length === 0) { showError('2', ERR.check); return; }
      if (!prepSelect.value) { showError('2', ERR.choice); prepSelect.focus(); return; }
      showStep('3');
    } else {
      showStep('4');
    }
  });

  // STEP 3 → 4 (solo Scuola Tennis)
  root.querySelector('[data-isc-next="3"]').addEventListener('click', () => {
    clearError('3');
    const sizes = ['isc-size-shirt','isc-size-shorts','isc-size-hoodie'];
    for (const id of sizes) {
      const el = document.getElementById(id);
      if (!el.value) { showError('3', ERR.choice); el.focus(); return; }
    }
    showStep('4');
  });

  // Indietro da step 4: torna a 3 se Scuola Tennis, altrimenti a 2
  root.querySelector('[data-isc-back-dynamic]').addEventListener('click', () => {
    showStep(tipoSelect.value === 'tennis' ? '3' : '2');
  });

  // Raccoglie tutti i campi compilati negli step 1-3 per l'invio finale
  function collectPayload() {
    const val = (id) => { const el = document.getElementById(id); return el ? el.value.trim() : ''; };
    const tipo = tipoSelect.value;
    const giorni = Array.from(root.querySelectorAll(`input[name="isc-giorni-${tipo}"]:checked`)).map((el) => el.value);
    const freqEl = root.querySelector(`input[name="isc-freq-${tipo}"]:checked`);

    const payload = {
      minore: {
        nome: val('isc-minor-nome'),
        cognome: val('isc-minor-cognome'),
        dataNascita: val('isc-minor-dob'),
        luogoNascita: val('isc-minor-pob'),
        codiceFiscale: val('isc-minor-cf'),
      },
      indirizzo: {
        via: val('isc-addr'),
        citta: val('isc-city'),
        provincia: val('isc-prov'),
        cap: val('isc-cap'),
      },
      genitore: {
        nome: val('isc-parent-nome'),
        cognome: val('isc-parent-cognome'),
        email: val('isc-email'),
        cellulare: val('isc-cell'),
      },
      iscrizione: {
        tipo,
        frequenza: freqEl ? freqEl.value : '',
        giorni,
        compagnoPreferito: val('isc-buddy'),
      },
      consensi: { termini: true, regolamento: true, privacy: true },
      pagina: location.href,
      referrer: document.referrer || null,
      utm: getUtm(),
      vid: getVid(),
    };

    if (tipo === 'tennis') {
      payload.iscrizione.orariPreferiti = Array.from(root.querySelectorAll('input[name="isc-orari-tennis"]:checked')).map((el) => el.value);
      payload.iscrizione.orarioPreparazione = prepSelect.value;
      payload.taglie = {
        maglietta: val('isc-size-shirt'),
        pantaloncini: val('isc-size-shorts'),
        felpa: val('isc-size-hoodie'),
      };
    }

    return payload;
  }

  // STEP 4 → invio + conferma
  const submitBtn = document.getElementById('isc-submit');
  submitBtn.addEventListener('click', async () => {
    clearError('4');
    const terms = document.getElementById('isc-accept-terms');
    const rules = document.getElementById('isc-accept-rules');
    const privacy = document.getElementById('isc-accept-privacy');
    if (!terms.checked || !rules.checked || !privacy.checked) { showError('4', ERR.consent); return; }

    submitBtn.disabled = true;
    try {
      await fetch(WEBHOOK_ISCRIZIONE, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(collectPayload()),
      });
    } catch (e) {}
    submitBtn.disabled = false;

    showStep('confirm');
  });
</script>
