  sizeShorts: 'Taglia pantaloncini',
  sizeHoodie: 'Taglia felpa',
  sizePh: 'Scegli una taglia',

  termsTitle: 'Termini e condizioni',
  termsList: [
    'la presente preiscrizione è ritenuta valida subordinatamente al versamento dell’acconto di €300 tramite pagamento sicuro online oppure bonifico bancario entro il 15 agosto 2026;',
