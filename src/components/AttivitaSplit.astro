---
import { getLocalePath, useTranslations, publicUrl, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'it' } = Astro.props;
const p = (path: string) => getLocalePath(lang, path);
const t = useTranslations(lang);

const adulti = [
  {
    num: '01',
    name: t.attivita.prepAtleticaName,
    desc: t.attivita.prepAtleticaDesc,
    href: p('/preparazione-atletica'),
    img: publicUrl('/c99ebd5f-16b9-442f-9bb7-2437d5203cd2_TCA+Fitness+5.avif'),
  },
  {
    num: '02',
    name: t.attivita.tennisName,
    desc: t.attivita.tennisDesc,
    href: p('/tennis'),
    img: publicUrl('/3fc4b526-1192-4919-9507-0700f9dbd3bd_TCA+Tennis+2.avif'),
  },
  {
    num: '03',
    name: t.attivita.padelName,
    desc: t.attivita.padelDesc,
    href: p('/padel'),
    img: publicUrl('/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif'),
  },
];

const junior = [
  {
    num: '01',
    name: t.attivita.scuolaName,
    desc: t.attivita.scuolaDesc,
    href: p('/scuola-tennis'),
    img: publicUrl('/ajAJSI1P9HI4UhOS_tenniskidsTCA.avif'),
  },
  {
    num: '02',
    name: t.attivita.agonisticaName,
    desc: t.attivita.agonisticaDesc,
    href: p('/agonistica'),
    img: publicUrl('/ajADmY1P9HI4UhI2_235804_lifestyle_tennis_junior_coco_range_action-6-.avif'),
  },
  {
    num: '03',
    name: t.attivita.summerName,
    desc: t.attivita.summerDesc,
    href: p('/summer-camps'),
    img: publicUrl('/ZhlJNzjCgu4jzybm_shutterstock_409391734_kidsrunfunoutdoor.avif'),
  },
];
---

<section class="attivita">
  <div class="attivita__panels">

    <!-- ADULTI -->
    <div class="attivita__panel">
      <span class="panel__watermark" aria-hidden="true">{t.attivita.titleAdulti}</span>
      <div class="panel__head">
        <div class="panel__head-text">
          <span class="eyebrow eyebrow--light">{t.attivita.eyebrowAdulti}</span>
          <h2 class="panel__title">{t.attivita.titleAdulti}</h2>
          <p class="panel__sub">{t.attivita.subAdulti}</p>
        </div>
        <div class="carousel-nav" aria-label={t.attivita.navAdulti}>
          <button class="carousel-btn" data-dir="-1" data-track="adulti" aria-label={t.attivita.prev}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="carousel-btn" data-dir="1" data-track="adulti" aria-label={t.attivita.next}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>

      <!-- Desktop rows -->
      <div class="panel__rows">
        {adulti.map((item, i) => (
          <a
            class="act-row"
            href={item.href}
            style={`--bg: url('${item.img}')`}
            data-anim="from-left"
            data-anim-delay={String(i * 110)}
          >
            <div class="act-row__inner">
              <span class="act-row__num">{item.num}</span>
              <div class="act-row__content">
                <strong class="act-row__name">{item.name}</strong>
                <p class="act-row__desc">{item.desc}</p>
              </div>
              <span class="act-row__arrow" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Mobile carousel -->
      <div class="act-carousel">
        <div class="act-carousel__track" data-carousel-id="adulti">
          {adulti.map((item) => (
            <a class="act-card" href={item.href}>
              <div class="act-card__img" style={`background-image: url('${item.img}')`}></div>
              <div class="act-card__body">
                <span class="act-card__num">{item.num}</span>
                <strong class="act-card__name">{item.name}</strong>
                <p class="act-card__desc">{item.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="attivita__divider" aria-hidden="true"></div>

    <!-- JUNIOR -->
    <div class="attivita__panel">
      <span class="panel__watermark" aria-hidden="true">{t.attivita.titleJunior}</span>
      <div class="panel__head">
        <div class="panel__head-text">
          <span class="eyebrow eyebrow--light">{t.attivita.eyebrowJunior}</span>
          <h2 class="panel__title">{t.attivita.titleJunior}</h2>
          <p class="panel__sub">{t.attivita.subJunior}</p>
        </div>
        <div class="carousel-nav" aria-label={t.attivita.navJunior}>
          <button class="carousel-btn" data-dir="-1" data-track="junior" aria-label={t.attivita.prev}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="carousel-btn" data-dir="1" data-track="junior" aria-label={t.attivita.next}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>

      <!-- Desktop rows -->
      <div class="panel__rows">
        {junior.map((item, i) => (
          <a
            class="act-row"
            href={item.href}
            style={`--bg: url('${item.img}')`}
            data-anim="from-left"
            data-anim-delay={String(i * 110)}
          >
            <div class="act-row__inner">
              <span class="act-row__num">{item.num}</span>
              <div class="act-row__content">
                <strong class="act-row__name">{item.name}</strong>
                <p class="act-row__desc">{item.desc}</p>
              </div>
              <span class="act-row__arrow" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Mobile carousel -->
      <div class="act-carousel">
        <div class="act-carousel__track" data-carousel-id="junior">
          {junior.map((item) => (
            <a class="act-card" href={item.href}>
              <div class="act-card__img" style={`background-image: url('${item.img}')`}></div>
              <div class="act-card__body">
                <span class="act-card__num">{item.num}</span>
                <strong class="act-card__name">{item.name}</strong>
                <p class="act-card__desc">{item.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .attivita {
    background: #0f1013;
    color: #ffffff;
  }

  .attivita__panels {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
  }

  .attivita__divider {
    background: var(--color-accent);
    width: 1px;
    min-height: 100%;
  }

  /* ── Panel ── */
  .attivita__panel {
    position: relative;
    padding: 6vh var(--pad-x);
    overflow: hidden;
  }

  /* Ghosted watermark */
  .panel__watermark {
    position: absolute;
    top: -0.08em;
    left: 0;
    font-family: var(--font-display);
    font-size: clamp(7rem, 14vw, 18rem);
    font-weight: 800;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.025);
    line-height: 0.85;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    z-index: 0;
  }

  /* Panel header */
  .panel__head {
    position: relative;
    z-index: 1;
    margin-bottom: 3vh;
    padding-bottom: 2.5vh;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .panel__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 5rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.9;
    margin-top: 0.4rem;
    margin-bottom: 0.6rem;
    color: #ffffff;
  }

  .panel__sub {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: #ffffff;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Carousel nav arrows — hidden on desktop ── */
  .carousel-nav {
    display: none;
  }

  .carousel-btn {
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    background: transparent;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }

  .carousel-btn:active {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ── Activity rows ── */
  .panel__rows {
    position: relative;
    z-index: 1;
  }

  .act-row {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 150px;
    padding: 3rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .act-row:last-child {
    border-bottom: none;
  }

  .act-row::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--bg);
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    transform: scale(1.04);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .act-row::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(8, 8, 10, 0.72);
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .act-row:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .act-row:hover::after {
    opacity: 1;
  }

  .act-row__inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    transition: transform 0.3s ease;
  }

  .act-row:hover .act-row__inner {
    transform: translateX(8px);
  }

  .act-row__num {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.9vw, 13px);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    flex-shrink: 0;
    width: 1.8rem;
  }

  .act-row__content {
    flex: 1;
    min-width: 0;
  }

  .act-row__name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 3.2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: #ffffff;
    white-space: nowrap;
  }

  .act-row__desc {
    font-family: var(--font-body);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.5;
    margin-top: 0.5rem;
    transition: color 0.25s;
  }

  .act-row:hover .act-row__desc {
    color: rgba(255, 255, 255, 0.85);
  }

  .act-row__arrow {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.2vw, 2.2rem);
    color: var(--color-accent);
    flex-shrink: 0;
    opacity: 0.45;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .act-row:hover .act-row__arrow {
    opacity: 1;
    transform: translateX(6px);
  }

  /* ── Mobile carousel — hidden on desktop ── */
  .act-carousel {
    display: none;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .attivita__panels {
      grid-template-columns: 1fr;
    }

    .attivita__divider {
      width: 100%;
      height: 1px;
    }

    .attivita__panel {
      padding: 5vh 20px;
      overflow: visible;
    }

    .panel__watermark {
      font-size: clamp(5rem, 22vw, 8rem);
    }

    /* Header: title on left, arrows on right */
    .panel__head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
    }

    .panel__head-text {
      flex: 1;
      min-width: 0;
    }

    /* Show nav arrows on mobile */
    .carousel-nav {
      display: flex;
      gap: 8px;
      align-items: center;
      padding-bottom: 2px;
      flex-shrink: 0;
    }

    /* Hide desktop rows on mobile */
    .panel__rows {
      display: none;
    }

    /* Show carousel on mobile */
    .act-carousel {
      display: block;
      margin: 0 -20px;
      overflow: hidden;
    }

    .act-carousel__track {
      display: flex;
      gap: 12px;
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 20px 20px;
      scroll-padding-left: 20px;
    }

    .act-carousel__track::-webkit-scrollbar {
      display: none;
    }

    /* Card */
    .act-card {
      flex: 0 0 calc(78vw);
      scroll-snap-align: start;
      border-radius: 6px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      display: block;
      background: var(--color-off-white);
    }

    .act-card__img {
      height: 210px;
      background-size: cover;
      background-position: center;
    }

    .act-card__body {
      padding: 14px 16px 18px;
    }

    .act-card__num {
      display: block;
      font-family: var(--font-display);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--color-accent);
      margin-bottom: 6px;
    }

    .act-card__name {
      display: block;
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 6vw, 1.9rem);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: -0.01em;
      line-height: 1;
      color: var(--color-text);
      margin-bottom: 8px;
    }

    .act-card__desc {
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 300;
      color: var(--color-text-light);
      line-height: 1.5;
    }

    /* On mobile always show arrow (no hover state) */
    .act-row__arrow {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.carousel-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLButtonElement;
        const dir = Number(el.dataset.dir);
        const trackId = el.dataset.track;
        const track = document.querySelector<HTMLElement>(
          `[data-carousel-id="${trackId}"]`
        );
        if (!track) return;
        const card = track.querySelector<HTMLElement>('.act-card');
        if (!card) return;
        const cardWidth = card.offsetWidth + 12; // 12px = gap
        track.scrollBy({ left: dir * cardWidth, behavior: 'smooth' });
      });
    });
  });
</script>
