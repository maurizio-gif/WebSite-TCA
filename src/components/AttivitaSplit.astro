---
import { getLocalePath, useTranslations, publicUrl, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'it' } = Astro.props;
const p = (path: string) => getLocalePath(lang, path);
const t = useTranslations(lang);

interface ActivityItem {
  num: string;
  name: string;
  desc: string;
  href: string;
  img: string;
  imgPosition?: string;
}

const adulti: ActivityItem[] = [
  {
    num: '01',
    name: t.attivita.prepAtleticaName,
    desc: t.attivita.prepAtleticaDesc,
    href: p('/preparazione-atletica'),
    img: publicUrl('/Sala%20Attrezzi%206.jpg'),
  },
  {
    num: '02',
    name: t.attivita.tennisName,
    desc: t.attivita.tennisDesc,
    href: p('/tennis'),
    img: publicUrl('/home-tennis-adulti.avif'),
  },
  {
    num: '03',
    name: t.attivita.padelName,
    desc: t.attivita.padelDesc,
    href: p('/padel'),
    img: publicUrl('/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif'),
  },
];

const junior: ActivityItem[] = [
  {
    num: '01',
    name: t.attivita.scuolaName,
    desc: t.attivita.scuolaDesc,
    href: p('/scuola-tennis'),
    img: publicUrl('/home-scuola-tennis-junior.avif'),
    imgPosition: 'center top',
  },
  {
    num: '02',
    name: t.attivita.agonisticaName,
    desc: t.attivita.agonisticaDesc,
    href: p('/agonistica'),
    img: publicUrl('/Tennis%20Agonistica.jpg'),
  },
  {
    num: '03',
    name: t.attivita.summerName,
    desc: t.attivita.summerDesc,
    href: p('/summer-camps'),
    img: publicUrl('/Summer%20Camp.avif'),
  },
];
---

<section class="attivita">
  <div class="attivita__panels">

    <!-- ADULTI -->
    <div class="attivita__panel">
      <span class="panel__watermark" aria-hidden="true">{t.attivita.titleAdulti}</span>
      <div class="panel__head">
        <div class="panel__head-text">
          <span class="eyebrow eyebrow--light">{t.attivita.eyebrowAdulti}</span>
          <h2 class="panel__title">{t.attivita.titleAdulti}</h2>
          <p class="panel__sub">{t.attivita.subAdulti}</p>
        </div>
        <div class="carousel-nav" aria-label={t.attivita.navAdulti}>
          <button class="carousel-btn" data-dir="-1" data-track="adulti" aria-label={t.attivita.prev}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="carousel-btn" data-dir="1" data-track="adulti" aria-label={t.attivita.next}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>

      <!-- Carousel -->
      <div class="act-carousel">
        <div class="act-carousel__track" data-carousel-id="adulti">
          {adulti.map((item) => (
            <a class="act-card" href={item.href}>
              <div class="act-card__media" style={`background-image: url('${item.img}'); background-position: ${item.imgPosition ?? 'center'};`}>
                <span class="act-card__scrim" aria-hidden="true"></span>
                <span class="act-card__backdrop" aria-hidden="true"></span>
                <div class="act-card__content">
                  <span class="act-card__num">{item.num}</span>
                  <strong class="act-card__name">{item.name}</strong>
                  <p class="act-card__desc">{item.desc}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="attivita__divider" aria-hidden="true"></div>

    <!-- JUNIOR -->
    <div class="attivita__panel">
      <span class="panel__watermark" aria-hidden="true">{t.attivita.titleJunior}</span>
      <div class="panel__head">
        <div class="panel__head-text">
          <span class="eyebrow eyebrow--light">{t.attivita.eyebrowJunior}</span>
          <h2 class="panel__title">{t.attivita.titleJunior}</h2>
          <p class="panel__sub">{t.attivita.subJunior}</p>
        </div>
        <div class="carousel-nav" aria-label={t.attivita.navJunior}>
          <button class="carousel-btn" data-dir="-1" data-track="junior" aria-label={t.attivita.prev}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="carousel-btn" data-dir="1" data-track="junior" aria-label={t.attivita.next}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>

      <!-- Carousel -->
      <div class="act-carousel">
        <div class="act-carousel__track" data-carousel-id="junior">
          {junior.map((item) => (
            <a class="act-card" href={item.href}>
              <div class="act-card__media" style={`background-image: url('${item.img}'); background-position: ${item.imgPosition ?? 'center'};`}>
                <span class="act-card__scrim" aria-hidden="true"></span>
                <span class="act-card__backdrop" aria-hidden="true"></span>
                <div class="act-card__content">
                  <span class="act-card__num">{item.num}</span>
                  <strong class="act-card__name">{item.name}</strong>
                  <p class="act-card__desc">{item.desc}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .attivita {
    background: #0f1013;
    color: #ffffff;
  }

  .attivita__panels {
    display: grid;
    grid-template-columns: 1fr;
  }

  .attivita__divider {
    background: var(--color-accent);
    width: 100%;
    height: 1px;
  }

  /* ── Panel ── */
  .attivita__panel {
    position: relative;
    padding: 6vh var(--pad-x);
    overflow: hidden;
    min-width: 0;
  }

  /* Ghosted watermark */
  .panel__watermark {
    position: absolute;
    top: -0.08em;
    left: 0;
    font-family: var(--font-display);
    font-size: clamp(7rem, 14vw, 18rem);
    font-weight: 800;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.025);
    line-height: 0.85;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    z-index: 0;
  }

  /* Panel header: title on left, nav arrows on right */
  .panel__head {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 3vh;
    padding-bottom: 2.5vh;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .panel__head-text {
    flex: 1;
    min-width: 0;
  }

  .panel__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 5rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.9;
    margin-top: 0.4rem;
    margin-bottom: 0.6rem;
    color: #ffffff;
  }

  .panel__sub {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: #ffffff;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Carousel nav arrows ── */
  .carousel-nav {
    display: flex;
    gap: 8px;
    align-items: center;
    padding-bottom: 2px;
    flex-shrink: 0;
  }

  .carousel-btn {
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    background: transparent;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }

  .carousel-btn:hover,
  .carousel-btn:active {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ── Carousel ── */
  .act-carousel {
    position: relative;
    z-index: 1;
    margin: 0 calc(var(--pad-x) * -1);
    overflow: hidden;
  }

  .act-carousel__track {
    display: flex;
    gap: 1.25rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.5rem var(--pad-x) 1.5rem;
    scroll-padding-left: var(--pad-x);
  }

  .act-carousel__track::-webkit-scrollbar {
    display: none;
  }

  /* Card — foto piena, titolo sempre visibile, descrizione rivelata
     all'hover (mouse) o al passaggio in viewport su mobile (.is-revealed). */
  .act-card {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    scroll-snap-align: start;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: block;
    background: var(--color-off-white);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .act-card:hover,
  .act-card:focus-within {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45);
  }

  .act-card__media {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    background-size: cover;
    display: flex;
    align-items: flex-end;
  }

  /* Scrim leggero sempre presente: legge meglio numero/titolo sulla foto */
  .act-card__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.35) 38%, rgba(0, 0, 0, 0) 68%);
    pointer-events: none;
  }

  /* Layer scuro che sale/si intensifica quando la card si rivela */
  .act-card__backdrop {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.55) 55%, rgba(0, 0, 0, 0) 85%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .act-card:hover .act-card__backdrop,
  .act-card:focus-within .act-card__backdrop,
  .act-card.is-revealed .act-card__backdrop {
    opacity: 1;
  }

  .act-card__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 1.25rem;
  }

  .act-card__num {
    display: block;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 6px;
  }

  .act-card__name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.8vw, 2.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: #ffffff;
  }

  .act-card__desc {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.3vw, 19px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
    margin-top: 10px;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, opacity 0.3s ease 0.05s, margin-top 0.35s ease;
  }

  .act-card:hover .act-card__desc,
  .act-card:focus-within .act-card__desc,
  .act-card.is-revealed .act-card__desc {
    max-height: 200px;
    opacity: 1;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .attivita__panel {
      padding: 5vh 20px;
      overflow: visible;
    }

    .panel__watermark {
      font-size: clamp(5rem, 22vw, 8rem);
    }

    .act-card__name {
      font-size: clamp(1.7rem, 7vw, 2.2rem);
    }

    .act-card__desc {
      font-size: clamp(16px, 4vw, 18px);
    }
  }

  @media (max-width: 860px) {
    .act-card {
      flex: 0 0 calc((100% - 1.25rem) / 2);
    }
  }

  @media (max-width: 640px) {
    .act-card {
      flex: 0 0 calc(78vw);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.carousel-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLButtonElement;
        const dir = Number(el.dataset.dir);
        const trackId = el.dataset.track;
        const track = document.querySelector<HTMLElement>(
          `[data-carousel-id="${trackId}"]`
        );
        if (!track) return;
        const card = track.querySelector<HTMLElement>('.act-card');
        if (!card) return;
        const cardWidth = card.offsetWidth + 12; // 12px = gap
        track.scrollBy({ left: dir * cardWidth, behavior: 'smooth' });
      });
    });

    // ── Reveal della descrizione su touch: senza hover del mouse, la card
    // si "apre" da sola quando entra a metà nel viewport durante lo scroll. ──
    if (window.matchMedia('(hover: none)').matches) {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            entry.target.classList.toggle('is-revealed', entry.isIntersecting);
          });
        },
        { threshold: 0.6 }
      );
      document.querySelectorAll('.act-card').forEach((card) => obs.observe(card));
    }
  });
</script>
