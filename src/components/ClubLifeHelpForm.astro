---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'it' } = Astro.props;
const t = useTranslations(lang);
---

<section class="cl-help-form" id="contatti">
  <div class="cl-help-form__inner">
    <div class="cl-help-form__intro">
      <span class="eyebrow eyebrow--light">{t.clubLife.helpFormEyebrow}</span>
      <h2 class="cl-help-form__title">{t.clubLife.helpFormTitle}</h2>
      <p class="cl-help-form__sub">{t.clubLife.helpFormSub}</p>
    </div>

    <div class="cl-help-form__cta">
      <button class="btn btn-red cl-help-form__submit" type="button" data-open-modal="modal-contatti">
        {t.common.richiediInfo}
      </button>
    </div>
  </div>
</section>

<style>
  .cl-help-form {
    padding: 8vh var(--pad-x);
    background: #0f1013;
    color: #ffffff;
  }

  .cl-help-form__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 4rem;
    align-items: start;
  }

  .cl-help-form__intro { position: sticky; top: calc(var(--header-h) + 3rem); }

  .cl-help-form__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-top: 0.4rem;
    margin-bottom: 1.2rem;
    color: #ffffff;
  }

  .cl-help-form__sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.05vw, 17px);
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.6);
    max-width: 42ch;
  }

  .cl-help-form__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .cl-help-form__submit { min-width: 260px; }

  @media (max-width: 860px) {
    .cl-help-form__inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .cl-help-form__intro { position: static; }
    .cl-help-form__cta { justify-content: flex-start; }
  }

  @media (max-width: 560px) {
    .cl-help-form__submit { width: 100%; }
  }
</style>
