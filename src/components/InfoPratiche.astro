---

<section class="info">
  <div class="info__inner">
    <h2 class="info__title">Vieni a trovarci.</h2>

    <div class="info__grid">
      <div class="info__item">
        <span class="info__label">Indirizzo</span>
        <p class="info__value">Via Feltre 33, 20134 Milano</p>
      </div>

      <div class="info__item">
        <span class="info__label">Come arrivare</span>
        <p class="info__value">
          Metro Udine (linea M2), a pochi minuti a piedi. Ampio parcheggio
          disponibile.
        </p>
      </div>

      <div class="info__item">
        <span class="info__label">Orari Club</span>
        <p class="info__value">
          Lun–Ven 7:00–24:00 · Sab–Dom 8:00–21:00
        </p>
      </div>

      <div class="info__item">
        <span class="info__label">Reception</span>
        <p class="info__value">
          <a href="tel:+390226414392">+39 02 2641 4392</a> ·
          <a href="mailto:info@tcambrosiano.com">info@tcambrosiano.com</a>
        </p>
      </div>
    </div>

    <div class="info__actions">
      <a
        class="info__btn info__btn--accent"
        href="https://maps.google.com/?q=Via+Feltre+33+Milano"
        target="_blank"
        rel="noopener">Indicazioni Google Maps</a
      >
      {/* TODO: inserire numero WhatsApp */}
      <a class="info__btn info__btn--outline" href="#">WhatsApp</a>
      <a class="info__btn info__btn--outline" href="tel:+390226414392">Chiama</a>
    </div>
  </div>
</section>

<style>
  .info {
    padding: 6rem 1.5rem;
    background: #f9f9f9;
  }

  .info__inner {
    max-width: 1080px;
    margin: 0 auto;
    text-align: center;
  }

  .info__title {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    margin-bottom: 3rem;
  }

  .info__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
    text-align: left;
    max-width: 760px;
    margin: 0 auto 3rem;
  }

  .info__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .info__value {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .info__value a {
    color: var(--color-text);
  }

  .info__value a:hover {
    color: var(--color-accent);
  }

  .info__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .info__btn {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.85rem 1.7rem;
    border-radius: 4px;
    transition: opacity 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .info__btn--accent {
    background: var(--color-accent);
    color: #ffffff;
  }

  .info__btn--accent:hover {
    opacity: 0.88;
  }

  .info__btn--outline {
    background: transparent;
    color: var(--color-text);
    border: 1.5px solid var(--color-border);
  }

  .info__btn--outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .info__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
