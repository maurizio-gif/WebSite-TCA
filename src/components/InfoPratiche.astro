---

<section class="info">
  <div class="info__inner">
    <span class="eyebrow">Come trovarci</span>
    <h2 class="info__title">Vieni a trovarci.</h2>

    <div class="info__grid">
      <div class="info__item">
        <span class="info__label">Indirizzo</span>
        <p class="info__value">Via Feltre 33, 20134 Milano</p>
      </div>

      <div class="info__item">
        <span class="info__label">Come arrivare</span>
        <p class="info__value">
          Metro Udine (linea M2), a pochi minuti a piedi.<br>
          Ampio parcheggio disponibile.
        </p>
      </div>

      <div class="info__item">
        <span class="info__label">Orari Club</span>
        <p class="info__value">Lun–Ven 7:00–24:00 · Sab–Dom 8:00–21:00</p>
      </div>

      <div class="info__item">
        <span class="info__label">Reception</span>
        <p class="info__value">
          <a href="tel:+390226414392">+39 02 2641 4392</a><br>
          <a href="mailto:info@tcambrosiano.com">info@tcambrosiano.com</a>
        </p>
      </div>
    </div>

    <div class="info__actions">
      <a
        class="btn btn-red"
        href="https://maps.google.com/?q=Via+Feltre+33+Milano"
        target="_blank"
        rel="noopener"
      >Indicazioni Google Maps</a>
      {/* TODO: inserire numero WhatsApp */}
      <a class="btn btn-outline--dark" href="#">WhatsApp</a>
      <a class="btn btn-outline--dark" href="tel:+390226414392">Chiama</a>
    </div>
  </div>
</section>

<style>
  .info {
    padding: 7vh var(--pad-x);
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .info__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .info__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .info__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 3vh;
  }

  .info__item {
    background: var(--color-bg);
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .info__label {
    font-family: var(--font-display);
    font-size: clamp(9px, 0.8vw, 11px);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .info__value {
    font-family: var(--font-body);
    font-size: clamp(13px, 1vw, 16px);
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text);
  }

  .info__value a {
    color: var(--color-text);
    transition: color 0.18s;
  }

  .info__value a:hover { color: var(--color-accent); }

  .info__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 1024px) {
    .info__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .info__grid { grid-template-columns: 1fr; }
  }
</style>
