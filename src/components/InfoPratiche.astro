---
import type { Lang } from '../i18n/utils';
interface Props { lang?: Lang; }
const { lang = 'it' } = Astro.props;

const t = lang === 'en' ? {
  eyebrow:        'How to find us',
  title:          'Visit us.',
  labelAddress:   'Address',
  labelHow:       'Getting here',
  howText:        "Metro Udine (line M2), a few minutes' walk.<br>Ample parking available.",
  labelHours:     'Club Hours',
  hoursText:      'Mon–Fri 7:00–24:00<br>Sat–Sun 8:00–21:00',
  labelReception: 'Reception',
  btnDirections:  'Directions',
  btnContact:     'Contact us',
} : {
  eyebrow:        'Come trovarci',
  title:          'Vieni a trovarci.',
  labelAddress:   'Indirizzo',
  labelHow:       'Come arrivare',
  howText:        'Metro Udine (linea M2), a pochi minuti a piedi.<br>Ampio parcheggio disponibile.',
  labelHours:     'Orari Club',
  hoursText:      'Lun–Ven 7:00–24:00<br>Sab–Dom 8:00–21:00',
  labelReception: 'Reception',
  btnDirections:  'Indicazioni',
  btnContact:     'Contattaci',
};
---

<section class="info">
  <div class="info__inner">
    <div class="info__head">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2 class="info__title">{t.title}</h2>
    </div>

    <!-- Google Maps embed — protagonista -->
    <div class="info__map">
      <iframe
        class="info__map-iframe"
        src="https://www.google.com/maps?q=Via+Feltre+33,+20134+Milano&z=16&output=embed"
        title="Tennis Club Ambrosiano — Via Feltre 33, Milano"
        width="600"
        height="500"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>

    <!-- Info sotto la mappa -->
    <div class="info__bottom">
      <div class="info__grid">
        <div class="info__item">
          <span class="info__label">{t.labelAddress}</span>
          <p class="info__value">Via Feltre 33, 20134 Milano</p>
        </div>

        <div class="info__item">
          <span class="info__label">{t.labelHow}</span>
          <p class="info__value" set:html={t.howText} />
        </div>

        <div class="info__item">
          <span class="info__label">{t.labelHours}</span>
          <p class="info__value" set:html={t.hoursText} />
        </div>

        <div class="info__item">
          <span class="info__label">{t.labelReception}</span>
          <p class="info__value">
            <a href="tel:+390226414392">+39 02 2641 4392</a><br>
            <a href="mailto:info@tcambrosiano.com">info@tcambrosiano.com</a>
          </p>
        </div>
      </div>

      <div class="info__actions">
        <a class="btn btn-outline--dark" href="https://maps.google.com/?q=Via+Feltre+33,+20134+Milano" target="_blank" rel="noopener">{t.btnDirections}</a>
        <button class="btn btn-red" data-open-modal="modal-contatti">{t.btnContact}</button>
      </div>
    </div>

  </div>
</section>

<style>
  .info {
    padding: 7vh var(--pad-x) 8vh;
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
  }

  .info__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .info__head {
    margin-bottom: 3vh;
  }

  .info__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-top: 0.5rem;
  }

  /* Mappa — elemento principale */
  .info__map {
    width: 100%;
    border: 1px solid var(--color-border);
    overflow: hidden;
    margin-bottom: 1px;
  }

  .info__map-iframe {
    display: block;
    width: 100%;
    height: 500px;
    border: none;
    filter: grayscale(10%) contrast(1.05);
  }

  /* Info row sotto la mappa */
  .info__bottom {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-top: none;
    align-items: stretch;
  }

  .info__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
  }

  .info__item {
    background: var(--color-bg);
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .info__label {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.7vw, 13px);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .info__value {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-text);
  }

  .info__value a {
    color: var(--color-text);
    transition: color 0.18s;
  }
  .info__value a:hover { color: var(--color-accent); }

  .info__actions {
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 10px;
    padding: 22px 28px;
    white-space: nowrap;
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .info__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 900px) {
    .info__map-iframe { height: 420px; }

    .info__bottom {
      grid-template-columns: 1fr;
    }

    .info__actions {
      flex-direction: row;
      flex-wrap: wrap;
      border-top: 1px solid var(--color-border);
      padding: 18px 22px;
    }
  }

  @media (max-width: 560px) {
    .info__map-iframe { height: 300px; }
    .info__grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 400px) {
    .info__grid { grid-template-columns: 1fr; }
  }
</style>
