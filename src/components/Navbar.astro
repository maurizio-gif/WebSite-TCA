---
import { useTranslations, getLocalePath, getAlternatePath, publicUrl, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'it' } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => getLocalePath(lang, path);

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const rawPath = Astro.url.pathname;
const cleanPath = base && rawPath.startsWith(base)
  ? (rawPath.slice(base.length) || '/')
  : rawPath;
const { it: itClean } = getAlternatePath(cleanPath);
const itPath = getLocalePath('it', itClean);
const enPath = getLocalePath('en', itClean);

// ── Mega menu data ────────────────────────────────────────────────
const adultiItems = [
  {
    num: '01', label: t.nav.prepAtletica,
    desc: 'Allenamento in Sala Pesi e Corsi di Gruppo.',
    href: p('/preparazione-atletica'),
    img: publicUrl('/c99ebd5f-16b9-442f-9bb7-2437d5203cd2_TCA+Fitness+5.avif'),
  },
  {
    num: '02', label: t.nav.tennis,
    desc: 'Sedici campi, istruttori federali e tornei per tutti i livelli.',
    href: p('/tennis'),
    img: publicUrl('/3fc4b526-1192-4919-9507-0700f9dbd3bd_TCA+Tennis+2.avif'),
  },
  {
    num: '03', label: t.nav.padel,
    desc: 'Campi coperti e aperti, lezioni con istruttori certificati.',
    href: p('/padel'),
    img: publicUrl('/ba63296a-9191-42dd-ae45-f53124e649ce_Padel.avif'),
  },
];

const juniorItems = [
  {
    num: '01', label: t.nav.scuolaTennis,
    desc: 'Istruttori certificati, piccoli gruppi. Dai 4 anni in su.',
    href: p('/scuola-tennis'),
    img: publicUrl('/ajAJSI1P9HI4UhOS_tenniskidsTCA.avif'),
  },
  {
    num: '02', label: t.nav.agonistica,
    desc: 'Squadre federate, tornei nazionali e internazionali.',
    href: p('/agonistica'),
    img: publicUrl('/0cd25eb6-cb2a-48cf-a65e-2a7107787fba_Web_Square-1PA_1811.avif'),
  },
  {
    num: '03', label: t.nav.summerCamps,
    desc: 'Sport, divertimento e nuove amicizie. Programmi intensivi estate.',
    href: p('/summer-camps'),
    img: publicUrl('/aYszOt0YXLCxVpqZ_TCA_summercamp2026_orizzontale_tennisfemmina_nologhi.avif'),
  },
];

// Voci secondarie (senza mega menu)
const secondaryItems = [
  { label: t.nav.torneoAvvenire, href: p('/torneo-avvenire') },
  { label: t.nav.storia,         href: p('/storia') },
  { label: t.nav.eventi,         href: p('/eventi') },
];

// navItems per il mobile menu — children con img/desc/num per il look scenico
const navItems = [
  { label: t.nav.adulti,  href: null, secondary: false, children: adultiItems },
  { label: t.nav.junior,  href: null, secondary: false, children: juniorItems },
  ...secondaryItems.map(i => ({ ...i, secondary: true, children: [] as typeof adultiItems })),
];
---

<header class="navbar" id="navbar">
  <div class="navbar__inner">
    <!-- Logo -->
    <a class="navbar__logo" href={p('/')} aria-label="Tennis Club Ambrosiano — home">
      <img
        src={publicUrl('/logos/tca-logo.png')}
        alt="Tennis Club Ambrosiano"
        class="navbar__logo-img"
        width="80" height="54"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="navbar__nav" aria-label="Navigazione principale">
      <ul class="navbar__list">

        <!-- ADULTI — mega menu -->
        <li class="navbar__item navbar__item--mega" id="nav-adulti">
          <button class="navbar__link navbar__link--btn" aria-haspopup="true" aria-expanded="false">
            {t.nav.adulti}
            <svg class="navbar__chevron" width="10" height="6" viewBox="0 0 10 6" fill="none">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="navbar__mega mega--adulti">
            <div class="mega__inner">
              <ul class="mega__list">
                {adultiItems.map((item) => (
                  <li>
                    <a class="mega__item" href={item.href}>
                      <span class="mega__num">{item.num}</span>
                      <div class="mega__body">
                        <strong class="mega__name">{item.label}</strong>
                        <span class="mega__desc">{item.desc}</span>
                      </div>
                      <span class="mega__arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
              <div class="mega__feature">
                {adultiItems.map((item, i) => (
                  <img
                    class={`mega__feat-img mega__feat-img--${i + 1}`}
                    src={item.img}
                    alt={item.label}
                    loading="eager"
                  />
                ))}
                <div class="mega__feat-overlay"></div>
              </div>
            </div>
          </div>
        </li>

        <!-- JUNIOR — mega menu -->
        <li class="navbar__item navbar__item--mega" id="nav-junior">
          <button class="navbar__link navbar__link--btn" aria-haspopup="true" aria-expanded="false">
            {t.nav.junior}
            <svg class="navbar__chevron" width="10" height="6" viewBox="0 0 10 6" fill="none">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="navbar__mega mega--junior">
            <div class="mega__inner">
              <ul class="mega__list">
                {juniorItems.map((item) => (
                  <li>
                    <a class="mega__item" href={item.href}>
                      <span class="mega__num">{item.num}</span>
                      <div class="mega__body">
                        <strong class="mega__name">{item.label}</strong>
                        <span class="mega__desc">{item.desc}</span>
                      </div>
                      <span class="mega__arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
              <div class="mega__feature">
                {juniorItems.map((item, i) => (
                  <img
                    class={`mega__feat-img mega__feat-img--${i + 1}`}
                    src={item.img}
                    alt={item.label}
                    loading="eager"
                  />
                ))}
                <div class="mega__feat-overlay"></div>
              </div>
            </div>
          </div>
        </li>

        <!-- Voci secondarie -->
        {secondaryItems.map((item) => (
          <li class="navbar__item">
            <a class="navbar__link navbar__link--secondary" href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="navbar__right">
      <button class="navbar__cta btn btn-red" data-open-modal="modal-contatti">{t.nav.contattaci}</button>
      <a class="navbar__mobile-contact" data-open-modal="modal-contatti">{t.nav.contattaci}</a>
      <button class="navbar__accedi" id="btn-accedi" type="button">
        <svg width="13" height="14" viewBox="0 0 24 26" fill="none" aria-hidden="true" style="flex-shrink:0">
          <circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="2"/>
          <path d="M2 24c0-5.523 4.477-10 10-10s10 4.477 10 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        ACCEDI
      </button>

      <div class="lang-switcher" id="lang-switcher" aria-label="Seleziona lingua / Select language">
        <button class="lang-switcher__toggle" id="lang-toggle" aria-haspopup="listbox" aria-expanded="false">
          {lang === 'it' ? (
            <svg class="lang-flag" width="18" height="13" viewBox="0 0 3 2" aria-hidden="true"><rect width="1" height="2" fill="#009246"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#ce2b37"/></svg>
          ) : (
            <svg class="lang-flag" width="18" height="13" viewBox="0 0 60 30" aria-hidden="true"><rect width="60" height="30" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#c8102e" stroke-width="4"/><path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/><path d="M30,0 V30 M0,15 H60" stroke="#c8102e" stroke-width="6"/></svg>
          )}
          {lang.toUpperCase()}
          <svg class="lang-switcher__chevron" width="8" height="5" viewBox="0 0 8 5" fill="none" aria-hidden="true">
            <path d="M1 1L4 4L7 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <ul class="lang-switcher__dropdown" role="listbox" aria-label="Seleziona lingua">
          <li role="option" aria-selected={lang === 'it'}>
            <a class={`lang-switcher__option${lang === 'it' ? ' is-active' : ''}`} href={itPath} hreflang="it">
              <svg class="lang-flag" width="18" height="13" viewBox="0 0 3 2" aria-hidden="true"><rect width="1" height="2" fill="#009246"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#ce2b37"/></svg>
              IT <span class="lang-switcher__option-label">Italiano</span>
            </a>
          </li>
          <li role="option" aria-selected={lang === 'en'}>
            <a class={`lang-switcher__option${lang === 'en' ? ' is-active' : ''}`} href={enPath} hreflang="en">
              <svg class="lang-flag" width="18" height="13" viewBox="0 0 60 30" aria-hidden="true"><rect width="60" height="30" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#c8102e" stroke-width="4"/><path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/><path d="M30,0 V30 M0,15 H60" stroke="#c8102e" stroke-width="6"/></svg>
              EN <span class="lang-switcher__option-label">English</span>
            </a>
          </li>
        </ul>
      </div>

      <button
        class="navbar__burger"
        type="button"
        aria-label={t.nav.openMenu}
        aria-expanded="false"
        aria-controls="g-menu"
        id="burger-btn"
      >
        <span class="burger-bar b1"></span>
        <span class="burger-bar b2"></span>
        <span class="burger-bar b3"></span>
      </button>
    </div>
  </div>
</header>

<!-- Modal Accedi -->
<dialog class="accedi-modal" id="modal-accedi" aria-labelledby="accedi-title">
  <div class="accedi-modal__inner">
    <button class="accedi-modal__close" id="accedi-close" aria-label="Chiudi">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <p class="accedi-modal__eyebrow">Il tuo Club</p>
    <h2 class="accedi-modal__title" id="accedi-title">
      Il tuo club<br>a portata di click
      <span class="accedi-modal__title-sub">Gestisci il tuo abbonamento</span>
    </h2>
    <div class="accedi-modal__btns">
      <a class="accedi-modal__btn accedi-modal__btn--red" href="https://tcambrosiano.perfectgym.com/clientportal2/#/Login" target="_blank" rel="noopener">
        ACCEDI DA WEB
      </a>
      <a class="accedi-modal__btn accedi-modal__btn--outline" id="btn-app-store" href="https://tcambrosiano.perfectgym.com/clientportal2/#/Login" target="_blank" rel="noopener">
        ACCEDI DA APP
      </a>
    </div>

    <div class="accedi-modal__divider" aria-hidden="true"></div>

    <p class="accedi-modal__eyebrow">Prenotazioni</p>
    <div class="accedi-modal__btns">
      <a class="accedi-modal__btn accedi-modal__btn--outline" href="https://playtomic.com/clubs/club-ambrosiano-tennis" target="_blank" rel="noopener">
        PRENOTA UN CAMPO
      </a>
      <a class="accedi-modal__btn accedi-modal__btn--outline" href="https://tcambrosiano.perfectgym.com/clientportal2/?lang=it#/Classes/1/Calendar" target="_blank" rel="noopener">
        PRENOTA UN CORSO
      </a>
    </div>
  </div>
</dialog>

<!-- Menu fullscreen (mobile) -->
<nav class="g-menu" id="g-menu" aria-label="Menu mobile" aria-hidden="true">
  <div class="g-menu__inner">
    <ul class="g-menu__list">
      {navItems.map((item) => (
        item.children && item.children.length > 0 ? (
          <li class="g-menu__item g-menu__item--accordion">
            <button class="g-menu__link g-menu__accordion-btn" aria-expanded="false">
              {item.label}
              <svg class="g-menu__acc-icon" width="16" height="10" viewBox="0 0 16 10" fill="none">
                <path d="M1 1L8 9L15 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <ul class="g-menu__sub">
              {item.children.map((child) => (
                <li>
                  <a class="g-menu__sub-link" href={child.href}>
                    <span class="g-menu__sub-num">{child.num}</span>
                    <div class="g-menu__sub-body">
                      <strong class="g-menu__sub-name">{child.label}</strong>
                      <span class="g-menu__sub-desc">{child.desc}</span>
                    </div>
                    <div class="g-menu__sub-thumb" style={`background-image: url('${child.img}')`}></div>
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ) : (
          <li class={`g-menu__item${item.secondary ? ' g-menu__item--secondary' : ''}`}>
            <a class="g-menu__link" href={item.href}>{item.label}</a>
          </li>
        )
      ))}
    </ul>

    <div class="g-menu__ctas">
      <a class="g-menu__cta-btn g-menu__cta-btn--red btn btn-red" href="#">INIZIA ORA</a>
      <a class="g-menu__cta-btn g-menu__cta-btn--outline" href="#">RICHIEDI LA PROVA</a>
    </div>

    <div class="g-menu__footer">
      <div class="g-menu__lang">
        <a class={`g-menu__lang-link${lang === 'it' ? ' is-active' : ''}`} href={itPath} hreflang="it">
          <svg class="lang-flag" width="16" height="12" viewBox="0 0 3 2" aria-hidden="true"><rect width="1" height="2" fill="#009246"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#ce2b37"/></svg>
          IT
        </a>
        <span class="g-menu__lang-sep" aria-hidden="true">|</span>
        <a class={`g-menu__lang-link${lang === 'en' ? ' is-active' : ''}`} href={enPath} hreflang="en">
          <svg class="lang-flag" width="16" height="12" viewBox="0 0 60 30" aria-hidden="true"><rect width="60" height="30" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#c8102e" stroke-width="4"/><path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/><path d="M30,0 V30 M0,15 H60" stroke="#c8102e" stroke-width="6"/></svg>
          EN
        </a>
      </div>
      {t.nav.menuFooter}
    </div>
  </div>
</nav>

<style>
  /* ════════════════════════════════════════════
     NAVBAR
  ════════════════════════════════════════════ */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    height: var(--header-h);
    background: #ffffff;
    border-bottom: 1px solid var(--color-border);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 var(--pad-x);
    max-width: var(--max-width);
    margin: 0 auto;
    gap: 1.5rem;
  }

  /* ── Logo ── */
  .navbar__logo { display: block; flex-shrink: 0; line-height: 0; }
  .navbar__logo-img {
    height: calc(var(--header-h) - 16px);
    width: auto; object-fit: contain;
    display: block;
    mix-blend-mode: multiply;
  }

  /* ── Desktop nav ── */
  .navbar__nav { flex: 1; display: flex; }
  .navbar__list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .navbar__item { position: static; }

  .navbar__link,
  .navbar__link--btn {
    font-family: var(--font-display);
    font-size: clamp(14px, 1.14vw, 17px);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    padding: 0 0.9rem;
    height: var(--header-h);
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.18s;
    position: relative;
  }

  /* Underline animato su hover */
  .navbar__link::after,
  .navbar__link--btn::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0.9rem; right: 0.9rem;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s cubic-bezier(0.22, 0.68, 0, 1.1);
  }

  .navbar__link:hover::after,
  .navbar__link--btn:hover::after,
  .navbar__item--mega.is-open .navbar__link--btn::after {
    transform: scaleX(1);
  }

  .navbar__link:hover,
  .navbar__link--btn:hover,
  .navbar__item--mega.is-open .navbar__link--btn {
    color: var(--color-accent);
  }

  /* Voci secondarie: più leggere */
  .navbar__link--secondary {
    font-weight: 600;
    color: var(--color-text-light);
    font-size: clamp(14px, 1.02vw, 16px);
    letter-spacing: 0.1em;
  }
  .navbar__link--secondary:hover { color: var(--color-accent); }

  .navbar__chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .navbar__item--mega.is-open .navbar__chevron { transform: rotate(180deg); }

  /* ════════════════════════════════════════════
     MEGA MENU
  ════════════════════════════════════════════ */
  .navbar__mega {
    position: fixed;
    top: var(--header-h);
    left: 0; right: 0;
    background: #0f1013;
    border-top: 2px solid var(--color-accent);
    box-shadow: 0 20px 60px rgba(0,0,0,0.45);

    /* nascosto di default */
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
    pointer-events: none;
    z-index: 490;
  }

  .navbar__item--mega.is-open .navbar__mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: all;
  }

  /* Layout interno: lista (60%) + immagine featured (40%) */
  .mega__inner {
    display: grid;
    grid-template-columns: 58% 42%;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* ── Lista attività ── */
  .mega__list {
    list-style: none;
    padding: 0;
    border-right: 1px solid rgba(255,255,255,0.06);
  }

  .mega__item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.6rem var(--pad-x);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    text-decoration: none;
    color: #fff;
    transition: background 0.18s;
    position: relative;
  }

  .mega__item:last-child { border-bottom: none; }

  .mega__item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.22s cubic-bezier(0.22, 0.68, 0, 1.1);
  }

  .mega__item:hover {
    background: rgba(255,255,255,0.03);
  }

  .mega__item:hover::before {
    transform: scaleY(1);
  }

  .mega__num {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    flex-shrink: 0;
    width: 1.6rem;
  }

  .mega__body { flex: 1; min-width: 0; }

  .mega__name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.2vw, 2.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: rgba(255,255,255,0.85);
    transition: color 0.18s;
  }

  .mega__item:hover .mega__name { color: #fff; }

  .mega__desc {
    display: block;
    font-family: var(--font-body);
    font-size: clamp(11px, 0.85vw, 13px);
    font-weight: 300;
    color: rgba(255,255,255,0.38);
    margin-top: 0.35rem;
    transition: color 0.18s;
  }

  .mega__item:hover .mega__desc { color: rgba(255,255,255,0.6); }

  .mega__arrow {
    font-size: 1.5rem;
    color: var(--color-accent);
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.2s, transform 0.2s;
  }

  .mega__item:hover .mega__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Panel immagine featured ── */
  .mega__feature {
    position: relative;
    min-height: 280px;
    overflow: hidden;
    background: #080809;
  }

  .mega__feat-img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 0.45s ease, transform 0.6s ease;
  }

  /* Prima immagine visibile di default */
  .mega__feat-img--1 {
    opacity: 0.7;
    transform: scale(1);
  }

  /* CSS :has() — cambia immagine in base all'item in hover */
  .mega--adulti:has(.mega__item:nth-child(1) a:hover) .mega__feat-img--1,
  .mega--junior:has(.mega__item:nth-child(1) a:hover) .mega__feat-img--1 {
    opacity: 0.85; transform: scale(1);
  }
  .mega--adulti:has(.mega__item:nth-child(2) a:hover) .mega__feat-img--1,
  .mega--junior:has(.mega__item:nth-child(2) a:hover) .mega__feat-img--1 { opacity: 0; }
  .mega--adulti:has(.mega__item:nth-child(3) a:hover) .mega__feat-img--1,
  .mega--junior:has(.mega__item:nth-child(3) a:hover) .mega__feat-img--1 { opacity: 0; }

  .mega--adulti:has(.mega__item:nth-child(2) a:hover) .mega__feat-img--2,
