    border-color: var(--color-accent);
    color: var(--color-accent);
  }

</style>

<script>
  // ── Language dropdown ──
  const langSwitcher = document.getElementById('lang-switcher') as HTMLElement | null;
  const langToggle   = document.getElementById('lang-toggle')   as HTMLButtonElement | null;

  langToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = langSwitcher?.classList.toggle('is-open');
    langToggle.setAttribute('aria-expanded', String(!!open));
  });

  document.addEventListener('click', (e) => {
    if (!langSwitcher?.contains(e.target as Node)) {
      langSwitcher?.classList.remove('is-open');
      langToggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // ── Modal Accedi ──
  const accediModal = document.getElementById('modal-accedi') as HTMLDialogElement | null;
  document.getElementById('btn-accedi')?.addEventListener('click', () => accediModal?.showModal());
  document.getElementById('accedi-close')?.addEventListener('click', () => accediModal?.close());
  accediModal?.addEventListener('click', (e) => { if (e.target === accediModal) accediModal.close(); });

  // Smart app store link — iOS → App Store, Android → Play Store
  const btnApp = document.getElementById('btn-app-store') as HTMLAnchorElement | null;
  if (btnApp) {
    const ua = navigator.userAgent;
    if (/iphone|ipad|ipod/i.test(ua)) {
      btnApp.href = 'https://apps.apple.com/it/app/club-ambrosiano/id1583896957';
    } else if (/android/i.test(ua)) {
      btnApp.href = 'https://play.google.com/store/apps/details?id=com.perfectgym.perfectgymgo2.ambrosiano&pcampaignid=web_share';
    } else {
      // Desktop: mostra entrambe le opzioni aprendo il Play Store come fallback generico
      btnApp.href = 'https://apps.apple.com/it/app/club-ambrosiano/id1583896957';
    }
  }

  const menu   = document.getElementById('g-menu') as HTMLElement | null;
  const burger = document.getElementById('burger-btn') as HTMLButtonElement | null;

  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    document.body.classList.toggle('menu-open', open ?? false);
    burger.setAttribute('aria-expanded', String(!!open));
    menu?.setAttribute('aria-hidden', String(!open));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      menu?.classList.remove('is-open');
      document.body.classList.remove('menu-open');
      burger?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
      // chiudi anche i mega menu
      document.querySelectorAll('.navbar__item--mega.is-open').forEach(el => el.classList.remove('is-open'));
    }
  });

  // Desktop mega menu — click toggle
  document.querySelectorAll<HTMLElement>('.navbar__item--mega').forEach((item) => {
    const btn = item.querySelector<HTMLButtonElement>('.navbar__link--btn');
    btn?.addEventListener('click', () => {
      const isOpen = item.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(isOpen));
      // chiudi gli altri
      document.querySelectorAll<HTMLElement>('.navbar__item--mega').forEach((other) => {
        if (other !== item) {
          other.classList.remove('is-open');
          other.querySelector<HTMLButtonElement>('.navbar__link--btn')?.setAttribute('aria-expanded', 'false');
        }
      });
    });

    // Chiudi cliccando fuori
    document.addEventListener('click', (e) => {
      if (!item.contains(e.target as Node)) {
        item.classList.remove('is-open');
        btn?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
