---
import { getLocalePath, getAlternatePath, type Lang } from '../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'it' } = Astro.props;

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const rawPath = Astro.url.pathname;
const cleanPath = base && rawPath.startsWith(base)
  ? (rawPath.slice(base.length) || '/')
  : rawPath;
const { it: itClean } = getAlternatePath(cleanPath);
const itPath = getLocalePath('it', itClean);
const enPath = getLocalePath('en', itClean);
---

<div class="cl-lang" id="cl-lang" aria-label="Seleziona lingua / Select language">
  <button class="cl-lang__toggle" id="cl-lang-toggle" aria-haspopup="listbox" aria-expanded="false">
    {lang === 'it' ? (
      <svg class="lang-flag" width="18" height="13" viewBox="0 0 3 2" aria-hidden="true"><rect width="1" height="2" fill="#009246"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#ce2b37"/></svg>
    ) : (
      <svg class="lang-flag" width="18" height="13" viewBox="0 0 60 30" aria-hidden="true"><rect width="60" height="30" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#c8102e" stroke-width="4"/><path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/><path d="M30,0 V30 M0,15 H60" stroke="#c8102e" stroke-width="6"/></svg>
    )}
    <span class="cl-lang__label">{lang.toUpperCase()}</span>
    <svg class="cl-lang__chevron" width="8" height="5" viewBox="0 0 8 5" fill="none" aria-hidden="true">
      <path d="M1 1L4 4L7 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <ul class="cl-lang__dropdown" role="listbox" aria-label="Seleziona lingua">
    <li role="option" aria-selected={lang === 'it'}>
      <a class={`cl-lang__option${lang === 'it' ? ' is-active' : ''}`} href={itPath} hreflang="it">
        <svg class="lang-flag" width="18" height="13" viewBox="0 0 3 2" aria-hidden="true"><rect width="1" height="2" fill="#009246"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#ce2b37"/></svg>
        IT <span class="cl-lang__option-label">Italiano</span>
      </a>
    </li>
    <li role="option" aria-selected={lang === 'en'}>
      <a class={`cl-lang__option${lang === 'en' ? ' is-active' : ''}`} href={enPath} hreflang="en">
        <svg class="lang-flag" width="18" height="13" viewBox="0 0 60 30" aria-hidden="true"><rect width="60" height="30" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#c8102e" stroke-width="4"/><path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10"/><path d="M30,0 V30 M0,15 H60" stroke="#c8102e" stroke-width="6"/></svg>
        EN <span class="cl-lang__option-label">English</span>
      </a>
    </li>
  </ul>
</div>

<script>
  const wrap   = document.getElementById('cl-lang') as HTMLElement | null;
  const toggle = document.getElementById('cl-lang-toggle') as HTMLButtonElement | null;

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = wrap?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });

  document.addEventListener('click', (e) => {
    if (!wrap?.contains(e.target as Node)) {
      wrap?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .cl-lang {
    position: fixed;
    top: clamp(1rem, 3vh, 1.75rem);
    left: clamp(1rem, 3vw, 2rem);
    z-index: 700;
  }

  .lang-flag {
    display: inline-block;
    flex-shrink: 0;
    border-radius: 1px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    width: 22px;
    height: 15px;
  }

  .cl-lang__toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    background: #fff;
    border: none;
    cursor: pointer;
    padding: 12px 16px;
    border-radius: 999px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
    transition: box-shadow 0.15s;
  }

  .cl-lang.is-open .cl-lang__toggle,
  .cl-lang__toggle:hover {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.22);
  }

  .cl-lang__chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
    color: var(--color-text-light);
  }

  .cl-lang.is-open .cl-lang__chevron { transform: rotate(180deg); }

  .cl-lang__dropdown {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    background: #ffffff;
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.14);
    list-style: none;
    min-width: 140px;
    border-radius: 8px;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease;
  }

  .cl-lang.is-open .cl-lang__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .cl-lang__option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .cl-lang__option:hover {
    background: var(--color-off-white);
    color: var(--color-text);
  }

  .cl-lang__option.is-active {
    color: var(--color-accent);
    pointer-events: none;
  }

  .cl-lang__option-label {
    font-weight: 300;
    letter-spacing: 0.04em;
    text-transform: none;
    font-family: var(--font-body);
    color: inherit;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .cl-lang__label { display: none; }
    .cl-lang__toggle { padding: 12px; }
  }
</style>
