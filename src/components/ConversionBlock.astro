---
import type { Lang } from '../i18n/utils';
interface Props { lang?: Lang; }
const { lang = 'it' } = Astro.props;

const c = lang === 'en' ? {
  eyebrow: 'Get started',
  title:   'Ready to begin?',
  sub:     'Choose your starting point.',
  card1title: 'Become a Member',
  card1text:  'Access all Club facilities and make the most of them every day. Choose the membership that suits you and your family and sign up online in minutes.',
  card1cta:   'Sign Up Online',
  card2title: 'Want to try the Club?',
  card2text:  'Click below to request a trial of your favourite activity: Athletic Training, Tennis School, Tennis and Padel.',
  card2cta:   'Request a Trial',
} : {
  eyebrow: 'Inizia ora',
  title:   'Pronto a iniziare?',
  sub:     'Scegli il tuo punto di partenza.',
  card1title: 'Diventa Socio',
  card1text:  'Accedi a tutti gli impianti del Club e vivilo ogni giorno. Scegli la membership più adatta a te e alla tua famiglia e iscriviti online in pochi minuti.',
  card1cta:   'Iscriviti Online',
  card2title: 'Vuoi provare il Club?',
  card2text:  'Clicca qui sotto per richiedere la prova della tua attività preferita: Preparazione Atletica, Scuola Tennis, Tennis e Padel.',
  card2cta:   'Richiedi la Prova',
};
---

<section class="conversion">
  <div class="conversion__inner">
    <span class="eyebrow eyebrow--grey">{c.eyebrow}</span>
    <h2 class="conversion__title">
      {c.title}<br /><em>{c.sub}</em>
    </h2>

    <div class="conversion__grid">
      <div class="conversion__card conversion__card--light">
        <h3 class="conversion__card-title">{c.card1title}</h3>
        <p class="conversion__card-text">{c.card1text}</p>
        <a class="btn btn-red" href="https://tcambrosiano.perfectgym.com/clientportal2/#/Registration" target="_blank" rel="noopener noreferrer">{c.card1cta}</a>
      </div>

      <div class="conversion__card conversion__card--dark">
        <h3 class="conversion__card-title">{c.card2title}</h3>
        <p class="conversion__card-text">{c.card2text}</p>
        <button class="btn btn-outline" data-open-modal="modal-contatti">{c.card2cta}</button>
      </div>
    </div>
  </div>
</section>

<style>
  .conversion {
    padding: 7vh var(--pad-x);
  }

  .conversion__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .conversion__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .conversion__title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .conversion__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .conversion__card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    gap: 1rem;
  }

  .conversion__card--light {
    background: var(--color-bg);
  }

  .conversion__card--dark {
    background: var(--color-accent);
    color: #fff;
  }

  .conversion__card--dark .btn-outline {
    border-color: rgba(255, 255, 255, 0.55);
    color: #fff;
  }

  .conversion__card-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2vw, 2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .conversion__card-text {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.98vw, 16px);
    font-weight: 300;
    line-height: 1.7;
    flex: 1;
  }

  .conversion__card--light .conversion__card-text {
    color: var(--color-text-light);
  }

  .conversion__card--dark .conversion__card-text {
    color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 760px) {
    .conversion__grid { grid-template-columns: 1fr; }
  }
</style>
