---
---

<section class="ms">
  <div class="ms__inner">

    <div class="ms__head">
      <span class="eyebrow">Membership</span>
      <h2 class="ms__title">Scegli il tuo<br><em>abbonamento.</em></h2>
      <p class="ms__sub">
        Tre livelli pensati per esigenze diverse. Tutti i soci accedono alle strutture
        del Club, alle agevolazioni e all'atmosfera unica dell'Ambrosiano.
      </p>
    </div>

    <!-- Tab switcher — visibile solo su mobile -->
    <div class="ms__tabs" role="tablist" aria-label="Seleziona abbonamento">
      <button class="ms__tab ms__tab--silver ms__tab--active" data-tier="silver" role="tab" aria-selected="true">Silver</button>
      <button class="ms__tab ms__tab--gold"                   data-tier="gold"   role="tab" aria-selected="false">Gold</button>
      <button class="ms__tab ms__tab--platinum"               data-tier="platinum" role="tab" aria-selected="false">Platinum</button>
    </div>

    <div class="ms__table-wrap">
      <table class="ms__table">
        <colgroup>
          <col class="col-feat">
          <col class="col-silver">
          <col class="col-gold">
          <col class="col-platinum">
        </colgroup>
        <thead>
          <tr class="ms__head-row">
            <th class="ms__th ms__th--feat"></th>

            <th class="ms__th ms__th--silver">
              <span class="ms__tier-name">Silver</span>
              <button class="ms__discover" data-open-modal="modal-contatti">Scopri di più</button>
            </th>

            <th class="ms__th ms__th--gold">
              <span class="ms__tier-name">Gold</span>
              <button class="ms__discover" data-open-modal="modal-contatti">Scopri di più</button>
            </th>

            <th class="ms__th ms__th--platinum">
              <span class="ms__plat-badge">Più completo</span>
              <span class="ms__tier-name">Platinum</span>
              <button class="ms__discover ms__discover--plat" data-open-modal="modal-contatti">Scopri di più</button>
            </th>
          </tr>
        </thead>
        <tbody>

          <tr class="ms__cat-row">
            <td colspan="4" class="ms__cat-label">Accesso ai campi</td>
          </tr>
          <tr>
            <td class="ms__feat">Campi da tennis all'aperto</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--yes">Incluso</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Incluso</td>
          </tr>
          <tr>
            <td class="ms__feat">Campi da tennis al coperto</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Incluso</td>
          </tr>
          <tr>
            <td class="ms__feat">Campi da padel</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Incluso</td>
          </tr>

          <tr class="ms__cat-row">
            <td colspan="4" class="ms__cat-label">Preparazione Atletica</td>
          </tr>
          <tr>
            <td class="ms__feat">Sale di allenamento</td>
            <td class="ms__cell ms__cell--yes">Incluso</td>
            <td class="ms__cell ms__cell--yes">Incluso</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Incluso</td>
          </tr>
          <tr>
            <td class="ms__feat">Corsi di gruppo</td>
            <td class="ms__cell ms__cell--partial">Selezione inclusa</td>
            <td class="ms__cell ms__cell--yes">Tutti inclusi</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Tutti inclusi</td>
          </tr>

          <tr class="ms__cat-row">
            <td colspan="4" class="ms__cat-label">Priorità di prenotazione</td>
          </tr>
          <tr>
            <td class="ms__feat">Anticipo prenotazione campi</td>
            <td class="ms__cell ms__cell--value">4 giorni</td>
            <td class="ms__cell ms__cell--value">7 giorni</td>
            <td class="ms__cell ms__cell--value ms__cell--plat">10 giorni</td>
          </tr>
          <tr>
            <td class="ms__feat">Prenotazioni anticipate tennis</td>
            <td class="ms__cell ms__cell--value">2 / sett.</td>
            <td class="ms__cell ms__cell--value">3 / sett.</td>
            <td class="ms__cell ms__cell--value ms__cell--plat">4 / sett.</td>
          </tr>
          <tr>
            <td class="ms__feat">Prenotazioni anticipate padel</td>
            <td class="ms__cell ms__cell--value">1 / sett.</td>
            <td class="ms__cell ms__cell--value">2 / sett.</td>
            <td class="ms__cell ms__cell--value ms__cell--plat">2 / sett.</td>
          </tr>

          <tr class="ms__cat-row">
            <td colspan="4" class="ms__cat-label">Vantaggi economici</td>
          </tr>
          <tr>
            <td class="ms__feat">Tariffe agevolate su corsi</td>
            <td class="ms__cell ms__cell--check">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
            <td class="ms__cell ms__cell--check">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
            <td class="ms__cell ms__cell--check ms__cell--plat">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
          </tr>
          <tr>
            <td class="ms__feat">Sconto su lezioni individuali</td>
            <td class="ms__cell ms__cell--check">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
            <td class="ms__cell ms__cell--check">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
            <td class="ms__cell ms__cell--check ms__cell--plat">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
          </tr>

        </tbody>
      </table>
    </div>

  </div>
</section>

<style>
  /* ── Sezione ── */
  .ms {
    padding: 7vh var(--pad-x) 8vh;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .ms__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* ── Head ── */
  .ms__head { margin-bottom: 4vh; }

  .ms__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-top: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .ms__title em { color: var(--color-accent); font-style: normal; }

  .ms__sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.05vw, 17px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
    max-width: 58ch;
  }

  /* ── Tab switcher (solo mobile) ── */
  .ms__tabs {
    display: none;
  }

  /* ── Table wrapper ── */
  .ms__table-wrap {
    border: 1px solid var(--color-border);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ms__table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  /* ── Column widths (desktop) ── */
  .col-feat     { width: 40%; }
  .col-silver   { width: 20%; }
  .col-gold     { width: 20%; }
  .col-platinum { width: 20%; }

  /* ── Header row ── */
  .ms__th {
    padding: 28px 20px 24px;
    text-align: center;
    vertical-align: bottom;
    background: var(--color-off-white);
    border-bottom: 1px solid var(--color-border);
  }

  .ms__th--feat    { text-align: left; }
  .ms__th--silver  { border-top: 4px solid #6B7280; }
  .ms__th--gold    { border-top: 4px solid #A07B10; }
  .ms__th--platinum {
    border-top: 4px solid var(--color-accent);
    background: #FBF3F3;
  }

  /* Tier name — grande e visibile */
  .ms__tier-name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.4vw, 2.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1;
    margin-bottom: 12px;
  }

  .ms__th--silver   .ms__tier-name { color: #4B5563; }
  .ms__th--gold     .ms__tier-name { color: #7A5E0A; }
  .ms__th--platinum .ms__tier-name { color: var(--color-accent); }

  /* Badge Platinum */
  .ms__plat-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(139, 26, 26, 0.1);
    padding: 3px 10px;
    margin-bottom: 8px;
  }

  /* Bottone "Scopri di più" */
  .ms__discover {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(10px, 0.75vw, 11px);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-light);
    background: none;
    border: 1px solid var(--color-border);
    padding: 7px 14px;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    white-space: nowrap;
  }

  .ms__discover:hover {
    background: var(--color-text);
    border-color: var(--color-text);
    color: #fff;
  }

  .ms__discover--plat {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .ms__discover--plat:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* ── Category rows ── */
  .ms__cat-row .ms__cat-label {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-light);
    padding: 10px 20px 8px;
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Feature rows ── */
  .ms__table tbody tr:not(.ms__cat-row) {
    border-bottom: 1px solid var(--color-border);
  }

  .ms__table tbody tr:not(.ms__cat-row):last-child {
    border-bottom: none;
  }

  .ms__table tbody tr:not(.ms__cat-row):hover {
    background: rgba(0, 0, 0, 0.018);
  }

  .ms__feat {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 14.5px);
    font-weight: 400;
    color: var(--color-text);
    padding: 15px 20px;
    vertical-align: middle;
  }

  /* ── Data cells ── */
  .ms__cell {
    font-family: var(--font-body);
    font-size: clamp(12.5px, 0.88vw, 14px);
    text-align: center;
    padding: 15px 12px;
    vertical-align: middle;
  }

  .ms__cell--yes     { color: #1A6636; font-weight: 600; }
  .ms__cell--partial { color: #7A5E0A; font-weight: 400; }

  .ms__cell--value {
    color: var(--color-text);
    font-weight: 700;
    font-family: var(--font-display);
    font-size: clamp(12px, 0.88vw, 13.5px);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ms__cell--check { color: #1A6636; }

  .ms__cell--check svg {
    display: inline-block;
    vertical-align: middle;
  }

  .ms__cell--plat { background: rgba(139, 26, 26, 0.04); }

  /* ── MOBILE ── */
  @media (max-width: 768px) {

    /* Tab switcher */
    .ms__tabs {
      display: flex;
      border: 1px solid var(--color-border);
      border-bottom: none;
      overflow: hidden;
    }

    .ms__tab {
      flex: 1;
      font-family: var(--font-display);
      font-size: clamp(0.8rem, 3.8vw, 1rem);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 13px 4px;
      background: var(--color-off-white);
      border: none;
      border-right: 1px solid var(--color-border);
      border-bottom: 3px solid transparent;
      cursor: pointer;
      color: var(--color-text-light);
      transition: background 0.15s, color 0.15s, border-bottom-color 0.15s;
    }

    .ms__tab:last-child { border-right: none; }

    .ms__tab--silver.ms__tab--active {
      background: #fff;
      color: #4B5563;
      border-bottom-color: #6B7280;
    }

    .ms__tab--gold.ms__tab--active {
      background: #fff;
      color: #7A5E0A;
      border-bottom-color: #A07B10;
    }

    .ms__tab--platinum.ms__tab--active {
      background: #FBF3F3;
      color: var(--color-accent);
      border-bottom-color: var(--color-accent);
    }

    /* Tabella senza scroll orizzontale */
    .ms__table-wrap {
      overflow-x: visible;
      border-top: none;
    }

    /* table-layout: auto — il browser ignora le colonne collassate
       e ridistribuisce lo spazio tra le due colonne visibili */
    .ms__table {
      table-layout: auto;
      width: 100%;
    }

    /* Azzera le larghezze fisse: su mobile ci pensa auto-layout */
    .col-feat,
    .col-silver,
    .col-gold,
    .col-platinum { width: auto; }

    /* Intestazione: cella feat vuota, tier col più compatta */
    .ms__th {
      padding: 18px 12px 16px;
    }

    .ms__th--feat {
      background: var(--color-off-white);
      border-top: 4px solid transparent;
    }

    .ms__tier-name {
      font-size: clamp(1.5rem, 7vw, 2rem);
      margin-bottom: 10px;
    }

    .ms__plat-badge {
      font-size: 9px;
      padding: 2px 8px;
      margin-bottom: 6px;
    }

    .ms__discover {
      font-size: 10px;
      padding: 6px 10px;
      white-space: normal;
      line-height: 1.3;
    }

    /* Celle dati */
    .ms__feat {
      font-size: 13px;
      padding: 13px 14px;
    }

    .ms__cell {
      font-size: 13px;
      padding: 13px 10px;
    }

    .ms__cell--value {
      font-size: 12px;
    }
  }
</style>

<script>
  (function () {
    var BREAKPOINT = 768;

    var table = document.querySelector<HTMLTableElement>('.ms__table');
    var tabs  = Array.from(document.querySelectorAll<HTMLButtonElement>('.ms__tab'));
    var currentTier = 'silver';

    // Indici (1-based) delle celle tier nell'array row.cells:
    // [0]=feat, [1]=silver, [2]=gold, [3]=platinum
    var TIER_IDX: Record<string, number> = { silver: 1, gold: 2, platinum: 3 };

    function setTier(tier: string) {
      currentTier = tier;
      var isMobile = window.innerWidth <= BREAKPOINT;

      if (!table) return;

      table.querySelectorAll('tr:not(.ms__cat-row)').forEach((row) => {
        var cells = Array.from((row as HTMLTableRowElement).cells);
        if (cells.length < 4) return;

        if (isMobile) {
          // Mostra solo feat [0] + colonna tier attiva
          cells[1].style.display = tier === 'silver'   ? '' : 'none';
          cells[2].style.display = tier === 'gold'     ? '' : 'none';
          cells[3].style.display = tier === 'platinum' ? '' : 'none';
        } else {
          // Desktop: ripristina tutto
          cells.forEach((c) => (c.style.display = ''));
        }
      });

      // Aggiorna tab
      tabs.forEach((btn) => {
        var active = btn.dataset.tier === tier;
        btn.classList.toggle('ms__tab--active', active);
        btn.setAttribute('aria-selected', String(active));
      });
    }

    function applyLayout() {
      setTier(currentTier);
    }

    tabs.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.tier) setTier(btn.dataset.tier);
      });
    });

    applyLayout();
    window.addEventListener('resize', applyLayout);
  })();
</script>
