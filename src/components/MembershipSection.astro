---
import type { Lang } from '../i18n/utils';
import { getEntry } from 'astro:content';
interface Props { lang?: Lang; }
const { lang = 'it' } = Astro.props;
const tx = (itVal: string, enVal?: string) => (lang === 'en' && enVal ? enVal : itVal);

// Tabella membership gestibile da TinaCMS → src/content/membership/membership.md
const m = (await getEntry('membership', 'membership'))!.data;

const cellClass = (tipo: string, isPlat: boolean) => {
  const map: Record<string, string> = {
    incluso: 'ms__cell--yes',
    parziale: 'ms__cell--partial',
    valore: 'ms__cell--value',
    check: 'ms__cell--check',
  };
  return `ms__cell ${map[tipo]}${isPlat ? ' ms__cell--plat' : ''}`;
};

const REGISTER_URL = 'https://tcambrosiano.perfectgym.com/clientportal2/#/Registration';

// Il tfoot è emesso via set:html per aggirare un bug del compilatore Astro:
// un elemento di formattazione (<a>) in coda a una <table> viene "ricostruito"
// duplicato (vuoto ma cliccabile) dopo ogni contenitore chiuso. Con set:html
// il compilatore non parsa il markup e il problema sparisce. NB: le classi
// usate qui sotto richiedono selettori :global negli stili scoped.
const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
const ctaLabel = esc(tx(m.cta_label, m.cta_label_en));
const footHtml = `
  <tr class="ms__foot-row">
    <td class="ms__foot-cell ms__foot-cell--feat"></td>
    <td class="ms__foot-cell ms__foot-cell--silver">
      <a class="ms__discover" href="${REGISTER_URL}" target="_blank" rel="noopener noreferrer">${ctaLabel}</a>
    </td>
    <td class="ms__foot-cell ms__foot-cell--gold">
      <a class="ms__discover" href="${REGISTER_URL}" target="_blank" rel="noopener noreferrer">${ctaLabel}</a>
    </td>
    <td class="ms__foot-cell ms__foot-cell--platinum">
      <a class="ms__discover ms__discover--plat" href="${REGISTER_URL}" target="_blank" rel="noopener noreferrer">${ctaLabel}</a>
    </td>
  </tr>`;
---

<section class="ms">
  <div class="ms__inner">

    <div class="ms__head">
      <span class="eyebrow">Membership</span>
      <h2 class="ms__title">{tx(m.titolo, m.titolo_en)}<br><em>{tx(m.titolo_accent, m.titolo_accent_en)}</em></h2>
      <p class="ms__sub">{tx(m.sottotitolo, m.sottotitolo_en)}</p>
    </div>

    <div class="ms__table-wrap">
      <table class="ms__table">
        <colgroup>
          <col class="col-feat">
          <col class="col-silver">
          <col class="col-gold">
          <col class="col-platinum">
        </colgroup>
        <thead>
          <tr class="ms__head-row">
            <th class="ms__th ms__th--feat"></th>

            <th class="ms__th ms__th--silver">
              <span class="ms__tier-name">{m.silver_nome}</span>
            </th>

            <th class="ms__th ms__th--gold">
              <span class="ms__tier-name">{m.gold_nome}</span>
            </th>

            <th class="ms__th ms__th--platinum">
              <span class="ms__plat-badge">{tx(m.platinum_badge, m.platinum_badge_en)}</span>
              <span class="ms__tier-name">{m.platinum_nome}</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {m.categorie.map((cat) => (
            <>
              <tr class="ms__cat-row">
                <td class="ms__cat-label">{tx(cat.label, cat.label_en)}</td>
                <td class="ms__cat-fill" colspan="3"></td>
              </tr>
              {cat.righe.map((r) => (
                <tr>
                  <td class="ms__feat">
                    {tx(r.feature, r.feature_en)}
                    {r.feature_tooltip && (
                      <span class="ms__info" tabindex="0">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9.5" stroke="currentColor" stroke-width="1.6"/><path d="M12 11v5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="12" cy="7.8" r="1.1" fill="currentColor"/></svg>
                        <span class="ms__tooltip" role="tooltip">{tx(r.feature_tooltip, r.feature_tooltip_en)}</span>
                      </span>
                    )}
                  </td>
                  <td class={cellClass(r.silver_tipo, false)}>
                    {r.silver_tipo === 'check'
                      ? <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      : tx(r.silver_valore ?? '', r.silver_valore_en)}
                  </td>
                  <td class={cellClass(r.gold_tipo, false)}>
                    {r.gold_tipo === 'check'
                      ? <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      : tx(r.gold_valore ?? '', r.gold_valore_en)}
                  </td>
                  <td class={cellClass(r.platinum_tipo, true)}>
                    {r.platinum_tipo === 'check'
                      ? <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-opacity=".2"/><path d="M5 9.5l2.8 2.8 5.2-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      : tx(r.platinum_valore ?? '', r.platinum_valore_en)}
                  </td>
                </tr>
              ))}
            </>
          ))}
        </tbody>
        <tfoot set:html={footHtml} />
      </table>
    </div>

  </div>
</section>

<style>
  /* ── Sezione ── */
  .ms {
    padding: 7vh var(--pad-x) 8vh;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .ms__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* ── Head ── */
  .ms__head { margin-bottom: 4vh; }

  .ms__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-top: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .ms__title em { color: var(--color-accent); font-style: normal; }

  .ms__sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.05vw, 17px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  /* ── Table wrapper ── */
  .ms__table-wrap {
    position: relative;
    border: 1px solid var(--color-border);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }

  .ms__table-wrap::-webkit-scrollbar { display: none; }

  .ms__table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  /* ── Column widths — desktop ── */
  .col-feat     { width: 28%; }
  .col-silver   { width: 24%; }
  .col-gold     { width: 24%; }
  .col-platinum { width: 24%; }

  /* ── Header row ── */
  .ms__th {
    padding: 28px 20px 24px;
    text-align: center;
    vertical-align: bottom;
    background: var(--color-off-white);
    border-bottom: 1px solid var(--color-border);
  }

  .ms__th--feat    { text-align: left; }
  .ms__th--silver  { border-top: 4px solid #6B7280; }
  .ms__th--gold    { border-top: 4px solid #A07B10; }
  .ms__th--platinum {
    border-top: 4px solid var(--color-accent);
    background: #FBF3F3;
  }

  /* Tier name */
  .ms__tier-name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.4vw, 2.4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1;
    margin-bottom: 12px;
  }

  .ms__th--silver   .ms__tier-name { color: #4B5563; }
  .ms__th--gold     .ms__tier-name { color: #7A5E0A; }
  .ms__th--platinum .ms__tier-name { color: var(--color-accent); }

  /* Badge Platinum */
  .ms__plat-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(139, 26, 26, 0.1);
    padding: 3px 10px;
    margin-bottom: 8px;
  }

  /* Bottone "Scopri di più" — :global perché il tfoot è emesso via set:html
     (vedi nota nel frontmatter) e non riceve l'attributo di scoping */
  .ms__table :global(.ms__discover) {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(12px, 1vw, 14px);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: var(--color-text);
    border: 2px solid var(--color-text);
    padding: 13px 32px;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    white-space: nowrap;
  }

  .ms__table :global(.ms__discover:hover) {
    background: #333;
    border-color: #333;
    color: #fff;
  }

  .ms__table :global(.ms__discover--plat) {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .ms__table :global(.ms__discover--plat:hover) {
    background: var(--color-accent-dark);
    border-color: var(--color-accent-dark);
    color: #fff;
  }

  /* ── Category fill cells (le 3 colonne destra nelle righe categoria) ── */
  .ms__cat-fill {
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Category rows ── */
  .ms__cat-row .ms__cat-label {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-light);
    padding: 10px 20px 8px;
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Feature rows ── */
  .ms__table tbody tr:not(.ms__cat-row) {
    border-bottom: 1px solid var(--color-border);
  }

  .ms__table tbody tr:not(.ms__cat-row):last-child {
    border-bottom: none;
  }

  /* Solo su dispositivi con puntatore preciso (mouse): su touch lo stato
     :hover resta agganciato all'ultima riga toccata, lasciando una riga
     grigia "bloccata" durante lo scorrimento orizzontale. */
  @media (hover: hover) and (pointer: fine) {
    .ms__table tbody tr:not(.ms__cat-row):hover {
      background: rgba(0, 0, 0, 0.018);
    }
  }

  .ms__feat {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 14.5px);
    font-weight: 400;
    color: var(--color-text);
    padding: 15px 20px;
    vertical-align: middle;
  }

  /* ── Info tooltip ── */
  .ms__info {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: 5px;
    color: var(--color-text-light);
    cursor: help;
    vertical-align: middle;
  }

  .ms__info:hover,
  .ms__info:focus,
  .ms__info:focus-visible {
    color: var(--color-accent);
    outline: none;
  }

  .ms__tooltip {
    position: absolute;
    left: 0;
    bottom: calc(100% + 10px);
    z-index: 20;
    width: max-content;
    max-width: 260px;
    background: var(--color-text);
    color: #fff;
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 300;
    line-height: 1.5;
    padding: 10px 12px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    pointer-events: none;
  }

  .ms__info:hover .ms__tooltip,
  .ms__info:focus .ms__tooltip,
  .ms__info:focus-visible .ms__tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* ── Data cells ── */
  .ms__cell {
    font-family: var(--font-body);
    font-size: clamp(12.5px, 0.88vw, 14px);
    text-align: center;
    padding: 15px 12px;
    vertical-align: middle;
  }

  .ms__cell--yes     { color: #1A6636; font-weight: 600; }
  .ms__cell--partial { color: #7A5E0A; font-weight: 400; }

  .ms__cell--value {
    color: var(--color-text);
    font-weight: 700;
    font-family: var(--font-display);
    font-size: clamp(12px, 0.88vw, 13.5px);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ms__cell--check { color: #1A6636; }

  .ms__cell--check svg {
    display: inline-block;
    vertical-align: middle;
  }

  .ms__cell--plat { background: rgba(139, 26, 26, 0.04); }

  /* ── Footer row (Scopri di più) — :global per il set:html del tfoot ── */
  .ms__table :global(.ms__foot-row) { border-top: 1px solid var(--color-border); }

  .ms__table :global(.ms__foot-cell) {
    padding: 20px 20px;
    text-align: center;
    background: var(--color-off-white);
    vertical-align: middle;
  }

  .ms__table :global(.ms__foot-cell--feat) { background: var(--color-bg); }
  .ms__table :global(.ms__foot-cell--platinum) { background: #FBF3F3; }

  /* ── MOBILE: scroll orizzontale + prima colonna sticky ── */
  @media (max-width: 768px) {

    /* Rimuovi padding orizzontale della sezione per far andare
       la tabella edge-to-edge e massimizzare lo spazio utile */
    .ms {
      padding-left: 0;
      padding-right: 0;
    }

    .ms__head {
      padding-left: var(--pad-x);
      padding-right: var(--pad-x);
    }

    .ms__table-wrap {
      border-left: none;
      border-right: none;
    }

    /* Colonna feature: fissa, abbastanza larga da leggere le label */
    .col-feat     { width: 29vw; }
    /* Ogni colonna tier occupa ~36vw → su 375px si vede
       feat (157px) + silver (135px) + ~83px di gold = chiaro che c'è altro */
    .col-silver   { width: 36vw; }
    .col-gold     { width: 36vw; }
    .col-platinum { width: 36vw; }

    /* La tabella è più larga del viewport → scroll */
    .ms__table {
      width: calc(42vw + 36vw * 3); /* 150vw */
      /* border-collapse: separate è necessario per il corretto funzionamento
         di position: sticky sulla prima colonna in Safari/Chrome */
      border-collapse: separate;
      border-spacing: 0;
    }

    /* Con separate collapse i border su <tr> non vengono renderizzati:
       sposta i bordi orizzontali sulle singole celle */
    .ms__table tbody tr:not(.ms__cat-row) .ms__feat,
    .ms__table tbody tr:not(.ms__cat-row) .ms__cell {
      border-bottom: 1px solid var(--color-border);
    }

    /* Righe categoria: il border-bottom della riga precedente già separa,
       rimuovi border-top per evitare doppio bordo */
    .ms__cat-row .ms__cat-label,
    .ms__cat-row .ms__cat-fill {
      border-top: none;
    }

    /* ── Sticky: prima colonna bloccata a sinistra ── */
    .ms__th--feat,
    .ms__feat,
    .ms__cat-row .ms__cat-label,
    .ms__table :global(.ms__foot-cell--feat) {
      position: sticky;
      left: 0;
      z-index: 2;
      /* Ombra sottile che separa la colonna fissa da quelle scorrevoli */
      box-shadow: 3px 0 8px -2px rgba(0,0,0,0.10);
    }

    /* Header sticky: z-index maggiore per stare sopra le celle body */
    .ms__th--feat {
      z-index: 3;
      background: var(--color-off-white);
    }

    /* Celle body prima colonna: sfondo opaco per coprire il contenuto che scorre */
    .ms__feat {
      background: var(--color-bg);
    }

    /* Righe categoria: label sticky */
    .ms__cat-row .ms__cat-label {
      background: var(--color-off-white);
    }

    /* Footer prima colonna */
    .ms__table :global(.ms__foot-cell--feat) {
      background: var(--color-bg);
    }

    /* Hover prima cella: solo su mouse (vedi nota sopra). Colore OPACO
       (#FAFAFA = rgba(0,0,0,0.018) su bianco) così, anche se :hover si
       agganciasse, le celle dei valori che scorrono sotto non traspaiono
       mai attraverso la colonna sticky. */
    @media (hover: hover) and (pointer: fine) {
      .ms__table tbody tr:not(.ms__cat-row):hover .ms__feat {
        background: #FAFAFA;
      }
    }

    /* Header più compatto */
    .ms__th {
      padding: 20px 12px 16px;
    }

    .ms__tier-name {
      font-size: 1.5rem;
      margin-bottom: 10px;
    }

    .ms__plat-badge {
      font-size: 9px;
      padding: 2px 8px;
      margin-bottom: 6px;
    }

    .ms__table :global(.ms__discover) {
      font-size: 12px;
      padding: 12px 20px;
      width: 100%;
      text-align: center;
      box-sizing: border-box;
    }

    .ms__feat {
      font-size: 12.5px;
      padding: 13px 14px;
    }

    .ms__cell {
      font-size: 12.5px;
      padding: 13px 10px;
    }

    .ms__cell--value { font-size: 12px; }

    /* Sfumatura destra — segnala che c'è altro da scorrere */
    .ms__table-wrap::after {
      content: '';
      position: sticky;
      right: 0;
      top: 0;
      display: block;
      width: 40px;
      height: 100%;
      margin-left: -40px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.85));
      pointer-events: none;
      flex-shrink: 0;
    }
  }
</style>

<script>
  (function () {
    var BREAKPOINT = 768;

    function runPeek(wrap: HTMLElement) {
      // ~1 colonna tier in px (34vw)
      var peek = Math.round(window.innerWidth * 0.34);
      var fwdMs  = 900;  // andata
      var holdMs = 550;  // pausa
      var bckMs  = 650;  // ritorno

      var start: number | null = null;
      var phase: 'fwd' | 'hold' | 'back' = 'fwd';
      var holdStart = 0;
      var raf = 0;
      var cancelled = false;

      // Cancella se l'utente tocca la tabella
      function cancel() { cancelled = true; cancelAnimationFrame(raf); }
      wrap.addEventListener('touchstart', cancel, { once: true, passive: true });
      wrap.addEventListener('wheel',      cancel, { once: true, passive: true });

      function easeOutCubic(t: number) { return 1 - Math.pow(1 - t, 3); }
      function easeInCubic(t: number)  { return t * t * t; }

      function step(ts: number) {
        if (cancelled) return;

        if (phase === 'fwd') {
          if (start === null) start = ts;
          var p = Math.min((ts - start) / fwdMs, 1);
          wrap.scrollLeft = peek * easeOutCubic(p);
          if (p < 1) { raf = requestAnimationFrame(step); return; }
          phase = 'hold'; holdStart = ts;
          raf = requestAnimationFrame(step); return;
        }

        if (phase === 'hold') {
          if (ts - holdStart < holdMs) { raf = requestAnimationFrame(step); return; }
          phase = 'back'; start = ts;
          raf = requestAnimationFrame(step); return;
        }

        if (phase === 'back') {
          var p2 = Math.min((ts - (start as number)) / bckMs, 1);
          wrap.scrollLeft = peek * (1 - easeInCubic(p2));
          if (p2 < 1) raf = requestAnimationFrame(step);
        }
      }

      // Piccolo delay iniziale prima di partire
      setTimeout(() => { if (!cancelled) raf = requestAnimationFrame(step); }, 500);
    }

    var wrap = document.querySelector<HTMLElement>('.ms__table-wrap');
    if (!wrap) return;

    // Parte solo su mobile e una sola volta quando la sezione è visibile
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        observer.disconnect();
        if (window.innerWidth <= BREAKPOINT) runPeek(wrap!);
      });
    }, { threshold: 0.5 });

    var section = document.querySelector('.ms');
    if (section) observer.observe(section);
  })();
</script>
