---
---

<section class="ms">
  <div class="ms__inner">

    <!-- ── Intestazione sezione ── -->
    <div class="ms__head">
      <span class="eyebrow">Membership</span>
      <h2 class="ms__title">Scegli il tuo<br><em>abbonamento.</em></h2>
      <p class="ms__sub">
        Tre livelli pensati per esigenze diverse. Tutti i soci accedono alle strutture del Club,
        alle agevolazioni e all'atmosfera unica dell'Ambrosiano.
      </p>
    </div>

    <!-- ── Card intestazione tier ── -->
    <div class="ms__tiers">

      <div class="ms__tier ms__tier--silver">
        <span class="ms__tier-name">Silver</span>
        <p class="ms__tier-tag">Il tuo ingresso nel Club</p>
        <p class="ms__tier-desc">
          Accesso alle strutture principali e a una selezione di corsi di gruppo.
          Ideale per chi vuole allenarsi con i vantaggi del Club.
        </p>
        <button class="btn btn-outline--dark ms__tier-cta" data-open-modal="modal-contatti">
          Richiedi informazioni
        </button>
      </div>

      <div class="ms__tier ms__tier--gold">
        <span class="ms__tier-name">Gold</span>
        <p class="ms__tier-tag">Il più scelto dai soci</p>
        <p class="ms__tier-desc">
          Campi da tennis all'aperto e sale di allenamento inclusi, tutti i corsi
          e sette giorni di prenotazione anticipata.
        </p>
        <button class="btn btn-outline--dark ms__tier-cta" data-open-modal="modal-contatti">
          Richiedi informazioni
        </button>
      </div>

      <div class="ms__tier ms__tier--platinum">
        <span class="ms__tier-featured-label">Più completo</span>
        <span class="ms__tier-name">Platinum</span>
        <p class="ms__tier-tag">L'esperienza completa</p>
        <p class="ms__tier-desc">
          Accesso totale a tutti i campi — coperti, all'aperto e padel inclusi —
          con la massima priorità di prenotazione e ogni corso compreso.
        </p>
        <button class="btn btn-red ms__tier-cta" data-open-modal="modal-contatti">
          Richiedi informazioni
        </button>
      </div>

    </div>

    <!-- ── Tabella comparativa ── -->
    <div class="ms__table-wrap">
      <table class="ms__table">
        <thead>
          <tr class="ms__head-row">
            <th class="ms__th ms__th--feat"></th>
            <th class="ms__th ms__th--silver">Silver</th>
            <th class="ms__th ms__th--gold">Gold</th>
            <th class="ms__th ms__th--platinum">Platinum</th>
          </tr>
        </thead>
        <tbody>

          <!-- Accesso ai campi -->
          <tr class="ms__cat-row">
            <td colspan="4" class="ms__cat-label">Accesso ai campi</td>
          </tr>
          <tr>
            <td class="ms__feat">Campi da tennis all'aperto</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--yes">Incluso</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Incluso</td>
          </tr>
          <tr>
            <td class="ms__feat">Campi da tennis al coperto</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Incluso</td>
          </tr>
          <tr>
            <td class="ms__feat">Campi da padel</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--partial">Sconto soci</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Incluso</td>
          </tr>

          <!-- Preparazione Atletica -->
          <tr class="ms__cat-row">
            <td colspan="4" class="ms__cat-label">Preparazione Atletica</td>
          </tr>
          <tr>
            <td class="ms__feat">Sale di allenamento</td>
            <td class="ms__cell ms__cell--yes">Incluso</td>
            <td class="ms__cell ms__cell--yes">Incluso</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Incluso</td>
          </tr>
          <tr>
            <td class="ms__feat">Corsi di gruppo</td>
            <td class="ms__cell ms__cell--partial">Selezione inclusa</td>
            <td class="ms__cell ms__cell--yes">Tutti inclusi</td>
            <td class="ms__cell ms__cell--yes ms__cell--plat">Tutti inclusi</td>
          </tr>

          <!-- Priorità prenotazione -->
          <tr class="ms__cat-row">
            <td colspan="4" class="ms__cat-label">Priorità di prenotazione</td>
          </tr>
          <tr>
            <td class="ms__feat">Anticipo prenotazione campi</td>
            <td class="ms__cell ms__cell--value">4 giorni</td>
            <td class="ms__cell ms__cell--value">7 giorni</td>
            <td class="ms__cell ms__cell--value ms__cell--plat">10 giorni</td>
          </tr>
          <tr>
            <td class="ms__feat">Prenotazioni anticipate tennis</td>
            <td class="ms__cell ms__cell--value">2 / settimana</td>
            <td class="ms__cell ms__cell--value">3 / settimana</td>
            <td class="ms__cell ms__cell--value ms__cell--plat">4 / settimana</td>
          </tr>
          <tr>
            <td class="ms__feat">Prenotazioni anticipate padel</td>
            <td class="ms__cell ms__cell--value">1 / settimana</td>
            <td class="ms__cell ms__cell--value">2 / settimana</td>
            <td class="ms__cell ms__cell--value ms__cell--plat">2 / settimana</td>
          </tr>

          <!-- Vantaggi economici -->
          <tr class="ms__cat-row">
            <td colspan="4" class="ms__cat-label">Vantaggi economici</td>
          </tr>
          <tr>
            <td class="ms__feat">Tariffe agevolate su corsi</td>
            <td class="ms__cell ms__cell--check">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="Sì"><circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity=".25"/><path d="M4.5 8.25l2.25 2.25 4.5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
            <td class="ms__cell ms__cell--check">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="Sì"><circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity=".25"/><path d="M4.5 8.25l2.25 2.25 4.5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
            <td class="ms__cell ms__cell--check ms__cell--plat">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="Sì"><circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity=".25"/><path d="M4.5 8.25l2.25 2.25 4.5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
          </tr>
          <tr>
            <td class="ms__feat">Sconto su lezioni individuali</td>
            <td class="ms__cell ms__cell--check">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="Sì"><circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity=".25"/><path d="M4.5 8.25l2.25 2.25 4.5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
            <td class="ms__cell ms__cell--check">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="Sì"><circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity=".25"/><path d="M4.5 8.25l2.25 2.25 4.5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
            <td class="ms__cell ms__cell--check ms__cell--plat">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="Sì"><circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity=".25"/><path d="M4.5 8.25l2.25 2.25 4.5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </td>
          </tr>

        </tbody>
      </table>
    </div>

    <!-- ── Nota a piè di sezione ── -->
    <p class="ms__note">
      Vuoi confrontare le opzioni o avere tutti i dettagli?
      <button class="ms__note-link" data-open-modal="modal-contatti">Contattaci</button>
      — il nostro team ti guiderà nella scelta giusta.
    </p>

  </div>
</section>

<style>
  /* ── Sezione ── */
  .ms {
    padding: 7vh var(--pad-x) 8vh;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .ms__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* ── Head ── */
  .ms__head {
    margin-bottom: 5vh;
  }

  .ms__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-top: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .ms__title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .ms__sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.05vw, 17px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
    max-width: 58ch;
  }

  /* ── Tier cards ── */
  .ms__tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 1px;
  }

  .ms__tier {
    background: var(--color-bg);
    padding: 2rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    border-top: 3px solid transparent;
  }

  .ms__tier--silver { border-top-color: #6B7280; }
  .ms__tier--gold   { border-top-color: #A07B10; }
  .ms__tier--platinum {
    border-top-color: var(--color-accent);
    background: #FDF7F7;
  }

  .ms__tier-featured-label {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(139, 26, 26, 0.08);
    padding: 3px 10px;
    align-self: flex-start;
    margin-bottom: -0.25rem;
  }

  .ms__tier-name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--color-text);
  }

  .ms__tier--silver .ms__tier-name { color: #4B5563; }
  .ms__tier--gold   .ms__tier-name { color: #7A5E0A; }
  .ms__tier--platinum .ms__tier-name { color: var(--color-accent); }

  .ms__tier-tag {
    font-family: var(--font-display);
    font-size: clamp(0.85rem, 1vw, 0.95rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
  }

  .ms__tier-desc {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 14.5px);
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-light);
    flex: 1;
  }

  .ms__tier-cta {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  /* ── Tabella ── */
  .ms__table-wrap {
    border: 1px solid var(--color-border);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ms__table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  /* Colonne */
  .ms__th--feat    { width: 42%; }
  .ms__th--silver  { width: 19%; }
  .ms__th--gold    { width: 19%; }
  .ms__th--platinum { width: 20%; }

  /* Head row */
  .ms__head-row .ms__th {
    font-family: var(--font-display);
    font-size: clamp(0.75rem, 0.85vw, 0.9rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 14px 20px;
    text-align: center;
    background: var(--color-off-white);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-light);
  }

  .ms__th--feat { text-align: left; }
  .ms__th--silver  { color: #4B5563; border-top: 3px solid #6B7280; }
  .ms__th--gold    { color: #7A5E0A; border-top: 3px solid #A07B10; }
  .ms__th--platinum {
    color: var(--color-accent);
    border-top: 3px solid var(--color-accent);
    background: #FDF7F7;
  }

  /* Category rows */
  .ms__cat-row .ms__cat-label {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-light);
    padding: 10px 20px 8px;
    background: var(--color-off-white);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  /* Feature rows */
  .ms__table tbody tr:not(.ms__cat-row) {
    border-bottom: 1px solid var(--color-border);
  }

  .ms__table tbody tr:not(.ms__cat-row):last-child {
    border-bottom: none;
  }

  .ms__table tbody tr:not(.ms__cat-row):hover {
    background: rgba(0, 0, 0, 0.018);
  }

  .ms__feat {
    font-family: var(--font-body);
    font-size: clamp(12.5px, 0.9vw, 14px);
    font-weight: 400;
    color: var(--color-text);
    padding: 14px 20px;
    vertical-align: middle;
  }

  /* Data cells */
  .ms__cell {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.85vw, 13.5px);
    font-weight: 400;
    text-align: center;
    padding: 14px 12px;
    vertical-align: middle;
  }

  /* ── Cell variants ── */
  .ms__cell--yes {
    color: #1A6636;
    font-weight: 600;
  }

  .ms__cell--partial {
    color: #7A5E0A;
    font-weight: 400;
  }

  .ms__cell--value {
    color: var(--color-text);
    font-weight: 600;
    font-family: var(--font-display);
    font-size: clamp(11.5px, 0.85vw, 13px);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ms__cell--check {
    color: #1A6636;
  }

  .ms__cell--check svg {
    display: inline-block;
    vertical-align: middle;
  }

  /* Colonna Platinum — sfondo tinto */
  .ms__cell--plat {
    background: rgba(139, 26, 26, 0.04);
  }

  /* ── Nota ── */
  .ms__note {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 14.5px);
    font-weight: 300;
    color: var(--color-text-light);
    line-height: 1.7;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    margin-top: 2.5rem;
  }

  .ms__note-link {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: var(--color-accent);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ms__note-link:hover {
    color: var(--color-accent-dark);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ms__tiers {
      grid-template-columns: 1fr;
    }

    .ms__tier--platinum {
      order: -1;
    }

    .ms__table-wrap {
      overflow-x: scroll;
    }

    .ms__table {
      min-width: 560px;
    }
  }

  @media (max-width: 600px) {
    .ms__table { min-width: 480px; }
    .ms__th--feat { width: 38%; }
  }
</style>
