---
import { publicUrl } from '../i18n/utils';

interface Cta {
  label: string;
  href?: string;
  outline?: boolean;
  external?: boolean;
  openModal?: boolean;
}

interface Props {
  eyebrow?: string;
  title: string;
  titleAccent?: string;
  sub?: string;
  image: string;
  imageAlt: string;
  imagePosition?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctas?: Cta[];
}

const {
  eyebrow,
  title,
  titleAccent,
  sub,
  image,
  imageAlt,
  imagePosition = "center center",
  ctaLabel,
  ctaHref = "#lead",
  ctas,
} = Astro.props;

const buttons: Cta[] = ctas?.length
  ? ctas
  : ctaLabel
    ? [{ label: ctaLabel, href: ctaHref }]
    : [];
---

<section class="page-hero">
  <div class="page-hero__bg">
    <img
      src={publicUrl(image)}
      alt={imageAlt}
      class="page-hero__img"
      style={`object-position: ${imagePosition};`}
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />
  </div>
  <div class="page-hero__grad"></div>

  <div class="page-hero__content">
    {eyebrow && <span class="eyebrow eyebrow--light">{eyebrow}</span>}
    <h1 class="page-hero__title">
      {title}{titleAccent && <><br /><em>{titleAccent}</em></>}
    </h1>
    {sub && <p class="page-hero__sub">{sub}</p>}
    {buttons.length > 0 && (
      <div class="page-hero__actions">
        {buttons.map((btn) => (
          btn.openModal ? (
            <button
              class={`btn ${btn.outline ? 'btn-outline' : 'btn-red'}`}
              data-open-modal="modal-contatti"
            >{btn.label}</button>
          ) : (
            <a
              class={`btn ${btn.outline ? 'btn-outline' : 'btn-red'}`}
              href={btn.href}
              target={btn.external ? '_blank' : undefined}
              rel={btn.external ? 'noopener noreferrer' : undefined}
            >{btn.label}</a>
          )
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-top: var(--header-h);
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .page-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .page-hero__grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(15, 15, 18, 0.78) 28%, rgba(139, 26, 26, 0.30));
  }

  .page-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8vh var(--pad-x);
    color: #ffffff;
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 6.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.93;
    margin-bottom: 2.5vh;
  }

  .page-hero__title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .page-hero__sub {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.2vw, 21px);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    max-width: 60ch;
    margin-bottom: 3.5vh;
  }

  .page-hero__actions { display: flex; flex-wrap: wrap; gap: 12px; }

  @media (max-width: 768px) {
    .page-hero { min-height: 55vh; }
    .page-hero__content { padding: 5vh 20px 6vh; }
    .page-hero__title { font-size: clamp(2.2rem, 9vw, 3.5rem); }
  }
</style>
