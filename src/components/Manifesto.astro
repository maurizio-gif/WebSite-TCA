---
import { getLocalePath, type Lang } from '../i18n/utils';
interface Props { lang?: Lang; }
const { lang = 'it' } = Astro.props;
const p = (path: string) => getLocalePath(lang, path);

const copy = lang === 'en' ? {
  title:  'A club built on tradition,<br>made for today.',
  p1:     'Tennis Club Ambrosiano is home to the <strong>Avvenire Tournament</strong>, the competition that since 1965 has discovered the next generation of tennis talent. From that same calling — the future training every day — everything we do today was born.',
  p2:     "Here you'll find some of the finest facilities in east Milan: <strong>tennis courts, padel, athletic training spaces</strong> and an activity calendar for every age. Whether you want to get back on court, raise a child through sport, or simply take care of yourself, the Club makes it easy.",
  cta:    'Discover our history →',
  quote:  'Sport and Tradition.',
} : {
  title:  'Un club fondato<br>sulla tradizione,<br><em>costruito per il presente.</em>',
  p1:     'Il Tennis Club Ambrosiano è la casa del <strong>Torneo Avvenire</strong>, la gara che dal 1965 scopre i talenti del tennis di domani. Da quella stessa vocazione — il futuro che si allena ogni giorno — nasce tutto ciò che facciamo oggi.',
  p2:     "Qui trovi alcuni dei migliori impianti della zona est di Milano: <strong>campi da tennis, padel, spazi per la preparazione atletica</strong> e un calendario di attività che accompagna ogni età. Che tu voglia tornare a giocare, far crescere un figlio nello sport o semplicemente prenderti cura di te, il Club è pensato per renderlo semplice.",
  cta:    'Scopri la nostra storia →',
  quote:  'Sport e Tradizione.',
};
---

<section class="manifesto">
  <div class="manifesto__inner">
    <h2 class="manifesto__title" data-anim="reveal" set:html={copy.title} />

    <div class="manifesto__right">
      <div class="manifesto__body" data-anim="from-left" data-anim-delay="150">
        <p set:html={copy.p1} />
        <p set:html={copy.p2} />
      </div>
      <a class="btn btn-red manifesto__cta" href={p('/storia')} data-anim="from-left" data-anim-delay="280">
        {copy.cta}
      </a>
    </div>

    <p class="manifesto__quote" data-anim="reveal" data-anim-delay="200">{copy.quote}</p>
  </div>
</section>

<style>
  .manifesto { padding: 8vh var(--pad-x); }

  .manifesto__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem 5rem;
    align-items: start;
  }

  .manifesto__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
  }
  .manifesto__title em { color: var(--color-accent); font-style: normal; }

  .manifesto__right {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .manifesto__body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .manifesto__body p {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.05vw, 17px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .manifesto__cta {
    align-self: flex-start;
  }

  .manifesto__quote {
    grid-column: 1 / -1;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.95;
    color: var(--color-accent);
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 860px) {
    .manifesto__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .manifesto__quote {
      grid-column: 1;
      border-top: 3px solid var(--color-accent);
      padding-top: 2rem;
      margin-top: 0.5rem;
    }
  }
</style>
