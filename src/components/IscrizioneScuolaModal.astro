  </div>
</dialog>

<style is:global>
  /* ── Select coerenti con input/textarea del sistema .lm ─────────── */
  .lm__field select {
    font-family: var(--font-body); font-size: clamp(13px,.95vw,15px);
    font-weight: 300; padding: 0.7rem 2rem 0.7rem 0.85rem;
    border: 1px solid var(--lm-input-bd);
    background: var(--lm-input-bg); color: var(--lm-text);
    width: 100%; transition: border-color 0.18s;
    -webkit-appearance: none; appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%236B5C57' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat; background-position: right 14px center;
  }
  .lm__field select:invalid { color: var(--lm-text-dim); }
  .lm__field select:focus { outline: none; border-color: var(--color-accent); background-color: #fff; }

  .lm__check-item input[type="radio"] { accent-color: var(--color-accent); flex-shrink: 0; }

  .lm__input--cf { text-transform: uppercase; }

  /* ── Riga di contesto passo (fase + contatore) ───────────────────── */
  .lm__step-context {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    font-family: var(--font-display); font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent);
    margin: 0; padding-bottom: 0.6rem; border-bottom: 1px solid var(--lm-border);
  }
  .lm__step-context .lm__progress { color: var(--lm-text-dim); font-weight: 600; white-space: nowrap; }

  .lm__hint {
    font-family: var(--font-body); font-size: clamp(11px,.8vw,12px);
    font-weight: 300; color: var(--lm-text-dim); margin: -0.6rem 0 0;
  }

  .lm__sub a { color: var(--color-accent); text-decoration: underline; }
  .lm__sub a:hover { color: var(--color-accent-dark); }

  /* ── Box informativo (date, quote di riferimento) ────────────────── */
  .lm__notice {
    background: var(--lm-input-bg); border: 1px solid var(--lm-border);
    border-left: 3px solid var(--color-accent);
    padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.6rem;
  }
  .lm__notice p {
    font-family: var(--font-body); font-size: clamp(12px,.9vw,13px);
    font-weight: 300; line-height: 1.6; color: var(--lm-text-sub); margin: 0;
  }
  .lm__notice p strong { color: var(--lm-text); font-weight: 700; }

  .lm__notice-warn {
    font-family: var(--font-body); font-size: clamp(12px,.9vw,13px);
    font-weight: 400; line-height: 1.6; color: var(--color-accent); margin: 0;
  }

  /* ── Elenco termini e condizioni ──────────────────────────────────── */
  .lm__terms-list {
    margin: 0; padding-left: 1.1rem;
    display: flex; flex-direction: column; gap: 0.6rem;
    font-family: var(--font-body); font-size: clamp(12px,.9vw,13px);
    font-weight: 300; line-height: 1.6; color: var(--lm-text-sub);
  }

  /* ── Tabella slot preparazione fisica ─────────────────────────────── */
  .lm__table-wrap { overflow-x: auto; border: 1px solid var(--lm-border); }
  .lm__table { width: 100%; border-collapse: collapse; font-family: var(--font-body); font-size: clamp(11px,.85vw,12.5px); }
  .lm__table th, .lm__table td { padding: 0.5rem 0.65rem; border-bottom: 1px solid var(--lm-border); text-align: left; }
  .lm__table th { font-weight: 700; color: var(--lm-text); background: var(--lm-bg-head); white-space: nowrap; }
  .lm__table td { font-weight: 300; color: var(--lm-text-sub); }
  .lm__table tr:last-child td { border-bottom: none; }

  /* ── Modal iscrizione: passi corti, niente scroll su mobile ───────── */
  .lm--isc .lm__body { gap: 1rem; }

  @media (max-width: 640px) {
    .lm--isc { max-width: 100vw; width: 100%; height: 100dvh; max-height: 100dvh; margin: 0; }
    .lm--isc .lm__panel { max-height: 100dvh; height: 100%; display: flex; flex-direction: column; }
    .lm--isc .lm__head { padding: 1rem 1.1rem 0.9rem; flex-shrink: 0; }
    .lm--isc .lm__title { font-size: 1.3rem; margin-top: 0.15rem; }
    .lm--isc .lm__body { padding: 1.1rem 1.1rem 1.3rem; }
    .lm--isc .lm__body:not([hidden]) { flex: 1; display: flex; flex-direction: column; }
    .lm--isc .lm__body:not([hidden]) .lm__actions { margin-top: auto; }
    .lm--isc .lm__notice { padding: 0.8rem 1rem; }
    .lm--isc .lm__confirm-check { width: 2.6rem; height: 2.6rem; }
    .lm--isc .lm__confirm-title { font-size: 1.5rem; }
  }
</style>

<script define:vars={{ ERR: {
  required: t.errRequired,
  email: t.errEmail,
  choice: t.errChoice,
  check: t.errCheck,
  consent: t.errConsent,
}, STEP_LABEL: t.stepLabel }}>
  const modal = document.getElementById('modal-iscrizione-scuola');

  function isValidEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim()); }

  const tipoSelect = document.getElementById('isc-tipo');
  const prepSelect = document.getElementById('isc-prep-orario');

  const PREFIX = ['minore-nome','minore-nascita','minore-cf','minore-indirizzo','minore-cap',
                  'genitore-nome','genitore-email','genitore-cell','corso-notice','corso-tipo'];
  const MID_TENNIS = ['corso-frequenza','corso-giorni','corso-orari','corso-compagno','corso-prep',
                      'taglie-maglietta','taglie-pantaloncini','taglie-felpa'];
  const MID_MINI = ['corso-frequenza','corso-giorni','corso-compagno','corso-prep'];
  const SUFFIX = ['termini-1','termini-2','consensi'];

  function getSteps() {
    const mid = tipoSelect.value === 'tennis' ? MID_TENNIS : MID_MINI;
    return ['intro'].concat(PREFIX, mid, SUFFIX);
  }

  let currentStep = 'intro';

  function updateProgress(key) {
    const steps = getSteps();
    const idx = steps.indexOf(key);
    const label = idx === -1 ? '' : STEP_LABEL.replace('{n}', idx + 1).replace('{total}', steps.length);
    modal.querySelectorAll('.lm__progress').forEach((el) => { el.textContent = label; });
  }

  function renderStep(key) {
    currentStep = key;
    modal.querySelectorAll('[data-isc-step]').forEach((el) => {
      el.hidden = el.dataset.iscStep !== key;
    });
    modal.querySelector('.lm__panel').scrollTop = 0;
    updateProgress(key);
  }

  function showError(msg) {
    const err = modal.querySelector(`[data-isc-step="${currentStep}"] > .lm__error`);
    if (err) { err.textContent = msg; err.hidden = false; }
  }
  function clearError() {
    const err = modal.querySelector(`[data-isc-step="${currentStep}"] > .lm__error`);
    if (err) err.hidden = true;
  }

  function syncTipoGroups() {
    const tipo = tipoSelect.value;
    modal.querySelectorAll('[data-isc-tipo-group]').forEach((el) => {
      el.hidden = el.dataset.iscTipoGroup !== tipo;
    });
  }
  tipoSelect.addEventListener('change', syncTipoGroups);

  function requireFields(ids) {
    for (const id of ids) {
      const el = document.getElementById(id);
      if (!el.value.trim()) { showError(ERR.required); el.focus(); return false; }
    }
    return true;
  }
  function requireSelect(id) {
    const el = document.getElementById(id);
    if (!el.value) { showError(ERR.choice); el.focus(); return false; }
    return true;
  }

  const VALIDATORS = {
    'minore-nome': () => requireFields(['isc-minor-nome','isc-minor-cognome']),
    'minore-nascita': () => requireFields(['isc-minor-dob','isc-minor-pob']),
    'minore-cf': () => requireFields(['isc-minor-cf']),
    'minore-indirizzo': () => requireFields(['isc-addr','isc-city']),
    'minore-cap': () => requireFields(['isc-prov','isc-cap']),
    'genitore-nome': () => requireFields(['isc-parent-nome','isc-parent-cognome']),
    'genitore-email': () => {
      if (!requireFields(['isc-email'])) return false;
      const el = document.getElementById('isc-email');
      if (!isValidEmail(el.value)) { showError(ERR.email); el.focus(); return false; }
      return true;
    },
    'genitore-cell': () => requireFields(['isc-cell']),
    'corso-tipo': () => {
      if (!tipoSelect.value) { showError(ERR.choice); tipoSelect.focus(); return false; }
      return true;
    },
    'corso-frequenza': () => {
      const tipo = tipoSelect.value;
      if (!modal.querySelector(`input[name="isc-freq-${tipo}"]:checked`)) { showError(ERR.choice); return false; }
      return true;
    },
    'corso-giorni': () => {
      const tipo = tipoSelect.value;
      if (modal.querySelectorAll(`input[name="isc-giorni-${tipo}"]:checked`).length === 0) { showError(ERR.check); return false; }
      return true;
    },
    'corso-orari': () => {
      if (modal.querySelectorAll('input[name="isc-orari-tennis"]:checked').length === 0) { showError(ERR.check); return false; }
      return true;
    },
    'corso-prep': () => {
      if (tipoSelect.value === 'tennis' && !prepSelect.value) { showError(ERR.choice); prepSelect.focus(); return false; }
      return true;
    },
    'taglie-maglietta': () => requireSelect('isc-size-shirt'),
    'taglie-pantaloncini': () => requireSelect('isc-size-shorts'),
    'taglie-felpa': () => requireSelect('isc-size-hoodie'),
    'consensi': () => {
      const ok = ['isc-accept-terms','isc-accept-rules','isc-accept-privacy']
        .every((id) => document.getElementById(id).checked);
      if (!ok) { showError(ERR.consent); return false; }
      return true;
    },
  };

  function goNext() {
    const steps = getSteps();
    const idx = steps.indexOf(currentStep);
    if (idx === -1 || idx === steps.length - 1) { renderStep('confirm'); return; }
    renderStep(steps[idx + 1]);
  }
  function goBack() {
    const steps = getSteps();
    const idx = steps.indexOf(currentStep);
    if (idx <= 0) { renderStep('intro'); return; }
    renderStep(steps[idx - 1]);
  }

  function resetForm() {
    modal.querySelectorAll('input[type="text"], input[type="email"], input[type="tel"], input[type="date"], input[inputmode="numeric"]').forEach((el) => {
      el.value = '';
    });
    modal.querySelectorAll('select').forEach((el) => { el.selectedIndex = 0; });
    modal.querySelectorAll('input[type="checkbox"], input[type="radio"]').forEach((el) => { el.checked = false; });
    modal.querySelectorAll('.lm__error').forEach((el) => { el.hidden = true; });
    syncTipoGroups();
    renderStep('intro');
  }

  function closeAndReset() {
    modal.close();
    resetForm();
  }

  document.addEventListener('click', (e) => {
    const trigger = e.target.closest('[data-open-modal]');
    if (trigger && trigger.dataset.openModal === 'modal-iscrizione-scuola') {
      modal.showModal();
      renderStep('intro');
    }
  });

  modal.addEventListener('click', (e) => {
    if (e.target.closest('[data-isc-close]') || e.target === modal) { closeAndReset(); return; }
    if (e.target.closest('[data-isc-back]')) { goBack(); return; }
    if (e.target.closest('[data-isc-next]')) {
      clearError();
      const validator = VALIDATORS[currentStep];
      if (validator && !validator()) return;
      goNext();
    }
  });
</script>
