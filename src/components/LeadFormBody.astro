---
import type { Lang } from '../i18n/utils';
interface Props {
  prefix: string;
  lang?: Lang;
}
const { prefix, lang = 'it' } = Astro.props;

const attivita = lang === 'en' ? [
  { id: 'tennis',     label: 'Tennis' },
  { id: 'padel',      label: 'Padel' },
  { id: 'prep',       label: 'Athletic Training' },
  { id: 'scuola',     label: 'Tennis School (children)' },
  { id: 'agonistica', label: 'Competitive Tennis' },
  { id: 'camps',      label: 'Summer Camps' },
  { id: 'membership', label: 'Membership' },
] : [
  { id: 'tennis',     label: 'Tennis' },
  { id: 'padel',      label: 'Padel' },
  { id: 'prep',       label: 'Preparazione Atletica' },
  { id: 'scuola',     label: 'Scuola Tennis (bambini)' },
  { id: 'agonistica', label: 'Agonistica Tennis' },
  { id: 'camps',      label: 'Summer Camps' },
  { id: 'membership', label: 'Membership / Abbonamento' },
];

const t = lang === 'en' ? {
  step1sub:         "Enter your email and tell us what you're interested in.",
  activitiesLabel:  'Activities of interest',
  continueBtn:      'Continue',
  checking:         'Checking…',
  step2sub:         'Nice to meet you! Please fill in your details to continue.',
  firstName:        'First name',
  lastName:         'Last name',
  mobile:           'Mobile',
  privacyText:      'I have read and accept the <a href="/privacy-policy" target="_blank">Privacy Policy</a>. I consent to the processing of my personal data to respond to this request. <strong>(required)</strong>',
  marketingText:    'I consent to receiving commercial communications, offers and news from Tennis Club Ambrosiano by email, SMS and WhatsApp. <em>(optional)</em>',
  backBtn:          '← Back',
  step3sub:         'How can we help you?',
  callbackLabel:    'CALL ME BACK',
  callbackSub:      "Choose a day and time — we'll call you",
  visitLabel:       'BOOK A VISIT TO THE CLUB',
  visitSub:         "Come and visit us — we'll show you everything",
  messageLabel:     'SEND A MESSAGE',
  messageSub:       "We'll reply by email as soon as possible",
  step4cbSub:       'Choose a day and time, then tell us the reason for your call.',
  chooseDay:        'Choose a day',
  availableTimes:   'Available times',
  callReason:       'Reason for your call',
  callReasonPh:     "E.g. I'd like information about membership, I've played before and want to get back into it…",
  confirmBtn:       'Confirm',
  step4visitSub:    'Choose your arrival day and time, then tell us the reason for your visit.',
  visitReason:      'Reason for your visit',
  visitReasonPh:    "E.g. I'd like to visit the facilities, I'm interested in joining for padel…",
  confirmVisitBtn:  'Confirm visit',
  step4msgSub:      "Write your request: we'll get back to you as soon as possible.",
  yourRequest:      'Your request',
  requestPh:        "Tell us what you're looking for, what you're interested in, or any questions about the Club, our activities or pricing…",
  sendBtn:          'Send request',
  confirmCbTitle:   "Great!<br><em>We'll call you back.</em>",
  confirmVisitTitle:'See you<br><em>at the Club!</em>',
  confirmMsgTitle:  'Message<br><em>received!</em>',
  closeBtn:         'Close',
  howToFind:        'How to find us',
  dirLine1:         "🚇 Metro Udine (M2 Green Line) — a few minutes' walk from the exit",
  dirLine2:         '🚌 Bus lines 62 and 66 — Via Feltre stop',
  openMaps:         'Open in Google Maps →',
  confirmNote:      "We'll reply to the email address you provided as soon as possible.<br>See you at TCA!",
} : {
  step1sub:         'Inserisci la tua email e dicci cosa ti interessa.',
  activitiesLabel:  'Attività di interesse',
  continueBtn:      'Continua',
  checking:         'Verifica in corso…',
  step2sub:         'Piacere di conoscerti! Aggiungi i tuoi dati per procedere.',
  firstName:        'Nome',
  lastName:         'Cognome',
  mobile:           'Cellulare',
  privacyText:      'Ho letto e accetto la <a href="/privacy-policy" target="_blank">Privacy Policy</a>. Acconsento al trattamento dei dati personali per rispondermi a questa richiesta. <strong>(obbligatorio)</strong>',
  marketingText:    'Acconsento a ricevere comunicazioni commerciali, offerte e novità dal Tennis Club Ambrosiano via email, SMS e WhatsApp. <em>(facoltativo)</em>',
  backBtn:          '← Indietro',
  step3sub:         'Come possiamo aiutarti?',
  callbackLabel:    'RICHIAMAMI',
  callbackSub:      'Scegli giorno e orario — ti chiamiamo noi',
  visitLabel:       'PRENOTA UNA VISITA IN SEDE',
  visitSub:         'Vieni a trovarci al Club — ti mostriamo tutto',
  messageLabel:     'SCRIVI UN MESSAGGIO',
  messageSub:       'Ti risponderemo via email al più presto',
  step4cbSub:       'Scegli giorno e orario, poi raccontaci il motivo della chiamata.',
  chooseDay:        'Scegli il giorno',
  availableTimes:   'Orari disponibili',
  callReason:       'Motivo della chiamata',
  callReasonPh:     "Es. vorrei informazioni sull'abbonamento, ho già giocato e voglio riprendere…",
  confirmBtn:       'Conferma',
  step4visitSub:    'Scegli giorno e orario di arrivo, poi raccontaci il motivo della visita.',
  visitReason:      'Motivo della visita',
  visitReasonPh:    'Es. voglio visitare la struttura, mi interessa iscrivermi al padel…',
  confirmVisitBtn:  'Conferma visita',
  step4msgSub:      'Scrivici la tua richiesta: ti risponderemo nel più breve tempo possibile.',
  yourRequest:      'La tua richiesta',
  requestPh:        'Raccontaci cosa cerchi, cosa ti interessa o qualsiasi domanda sul Club, sulle attività o sulle tariffe…',
  sendBtn:          'Invia richiesta',
  confirmCbTitle:   'Perfetto!<br><em>Ti richiamiamo noi.</em>',
  confirmVisitTitle:'Ti aspettiamo<br><em>al Club!</em>',
  confirmMsgTitle:  'Messaggio<br><em>ricevuto!</em>',
  closeBtn:         'Chiudi',
  howToFind:        'Come raggiungerci',
  dirLine1:         "🚇 Metro Udine (Linea 2 Verde) — pochi minuti a piedi dall'uscita",
  dirLine2:         '🚌 Bus linee 62 e 66 — fermata Via Feltre',
  openMaps:         'Apri in Google Maps →',
  confirmNote:      "Ti risponderemo all'indirizzo indicato nel più breve tempo possibile.<br>A presto al TCA!",
};
---

<!-- ── Step indicator ──────────────────────────────────────────────── -->
<div class="lm__steps" aria-hidden="true">
  <span class="lm__step is-active" data-step-dot="1">1</span>
  <span class="lm__step-line"></span>
  <span class="lm__step" data-step-dot="2">2</span>
  <span class="lm__step-line"></span>
  <span class="lm__step" data-step-dot="3">3</span>
</div>

<!-- ─── STEP 1 · Email + attività ─────────────────────────────────── -->
<div class="lm__body" data-step="1">
  <p class="lm__sub">{t.step1sub}</p>

  <div class="lm__field">
    <label for={`${prefix}-email`}>Email <span aria-hidden="true">*</span></label>
    <input id={`${prefix}-email`} name="email" type="email" autocomplete="email"
           placeholder="nome@esempio.com" required />
  </div>

  <div>
    <p class="lm__label-group">{t.activitiesLabel}</p>
    <div class="lm__checks">
      {attivita.map((a) => (
        <label class="lm__check-item">
          <input type="checkbox" name="attivita" value={a.id} />
          <span>{a.label}</span>
        </label>
      ))}
    </div>
  </div>

  <div class="lm__actions">
    <button class="btn btn-red lm__next" id={`${prefix}-step1-next`} type="button">
      {t.continueBtn} <span class="lm__arrow">→</span>
    </button>
  </div>
  <div class="lm__loader" hidden aria-live="polite">
    <span class="lm__spinner"></span> {t.checking}
  </div>
  <p class="lm__error" hidden role="alert"></p>
</div>

<!-- ─── STEP 2 · Dati nuovo utente ────────────────────────────────── -->
<div class="lm__body" data-step="2" hidden>
  <p class="lm__sub">{t.step2sub}</p>

  <div class="lm__grid">
    <div class="lm__field">
      <label for={`${prefix}-nome`}>{t.firstName} <span aria-hidden="true">*</span></label>
      <input id={`${prefix}-nome`} name="nome" type="text" autocomplete="given-name" required />
    </div>
    <div class="lm__field">
      <label for={`${prefix}-cognome`}>{t.lastName} <span aria-hidden="true">*</span></label>
      <input id={`${prefix}-cognome`} name="cognome" type="text" autocomplete="family-name" required />
    </div>
    <div class="lm__field lm__field--full">
      <label for={`${prefix}-cell`}>{t.mobile} <span aria-hidden="true">*</span></label>
      <div class="lm__tel-wrap">
        <select id={`${prefix}-pfx`} name="prefisso" class="lm__tel-prefix" autocomplete="tel-country-code">
          <option value="+39" selected>🇮🇹 +39</option>
          <option value="+41">🇨🇭 +41</option>
          <option value="+43">🇦🇹 +43</option>
          <option value="+33">🇫🇷 +33</option>
          <option value="+49">🇩🇪 +49</option>
          <option value="+44">🇬🇧 +44</option>
          <option value="+34">🇪🇸 +34</option>
          <option value="+351">🇵🇹 +351</option>
          <option value="+31">🇳🇱 +31</option>
          <option value="+32">🇧🇪 +32</option>
          <option value="+1">🇺🇸 +1</option>
          <option value="+55">🇧🇷 +55</option>
          <option value="+54">🇦🇷 +54</option>
        </select>
        <input id={`${prefix}-cell`} name="cellulare" type="tel" autocomplete="tel-national"
               placeholder="3XX XXX XXXX" required />
      </div>
    </div>
  </div>

  <div class="lm__consent">
    <label class="lm__consent-item">
      <input id={`${prefix}-privacy`} name="privacy" type="checkbox" required />
      <span set:html={t.privacyText} />
    </label>
    <label class="lm__consent-item">
      <input id={`${prefix}-marketing`} name="marketing" type="checkbox" />
      <span set:html={t.marketingText} />
    </label>
  </div>

  <div class="lm__actions">
    <button class="lm__back" id={`${prefix}-step2-back`} type="button">{t.backBtn}</button>
    <button class="btn btn-red lm__next" id={`${prefix}-step2-next`} type="button">
      {t.continueBtn} <span class="lm__arrow">→</span>
    </button>
  </div>
  <p class="lm__error" hidden role="alert"></p>
</div>

<!-- ─── STEP 3 · Scelta azione ────────────────────────────────────── -->
<div class="lm__body" data-step="3" hidden>
  <p class="lm__sub">{t.step3sub}</p>

  <div class="lm__action-choice">
    <button class="lm__action-btn" data-action="callback" type="button">
      <span class="lm__action-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <path d="M6.6 10.8C7.8 13.2 9.8 15.2 12.2 16.4L14.2 14.4C14.5 14.1 14.9 14 15.3 14.2C16.5 14.6 17.8 14.8 19 14.8C19.6 14.8 20 15.2 20 15.8V19C20 19.6 19.6 20 19 20C10.2 20 3 12.8 3 4C3 3.4 3.4 3 4 3H7.5C8.1 3 8.5 3.4 8.5 4C8.5 5.3 8.7 6.5 9.1 7.7C9.2 8.1 9.1 8.5 8.8 8.8L6.6 10.8Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="lm__action-texts">
        <span class="lm__action-label">{t.callbackLabel}</span>
        <span class="lm__action-sub">{t.callbackSub}</span>
      </span>
      <span class="lm__action-arr">→</span>
    </button>

    <button class="lm__action-btn" data-action="visit" type="button">
      <span class="lm__action-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <path d="M12 2C8.13 2 5 5.13 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.13 15.87 2 12 2Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.6"/>
        </svg>
      </span>
      <span class="lm__action-texts">
        <span class="lm__action-label">{t.visitLabel}</span>
        <span class="lm__action-sub">{t.visitSub}</span>
      </span>
      <span class="lm__action-arr">→</span>
    </button>

    <button class="lm__action-btn" data-action="message" type="button">
      <span class="lm__action-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/>
          <path d="M22 6L12 13L2 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="lm__action-texts">
        <span class="lm__action-label">{t.messageLabel}</span>
        <span class="lm__action-sub">{t.messageSub}</span>
      </span>
      <span class="lm__action-arr">→</span>
    </button>
  </div>

  <button class="lm__back lm__back--center" id={`${prefix}-step3-back`} type="button">{t.backBtn}</button>
</div>

<!-- ─── STEP 4a · RICHIAMAMI ──────────────────────────────────────── -->
<div class="lm__body" data-step="4-callback" hidden>
  <p class="lm__sub">{t.step4cbSub}</p>

  <div class="lm__cal">
    <p class="lm__label-group">{t.chooseDay} <span aria-hidden="true">*</span></p>
    <div class="lm__cal-month-wrap" id={`${prefix}-cal-cb`}></div>
    <div class="lm__slots-wrap" id={`${prefix}-slots-wrap-cb`} hidden>
      <p class="lm__slots-wrap-title">{t.availableTimes}</p>
      <div class="lm__slots-body" id={`${prefix}-cal-slots-cb`}></div>
    </div>
  </div>

  <div class="lm__field">
    <label for={`${prefix}-cb-reason`}>{t.callReason} <span aria-hidden="true">*</span></label>
    <textarea id={`${prefix}-cb-reason`} name="cb-reason" rows="3"
              placeholder={t.callReasonPh}></textarea>
  </div>

  <div class="lm__actions">
    <button class="lm__back" data-step-back="3" type="button">{t.backBtn}</button>
    <button class="btn btn-red" id={`${prefix}-cb-confirm`} type="button">
      {t.confirmBtn} <span class="lm__arrow">→</span>
    </button>
  </div>
  <p class="lm__error" hidden role="alert"></p>
</div>

<!-- ─── STEP 4b · PRENOTA VISITA ──────────────────────────────────── -->
<div class="lm__body" data-step="4-visit" hidden>
  <p class="lm__sub">{t.step4visitSub}</p>

  <div class="lm__cal">
    <p class="lm__label-group">{t.chooseDay} <span aria-hidden="true">*</span></p>
    <div class="lm__cal-month-wrap" id={`${prefix}-cal-visit`}></div>
    <div class="lm__slots-wrap" id={`${prefix}-slots-wrap-visit`} hidden>
      <p class="lm__slots-wrap-title">{t.availableTimes}</p>
      <div class="lm__slots-body" id={`${prefix}-cal-slots-visit`}></div>
    </div>
  </div>

  <div class="lm__field">
    <label for={`${prefix}-visit-reason`}>{t.visitReason} <span aria-hidden="true">*</span></label>
    <textarea id={`${prefix}-visit-reason`} name="visit-reason" rows="3"
              placeholder={t.visitReasonPh}></textarea>
  </div>

  <div class="lm__actions">
    <button class="lm__back" data-step-back="3" type="button">{t.backBtn}</button>
    <button class="btn btn-red" id={`${prefix}-visit-confirm`} type="button">
      {t.confirmVisitBtn} <span class="lm__arrow">→</span>
    </button>
  </div>
  <p class="lm__error" hidden role="alert"></p>
</div>

<!-- ─── STEP 4c · SCRIVI UN MESSAGGIO ────────────────────────────── -->
<div class="lm__body" data-step="4-message" hidden>
  <p class="lm__sub">{t.step4msgSub}</p>

  <div class="lm__field">
    <label for={`${prefix}-msg-text`}>{t.yourRequest} <span aria-hidden="true">*</span></label>
    <textarea id={`${prefix}-msg-text`} name="message" rows="6"
              placeholder={t.requestPh}></textarea>
  </div>

  <div class="lm__actions">
    <button class="lm__back" data-step-back="3" type="button">{t.backBtn}</button>
    <button class="btn btn-red" id={`${prefix}-msg-send`} type="button">
      {t.sendBtn} <span class="lm__arrow">→</span>
    </button>
  </div>
  <p class="lm__error" hidden role="alert"></p>
</div>

<!-- ─── CONFERMA · RICHIAMAMI ──────────────────────────────────────── -->
<div class="lm__body lm__confirm" data-step="confirm-callback" hidden aria-live="polite">
  <div class="lm__confirm-check" aria-hidden="true">
    <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
      <path d="M4 13L10 19L22 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <h3 class="lm__confirm-title" set:html={t.confirmCbTitle} />
  <div class="lm__confirm-when" id={`${prefix}-cb-when`}></div>
  <div class="lm__confirm-summary" id={`${prefix}-cb-summary`}></div>
  <button class="btn btn-red lm__confirm-cta" data-lm-close>{t.closeBtn}</button>
</div>

<!-- ─── CONFERMA · VISITA IN SEDE ────────────────────────────────── -->
<div class="lm__body lm__confirm" data-step="confirm-visit" hidden aria-live="polite">
  <div class="lm__confirm-check" aria-hidden="true">
    <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
      <path d="M4 13L10 19L22 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <h3 class="lm__confirm-title" set:html={t.confirmVisitTitle} />
  <div class="lm__confirm-when" id={`${prefix}-visit-when`}></div>
  <div class="lm__confirm-summary" id={`${prefix}-visit-summary`}></div>
  <div class="lm__confirm-dir">
    <p class="lm__confirm-dir-title">{t.howToFind}</p>
    <ul class="lm__confirm-dir-list">
      <li><strong>Tennis Club Ambrosiano — Via Feltre 33, 20134 Milano</strong></li>
      <li>{t.dirLine1}</li>
      <li>{t.dirLine2}</li>
    </ul>
    <div class="lm__confirm-dir-contacts">
      <a href="tel:+390226414392">📞 +39 02 2641 4392</a>
      <a href="mailto:info@tcambrosiano.com">✉️ info@tcambrosiano.com</a>
    </div>
    <a class="btn btn-outline--dark lm__confirm-map-btn"
       href="https://maps.google.com/?q=Via+Feltre+33,+20134+Milano"
       target="_blank" rel="noopener">{t.openMaps}</a>
  </div>
  <button class="btn btn-red lm__confirm-cta" data-lm-close>{t.closeBtn}</button>
</div>

<!-- ─── CONFERMA · MESSAGGIO ─────────────────────────────────────── -->
<div class="lm__body lm__confirm" data-step="confirm-message" hidden aria-live="polite">
  <div class="lm__confirm-check" aria-hidden="true">
    <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
      <path d="M4 13L10 19L22 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <h3 class="lm__confirm-title" set:html={t.confirmMsgTitle} />
  <div class="lm__confirm-summary" id={`${prefix}-msg-summary`}></div>
  <p class="lm__confirm-note" set:html={t.confirmNote} />
  <button class="btn btn-red lm__confirm-cta" data-lm-close>{t.closeBtn}</button>
</div>
