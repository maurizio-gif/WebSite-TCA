---

<!-- ── Step indicator ──────────────────────────────────────────────── -->
<div class="lm__steps" aria-hidden="true">
  <span class="lm__step is-active" data-step-dot="1">1</span>
  <span class="lm__step-line"></span>
  <span class="lm__step" data-step-dot="2">2</span>
  <span class="lm__step-line"></span>
  <span class="lm__step" data-step-dot="3">3</span>
</div>

<!-- ─── STEP 1 · Email + attività ─────────────────────────────────── -->
<div class="lm__body" data-step="1">
  <p class="lm__sub">{t.step1sub}</p>

  <div class="lm__field">
    <label for={`${prefix}-email`}>Email <span aria-hidden="true">*</span></label>
    <input id={`${prefix}-email`} name="email" type="email" autocomplete="email"
           placeholder="nome@esempio.com" required />
  </div>

  <div>
    <p class="lm__label-group">{t.activitiesLabel}</p>
    <div class="lm__checks">
      {attivita.map((a) => (
        <label class="lm__check-item">
          <input type="checkbox" name="attivita" value={a.id} />
          <span>{a.label}</span>
        </label>
      ))}
    </div>
  </div>

  <div class="lm__actions">
    <button class="btn btn-red lm__next" id={`${prefix}-step1-next`} type="button">
      {t.continueBtn} <span class="lm__arrow">→</span>
    </button>
  </div>
  <div class="lm__loader" hidden aria-live="polite">
    <span class="lm__spinner"></span> {t.checking}
  </div>
  <p class="lm__error" hidden role="alert"></p>
</div>

<!-- ─── STEP 2 · Dati nuovo utente ────────────────────────────────── -->
<div class="lm__body" data-step="2" hidden>
  <p class="lm__sub">{t.step2sub}</p>

  <div class="lm__grid">
    <div class="lm__field">
      <label for={`${prefix}-nome`}>{t.firstName} <span aria-hidden="true">*</span></label>
      <input id={`${prefix}-nome`} name="nome" type="text" autocomplete="given-name" required />
    </div>
    <div class="lm__field">
      <label for={`${prefix}-cognome`}>{t.lastName} <span aria-hidden="true">*</span></label>
      <input id={`${prefix}-cognome`} name="cognome" type="text" autocomplete="family-name" required />
    </div>
    <div class="lm__field lm__field--full">
      <label for={`${prefix}-cell`}>{t.mobile} <span aria-hidden="true">*</span></label>
      <div class="lm__tel-wrap">
        <select id={`${prefix}-pfx`} name="prefisso" class="lm__tel-prefix" autocomplete="tel-country-code">
          {prefissi.map((pf, i) => (
            <option value={pf.dial} selected={i === 0}>{pf.flag} {pf.dial}</option>
          ))}
        </select>
        <input id={`${prefix}-cell`} name="cellulare" type="tel" autocomplete="tel-national"
               placeholder="3XX XXX XXXX" required />
      </div>
    </div>
  </div>

  <div class="lm__consent">
    <label class="lm__consent-item">
      <input id={`${prefix}-privacy`} name="privacy" type="checkbox" required />
      <span set:html={t.privacyText} />
    </label>
    <label class="lm__consent-item">
      <input id={`${prefix}-marketing`} name="marketing" type="checkbox" />
      <span set:html={t.marketingText} />
    </label>
  </div>

  <div class="lm__actions">
    <button class="lm__back" id={`${prefix}-step2-back`} type="button">{t.backBtn}</button>
    <button class="btn btn-red lm__next" id={`${prefix}-step2-next`} type="button">
      {t.continueBtn} <span class="lm__arrow">→</span>
    </button>
  </div>
  <p class="lm__error" hidden role="alert"></p>
</div>

<!-- ─── STEP 3 · Scelta azione ────────────────────────────────────── -->
<div class="lm__body" data-step="3" hidden>
  <p class="lm__sub">{t.step3sub}</p>

  <div class="lm__action-choice">
    <button class="lm__action-btn" data-action="callback" type="button">
      <span class="lm__action-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <path d="M6.6 10.8C7.8 13.2 9.8 15.2 12.2 16.4L14.2 14.4C14.5 14.1 14.9 14 15.3 14.2C16.5 14.6 17.8 14.8 19 14.8C19.6 14.8 20 15.2 20 15.8V19C20 19.6 19.6 20 19 20C10.2 20 3 12.8 3 4C3 3.4 3.4 3 4 3H7.5C8.1 3 8.5 3.4 8.5 4C8.5 5.3 8.7 6.5 9.1 7.7C9.2 8.1 9.1 8.5 8.8 8.8L6.6 10.8Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="lm__action-texts">
        <span class="lm__action-label">{t.callbackLabel}</span>
        <span class="lm__action-sub">{t.callbackSub}</span>
      </span>
      <span class="lm__action-arr">→</span>
    </button>

