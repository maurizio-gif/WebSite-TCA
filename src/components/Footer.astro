---
const columns = [
  {
    heading: "Discipline",
    links: [
      { label: "Tennis", href: "/tennis" },
      { label: "Padel e Pickleball", href: "/padel" },
      { label: "Preparazione Atletica", href: "/preparazione-atletica" },
      { label: "Famiglia", href: "/famiglia" },
      { label: "Summer Camps", href: "/summer-camps" },
    ],
  },
  {
    heading: "Il Club",
    links: [
      { label: "Torneo Avvenire", href: "/torneo-avvenire" },
      // TODO: collegare link esterno PerfectGym
      { label: "Iscrizioni", href: "#" },
      // TODO: definire pagina Partner
      { label: "Partner", href: "#" },
      // TODO: definire pagina News
      { label: "News", href: "#" },
    ],
  },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__col">
      <h3 class="footer__heading">{columns[0].heading}</h3>
      <ul class="footer__list">
        {
          columns[0].links.map((l) => (
            <li>
              <a class="footer__link" href={l.href}>
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer__col">
      <h3 class="footer__heading">{columns[1].heading}</h3>
      <ul class="footer__list">
        {
          columns[1].links.map((l) => (
            <li>
              <a class="footer__link" href={l.href}>
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer__col">
      <h3 class="footer__heading">Contatti</h3>
      <ul class="footer__list">
        <li><span class="footer__text">Via Feltre 33, Milano</span></li>
        <li><a class="footer__link" href="tel:+390226414392">+39 02 2641 4392</a></li>
        <li>
          <a class="footer__link" href="mailto:info@tcambrosiano.com"
            >info@tcambrosiano.com</a
          >
        </li>
      </ul>
    </div>

    <div class="footer__col">
      <h3 class="footer__heading">Social</h3>
      <ul class="footer__list">
        <li>
          <a
            class="footer__link"
            href="https://www.instagram.com/clubambrosiano"
            target="_blank"
            rel="noopener">Instagram</a
          >
        </li>
        <li>
          <a
            class="footer__link"
            href="https://www.facebook.com/tcambrosiano"
            target="_blank"
            rel="noopener">Facebook</a
          >
        </li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <div class="footer__legal">
        <a class="footer__link" href="/privacy-policy">Privacy Policy</a>
        <a class="footer__link" href="/terms-conditions">Termini e Condizioni</a>
      </div>
      <p class="footer__sign">Tennis Club Ambrosiano — Dal 1965</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-text);
    color: #ffffff;
  }

  .footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
  }

  .footer__heading {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.25rem;
  }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer__link,
  .footer__text {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer__bottom-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .footer__sign {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 860px) {
    .footer__inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
