---
const columns = [
  {
    heading: "Adulti",
    links: [
      { label: "Tennis",                href: "/tennis" },
      { label: "Padel e Pickleball",    href: "/padel" },
      { label: "Preparazione Atletica", href: "/preparazione-atletica" },
    ],
  },
  {
    heading: "Junior",
    links: [
      { label: "Scuola Tennis",  href: "/scuola-tennis" },
      { label: "Summer Camps",   href: "/summer-camps" },
      { label: "Agonistica",     href: "/agonistica" },
    ],
  },
  {
    heading: "Il Club",
    links: [
      { label: "Torneo Avvenire", href: "/torneo-avvenire" },
      { label: "Storia",          href: "/storia" },
      { label: "Eventi",          href: "/eventi" },
      // TODO: collegare link esterno PerfectGym
      { label: "Diventa Socio",   href: "#" },
    ],
  },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <img
        src="/logos/tca-logo.png"
        alt="Tennis Club Ambrosiano"
        class="footer__logo"
        width="100"
        height="68"
      />
      <p class="footer__tagline">Dal 1965, il tennis a Milano.</p>
    </div>

    {columns.map((col) => (
      <div class="footer__col">
        <h3 class="footer__heading">{col.heading}</h3>
        <ul class="footer__list">
          {col.links.map((l) => (
            <li><a class="footer__link" href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}

    <div class="footer__col">
      <h3 class="footer__heading">Contatti</h3>
      <ul class="footer__list">
        <li><span class="footer__text">Via Feltre 33, Milano</span></li>
        <li><a class="footer__link" href="tel:+390226414392">+39 02 2641 4392</a></li>
        <li><a class="footer__link" href="mailto:info@tcambrosiano.com">info@tcambrosiano.com</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h3 class="footer__heading">Social</h3>
      <ul class="footer__list">
        <li>
          <a class="footer__link" href="https://www.instagram.com/clubambrosiano" target="_blank" rel="noopener">
            Instagram
          </a>
        </li>
        <li>
          <a class="footer__link" href="https://www.facebook.com/tcambrosiano" target="_blank" rel="noopener">
            Facebook
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <div class="footer__legal">
        <a class="footer__link" href="/privacy-policy">Privacy Policy</a>
        <a class="footer__link" href="/terms-conditions">Termini e Condizioni</a>
      </div>
      <p class="footer__sign">Tennis Club Ambrosiano &mdash; Dal 1965</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0f1013;
    color: #ffffff;
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5vh var(--pad-x) 4vh;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__logo {
    height: 44px;
    width: auto;
    object-fit: contain;
    object-position: left center;
    /* Il logo è scuro — invertiamo per il footer dark */
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  .footer__tagline {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.45);
  }

  .footer__heading {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.9vw, 13px);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 1.25rem;
    /* Override h3 global uppercase (è già uppercase) */
    line-height: 1.4;
  }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__link,
  .footer__text {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.18s;
  }

  .footer__link:hover { color: #fff; }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__bottom-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem var(--pad-x);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .footer__sign {
    font-family: var(--font-display);
    font-size: clamp(9px, 0.7vw, 11px);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 1024px) {
    .footer__inner { grid-template-columns: 1fr 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }

  @media (max-width: 640px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
    .footer__bottom-inner { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 400px) {
    .footer__inner { grid-template-columns: 1fr; }
  }
</style>
