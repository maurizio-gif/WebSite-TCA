---
import { existsSync } from 'node:fs';
import path from 'node:path';
import { getEntry } from 'astro:content';
import { useTranslations, getLocalePath, publicUrl, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'it' } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => getLocalePath(lang, path);

// Loghi enti sportivi affiliati → public/logos/partners/
// Se il file non è ancora presente, mostra l'utility .img-placeholder
// (vedi CLAUDE.md) finché non viene aggiunta la foto reale.
const affiliazioni = [
  { file: 'csain.png', nome: 'C.S.A.In.' },
  { file: 'asi.png',   nome: 'A.S.I. — Associazioni Sportive Sociali Italiane' },
  { file: 'fitp.png',  nome: 'FITP — Federazione Italiana Tennis e Padel' },
  { file: 'coni.png',  nome: 'CONI — Comitato Olimpico Nazionale Italiano' },
].map((l) => ({
  ...l,
  exists: existsSync(path.join(process.cwd(), 'public', 'logos', 'partners', l.file)),
}));

// Con soli 4 loghi, un singolo giro non basta a riempire la fascia sui
// desktop molto larghi: il movimento risulterebbe appena percettibile
// invece di un vero loop continuo. Ripetiamo il set 3 volte (poi duplicato
// nel markup per lo scroll infinito) così il nastro resta denso anche su
// schermi ultra-wide.
const affiliazioniLoop = [...affiliazioni, ...affiliazioni, ...affiliazioni];

// PDF legali gestibili da TinaCMS → src/content/legal/documenti.md
const legal = (await getEntry('legal', 'documenti'))!.data;

const columns = [
  {
    heading: t.footer.adulti,
    links: [
      { label: t.nav.tennis,       href: p('/tennis') },
      { label: t.nav.padel,        href: p('/padel') },
      { label: t.nav.prepAtletica, href: p('/preparazione-atletica') },
    ],
  },
  {
    heading: t.footer.junior,
    links: [
      { label: t.nav.scuolaTennis, href: p('/scuola-tennis') },
      { label: t.nav.summerCamps,  href: p('/summer-camps') },
      { label: t.nav.agonistica,   href: p('/agonistica') },
    ],
  },
  {
    heading: t.footer.ilClub,
    links: [
      { label: t.nav.torneoAvvenire, href: p('/torneo-avvenire') },
      { label: t.nav.storia,         href: p('/storia') },
      { label: t.nav.eventi,         href: p('/eventi') },
      { label: t.footer.diventaSocio, href: '#' }, // TODO: PerfectGym
    ],
  },
];
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <img
        src={publicUrl('/logos/tca-logo.png')}
        alt="Tennis Club Ambrosiano"
        class="footer__logo"
        width="100"
        height="68"
      />
      <p class="footer__tagline">{t.footer.tagline}</p>
    </div>

    {columns.map((col) => (
      <div class="footer__col">
        <h3 class="footer__heading">{col.heading}</h3>
        <ul class="footer__list">
          {col.links.map((l) => (
            <li><a class="footer__link" href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}

    <div class="footer__col">
      <h3 class="footer__heading">{t.footer.contatti}</h3>
      <ul class="footer__list">
        <li><span class="footer__text">{t.footer.address}</span></li>
        <li><a class="footer__link" href="tel:+390226414392">{t.footer.phone}</a></li>
        <li><a class="footer__link" href={`mailto:${t.footer.email}`}>{t.footer.email}</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h3 class="footer__heading">{t.footer.social}</h3>
      <ul class="footer__list">
        <li>
          <a class="footer__link" href="https://www.instagram.com/clubambrosiano" target="_blank" rel="noopener">
            Instagram
          </a>
        </li>
        <li>
          <a class="footer__link" href="https://www.facebook.com/tcambrosiano" target="_blank" rel="noopener">
            Facebook
          </a>
        </li>
      </ul>
    </div>

    <div class="footer__col">
      <h3 class="footer__heading">{t.footer.legal}</h3>
      <ul class="footer__list">
        <li><a class="footer__link" href={p('/regolamento')}>{t.footer.regolamento}</a></li>
        <li><a class="footer__link" href={p('/privacy-policy')}>{t.footer.privacy}</a></li>
        {legal.codice_condotta && (
          <li><a class="footer__link" href={publicUrl(legal.codice_condotta)} target="_blank" rel="noopener">{t.footer.modelloCondotta}</a></li>
        )}
        {legal.nomina_responsabile && (
          <li><a class="footer__link" href={publicUrl(legal.nomina_responsabile)} target="_blank" rel="noopener">{t.footer.nominaSafeguarding}</a></li>
        )}
      </ul>
    </div>
  </div>

  <div class="footer__affiliazioni">
    <p class="footer__propaganda">{t.footer.propaganda}</p>

    <div class="footer__logos-slider" aria-label={t.footer.affiliazioni}>
      <div class="footer__logos-track">
        {[...affiliazioniLoop, ...affiliazioniLoop].map((l) => (
          <div class="footer__logo-chip">
            {l.exists
              ? <img src={publicUrl(`/logos/partners/${l.file}`)} alt={l.nome}
                     class="footer__logo-chip-img" loading="lazy" />
              : <div class="img-placeholder footer__logo-chip-placeholder" data-name={l.file}></div>}
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p class="footer__sign">{t.footer.sign}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0f1013;
    color: #ffffff;
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5vh var(--pad-x) 4vh;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__logo {
    height: 44px;
    width: auto;
    object-fit: contain;
    object-position: left center;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  .footer__tagline {
    font-family: var(--font-body);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.45);
  }

  .footer__heading {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.9vw, 13px);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 1.25rem;
    line-height: 1.4;
  }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__link,
  .footer__text {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.18s;
  }

  .footer__link { text-decoration: none; }
  .footer__link:hover { color: #fff; }

  /* ── Enti sportivi affiliati ─────────────────────────────────────── */
  .footer__affiliazioni {
    background: #ffffff;
    padding: 4vh 0 4.5vh;
  }

  .footer__propaganda {
    font-family: var(--font-display);
    font-size: clamp(11px, 1vw, 13px);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-text-light);
    width: 100%;
    padding: 0 var(--pad-x);
    margin-bottom: 3vh;
  }

  .footer__logos-slider {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }

  .footer__logos-track {
    display: flex;
    align-items: center;
    gap: clamp(3rem, 6vw, 6rem);
    width: max-content;
    animation: footer-marquee 90s linear infinite;
  }

  .footer__logos-slider:hover .footer__logos-track { animation-play-state: paused; }

  .footer__logo-chip {
    flex-shrink: 0;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer__logo-chip-img {
    height: 100%;
    width: auto;
    max-width: 170px;
    object-fit: contain;
    display: block;
  }

  .footer__logo-chip-placeholder {
    height: 100%;
    width: 140px;
    min-height: 0;
    font-size: 10px;
  }

  @keyframes footer-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer__logos-track { animation: none; }
    .footer__logos-slider { overflow-x: auto; }
  }

  @media (max-width: 640px) {
    .footer__logo-chip { height: 44px; }
    .footer__logo-chip-img { max-width: 120px; }
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__bottom-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem var(--pad-x);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
  }

  .footer__sign {
    font-family: var(--font-display);
    font-size: clamp(11px, 0.7vw, 11px);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 1024px) {
    .footer__inner { grid-template-columns: 1fr 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }

  @media (max-width: 640px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
    .footer__bottom-inner { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 400px) {
    .footer__inner { grid-template-columns: 1fr; }
  }
</style>
