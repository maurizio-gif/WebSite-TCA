---
import { useTranslations, getLocalePath, publicUrl, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'it' } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => getLocalePath(lang, path);
---

<section class="hero">
  <div class="hero__bg">
    <img
      src={publicUrl('/c0fbb171-c501-4040-81bf-867eb27bb1b3_TCA+Landscape.avif')}
      alt="Tennis Club Ambrosiano — vista aerea dei campi"
      class="hero__img"
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />
  </div>
  <div class="hero__grad"></div>

  <div class="hero__content">
    <span class="eyebrow eyebrow--light hero-reveal-fade" style="--reveal-delay:0s">{t.hero.eyebrow}</span>
    <h1 class="hero__title">
      <span class="hero__title-line">
        <span class="hero__title-inner" style="--reveal-delay:0.12s">Tennis Club</span>
      </span>
      <span class="hero__title-line">
        <em class="hero__title-inner" style="--reveal-delay:0.38s">Ambrosiano</em>
      </span>
    </h1>
    <p class="hero__sub hero-reveal-fade" style="--reveal-delay:0.72s">Tennis, Padel, Training and Community</p>

    <div class="hero__actions hero-reveal-fade" style="--reveal-delay:0.9s">
      {/* TODO: collegare link esterno PerfectGym */}
      <a class="btn btn-red" href="#">{t.hero.cta1}</a>
      <button class="btn btn-outline" data-open-modal="modal-contatti">{t.hero.cta2}</button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-top: var(--header-h);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  /* Gradiente diagonale */
  .hero__grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(15, 15, 18, 0.82) 30%, rgba(139, 26, 26, 0.35));
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 10vh var(--pad-x) 8vh;
    color: #ffffff;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 9rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.92;
    margin-bottom: 2.5vh;
    max-width: 14ch;
  }

  .hero__title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .hero__sub {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.6vw, 1.5rem);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 4vh;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 768px) {
    /* Altezza corretta su mobile: svh esclude le chrome bar del browser */
    .hero {
      min-height: 100svh;
      align-items: center;
    }

    .hero__content {
      padding: 8vh 24px 8vh;
    }

    .hero__title {
      font-size: clamp(3.4rem, 14vw, 5.5rem);
      max-width: none;
    }

    .hero__sub {
      font-size: clamp(0.85rem, 3.8vw, 1.1rem);
      letter-spacing: 0.12em;
    }

    .hero__img { object-position: 60% center; }
  }

  /* ── Entrance animations ─────────────────────────── */

  @keyframes heroSlideUp {
    from {
      transform: translateY(108%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mask container: clip the sliding text */
  .hero__title-line {
    display: block;
    overflow: hidden;
    /* small vertical padding so ascenders/descenders aren't clipped */
    padding-top: 0.04em;
    padding-bottom: 0.08em;
    margin-top: -0.04em;
    margin-bottom: -0.08em;
  }

  .hero__title-inner {
    display: block;
    animation: heroSlideUp 1.1s cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0s) both;
  }

  /* Fade-up for eyebrow, subtitle, and CTA */
  .hero-reveal-fade {
    animation: heroFadeUp 0.8s cubic-bezier(0.25, 1, 0.5, 1) var(--reveal-delay, 0s) both;
  }

  /* Respect reduced-motion preference */
  @media (prefers-reduced-motion: reduce) {
    .hero__title-inner,
    .hero-reveal-fade {
      animation: none;
    }
  }
</style>
