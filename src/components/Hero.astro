---
// TODO: quando disponibile, usare src/assets/images/hero/hero-home.jpg come background.
// Placeholder attuale: sfondo #141416.
---

<section class="hero">
  <div class="hero__bg" data-name="hero-home.jpg"></div>
  <div class="hero__grad"></div>

  <div class="hero__content">
    <span class="eyebrow eyebrow--light">Dal 1965, il tennis a Milano</span>
    <h1 class="hero__title">
      Il club dove<br>la tradizione<br>incontra il tuo<br><em>prossimo dritto.</em>
    </h1>
    <p class="hero__sub">
      Sedici campi, una scuola tennis tra le più storiche della città,
      e oltre 30.000 mq dedicati allo sport e alla famiglia.
      A pochi passi dalla metro Udine.
    </p>

    <div class="hero__actions">
      {/* TODO: collegare link esterno PerfectGym */}
      <a class="btn btn-red" href="#">Iscriviti ora</a>
      {/* TODO: aprire modal form lead */}
      <a class="btn btn-outline" href="#">Prenota una visita</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-top: var(--header-h);
  }

  /* Placeholder scuro — sostituire con la foto hero */
  .hero__bg {
    position: absolute;
    inset: 0;
    background-color: #141416;
    background-size: cover;
    background-position: center;
  }

  .hero__bg::after {
    content: attr(data-name);
    position: absolute;
    bottom: 1rem;
    right: 1.5rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.08em;
  }

  /* Gradiente diagonale come nel sito di riferimento */
  .hero__grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(20, 20, 22, 0.82) 28%, rgba(139, 26, 26, 0.42));
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8vh var(--pad-x);
    color: #ffffff;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 7.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 3vh;
    max-width: 16ch;
  }

  .hero__title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .hero__sub {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.2vw, 19px);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    max-width: 60ch;
    margin-bottom: 3.5vh;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 768px) {
    .hero__content { padding: 6vh 20px; }
    .hero__title { font-size: clamp(2.6rem, 10vw, 4rem); }
  }
</style>
