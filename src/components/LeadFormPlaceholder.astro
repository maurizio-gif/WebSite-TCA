---
const interessi = [
  "Tennis",
  "Padel/Pickleball",
  "Preparazione Atletica",
  "Attività famiglia/bambini",
  "Membership Club",
  "Altro",
];
---

<section class="lead" id="lead">
  <div class="lead__inner">
    <div class="lead__intro">
      <span class="eyebrow">Contattaci</span>
      <h2 class="lead__title">Parliamone.<br><em>Ti ricontattiamo noi.</em></h2>
      <p class="lead__text">
        Lascia i tuoi dati e raccontaci cosa cerchi: ti risponderemo con tutte
        le informazioni — orari, disponibilità e la soluzione più adatta a te.
      </p>
    </div>

    {/* TODO fase 2: configurare action e webhook n8n. Per ora form solo visivo (submit disabilitato). */}
    <form class="lead__form" onsubmit="return false;">
      <div class="lead__field">
        <label for="lead-nome">Nome e cognome <span aria-hidden="true">*</span></label>
        <input id="lead-nome" name="nome" type="text" required />
      </div>

      <div class="lead__field">
        <label for="lead-email">Email <span aria-hidden="true">*</span></label>
        <input id="lead-email" name="email" type="email" required />
      </div>

      <div class="lead__field">
        <label for="lead-telefono">Telefono <span aria-hidden="true">*</span></label>
        <input id="lead-telefono" name="telefono" type="tel" required />
      </div>

      <div class="lead__field">
        <label for="lead-interesse">Sono interessato a</label>
        <select id="lead-interesse" name="interesse">
          <option value="" selected disabled>Seleziona…</option>
          {interessi.map((i) => <option value={i}>{i}</option>)}
        </select>
      </div>

      <div class="lead__field lead__field--full">
        <label for="lead-messaggio">Messaggio</label>
        <textarea id="lead-messaggio" name="messaggio" rows="4"></textarea>
      </div>

      <div class="lead__field lead__field--full lead__consent">
        <input id="lead-privacy" name="privacy" type="checkbox" required />
        <label for="lead-privacy">
          Ho letto e accetto la <a href="/privacy-policy">Privacy Policy</a> e
          acconsento al trattamento dei miei dati. <span aria-hidden="true">*</span>
        </label>
      </div>

      <div class="lead__field--full">
        <button class="btn btn-red lead__submit" type="submit">Invia richiesta</button>
      </div>
    </form>
  </div>
</section>

<style>
  .lead {
    padding: 7vh var(--pad-x);
  }

  .lead__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .lead__intro { display: flex; flex-direction: column; gap: 1rem; }

  .lead__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
  }

  .lead__title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .lead__text {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.05vw, 17px);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .lead__form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .lead__field { display: flex; flex-direction: column; }

  .lead__field--full { grid-column: 1 / -1; }

  .lead__field label {
    font-family: var(--font-display);
    font-size: clamp(10px, 0.85vw, 12px);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-grey-mid);
    margin-bottom: 6px;
  }

  .lead__field label span { color: var(--color-accent); }

  .lead__field input,
  .lead__field select,
  .lead__field textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 300;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    width: 100%;
    transition: border-color 0.18s;
  }

  .lead__field input:focus,
  .lead__field select:focus,
  .lead__field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .lead__field textarea { resize: vertical; }

  .lead__consent { flex-direction: row; align-items: flex-start; gap: 0.6rem; }

  .lead__consent input { width: auto; margin-top: 0.25rem; }

  .lead__consent label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 300;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1.5;
    color: var(--color-text-light);
    margin-bottom: 0;
  }

  .lead__consent a { color: var(--color-accent); text-decoration: underline; }

  .lead__submit { width: 100%; justify-content: center; }

  @media (max-width: 860px) {
    .lead__inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  @media (max-width: 600px) {
    .lead__form { grid-template-columns: 1fr; }
  }
</style>
