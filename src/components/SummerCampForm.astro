---
import type { Lang } from '../i18n/utils';
import prefissi from '../data/prefissi-telefonici';

interface Props { lang?: Lang; backHref?: string; }
const { lang = 'it', backHref = '/summer-camps' } = Astro.props;

// endISO = ultimo giorno della settimana (2026), usato lato client per nascondere le settimane già trascorse
const WEEKS = [
  { id: 'w1', range: '8/06 – 12/06', endISO: '2026-06-12' },
  { id: 'w2', range: '15/06 – 19/06', endISO: '2026-06-19' },
  { id: 'w3', range: '22/06 – 26/06', endISO: '2026-06-26' },
  { id: 'w4', range: '29/06 – 3/07', endISO: '2026-07-03' },
  { id: 'w5', range: '6/07 – 10/07', endISO: '2026-07-10' },
  { id: 'w6', range: '13/07 – 17/07', endISO: '2026-07-17' },
  { id: 'w7', range: '20/07 – 24/07', endISO: '2026-07-24' },
  { id: 'w8', range: '27/07 – 31/07', endISO: '2026-07-31' },
  { id: 'w9', range: '3/08 – 7/08', endISO: '2026-08-07' },
  { id: 'w10', range: '24/08 – 28/08', endISO: '2026-08-28' },
  { id: 'w11', range: '31/08 – 4/09', endISO: '2026-09-04' },
  { id: 'w12', range: '7/09 – 11/09', endISO: '2026-09-11' },
];

const t = lang === 'en' ? {
  minorTitle: "Child's details",
  minorSub: 'Enter the details of the child to be enrolled.',
  minorFirst: "Child's first name",
  minorLast: "Child's last name",
  minorDob: 'Date of birth',
