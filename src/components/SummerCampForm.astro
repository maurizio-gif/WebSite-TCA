  addrPh: 'Via Feltre 33',
  city: 'Città',
  cityPh: 'Milano',
  cap: 'CAP',

  parentTitle: 'Dati del genitore',
  parentFirst: 'Nome del genitore',
  parentLast: 'Cognome del genitore',
  email: 'Email',
  emailNote: "Controlla bene di aver inserito un indirizzo email corretto: lì riceverai tutte le comunicazioni da parte del Club.",
  mobile: 'Cellulare',

  statusTitle: 'Stato iscrizione',
  fitp: 'Il bambino è tesserato FITP?',
  fitpCard: 'N° tessera',
  member: 'Il bambino è Socio del Club?',
  yes: 'Sì',
  no: 'No',
  pastCamp: 'Il bambino ha partecipato l’anno scorso ai nostri summer camp?',

  weeksTitle: 'Seleziona le settimane',
  weeksSub: 'Scegli le settimane di Summer Camp a cui iscriverti, e aggiungi il Pre-Camp dove serve (dalle 8.00).',
  weeksHeadWeek: 'Settimana',
  weeksHeadCamp: 'Summer Camp',
  weeksHeadPre: 'Pre-Camp (+25€/sett.)',
  quoteNotice: 'Quote: Soci 260€/sett. (250€ dalla 2ª settimana o per fratelli) · Scuola Tennis 270€/sett. (260€) · Non Soci 295€/sett. (285€). Le quote Soci si applicano solo ai bambini regolarmente iscritti con membership kids.',

  healthTitle: 'Salute e consensi',
  healthLabel: 'Cardiopatie / uso farmaci / intolleranze / allergie / diete speciali',
  healthPh: 'Lascia vuoto se non applicabile',
