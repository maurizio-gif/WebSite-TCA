  weeksHeadWeek: 'Week',
  weeksHeadCamp: 'Summer Camp',
  weeksHeadPre: 'Pre-Camp (+€25/week)',
  quoteNotice: 'Rates: Members €260/week (€250 from the 2nd week or for siblings) · Tennis School students €270/week (€260) · Non-Members €295/week (€285). Member rates apply only to children regularly enrolled with a kids membership.',

  healthTitle: 'Health & consents',
  healthLabel: 'Heart conditions / medication / intolerances / allergies / special diets',
  healthPh: 'Leave blank if not applicable',
  medicalCert: 'I confirm that I will submit a valid medical certificate at enrolment, as required.',
  termsNote: [
