} : {
  minorTitle: 'Dati del bambino',
  minorSub: 'Inserisci di seguito i dati del bambino da iscrivere.',
  minorFirst: 'Nome del bambino',
  minorLast: 'Cognome del bambino',
  minorDob: 'Data di nascita',
  minorPob: 'Luogo di nascita',
  minorCf: 'Codice fiscale',
