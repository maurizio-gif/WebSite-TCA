  backToPage: 'Back to the Summer Camps page',

  confirmTitle: 'Thank<br><em>you!</em>',
  confirmNote: 'Thank you for your interest — we’ve received your enrolment request.',
  confirmPayNote: 'A €50 deposit (+€10 CSAIN fee for non-members) is required to confirm your spot. Payment can be made at Reception or by bank transfer within 10 days of the camp start date, indicating in the description: <strong>Summer Camp deposit and the child’s first and last name.</strong>',
  payName: 'Name',
  payIban: 'IBAN',
  payBic: 'BIC',
  payReason: 'Description',
  payReasonVal: "Summer Camp deposit and the child's first and last name.",

  errRequired: 'Please fill in this required field.',
