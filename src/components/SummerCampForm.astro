  addrPh: 'Via Feltre 33',
  city: 'City',
  cityPh: 'Milano',
  cap: 'Postal code',

  parentTitle: "Parent's details",
  parentFirst: "Parent's first name",
  parentLast: "Parent's last name",
  email: 'Email',
  emailNote: "Make sure the email address is correct: you'll receive all communications from the Club there.",
  mobile: 'Mobile',

  statusTitle: 'Enrolment status',
  fitp: 'Is the child a registered FITP member?',
  fitpCard: 'Membership number',
  member: 'Is the child a Club Member?',
