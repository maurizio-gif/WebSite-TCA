---
const reasons = [
  {
    number: "01",
    title: "Una storia che continua",
    text: "Sessant'anni di tennis, il Torneo Avvenire e una hall of fame di campioni che hanno iniziato qui. Entri in una tradizione viva.",
  },
  {
    number: "02",
    title: "Eccellenza accessibile",
    text: "Maestri qualificati, l'Academy di Renato Vavassori e impianti di livello, in un ambiente accogliente e senza formalismi.",
  },
  {
    number: "03",
    title: "Tutto in un unico luogo",
    text: "Oltre 30.000 mq: tennis, padel, preparazione atletica, attività per i più piccoli e spazi per ritrovarsi. Il tuo tempo libero, in un solo indirizzo.",
  },
  {
    number: "04",
    title: "A due passi da casa",
    text: "Metro Udine a pochi minuti e ampio parcheggio. Aperto tutti i giorni, dalle prime ore del mattino a tarda sera.",
  },
];
---

<section class="reassurance">
  <div class="reassurance__inner">
    <span class="eyebrow">Perché sceglierci</span>
    <h2 class="reassurance__title">
      Quattro buone ragioni<br><em>per varcare il cancello.</em>
    </h2>

    <ul class="reassurance__list">
      {reasons.map((r) => (
        <li class="reassurance__item">
          <span class="reassurance__num">{r.number}</span>
          <div class="reassurance__body">
            <h3 class="reassurance__item-title">{r.title}</h3>
            <p class="reassurance__text">{r.text}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .reassurance {
    padding: 7vh var(--pad-x);
  }

  .reassurance__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .reassurance__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin-bottom: 4vh;
  }

  .reassurance__title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .reassurance__list {
    list-style: none;
    border: 1px solid var(--color-border);
  }

  .reassurance__item {
    display: flex;
    gap: 2rem;
    align-items: baseline;
    padding: 24px var(--pad-x);
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s;
  }

  .reassurance__item:last-child { border-bottom: none; }
  .reassurance__item:hover { background: var(--color-off-white); }

  .reassurance__num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 3.2rem);
    font-weight: 800;
    color: var(--color-accent);
    min-width: 2.5ch;
    line-height: 1;
    flex-shrink: 0;
  }

  .reassurance__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .reassurance__item-title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.5vw, 1.5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  .reassurance__text {
    font-family: var(--font-body);
    font-size: clamp(13px, 0.98vw, 16px);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-text-light);
    max-width: 80ch;
  }

  @media (max-width: 600px) {
    .reassurance__item { flex-direction: column; gap: 0.5rem; padding: 20px; }
  }
</style>
