---
import { getLocalePath, useTranslations, publicUrl, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'it' } = Astro.props;
const p = (path: string) => getLocalePath(lang, path);
const t = useTranslations(lang);
---

<section class="torneo">
  <div class="torneo__bg">
    <img
      src={publicUrl('/11d7e052-18b5-4f27-9737-e84bbe2b3736_FRA_0127.avif')}
      alt={t.torneo.imgAlt}
      class="torneo__img"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="torneo__grad"></div>

  <div class="torneo__inner">
    <div class="torneo__content">
      <span class="eyebrow eyebrow--light" data-anim="from-left">{t.torneo.eyebrow}</span>
      <h2 class="torneo__title">
        {t.torneo.titleA}<br><em>{t.torneo.titleB}</em>
      </h2>
      <p class="torneo__body">
        {t.torneo.body}
      </p>
      <a class="btn btn-red" href={p('/torneo-avvenire')} data-anim="from-left" data-anim-delay="200">{t.torneo.cta}</a>
    </div>

    <div class="torneo__stats">
      <div class="torneo__stat">
        <span class="stat__num">60+</span>
        <span class="stat__label">{t.torneo.statEdizioni}</span>
      </div>
      <div class="torneo__stat">
        <span class="stat__num">20+</span>
        <span class="stat__label">{t.torneo.statPaesi}</span>
      </div>
      <div class="torneo__stat">
        <span class="stat__num">U16</span>
        <span class="stat__label">{t.torneo.statCategoria}</span>
      </div>
      <div class="torneo__stat">
        <span class="stat__num">ITF</span>
        <span class="stat__label">{t.torneo.statCircuito}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .torneo {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #0f1013;
  }

  .torneo__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .torneo__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .torneo__grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(10, 10, 13, 0.93) 35%,
      rgba(139, 26, 26, 0.22) 72%,
      rgba(10, 10, 13, 0.55)
    );
  }

  .torneo__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 9vh var(--pad-x);
    display: flex;
    flex-direction: column;
    gap: 5vh;
  }

  .torneo__content {
    max-width: 52ch;
  }

  .torneo__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6.5vw, 7.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 0.9;
    color: #ffffff;
    margin-top: 0.5rem;
    margin-bottom: 2.5vh;
  }

  .torneo__title em {
    color: var(--color-accent);
    font-style: normal;
  }

  .torneo__body {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw, 19px);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.68);
    margin-bottom: 3.5vh;
  }

  /* Stats bar */
  .torneo__stats {
    display: flex;
    gap: clamp(2rem, 5vw, 5rem);
    flex-wrap: wrap;
    align-items: flex-end;
    padding-top: 2.5vh;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .torneo__stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat__num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
    text-transform: uppercase;
  }

  .stat__label {
    font-family: var(--font-body);
    font-size: clamp(10px, 0.75vw, 12px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.38);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  @media (max-width: 768px) {
    .torneo__title { font-size: clamp(2.8rem, 10vw, 4.5rem); }
    .torneo__stats { gap: 1.5rem 3rem; }
    .stat__num { font-size: clamp(1.8rem, 8vw, 3rem); }
  }
</style>
