---
const WEBHOOK_CHECK = '';
const WEBHOOK_LEAD  = '';

const attivita = [
  { id: 'tennis',     label: 'Tennis' },
  { id: 'padel',      label: 'Padel' },
  { id: 'prep',       label: 'Preparazione Atletica' },
  { id: 'scuola',     label: 'Scuola Tennis (bambini)' },
  { id: 'agonistica', label: 'Agonistica Tennis' },
  { id: 'camps',      label: 'Summer Camps' },
  { id: 'membership', label: 'Membership / Abbonamento' },
];
---

<dialog id="modal-contatti" class="lm" aria-labelledby="lm-title">
  <div class="lm__panel">

    <!-- ── Header fisso ─────────────────────────────────────────── -->
    <div class="lm__head">
      <div>
        <span class="eyebrow eyebrow--light">Contattaci</span>
        <h2 class="lm__title" id="lm-title">Parliamone.<br><em>Siamo qui per te.</em></h2>
      </div>
      <button class="lm__close" aria-label="Chiudi" data-lm-close>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- ── Step indicator ────────────────────────────────────────── -->
    <div class="lm__steps" aria-hidden="true">
      <span class="lm__step is-active" data-step-dot="1">1</span>
      <span class="lm__step-line"></span>
      <span class="lm__step" data-step-dot="2">2</span>
      <span class="lm__step-line"></span>
      <span class="lm__step" data-step-dot="3">3</span>
    </div>

    <!-- ─── STEP 1 · Email + attività ───────────────────────────── -->
    <div class="lm__body" data-step="1">
      <p class="lm__sub">Inserisci la tua email e dicci cosa ti interessa.</p>

      <div class="lm__field">
        <label for="lm-email">Email <span aria-hidden="true">*</span></label>
        <input id="lm-email" name="email" type="email" autocomplete="email"
               placeholder="nome@esempio.com" required />
      </div>

      <div>
        <p class="lm__label-group">Attività di interesse</p>
        <div class="lm__checks">
          {attivita.map((a) => (
            <label class="lm__check-item">
              <input type="checkbox" name="attivita" value={a.id} />
              <span>{a.label}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="lm__actions">
        <button class="btn btn-red lm__next" id="lm-step1-next" type="button">
          Continua <span class="lm__arrow">→</span>
        </button>
      </div>
      <div class="lm__loader" hidden aria-live="polite">
        <span class="lm__spinner"></span> Verifica in corso…
      </div>
      <p class="lm__error" hidden role="alert"></p>
    </div>

    <!-- ─── STEP 2 · Dati nuovo utente ──────────────────────────── -->
    <div class="lm__body" data-step="2" hidden>
      <p class="lm__sub">Piacere di conoscerti! Aggiungi i tuoi dati per procedere.</p>

      <div class="lm__grid">
        <div class="lm__field">
          <label for="lm-nome">Nome <span aria-hidden="true">*</span></label>
          <input id="lm-nome" name="nome" type="text" autocomplete="given-name" required />
        </div>
        <div class="lm__field">
          <label for="lm-cognome">Cognome <span aria-hidden="true">*</span></label>
          <input id="lm-cognome" name="cognome" type="text" autocomplete="family-name" required />
        </div>
        <div class="lm__field lm__field--full">
          <label for="lm-cell">Cellulare <span aria-hidden="true">*</span></label>
          <div class="lm__tel-wrap">
            <select id="lm-prefix" name="prefisso" class="lm__tel-prefix" autocomplete="tel-country-code">
              <option value="+39" selected>🇮🇹 +39</option>
              <option value="+41">🇨🇭 +41</option>
              <option value="+43">🇦🇹 +43</option>
              <option value="+33">🇫🇷 +33</option>
              <option value="+49">🇩🇪 +49</option>
              <option value="+44">🇬🇧 +44</option>
              <option value="+34">🇪🇸 +34</option>
              <option value="+351">🇵🇹 +351</option>
              <option value="+31">🇳🇱 +31</option>
              <option value="+32">🇧🇪 +32</option>
              <option value="+1">🇺🇸 +1</option>
              <option value="+55">🇧🇷 +55</option>
              <option value="+54">🇦🇷 +54</option>
            </select>
            <input id="lm-cell" name="cellulare" type="tel" autocomplete="tel-national"
                   placeholder="3XX XXX XXXX" required />
          </div>
        </div>
      </div>

      <div class="lm__consent">
        <label class="lm__consent-item">
          <input id="lm-privacy" name="privacy" type="checkbox" required />
          <span>
            Ho letto e accetto la <a href="/privacy-policy" target="_blank">Privacy Policy</a>.
            Acconsento al trattamento dei dati personali per rispondermi a questa richiesta.
            <strong>(obbligatorio)</strong>
          </span>
        </label>
        <label class="lm__consent-item">
          <input id="lm-marketing" name="marketing" type="checkbox" />
          <span>
            Acconsento a ricevere comunicazioni commerciali, offerte e novità dal
            Tennis Club Ambrosiano via email, SMS e WhatsApp.
            <em>(facoltativo)</em>
          </span>
        </label>
      </div>

      <div class="lm__actions">
        <button class="lm__back" id="lm-step2-back" type="button">← Indietro</button>
        <button class="btn btn-red lm__next" id="lm-step2-next" type="button">
          Continua <span class="lm__arrow">→</span>
        </button>
      </div>
      <p class="lm__error" hidden role="alert"></p>
    </div>

    <!-- ─── STEP 3 · Scelta azione ───────────────────────────────── -->
    <div class="lm__body" data-step="3" hidden>
      <p class="lm__sub">Come possiamo aiutarti?</p>

      <div class="lm__action-choice">
        <button class="lm__action-btn" data-action="callback" type="button">
          <span class="lm__action-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M6.6 10.8C7.8 13.2 9.8 15.2 12.2 16.4L14.2 14.4C14.5 14.1 14.9 14 15.3 14.2C16.5 14.6 17.8 14.8 19 14.8C19.6 14.8 20 15.2 20 15.8V19C20 19.6 19.6 20 19 20C10.2 20 3 12.8 3 4C3 3.4 3.4 3 4 3H7.5C8.1 3 8.5 3.4 8.5 4C8.5 5.3 8.7 6.5 9.1 7.7C9.2 8.1 9.1 8.5 8.8 8.8L6.6 10.8Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="lm__action-texts">
            <span class="lm__action-label">RICHIAMAMI</span>
            <span class="lm__action-sub">Scegli giorno e orario — ti chiamiamo noi</span>
          </span>
          <span class="lm__action-arr">→</span>
        </button>

        <button class="lm__action-btn" data-action="visit" type="button">
          <span class="lm__action-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M12 2C8.13 2 5 5.13 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.13 15.87 2 12 2Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.6"/>
            </svg>
          </span>
          <span class="lm__action-texts">
            <span class="lm__action-label">PRENOTA UNA VISITA IN SEDE</span>
            <span class="lm__action-sub">Vieni a trovarci al Club — ti mostriamo tutto</span>
          </span>
          <span class="lm__action-arr">→</span>
        </button>

        <button class="lm__action-btn" data-action="message" type="button">
          <span class="lm__action-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/>
              <path d="M22 6L12 13L2 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="lm__action-texts">
            <span class="lm__action-label">SCRIVI UN MESSAGGIO</span>
            <span class="lm__action-sub">Ti risponderemo via email al più presto</span>
          </span>
          <span class="lm__action-arr">→</span>
        </button>
      </div>

      <button class="lm__back lm__back--center" id="lm-step3-back" type="button">← Indietro</button>
    </div>

    <!-- ─── STEP 4a · RICHIAMAMI ─────────────────────────────────── -->
    <div class="lm__body" data-step="4-callback" hidden>
      <p class="lm__sub">Raccontaci come possiamo aiutarti e scegli quando richiamarti.</p>

      <div class="lm__field">
        <label for="lm-cb-reason">Motivo della chiamata <span aria-hidden="true">*</span></label>
        <textarea id="lm-cb-reason" name="cb-reason" rows="3"
                  placeholder="Es. vorrei informazioni sull'abbonamento, ho già giocato e voglio riprendere…"></textarea>
      </div>

      <!-- Calendario mensile -->
      <div class="lm__cal">
        <p class="lm__label-group">Scegli il giorno</p>
        <div class="lm__cal-month-wrap" id="lm-cal-cb"></div>
        <div class="lm__slots-wrap" id="lm-slots-wrap-cb" hidden>
          <p class="lm__slots-wrap-title">Orari disponibili</p>
          <div class="lm__slots-body" id="lm-cal-slots-cb"></div>
        </div>
      </div>

      <div class="lm__actions">
        <button class="lm__back" data-step-back="3" type="button">← Indietro</button>
        <button class="btn btn-red" id="lm-cb-confirm" type="button" disabled>
          Conferma <span class="lm__arrow">→</span>
        </button>
      </div>
      <p class="lm__error" hidden role="alert"></p>
    </div>

    <!-- ─── STEP 4b · PRENOTA VISITA ─────────────────────────────── -->
    <div class="lm__body" data-step="4-visit" hidden>
      <p class="lm__sub">Descrivici il motivo della visita e scegli giorno e orario di arrivo.</p>

      <div class="lm__field">
        <label for="lm-visit-reason">Motivo della visita <span aria-hidden="true">*</span></label>
        <textarea id="lm-visit-reason" name="visit-reason" rows="3"
                  placeholder="Es. voglio visitare la struttura, mi interessa iscrivermi al padel…"></textarea>
      </div>

      <!-- Calendario mensile -->
      <div class="lm__cal">
        <p class="lm__label-group">Scegli il giorno</p>
        <div class="lm__cal-month-wrap" id="lm-cal-visit"></div>
        <div class="lm__slots-wrap" id="lm-slots-wrap-visit" hidden>
          <p class="lm__slots-wrap-title">Orari disponibili</p>
          <div class="lm__slots-body" id="lm-cal-slots-visit"></div>
        </div>
      </div>

      <div class="lm__actions">
        <button class="lm__back" data-step-back="3" type="button">← Indietro</button>
        <button class="btn btn-red" id="lm-visit-confirm" type="button" disabled>
          Conferma visita <span class="lm__arrow">→</span>
        </button>
      </div>
      <p class="lm__error" hidden role="alert"></p>
    </div>

    <!-- ─── STEP 4c · SCRIVI UN MESSAGGIO ───────────────────────── -->
    <div class="lm__body" data-step="4-message" hidden>
      <p class="lm__sub">Scrivici la tua richiesta: ti risponderemo nel più breve tempo possibile.</p>

      <div class="lm__field">
        <label for="lm-msg-text">La tua richiesta <span aria-hidden="true">*</span></label>
        <textarea id="lm-msg-text" name="message" rows="6"
                  placeholder="Raccontaci cosa cerchi, cosa ti interessa o qualsiasi domanda sul Club, sulle attività o sulle tariffe…"></textarea>
      </div>

      <div class="lm__actions">
        <button class="lm__back" data-step-back="3" type="button">← Indietro</button>
        <button class="btn btn-red" id="lm-msg-send" type="button">
          Invia richiesta <span class="lm__arrow">→</span>
        </button>
      </div>
      <p class="lm__error" hidden role="alert"></p>
    </div>

    <!-- ─── CONFERMA · RICHIAMAMI ─────────────────────────────────── -->
    <div class="lm__body lm__confirm" data-step="confirm-callback" hidden aria-live="polite">
      <div class="lm__confirm-check" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
          <path d="M4 13L10 19L22 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="lm__confirm-title">Perfetto!<br><em>Ti richiamiamo noi.</em></h3>
      <div class="lm__confirm-when" id="lm-cb-when"></div>
      <div class="lm__confirm-summary" id="lm-cb-summary"></div>
      <button class="btn btn-red lm__confirm-cta" data-lm-close>Chiudi</button>
    </div>

    <!-- ─── CONFERMA · VISITA IN SEDE ────────────────────────────── -->
    <div class="lm__body lm__confirm" data-step="confirm-visit" hidden aria-live="polite">
      <div class="lm__confirm-check" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
          <path d="M4 13L10 19L22 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="lm__confirm-title">Ti aspettiamo<br><em>al Club!</em></h3>
      <div class="lm__confirm-when" id="lm-visit-when"></div>
      <div class="lm__confirm-summary" id="lm-visit-summary"></div>
      <div class="lm__confirm-dir">
        <p class="lm__confirm-dir-title">Come raggiungerci</p>
        <ul class="lm__confirm-dir-list">
          <li><strong>Tennis Club Ambrosiano — Via Feltre 33, 20134 Milano</strong></li>
          <li>🚇 Metro Udine (Linea 2 Verde) — pochi minuti a piedi dall'uscita</li>

          <li>🚌 Bus linee 62 e 66 — fermata Via Feltre</li>
        </ul>
        <div class="lm__confirm-dir-contacts">
          <a href="tel:+390226414392">📞 +39 02 2641 4392</a>
          <a href="mailto:info@tcambrosiano.com">✉️ info@tcambrosiano.com</a>
        </div>
        <a class="btn btn-outline--dark lm__confirm-map-btn"
           href="https://maps.google.com/?q=Via+Feltre+33,+20134+Milano"
           target="_blank" rel="noopener">Apri in Google Maps →</a>
      </div>
      <button class="btn btn-red lm__confirm-cta" data-lm-close>Chiudi</button>
    </div>

    <!-- ─── CONFERMA · MESSAGGIO ─────────────────────────────────── -->
    <div class="lm__body lm__confirm" data-step="confirm-message" hidden aria-live="polite">
      <div class="lm__confirm-check" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
          <path d="M4 13L10 19L22 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="lm__confirm-title">Messaggio<br><em>ricevuto!</em></h3>
      <div class="lm__confirm-summary" id="lm-msg-summary"></div>
      <p class="lm__confirm-note">
        Ti risponderemo all'indirizzo indicato nel più breve tempo possibile.<br>A presto al TCA!
      </p>
      <button class="btn btn-red lm__confirm-cta" data-lm-close>Chiudi</button>
    </div>

  </div>
</dialog>

<style is:global>
  :root {
    --lm-bg:       #F4EDE8;
    --lm-bg-head:  #EDE4DE;
    --lm-border:   rgba(139,26,26,0.12);
    --lm-text:     #1A1A1A;
    --lm-text-sub: #6B5C57;
    --lm-text-dim: rgba(90,60,55,0.5);
    --lm-input-bg: #FBF7F5;
    --lm-input-bd: rgba(139,26,26,0.18);
  }

  /* ── Dialog ──────────────────────────────────────────────────── */
  .lm {
    border: none; padding: 0; background: transparent;
    max-width: min(96vw, 680px);
    width: 100%; margin: auto;
  }

  .lm::backdrop {
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
  }

  /* ── Panel ───────────────────────────────────────────────────── */
  .lm__panel {
    background: var(--lm-bg);
    color: var(--lm-text);
    display: flex; flex-direction: column;
    max-height: 92vh; overflow-y: auto;
  }

  /* ── Header ──────────────────────────────────────────────────── */
  .lm__head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 1.5rem; padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid var(--lm-border);
    position: sticky; top: 0;
    background: var(--lm-bg-head); z-index: 2;
  }

  .lm__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800; text-transform: uppercase;
    letter-spacing: -0.01em; line-height: 0.92;
    margin-top: 0.4rem; color: var(--lm-text);
  }
  .lm__title em { color: var(--color-accent); font-style: normal; }

  .lm__close {
    background: none; border: 1px solid var(--lm-border);
    color: var(--lm-text-sub);
    width: 2rem; height: 2rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; cursor: pointer;
    transition: border-color 0.18s, color 0.18s; padding: 0;
  }
  .lm__close:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* ── Step indicator ──────────────────────────────────────────── */
  .lm__steps {
    display: flex; align-items: center;
    padding: 0.9rem 2rem;
    border-bottom: 1px solid var(--lm-border);
    background: var(--lm-bg-head);
  }

  .lm__step {
    width: 24px; height: 24px; border-radius: 50%;
    border: 1.5px solid var(--lm-border);
    color: var(--lm-text-dim);
    font-family: var(--font-display); font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.25s, border-color 0.25s, color 0.25s; flex-shrink: 0;
  }
  .lm__step.is-active { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }
  .lm__step.is-done   { background: rgba(139,26,26,0.1); border-color: rgba(139,26,26,0.2); color: var(--color-accent); }
  .lm__step-line { flex: 1; height: 1px; background: var(--lm-border); margin: 0 6px; }

  /* ── Body step ───────────────────────────────────────────────── */
  .lm__body {
    padding: 1.8rem 2rem 2rem;
    display: flex; flex-direction: column; gap: 1.2rem;
  }

  .lm__sub {
    font-family: var(--font-body); font-size: clamp(13px,.95vw,15px);
    font-weight: 300; line-height: 1.7; color: var(--lm-text-sub); margin: 0;
  }

  /* ── Campi form ──────────────────────────────────────────────── */
  .lm__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .lm__field { display: flex; flex-direction: column; gap: 6px; }
  .lm__field--full { grid-column: 1 / -1; }

  .lm__field label, .lm__label-group {
    font-family: var(--font-display);
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--lm-text-sub); margin: 0;
  }
  .lm__field label span { color: var(--color-accent); }

  .lm__field input, .lm__field textarea {
    font-family: var(--font-body); font-size: clamp(13px,.95vw,15px);
    font-weight: 300; padding: 0.7rem 0.85rem;
    border: 1px solid var(--lm-input-bd);
    background: var(--lm-input-bg); color: var(--lm-text);
    width: 100%; transition: border-color 0.18s;
    -webkit-appearance: none; appearance: none;
  }
  .lm__field input:focus, .lm__field textarea:focus {
    outline: none; border-color: var(--color-accent); background: #fff;
  }
  .lm__input--error { border-color: #c0392b !important; background: #fff5f5 !important; }
  .lm__field textarea { resize: vertical; min-height: 90px; }

  /* ── Tel prefisso ────────────────────────────────────────────── */
  .lm__tel-wrap { display: flex; }
  .lm__tel-prefix {
    font-family: var(--font-body); font-size: clamp(13px,.95vw,15px);
    font-weight: 300; padding: 0.7rem 0.5rem;
    border: 1px solid var(--lm-input-bd); border-right: none;
    background: var(--lm-input-bg); color: var(--lm-text);
    flex-shrink: 0; min-width: 90px; cursor: pointer;
    -webkit-appearance: none; appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%236B5C57' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat; background-position: right 8px center; padding-right: 22px;
    transition: border-color 0.18s;
  }
  .lm__tel-prefix:focus { outline: none; border-color: var(--color-accent); z-index: 1; }
  .lm__tel-wrap input[type="tel"] { flex: 1; min-width: 0; border-left: 1px solid var(--lm-input-bd) !important; }
  .lm__tel-wrap:focus-within .lm__tel-prefix,
  .lm__tel-wrap:focus-within input[type="tel"] { border-color: var(--color-accent); }

  /* ── Checkboxes attività ─────────────────────────────────────── */
  .lm__checks { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .lm__check-item {
    display: flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-body); font-size: clamp(12px,.85vw,13px); font-weight: 300;
    color: var(--lm-text-sub); cursor: pointer;
    border: 1px solid var(--lm-input-bd); padding: 5px 10px;
    background: var(--lm-input-bg);
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .lm__check-item:hover { border-color: var(--color-accent); color: var(--lm-text); }
  .lm__check-item input[type="checkbox"] { accent-color: var(--color-accent); flex-shrink: 0; }
  .lm__check-item:has(input:checked) {
    border-color: var(--color-accent); background: rgba(139,26,26,0.06); color: var(--color-accent);
  }

  /* ── Consensi ────────────────────────────────────────────────── */
  .lm__consent { display: flex; flex-direction: column; gap: 0.75rem; padding-top: 0.5rem; border-top: 1px solid var(--lm-border); }
  .lm__consent-item { display: flex; align-items: flex-start; gap: 0.6rem; cursor: pointer; }
  .lm__consent-item input[type="checkbox"] { flex-shrink: 0; margin-top: 0.2em; accent-color: var(--color-accent); }
  .lm__consent-item span { font-family: var(--font-body); font-size: clamp(11px,.8vw,12px); font-weight: 300; line-height: 1.55; color: var(--lm-text-dim); }
  .lm__consent-item span a { color: var(--color-accent); text-decoration: underline; }
  .lm__consent-item span strong { color: var(--lm-text-sub); font-weight: 500; }
  .lm__consent-item span em { color: var(--lm-text-dim); font-style: normal; }

  /* ── Actions row ─────────────────────────────────────────────── */
  .lm__actions {
    display: flex; align-items: center; justify-content: flex-end;
    gap: 1rem; padding-top: 0.4rem; border-top: 1px solid var(--lm-border);
  }
  .lm__back {
    font-family: var(--font-display); font-size: 12px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--lm-text-dim);
    background: none; border: none; cursor: pointer; padding: 0; transition: color 0.18s;
  }
  .lm__back:hover { color: var(--lm-text); }
  .lm__back--center { align-self: center; }
  .lm__next { gap: 0.4rem; }
  .lm__arrow { display: inline-block; transition: transform 0.18s; }
  .lm__next:hover .lm__arrow, .btn:hover .lm__arrow { transform: translateX(4px); }

  /* ── Loader ──────────────────────────────────────────────────── */
  .lm__loader { display: flex; align-items: center; gap: 0.6rem; font-family: var(--font-body); font-size: 13px; color: var(--lm-text-sub); }
  .lm__spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid var(--lm-border); border-top-color: var(--color-accent); border-radius: 50%; animation: lm-spin 0.7s linear infinite; flex-shrink: 0; }
  @keyframes lm-spin { to { transform: rotate(360deg); } }
  .lm__error { font-family: var(--font-body); font-size: 12px; color: #c0392b; margin: 0; }

  /* ── Pulsanti scelta azione (step 3) ─────────────────────────── */
  .lm__action-choice { display: flex; flex-direction: column; gap: 2px; }

  .lm__action-btn {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.15rem 1rem;
    background: var(--lm-input-bg); border: 1px solid var(--lm-input-bd);
    color: var(--lm-text); cursor: pointer; text-align: left;
    transition: background 0.18s, border-color 0.18s;
    position: relative; width: 100%;
  }
  .lm__action-btn::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: var(--color-accent); transform: scaleY(0);
    transition: transform 0.22s cubic-bezier(0.22, 0.68, 0, 1.1);
  }
  .lm__action-btn:hover { background: #fff; border-color: rgba(139,26,26,0.3); }
  .lm__action-btn:hover::before { transform: scaleY(1); }
  .lm__action-icon { flex-shrink: 0; color: var(--color-accent); opacity: 0.75; display: flex; align-items: center; }
  .lm__action-texts { flex: 1; display: flex; flex-direction: column; gap: 3px; }
  .lm__action-label { font-family: var(--font-display); font-size: clamp(.95rem,1.8vw,1.2rem); font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em; color: var(--lm-text); line-height: 1; }
  .lm__action-sub { font-family: var(--font-body); font-size: 12px; font-weight: 300; color: var(--lm-text-dim); line-height: 1.4; }
  .lm__action-arr { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--color-accent); opacity: 0; transition: opacity 0.18s, transform 0.18s; flex-shrink: 0; }
  .lm__action-btn:hover .lm__action-arr { opacity: 1; transform: translateX(3px); }

  /* ══════════════════════════════════════════════════════════════
     CALENDARIO MENSILE
  ══════════════════════════════════════════════════════════════ */
  .lm__cal { display: flex; flex-direction: column; gap: 1rem; }

  /* Wrapper del mese */
  .lm__cal-month-wrap {
    border: 1px solid var(--lm-border);
    background: var(--lm-input-bg);
    padding: 1rem;
    user-select: none;
  }

  /* Navigazione mese */
  .lm__cal-nav {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1rem;
  }

  .lm__cal-month-name {
    font-family: var(--font-display);
    font-size: 13px; font-weight: 800;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--lm-text);
  }

  .lm__cal-nav-btn {
    background: none; border: 1px solid var(--lm-border);
    cursor: pointer; width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    color: var(--lm-text-sub); font-size: 15px; font-weight: 700;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .lm__cal-nav-btn:hover:not(:disabled) { border-color: var(--color-accent); color: var(--color-accent); background: rgba(139,26,26,0.04); }
  .lm__cal-nav-btn:disabled { opacity: 0.25; cursor: not-allowed; }

  /* Griglia giorni */
  .lm__cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  /* Intestazioni giorni della settimana */
  .lm__cal-dow {
    font-family: var(--font-display); font-size: 10px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--lm-text-dim);
    text-align: center; padding: 2px 0 8px;
  }

  /* Celle giorno */
  .lm__cal-cell {
    height: 40px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-body); font-size: 13px; font-weight: 400;
    position: relative; border: 1px solid transparent;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
    color: var(--lm-text);
  }

  /* Giorno disponibile */
  .lm__cal-day--avail {
    cursor: pointer;
    background: #fff;
    border-color: var(--lm-border) !important;
  }
  .lm__cal-day--avail:hover {
    background: rgba(139,26,26,0.07) !important;
    border-color: rgba(139,26,26,0.35) !important;
    color: var(--color-accent);
    font-weight: 600;
  }

  /* Giorno non disponibile (passato o fuori range) */
  .lm__cal-day--off {
    color: var(--lm-text-dim);
    cursor: not-allowed;
    background: transparent;
    font-weight: 300;
  }

  /* Oggi — puntino rosso sotto il numero */
  .lm__cal-day--today::after {
    content: '';
    position: absolute; bottom: 5px; left: 50%; transform: translateX(-50%);
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--color-accent);
  }
  .lm__cal-day--sel.lm__cal-day--today::after { background: rgba(255,255,255,0.6); }

  /* Giorno selezionato */
  .lm__cal-day--sel {
    background: var(--color-accent) !important;
    color: #fff !important;
    border-color: var(--color-accent) !important;
    font-weight: 700;
  }

  /* ══════════════════════════════════════════════════════════════
     SLOT ORARI
  ══════════════════════════════════════════════════════════════ */
  .lm__slots-wrap {
    border: 1px solid var(--lm-border);
    background: var(--lm-input-bg);
    padding: 1rem;
    display: flex; flex-direction: column; gap: 1rem;
  }

  .lm__slots-wrap-title {
    font-family: var(--font-display); font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--lm-text-sub); margin: 0;
  }

  .lm__slots-body { display: flex; flex-direction: column; gap: 1rem; }

  /* Gruppo (Mattina / Pomeriggio / Sera) */
  .lm__slots-group { display: flex; flex-direction: column; gap: 0.5rem; }

  .lm__slots-group-label {
    font-family: var(--font-display); font-size: 10px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--lm-text-dim);
  }

  .lm__slots-row { display: flex; flex-wrap: wrap; gap: 6px; }

  /* Singolo slot */
  .lm__cal-slot-btn {
    font-family: var(--font-body); font-size: 13px; font-weight: 400;
    padding: 9px 14px; min-width: 70px; text-align: center;
    background: #fff; border: 1px solid var(--lm-input-bd);
    color: var(--lm-text); cursor: pointer;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
    letter-spacing: 0.02em;
  }
  .lm__cal-slot-btn:hover {
    background: rgba(139,26,26,0.07);
    border-color: var(--color-accent);
    color: var(--color-accent);
    font-weight: 600;
  }
  .lm__cal-slot-btn.is-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff; font-weight: 700;
  }

  /* ── Schermate di conferma ───────────────────────────────────── */
  .lm__confirm { align-items: stretch; gap: 1.4rem; }

  .lm__confirm-check {
    width: 3.5rem; height: 3.5rem; border: 2px solid var(--color-accent); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--color-accent); align-self: flex-start;
  }

  .lm__confirm-title {
    font-family: var(--font-display); font-size: clamp(1.6rem,3.5vw,2.4rem);
    font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em;
    line-height: 0.92; color: var(--lm-text); margin: 0;
  }
  .lm__confirm-title em { color: var(--color-accent); font-style: normal; }

  .lm__confirm-when {
    background: rgba(139,26,26,0.06); border: 1px solid rgba(139,26,26,0.18);
    border-left: 3px solid var(--color-accent);
    padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.6rem;
  }
  .lm__confirm-when-row { display: flex; flex-direction: column; gap: 2px; }
  .lm__confirm-when-label { font-family: var(--font-display); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent); }
  .lm__confirm-when-val { font-family: var(--font-display); font-size: clamp(1rem,2vw,1.3rem); font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em; color: var(--lm-text); line-height: 1.1; }

  .lm__confirm-summary { border: 1px solid var(--lm-border); background: var(--lm-input-bg); }
  .lm__confirm-row {
    display: grid; grid-template-columns: 120px 1fr; gap: 0.5rem;
    padding: 0.65rem 1rem; border-bottom: 1px solid var(--lm-border);
    font-family: var(--font-body); font-size: 13px; align-items: start;
  }
  .lm__confirm-row:last-child { border-bottom: none; }
  .lm__confirm-row > span:first-child { font-weight: 700; color: var(--lm-text-sub); text-transform: uppercase; font-size: 11px; letter-spacing: 0.06em; padding-top: 1px; }
  .lm__confirm-row > span:last-child { font-weight: 300; color: var(--lm-text); line-height: 1.5; word-break: break-word; }

  .lm__confirm-dir { border: 1px solid var(--lm-border); background: var(--lm-input-bg); padding: 1.2rem; display: flex; flex-direction: column; gap: 0.8rem; }
  .lm__confirm-dir-title { font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent); margin: 0; }
  .lm__confirm-dir-list { font-family: var(--font-body); font-size: clamp(12px,.9vw,13px); font-weight: 300; line-height: 1.6; color: var(--lm-text); padding: 0; margin: 0; list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .lm__confirm-dir-contacts { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .lm__confirm-dir-contacts a { font-family: var(--font-body); font-size: 13px; font-weight: 400; color: var(--lm-text); text-decoration: none; transition: color 0.18s; }
  .lm__confirm-dir-contacts a:hover { color: var(--color-accent); }
  .lm__confirm-map-btn { align-self: flex-start; font-size: 12px; padding: 0.5rem 1rem; }
  .lm__confirm-note { font-family: var(--font-body); font-size: clamp(13px,.95vw,15px); font-weight: 300; line-height: 1.7; color: var(--lm-text-sub); margin: 0; }
  .lm__confirm-cta { width: 100%; justify-content: center; }

  /* ── Fix [hidden] ────────────────────────────────────────────── */
  .lm__body[hidden]      { display: none !important; }
  .lm__loader[hidden]    { display: none !important; }
  .lm__error[hidden]     { display: none !important; }
  .lm__slots-wrap[hidden]{ display: none !important; }

  /* ── Mobile ──────────────────────────────────────────────────── */
  @media (max-width: 560px) {
    .lm__head  { padding: 1.4rem 1.2rem 1.2rem; }
    .lm__body  { padding: 1.4rem 1.2rem 1.6rem; }
    .lm__steps { padding: 0.75rem 1.2rem; }
    .lm__grid  { grid-template-columns: 1fr; }
    .lm__action-sub { display: none; }
    .lm__confirm-row { grid-template-columns: 90px 1fr; }
    .lm__cal-cell { height: 36px; font-size: 12px; }
    .lm__cal-slot-btn { padding: 8px 10px; min-width: 62px; font-size: 12px; }
  }
</style>

<script>
  var WEBHOOK_CHECK = '';
  var WEBHOOK_LEAD  = '';

  var ATTIVITA_LABELS = {
    tennis:'Tennis', padel:'Padel', prep:'Preparazione Atletica',
    scuola:'Scuola Tennis (bambini)', agonistica:'Agonistica Tennis',
    camps:'Summer Camps', membership:'Membership / Abbonamento',
  };

  var DAYS_SHORT    = ['Dom','Lun','Mar','Mer','Gio','Ven','Sab'];
  var DAYS_LONG     = ['Domenica','Lunedì','Martedì','Mercoledì','Giovedì','Venerdì','Sabato'];
  var MONTHS_SHORT  = ['gen','feb','mar','apr','mag','giu','lug','ago','set','ott','nov','dic'];
  var MONTHS_LONG   = ['gennaio','febbraio','marzo','aprile','maggio','giugno',
                       'luglio','agosto','settembre','ottobre','novembre','dicembre'];
  var MONTHS_FULL   = ['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno',
                       'Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];

  function fmtDateLong(d) {
    return DAYS_LONG[d.getDay()] + ' ' + d.getDate() + ' ' +
           MONTHS_LONG[d.getMonth()] + ' ' + d.getFullYear();
  }

  function pad2(n) { return String(n).padStart(2,'0'); }

  function esc(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;')
                      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Stato ────────────────────────────────────────────────────────
  var state = {
    email:'', nome:'', cognome:'', cellulare:'',
    attivita:[], privacy:false, marketing:false, isNewUser:true,
    callbackDate:null, callbackTime:null, callbackReason:'',
    visitDate:null,    visitTime:null,    visitReason:'', messageText:'',
  };

  var modal    = document.getElementById('modal-contatti');
  var stepsBar = modal.querySelector('.lm__steps');
  var stepDots = modal.querySelectorAll('[data-step-dot]');

  // ── Navigazione ──────────────────────────────────────────────────
  function showStep(n, activeDot) {
    var key = String(n);
    modal.querySelectorAll('[data-step]').forEach(function(el) {
      el.hidden = (el.dataset.step !== key);
    });
    var isMain = (key === '1' || key === '2' || key === '3');
    stepsBar.hidden = !isMain;
    if (isMain && activeDot !== undefined) {
      stepDots.forEach(function(dot) {
        var d = parseInt(dot.dataset.stepDot, 10);
        dot.classList.toggle('is-active', d === activeDot);
        dot.classList.toggle('is-done',   d < activeDot);
        if (d >= activeDot) dot.classList.remove('is-done');
        if (d !== activeDot) dot.classList.remove('is-active');
      });
    }
  }

  function getStep(n) { return modal.querySelector('[data-step="' + n + '"]'); }

  function showError(el, msg) {
    var err = el.querySelector('.lm__error');
    if (err) { err.textContent = msg; err.hidden = false; }
  }

  function clearError(el) {
    var err = el.querySelector('.lm__error');
    if (err) err.hidden = true;
  }

  function isValidEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim()); }

  // ── Reset ────────────────────────────────────────────────────────
  function closeAndReset() {
    modal.close();
    state = { email:'',nome:'',cognome:'',cellulare:'',attivita:[],privacy:false,marketing:false,isNewUser:true,
              callbackDate:null,callbackTime:null,callbackReason:'',
              visitDate:null,visitTime:null,visitReason:'',messageText:'' };

    ['#lm-email','#lm-nome','#lm-cognome','#lm-cell','#lm-cb-reason','#lm-visit-reason','#lm-msg-text']
      .forEach(function(s) { var el = modal.querySelector(s); if (el) el.value = ''; });
    modal.querySelectorAll('input[type="checkbox"]').forEach(function(c) { c.checked = false; });

    ['lm-cal-cb','lm-cal-visit'].forEach(function(id) { var el = document.getElementById(id); if (el) el.innerHTML = ''; });
    ['lm-cal-slots-cb','lm-cal-slots-visit'].forEach(function(id) { var el = document.getElementById(id); if (el) el.innerHTML = ''; });
    ['lm-slots-wrap-cb','lm-slots-wrap-visit'].forEach(function(id) { var el = document.getElementById(id); if (el) el.hidden = true; });

    var cb = document.getElementById('lm-cb-confirm');    if (cb) cb.disabled = true;
    var vi = document.getElementById('lm-visit-confirm'); if (vi) vi.disabled = true;

    showStep(1, 1);
  }

  // ── Apertura / Chiusura ──────────────────────────────────────────
  document.addEventListener('click', function(e) {
    var t = e.target.closest('[data-open-modal]');
    if (t && t.dataset.openModal === 'modal-contatti') { modal.showModal(); showStep(1,1); }
  });
  document.addEventListener('click', function(e) { if (e.target.closest('[data-lm-close]')) closeAndReset(); });
  modal.addEventListener('click', function(e) { if (e.target === modal) closeAndReset(); });

  // ── Back generico ─────────────────────────────────────────────────
  modal.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-step-back]');
    if (!btn) return;
    var t = btn.dataset.stepBack;
    showStep(t, parseInt(t,10) || 3);
  });

  // ═══════════════════════════════════════════════════════════════
  // STEP 1
  // ═══════════════════════════════════════════════════════════════
  var emailInput = modal.querySelector('#lm-email');
  emailInput.addEventListener('blur', function() {
    emailInput.classList.toggle('lm__input--error', !!emailInput.value && !isValidEmail(emailInput.value));
  });
  emailInput.addEventListener('input', function() {
    if (isValidEmail(emailInput.value)) emailInput.classList.remove('lm__input--error');
  });

  modal.querySelector('#lm-step1-next').addEventListener('click', async function() {
    var s1     = getStep(1);
    var loader = s1.querySelector('.lm__loader');
    var btn    = s1.querySelector('#lm-step1-next');
    clearError(s1); emailInput.classList.remove('lm__input--error');

    if (!emailInput.value.trim() || !isValidEmail(emailInput.value)) {
      emailInput.classList.add('lm__input--error');
      showError(s1,'Inserisci un indirizzo email valido.'); emailInput.focus(); return;
    }

    state.email    = emailInput.value.trim();
    state.attivita = Array.from(modal.querySelectorAll('input[name="attivita"]:checked')).map(function(c){return c.value;});
    btn.disabled   = true; loader.hidden = false;

    try {
      var isExisting = false;
      if (WEBHOOK_CHECK) {
        var r = await fetch(WEBHOOK_CHECK,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:state.email})});
        isExisting = !!(await r.json()).exists;
      }
      state.isNewUser = !isExisting;
      loader.hidden = true; btn.disabled = false;
      showStep(isExisting ? 3 : 2, isExisting ? 3 : 2);
    } catch(e) {
      loader.hidden = true; btn.disabled = false; state.isNewUser = true; showStep(2,2);
    }
  });

  // ═══════════════════════════════════════════════════════════════
  // STEP 2
  // ═══════════════════════════════════════════════════════════════
  modal.querySelector('#lm-step2-back').addEventListener('click', function(){ showStep(1,1); });

  modal.querySelector('#lm-step2-next').addEventListener('click', async function() {
    var s2 = getStep(2); clearError(s2);
    var nome=modal.querySelector('#lm-nome'), cognome=modal.querySelector('#lm-cognome'),
        cell=modal.querySelector('#lm-cell'), privacy=modal.querySelector('#lm-privacy');

    if (!nome.value.trim())    { showError(s2,'Inserisci il tuo nome.'); nome.focus(); return; }
    if (!cognome.value.trim()) { showError(s2,'Inserisci il tuo cognome.'); cognome.focus(); return; }
    if (!cell.value.trim())    { showError(s2,'Inserisci il numero di cellulare.'); cell.focus(); return; }
    if (!privacy.checked)      { showError(s2,'Il consenso alla Privacy Policy è obbligatorio.'); return; }

    var prefix = modal.querySelector('#lm-prefix');
    state.nome      = nome.value.trim();
    state.cognome   = cognome.value.trim();
    state.cellulare = (prefix ? prefix.value : '+39') + ' ' + cell.value.trim();
    state.privacy   = true;
    state.marketing = modal.querySelector('#lm-marketing').checked;

    if (WEBHOOK_LEAD) {
      try { await fetch(WEBHOOK_LEAD,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(Object.assign({},state,{tipo:'lead-nuovo'}))}); } catch(e){}
    }
    showStep(3,3);
  });

  // ═══════════════════════════════════════════════════════════════
  // STEP 3
  // ═══════════════════════════════════════════════════════════════
  modal.querySelector('#lm-step3-back').addEventListener('click', function() {
    showStep(state.isNewUser ? 2 : 1, state.isNewUser ? 2 : 1);
  });

  modal.querySelectorAll('.lm__action-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var a = btn.dataset.action;
      if      (a === 'callback') { buildCalendar('cb');    showStep('4-callback'); }
      else if (a === 'visit')    { buildCalendar('visit'); showStep('4-visit'); }
      else if (a === 'message')  { showStep('4-message'); }
    });
  });

  // ═══════════════════════════════════════════════════════════════
  // GENERAZIONE SLOT
  // ═══════════════════════════════════════════════════════════════
  function slotsCallback(date) {
    var day=date.getDay(), isWE=(day===0||day===6), endH=isWE?19:20, slots=[];
    for(var h=9;h<endH;h++) for(var m=0;m<60;m+=20) slots.push(pad2(h)+':'+pad2(m));
    return slots;
  }

  function slotsVisit(date) {
    var day=date.getDay(), isWE=(day===0||day===6), slots=[];
    if(isWE){ for(var h=9;h<19;h++) for(var m=0;m<60;m+=20) slots.push(pad2(h)+':'+pad2(m)); }
    else {
      for(var h=9;h<13;h++)  for(var m=0;m<60;m+=20) slots.push(pad2(h)+':'+pad2(m));
      for(var h=15;h<20;h++) for(var m=0;m<60;m+=20) slots.push(pad2(h)+':'+pad2(m));
    }
    return slots;
  }

  // ═══════════════════════════════════════════════════════════════
  // CALENDARIO MENSILE
  // ═══════════════════════════════════════════════════════════════
  function buildCalendar(type) {
    var numDays     = type === 'cb' ? 7 : 14;
    var slotsFn     = type === 'cb' ? slotsCallback : slotsVisit;
    var calWrapEl   = document.getElementById('lm-cal-' + type);
    var slotsWrapEl = document.getElementById('lm-slots-wrap-' + type);
    var slotsBodyEl = document.getElementById('lm-cal-slots-' + type);
    var confirmBtn  = document.getElementById('lm-' + type + '-confirm');
    var reasonEl    = document.getElementById(type === 'cb' ? 'lm-cb-reason' : 'lm-visit-reason');

    // Stato calendario
    var today   = new Date(); today.setHours(0,0,0,0);
    var endDate = new Date(today); endDate.setDate(today.getDate() + numDays - 1);
    var viewY   = today.getFullYear();
    var viewM   = today.getMonth();
    var selDate = null;
    var selTime = null;

    function checkConfirm() {
      var ok = reasonEl && reasonEl.value.trim().length > 0 && selDate && selTime;
      if (confirmBtn) confirmBtn.disabled = !ok;
    }

    if (reasonEl) {
      // Rimuovi vecchi listener clonando il nodo
      var newReason = reasonEl.cloneNode(true);
      reasonEl.parentNode.replaceChild(newReason, reasonEl);
      reasonEl = newReason;
      reasonEl.addEventListener('input', checkConfirm);
    }

    // ── Render griglia mensile ────────────────────────────────────
    function renderMonth() {
      var firstDay  = new Date(viewY, viewM, 1);
      var lastDay   = new Date(viewY, viewM + 1, 0);
      var startDOW  = (firstDay.getDay() + 6) % 7; // Lun=0 … Dom=6

      // Navigazione prev/next
      var canPrev = viewY > today.getFullYear() || (viewY === today.getFullYear() && viewM > today.getMonth());
      var nextM1  = new Date(viewY, viewM + 1, 1);
      var canNext = endDate >= nextM1;

      var html = '<div class="lm__cal-nav">' +
        '<button class="lm__cal-nav-btn" id="lm-nav-prev-' + type + '"' + (!canPrev ? ' disabled' : '') + '>&#8249;</button>' +
        '<span class="lm__cal-month-name">' + MONTHS_FULL[viewM] + ' ' + viewY + '</span>' +
        '<button class="lm__cal-nav-btn" id="lm-nav-next-' + type + '"' + (!canNext ? ' disabled' : '') + '>&#8250;</button>' +
      '</div>' +
      '<div class="lm__cal-grid">';

      // Intestazioni Lun … Dom
      ['Lun','Mar','Mer','Gio','Ven','Sab','Dom'].forEach(function(d) {
        html += '<div class="lm__cal-dow">' + d + '</div>';
      });

      // Celle vuote prima del 1°
      for (var i = 0; i < startDOW; i++) html += '<div class="lm__cal-cell"></div>';

      // Giorni del mese
      for (var day = 1; day <= lastDay.getDate(); day++) {
        var d    = new Date(viewY, viewM, day);
        var past = d < today;
        var fut  = d > endDate;
        var avail = !past && !fut;
        var isTod = d.getTime() === today.getTime();
        var isSel = selDate && d.getTime() === selDate.getTime();

        var cls = 'lm__cal-cell lm__cal-day';
        cls += avail ? ' lm__cal-day--avail' : ' lm__cal-day--off';
        if (isTod) cls += ' lm__cal-day--today';
        if (isSel) cls += ' lm__cal-day--sel';

        var attr = avail ? ' data-cal-d="' + d.toISOString() + '"' : '';
        html += '<div class="' + cls + '"' + attr + '>' + day + '</div>';
      }

      html += '</div>'; // .lm__cal-grid
      calWrapEl.innerHTML = html;

      // Nav click
      var prevBtn = document.getElementById('lm-nav-prev-' + type);
      var nextBtn = document.getElementById('lm-nav-next-' + type);
      if (prevBtn && canPrev) {
        prevBtn.addEventListener('click', function() {
          viewM--; if (viewM < 0) { viewM = 11; viewY--; } renderMonth();
        });
      }
      if (nextBtn && canNext) {
        nextBtn.addEventListener('click', function() {
          viewM++; if (viewM > 11) { viewM = 0; viewY++; } renderMonth();
        });
      }

      // Click su giorno disponibile
      calWrapEl.querySelectorAll('.lm__cal-day--avail').forEach(function(cell) {
        cell.addEventListener('click', function() {
          selDate = new Date(cell.dataset.calD);
          selTime = null;
          if (type === 'cb')   { state.callbackDate = selDate; state.callbackTime = null; }
          else                  { state.visitDate    = selDate; state.visitTime    = null; }
          renderMonth();   // aggiorna selezione visiva
          renderSlots();
          checkConfirm();
        });
      });
    }

    // ── Render slot orari ─────────────────────────────────────────
    function renderSlots() {
      if (!selDate) return;
      slotsBodyEl.innerHTML = '';
      if (slotsWrapEl) slotsWrapEl.hidden = false;

      var all = slotsFn(selDate);

      // Gruppi per fascia oraria
      var groups = [
        { label: 'Mattina',    slots: all.filter(function(s){ return parseInt(s)<13; }) },
        { label: 'Pomeriggio', slots: all.filter(function(s){ var h=parseInt(s); return h>=13&&h<17; }) },
        { label: 'Sera',       slots: all.filter(function(s){ return parseInt(s)>=17; }) },
      ];

      groups.forEach(function(g) {
        if (!g.slots.length) return;
        var gDiv  = document.createElement('div'); gDiv.className = 'lm__slots-group';
        var label = document.createElement('div'); label.className = 'lm__slots-group-label'; label.textContent = g.label;
        var row   = document.createElement('div'); row.className = 'lm__slots-row';

        g.slots.forEach(function(time) {
          var sb = document.createElement('button');
          sb.type = 'button'; sb.className = 'lm__cal-slot-btn'; sb.textContent = time;
          sb.addEventListener('click', function() {
            slotsBodyEl.querySelectorAll('.lm__cal-slot-btn').forEach(function(b){ b.classList.remove('is-active'); });
            sb.classList.add('is-active');
            selTime = time;
            if (type === 'cb') state.callbackTime = time;
            else               state.visitTime    = time;
            checkConfirm();
          });
          row.appendChild(sb);
        });

        gDiv.appendChild(label); gDiv.appendChild(row);
        slotsBodyEl.appendChild(gDiv);
      });

      // Scroll verso gli slot
      slotsWrapEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    renderMonth();
  }

  // ═══════════════════════════════════════════════════════════════
  // STEP 4a · Conferma richiamata
  // ═══════════════════════════════════════════════════════════════
  document.getElementById('lm-cb-confirm').addEventListener('click', function() {
    var s = getStep('4-callback'); clearError(s);
    var r = modal.querySelector('#lm-cb-reason');
    if (!r.value.trim()) { showError(s,'Descrivi il motivo della chiamata.'); r.focus(); return; }
    if (!state.callbackDate||!state.callbackTime) { showError(s,'Seleziona giorno e orario per la chiamata.'); return; }
    state.callbackReason = r.value.trim();

    var atts = state.attivita.map(function(id){return ATTIVITA_LABELS[id]||id;}).join(', ')||'—';
    document.getElementById('lm-cb-when').innerHTML =
      whenRow('Ti richiamiamo il', fmtDateLong(state.callbackDate)) +
      whenRow('Alle ore', state.callbackTime) +
      (state.cellulare ? whenRow('Al numero', esc(state.cellulare)) : '');

    document.getElementById('lm-cb-summary').innerHTML =
      row('Email', esc(state.email)) +
      (state.nome ? row('Nome', esc(state.nome+' '+state.cognome)) : '') +
      (atts!=='—' ? row('Attività', esc(atts)) : '') +
      row('Motivo', esc(state.callbackReason));

    showStep('confirm-callback');
  });

  // ═══════════════════════════════════════════════════════════════
  // STEP 4b · Conferma visita
  // ═══════════════════════════════════════════════════════════════
  document.getElementById('lm-visit-confirm').addEventListener('click', function() {
    var s = getStep('4-visit'); clearError(s);
    var r = modal.querySelector('#lm-visit-reason');
    if (!r.value.trim()) { showError(s,'Descrivi il motivo della visita.'); r.focus(); return; }
    if (!state.visitDate||!state.visitTime) { showError(s,'Seleziona giorno e orario per la visita.'); return; }
    state.visitReason = r.value.trim();

    var atts = state.attivita.map(function(id){return ATTIVITA_LABELS[id]||id;}).join(', ')||'—';
    document.getElementById('lm-visit-when').innerHTML =
      whenRow('Ci vediamo il', fmtDateLong(state.visitDate)) +
      whenRow('Alle ore', state.visitTime);

    document.getElementById('lm-visit-summary').innerHTML =
      row('Email', esc(state.email)) +
      (state.nome ? row('Nome', esc(state.nome+' '+state.cognome)) : '') +
      (state.cellulare ? row('Cellulare', esc(state.cellulare)) : '') +
      (atts!=='—' ? row('Attività', esc(atts)) : '') +
      row('Motivo', esc(state.visitReason));

    showStep('confirm-visit');
  });

  // ═══════════════════════════════════════════════════════════════
  // STEP 4c · Messaggio
  // ═══════════════════════════════════════════════════════════════
  document.getElementById('lm-msg-send').addEventListener('click', async function() {
    var s = getStep('4-message'); clearError(s);
    var msgEl = modal.querySelector('#lm-msg-text');
    if (!msgEl.value.trim()) { showError(s,'Scrivi la tua richiesta prima di inviare.'); msgEl.focus(); return; }
    state.messageText = msgEl.value.trim();

    if (WEBHOOK_LEAD) {
      try { await fetch(WEBHOOK_LEAD,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(Object.assign({},state,{tipo:'messaggio'}))}); } catch(e){}
    }

    var atts = state.attivita.map(function(id){return ATTIVITA_LABELS[id]||id;}).join(', ')||'—';
    document.getElementById('lm-msg-summary').innerHTML =
      row('Email', esc(state.email)) +
      (state.nome ? row('Nome', esc(state.nome+' '+state.cognome)) : '') +
      (atts!=='—' ? row('Attività', esc(atts)) : '') +
      row('Richiesta', esc(state.messageText));

    showStep('confirm-message');
  });

  // ── Template helpers ─────────────────────────────────────────────
  function whenRow(label, val) {
    return '<div class="lm__confirm-when-row">' +
      '<span class="lm__confirm-when-label">'+label+'</span>' +
      '<span class="lm__confirm-when-val">'+val+'</span>' +
    '</div>';
  }

  function row(label, val) {
    return '<div class="lm__confirm-row"><span>'+label+'</span><span>'+val+'</span></div>';
  }
</script>
